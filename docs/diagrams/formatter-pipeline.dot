digraph FormatterPipeline {
    rankdir=TB;
    bgcolor="white";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=12;
    ranksep=0.45;
    nodesep=0.55;

    node [fontname="Helvetica,Arial,sans-serif", fontsize=11];
    edge [fontname="Helvetica,Arial,sans-serif", fontsize=10, color="#555555"];

    // Data nodes
    node [shape=box, style="rounded,filled", fillcolor="#eef2f7", color="#7a95b8", fontcolor="#1c2b3a"];
    source     [label="your source code\n(text)"];
    astCtx     [label="code structure  +  comments\n(AST + Context)"];
    lpt        [label="a Logical Printing Tree"];
    renderPlan [label="a render plan\n(Box tree)"];
    formatted  [label="formatted code\n(text)"];

    // Process nodes
    node [shape=box, style="rounded,filled", fillcolor="#dbe9f7", color="#3f6fa8", fontcolor="#1c2b3a"];
    parse [label="parse\n(Gren's compiler-common parser,\nbefore this library gets involved)"];
    step1 [label="Step 1\nbuild the Logical Printing Tree"];
    step2 [label="Step 2\nbuild the render plan"];
    step3 [label="Step 3\nrender to text\n(cannot fail)"];

    // Error / failure nodes
    node [shape=box, style="rounded,filled", fillcolor="#fbdede", color="#c0392b", fontcolor="#7a1f13"];
    parseFail [label="parse error\n(invalid Gren syntax)"];
    step1Fail [label="Err\n(a code shape the tree builder\ndoesn't yet handle)"];
    step2Fail [label="Err\n(a construct the render-plan\nbuilder doesn't yet handle)"];

    // Explanatory note
    node [shape=note, style=filled, fillcolor="#fffbe6", color="#c9a227", fontcolor="#4a3b06", fontsize=9];
    errNote [label="Formatter.prettyPrint : Src.Module -> Ctx.Context -> Result String String\lStep 1 and Step 2 failures both surface as one Err from prettyPrint;\lthe gren-format CLI reports either as PrettyPrintFailure.\lBoth are gaps in the formatter's own coverage, not evidence of invalid\lsource — a well-formed program can hit an unhandled construct.\l"];

    // Main flow
    source -> parse;
    parse  -> astCtx;
    astCtx -> step1;
    step1  -> lpt;
    lpt    -> step2;
    step2  -> renderPlan;
    renderPlan -> step3;
    step3  -> formatted;

    // Error branches
    parse -> parseFail [style=dashed, color="#c0392b", fontcolor="#7a1f13", label="error"];
    step1 -> step1Fail [style=dashed, color="#c0392b", fontcolor="#7a1f13", label="error"];
    step2 -> step2Fail [style=dashed, color="#c0392b", fontcolor="#7a1f13", label="error"];

    step2Fail -> errNote [style=dotted, arrowhead=none, color="#c9a227", constraint=false];

    { rank=same; astCtx; parseFail }
    { rank=same; lpt; step1Fail }
    { rank=same; renderPlan; step2Fail; errNote }
}
