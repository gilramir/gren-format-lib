module Formatter.PrettyPrinter exposing (prettyPrint)

import Compiler.Ast.Source as Src
import Compiler.Parse.Context as Ctx

import Formatter.LogicalPrintingTree exposing (lptToString)
import Formatter.LPTCreate exposing (makeLogicalPrintingTree)
import Formatter.LPTPretty exposing (makePrettyResult)

import SourcePosition exposing (Located)


prettyPrint: Src.Module -> Ctx.Context -> Result String String
prettyPrint ast ctx =
    when makeLogicalPrintingTree ast ctx is
        Err errString ->
            Err errString
        Ok lpTree ->
            let
                res = makePrettyResult lpTree
                _ = when res is
                    Ok r -> Debug.log "(result)" ("\n"++r)
                    Err r -> Debug.log "(error)" r
            in
            res
