module Formatter.PExJson exposing (lptToPexJson)

{-| Stub: the PrettyExpressive Doc is no longer used; return an empty array.

@docs lptToPexJson
-}

import Formatter.LogicalPrintingTree exposing (LPNode)


{-| Return an empty JSON array. The --pex flag is no longer meaningful
since MakePretty now uses Formatter.Render rather than PrettyExpressive.
-}
lptToPexJson : LPNode -> Result String String
lptToPexJson _ =
    Ok "[]"
