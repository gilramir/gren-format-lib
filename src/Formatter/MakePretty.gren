module Formatter.MakePretty exposing
    ( makePrettyResult
    , makePrettyLineDoc
    )

{-| Render a Logical Printing Tree to its final formatted source string.

Each `LPBox` constructor maps to a `PrettyExpressive` `Doc` via `makePDoc`,
and the resulting `Doc` is resolved against an 80-column page width with a
4-space indent. `makePrettyResult` is the main entry point used by the
`gren format` CLI; `makePrettyLineDoc` exposes the unresolved per-root-child
`Doc` for the `--pex` debug flag.

Unhandled box types surface as `Err` rather than silently falling back, so
every supported construct must have an explicit case in `makePDoc`.

# Comments

Comments arrive in the LPT already woven into the right slots by
`Formatter.Comments`, so by the time `makePrettyResult` runs they're
just `LPNode`s interleaved with content at whatever depth they belong
to. What makes them tricky is that they can show up *anywhere* — in a
top-level slot, mid-expression, between record fields, between a
function and its arguments, inside a pipeline step, inside an exposing
list — and each surrounding context renders them slightly differently.

A handful of techniques carry the load:

  - **Unflattenability via `hardNl`.** A `--` line comment consumes the
    rest of its source line, so any `P.group` it appears in *must*
    resolve to the multi-line branch. Rendering a `SingleLineComment`
    as `--text` followed by `P.hardNl` makes any enclosing group
    unflatten-able by construction.

  - **Trailing vs. leading by row comparison.** Inside `buildFlowDoc` we
    track the source row of the preceding item. A comment whose row
    matches attaches to it with a space (`foo -- comment`); a comment
    on a different row gets a forced `hardNl` before it so it starts
    its own line.

  - **`AlreadyTerminated` separator state.** Because every line comment
    ends with a `hardNl`, the *next* item must not emit another
    newline-or-space separator. The flow-builder's `NextSeparator`
    carries an `AlreadyTerminated` value that suppresses the normal
    separator for one step.

  - **Container-specific peeling.** Some containers can't just let a
    leading comment ride along with the flow. A `PipelineStep`'s body
    is wrapped in an extra `+4` indent, so a leading comment is peeled
    off and emitted at the step's own column. `RecordUpdate` and the
    generic top-level builder peel leading comments via
    `splitLeadingComments` so they stand on their own lines above the
    first field or term.

  - **Forcing list layouts.** Bracketed lists can't put a `--` inside a
    flat group, so the presence of any comment in the children
    promotes the whole list to a vertical layout where each comment
    renders on its own line and never picks up a `, ` prefix.

  - **Top-level comment slots.** Comments that don't belong to any
    declaration sit at the LPT root as their own `OriginalRows` with
    `StSingleLineComment` / `StBlockComment` / `StDocComment`;
    `makePrettyLineDoc` dispatches them to a dedicated builder.

@docs makePrettyLineDoc
@docs makePrettyResult
-}

import Compiler.SourcePosition exposing (Located)

import Formatter.LogicalPrintingTree exposing (LPBox(..),
    LPNode, ListBrackets(..), SyntaxType(..),
    lpnBox, lpnChildren, lpnNode, firstRowInSubtree, lpnMaxRow, lpnLastPos)
import Formatter.LPTJson exposing (lptToJson)
import Formatter.LPTHelpers exposing (binopPrecedence, binopMinPrecedence)

import Formatter.Strings exposing
    ( joinResultStrings
    )

import PrettyExpressive as P
import PrettyExpressive exposing (Doc(..))
import PrettyExpressive.Builder as B

costFactory : P.CostFactory P.DefaultCostTuple
costFactory =
    P.defaultCostFactory { pageWidth = 80, computationWidth = Just 100 }


{-| Walk a Doc tree and wrap post-newline sub-documents in `P.share`.

The optimisation target: every `DocConcat { a = newline, b = item }` —
i.e. anywhere a (soft or hard) newline is immediately followed by some
sub-document. Both newline variants reset the resolver's column to `i`
(hardNl always; soft `nl` does too in its broken branch), so the inner
`item` is evaluated at `(i, i)` regardless of the incoming column.

Why this matters: `processConcat` iterates over every Pareto-optimal
measure of the prefix accumulator and re-resolves the right-hand operand
at each measure's `.last`. When the right-hand operand starts with a
newline, the post-newline `item`'s evaluation position is
column-invariant — every prefix measure resolves `item` at the *same*
`(i, i)`. Wrapping `item` in `P.share` makes the first such resolution
populate the renderer's memo cache and every subsequent resolution
short-circuit to a cache hit. Without sharing, the renderer re-walks
`item` once per prefix measure.

Patterns this catches:

  - `buildFlowDoc`'s flowSep `group(nl item)` (the choice's broken
    branch is `concat nl item`, recursively reached via DocChoice).
  - `indentedBlockRule.wrap = nest n (concat hardNl content)`.
  - `bodyBlockRule.wrap = concat hardNl content`.
  - `softIndentedBlockRule.wrap = group (nest n (concat nl content))`.

`P.share` requires a fresh id per invocation, threaded through
`B.Builder`. The walker uses `B.map` / `B.andThen` to plumb the id
counter through the recursive descent. Leaves and renderer-internal
nodes (DocText, DocNewline, DocFail, DocContext, DocBlank, DocEvaled)
return unchanged via `B.return`.

The flat branch of a DocChoice is recursed into normally but its inner
post-newline items are not specially shared by the choice case itself —
the generic `DocConcat { a = newline, b = item }` arm below still fires
for them, but only when the renderer reaches them through a column
that lines up across prefix measures (rare for flat branches, since
their item resolves at `m.last + 1`).
-}
insertShares : P.Doc cost -> B.Builder (P.Doc cost)
insertShares d =
    when d is
        DocConcat { a = DocNewline maybeFlat, b = item } ->
            -- The most common shape we want to share. Recurse into `item`
            -- first so any nested concat-newline patterns inside `item`
            -- also get their items shared, then wrap the whole item in
            -- `P.share` and reattach the original newline.
            insertShares item
                |> B.andThen P.share
                |> B.map (\sharedItem -> P.concat (DocNewline maybeFlat) sharedItem)

        DocChoice { a = brokenBranch, b = flatBranch } ->
            -- Recurse into both branches. If `brokenBranch` is a
            -- `DocConcat { newline, item }`, the arm above will fire on
            -- recursion and share its item.
            insertShares brokenBranch
                |> B.andThen (\newBroken ->
                    insertShares flatBranch
                        |> B.map (\newFlat -> P.choice newBroken newFlat)
                )

        DocConcat { a = a, b = b } ->
            insertShares a
                |> B.andThen (\newA ->
                    insertShares b
                        |> B.map (\newB -> P.concat newA newB)
                )

        DocNest { indent = indent, doc = inner } ->
            insertShares inner |> B.map (P.nest indent)

        DocAlign inner ->
            insertShares inner |> B.map P.align

        DocReset inner ->
            insertShares inner |> B.map P.reset

        DocAddCost { cost = c, doc = inner } ->
            insertShares inner |> B.map (P.addCost c)

        DocShared _ ->
            -- Already shared; pass through to avoid double-sharing.
            B.return d

        _ ->
            -- Leaves (DocText, DocNewline, DocFail) and renderer-internal
            -- nodes (DocContext, DocBlank, DocEvaled, DocTwoColumns): no
            -- child docs to walk into, nothing to share.
            B.return d

-- How many spaces we indent
grenIndent : Int
grenIndent =
    4


-- Author-layout combinators, shared by the constructs that follow the author's
-- one-line-vs-multi-line choice (signatures, pipelines, binop chains). Each is
-- "fit-based when the author wrote it on one line, forced-vertical when they
-- spread it across rows". The two helpers encode the invariant that the group's
-- broken branch is byte-identical to the forced form — build the segment
-- separators with `authorSep` and wrap the whole doc with `groupUnlessForced`,
-- and overflow == author-multi-line, so formatting stays a fixed point.

-- Separator between author-layout segments: an unflattenable hard break when
-- forced vertical (so an enclosing `name = body` group can't collapse a
-- multi-line construct back onto one line), otherwise a soft break that
-- flattens to a space when the whole thing fits.
authorSep : Bool -> P.Doc cost
authorSep forceVertical =
    if forceVertical then P.hardNl else P.nl


-- Wrap an author-layout doc: grouped (so the optimizer picks flat-or-broken by
-- fit) unless forced vertical, in which case it is returned as-is and its hard
-- breaks always fire.
groupUnlessForced : Bool -> P.Doc cost -> P.Doc cost
groupUnlessForced forceVertical full =
    if forceVertical then full else P.group full


-- True if the rows are not all equal — i.e. the items they came from span more
-- than one source line, so the author wrote the construct across rows and it
-- should stay vertical. The Doc-side mirror of `InsertExpressions.itemsSpanRows`
-- (which decides the same thing at LPT-build time for lists, records, pipelines,
-- and binops); used here for unions and signatures, whose layout decision is
-- still taken at render time.
rowsSpanMultiple : Array Int -> Bool
rowsSpanMultiple rows =
    when Array.popFirst rows is
        Nothing -> False
        Just { first, rest } -> Array.any (\r -> r /= first) rest


-- Canonical hanging indent for a multi-line block comment's continuation
-- lines: the width of the `{- ` opener, so the body aligns under the first
-- content character of the first line.
blockCommentBodyOffset : Int
blockCommentBodyOffset =
    3

{-| Render a complete Logical Printing Tree to its formatted source string.

Renders each root child independently via `makePrettyLine` and joins the
results with a single newline. The caller is expected to pass the root
`LPNode` produced by `Formatter.MakeLogical`; `EmptyLine` children
contribute blank separators here. Returns `Err` if any child contains an
unhandled box construct.
-}
makePrettyResult : LPNode -> Result String String
makePrettyResult root =
    let
        prettyLines = Array.map makePrettyLine (lpnChildren root)
    in
    joinResultStrings "\n" prettyLines

makePrettyLine : LPNode -> Result String String
makePrettyLine node =
    makePrettyLineDoc node
        |> Result.andThen (\doc ->
            genericRenderResult (P.prettyFormat costFactory (insertShares doc))
        )


-- True if the node is a line or block comment. (Doc comments are their own
-- top-level OriginalRows so they don't appear in mid-flow positions.)
nodeIsComment : LPNode -> Bool
nodeIsComment node =
    when lpnBox node is
        SingleLineComment _ -> True
        BlockComment _ -> True
        _ -> False


-- Take a prefix of comment nodes off `nodes`, returning the comments and
-- the remainder. Used wherever a container (top-level decl, record update,
-- pipeline step, ...) wants to render leading comments on their own lines
-- before the rest of its children.
splitLeadingComments : Array LPNode -> { leading : Array LPNode, rest : Array LPNode }
splitLeadingComments nodes =
    let
        step item acc =
            if acc.done then
                { acc | rest = Array.pushLast item acc.rest }
            else if nodeIsComment item then
                { acc | leading = Array.pushLast item acc.leading }
            else
                { leading = acc.leading, rest = [item], done = True }
    in
    Array.foldl step { leading = [], rest = [], done = False } nodes
        |> (\r -> { leading = r.leading, rest = r.rest })


makeUnionBodyDoc : Array LPNode -> Result String (P.Doc cost)
makeUnionBodyDoc nodes =
    let
        hasComment = Array.any nodeIsComment nodes
        variantNodes = Array.keepIf (\n -> not (nodeIsComment n)) nodes
        -- Signal B over the variants: a union the author wrote across rows stays
        -- one-variant-per-line; one written on a single line is fit-based
        -- (`= A | B | C` inline when it fits, one-per-line on overflow). Mirrors
        -- the record/list rule, with the fit-based↔vertical group built so the
        -- broken form is byte-identical to the always-vertical (P.vcat) form.
        variantsSpanRows =
            rowsSpanMultiple (Array.map firstRowInSubtree variantNodes)
    in
    if hasComment || variantsSpanRows then
        makeUnionBodyVertical nodes
    else
        traverseArray (\n -> buildFlowDoc 0 (lpnChildren n)) variantNodes
            |> Result.map (\docs ->
                P.group (P.foldDoc (\a b -> P.concat a (P.concat P.nl b)) docs)
            )


-- Always-vertical union body: one variant per line via P.vcat, with comments
-- placed inline after the variant they trail or on their own line otherwise.
makeUnionBodyVertical : Array LPNode -> Result String (P.Doc cost)
makeUnionBodyVertical nodes =
    let
        placeComment row commentDoc acc =
            when Array.popLast acc.docs is
                Nothing ->
                    Ok { docs = [commentDoc], prevRow = row }
                Just { last = lastDoc, initial = initDocs } ->
                    if row == acc.prevRow then
                        Ok { docs = Array.pushLast (P.concat lastDoc (P.concat (P.text " ") commentDoc)) initDocs
                           , prevRow = row
                           }
                    else
                        Ok { docs = Array.pushLast commentDoc acc.docs
                           , prevRow = row
                           }

        result =
            Array.foldl
                (\node accResult ->
                    when accResult is
                        Err e -> Err e
                        Ok acc ->
                            when lpnBox node is
                                SingleLineComment loc ->
                                    placeComment loc.start.row (commentNodeDoc node) acc

                                BlockComment loc ->
                                    placeComment loc.start.row (commentNodeDoc node) acc

                                _ ->
                                    when buildFlowDoc 0 (lpnChildren node) is
                                        Err e -> Err e
                                        Ok childDoc ->
                                            Ok { docs = Array.pushLast childDoc acc.docs
                                               -- The row of the variant's last *token*, not the
                                               -- subtree's max row: a variant carrying a multi-line
                                               -- block comment has a max row past its last token,
                                               -- but a comment trailing the variant shares the last
                                               -- token's row. (And not the first row — a multi-row
                                               -- variant's trailing comment would then look like a
                                               -- different row.) A mismatched row pushes the comment
                                               -- onto its own line, one row below and dedented from
                                               -- the variant, where it escapes to a top-level comment
                                               -- on reparse (non-idempotent).
                                               , prevRow =
                                                    lpnLastPos node
                                                        |> Maybe.map (\p -> p.row)
                                                        |> Maybe.withDefault (firstRowInSubtree node)
                                               }
                )
                (Ok { docs = [], prevRow = -1 })
                nodes
    in
    when result is
        Err e -> Err e
        Ok state -> Ok (P.vcat state.docs)


makeTypeBodyDoc : Array LPNode -> Result String (P.Doc cost)
makeTypeBodyDoc typeNodes =
    when Array.popFirst typeNodes is
        Nothing ->
            Ok P.empty
        Just { first = onlyNode, rest = rest } ->
            if Array.isEmpty rest then
                -- Render the single body node as-is. A record body now carries
                -- its own author-derived layout (`AllAcrossOrAllVertical` when
                -- written on one line, `AlwaysVertical` when written across
                -- rows — see `Src.TRecord`), so it is no longer force-
                -- verticalized; it sits inline on the body line when it fits,
                -- exactly like a non-record alias body (`type alias Id = Int`).
                makePDoc (lpnBox onlyNode) (lpnChildren onlyNode)
            else
                buildFlowDoc 0 typeNodes


{-| What separator to place before the next item.

  - `FirstItem` — nothing precedes; emit no separator.
  - `FlowSep` — normal flow: space or newline (via `group nl`).
  - `HardNl` — after an `IndentedBlock`: forced newline.
  - `AlreadyTerminated` — after a comment's `hardNl`: no extra separator.
-}
type NextSeparator
    = FirstItem
    | FlowSep
    | HardNl
    | AlreadyTerminated


-- Layout rule for a block-style child (IndentedBlock, BodyBlock, etc.):
--   `wrap` decorates the child doc (indenting, hardNl-prefixing, grouping…).
--   `bypassAlreadyTerminated = True` means the wrap is skipped when the
--     previous item ended its own line (no extra separator needed).
--   `nextSep` is the separator state to set after rendering this block.
type alias BlockRule cost =
    { wrap : P.Doc cost -> P.Doc cost
    , bypassAlreadyTerminated : Bool
    , nextSep : NextSeparator
    }


indentedBlockRule : BlockRule cost
indentedBlockRule =
    { wrap = \c -> P.nest grenIndent (P.concat P.hardNl c)
    , bypassAlreadyTerminated = False
    , nextSep = HardNl
    }


bodyBlockRule : BlockRule cost
bodyBlockRule =
    { wrap = \c -> P.concat P.hardNl c
    , bypassAlreadyTerminated = True
    , nextSep = FlowSep
    }


softIndentedBlockRule : BlockRule cost
softIndentedBlockRule =
    { wrap = \c -> P.group (P.nest grenIndent (P.concat P.nl c))
    , bypassAlreadyTerminated = False
    , nextSep = FlowSep
    }


-- Join a block's child doc onto the accumulator, honoring the rule's
-- FirstItem / AlreadyTerminated bypasses.
joinBlock : BlockRule cost -> NextSeparator -> P.Doc cost -> P.Doc cost -> P.Doc cost
joinBlock rule sep accDoc childDoc =
    when sep is
        FirstItem ->
            childDoc
        AlreadyTerminated ->
            if rule.bypassAlreadyTerminated then
                P.concat accDoc childDoc
            else
                -- The previous item (a comment) already ended its line with a
                -- hardNl, so applying the normal wrap — which begins with its own
                -- nl/hardNl — would emit a *second* newline: a whitespace-only
                -- blank line (the break re-emits the current indentation).
                -- Instead indent the child to the wrap's level without a leading
                -- break: `nest grenIndent` so the child's own line breaks land at
                -- +grenIndent, plus a literal run of spaces to push its first line
                -- there too (there is no leading break to do that). The two
                -- non-bypass rules (IndentedBlock, SoftIndentedBlock) both nest by
                -- exactly grenIndent, so this matches their broken form minus the
                -- spurious blank line.
                P.concat accDoc
                    (P.nest grenIndent
                        (P.concat (P.text (String.repeat grenIndent " ")) childDoc))
        _ ->
            P.concat accDoc (rule.wrap childDoc)


-- Peel a run of trailing single-line comments off the end of a block's
-- children, returning the remaining body nodes plus a doc that glues those
-- comments back on inline (each preceded by a space), in source order.
--
-- A comment left inside the block's flow rides a soft break, so an overflowing
-- line drops it onto its own line one row below the body's last token,
-- dedented; on reparse it sits past the body's range and re-attaches at the
-- enclosing level, the body collapses, and the layout oscillates
-- (non-idempotent). Gluing keeps the comment on the body's last row across
-- reformats.
--
-- `peelLineComments` selects the caller's rule:
--
--   * `True` (block bodies): also peel a trailing `--` comment. Because a `--`
--     consumes the rest of its line it may only be the *rightmost* glued
--     comment — a second `--` to its left would swallow it, so peeling stops
--     there.
--   * `False` (when-branch bodies): peel only block comments; a trailing `--`
--     is left in the flow (its soft-break handling already keeps it stable).
--
-- Either way, block comments may be chained freely and a multi-line block
-- comment is left in place (it legitimately breaks the line).
peelTrailingComments : Bool -> Array LPNode -> { bodyNodes : Array LPNode, trailingCommentDoc : P.Doc cost }
peelTrailingComments peelLineComments nodes =
    let
        go remaining accDoc sawLineComment =
            when Array.popLast remaining is
                Just { last = lastChild, initial = initChildren } ->
                    let
                        keep = { bodyNodes = remaining, trailingCommentDoc = accDoc }
                        glue newSawLineComment =
                            go initChildren
                                (P.concat (P.text " ") (P.concat (commentNodeDoc lastChild) accDoc))
                                newSawLineComment
                    in
                    when lpnBox lastChild is
                        SingleLineComment _ ->
                            if peelLineComments && not sawLineComment then glue True else keep
                        BlockComment loc ->
                            if isMultiLineCommentValue loc.value then keep else glue sawLineComment
                        _ ->
                            keep
                Nothing ->
                    { bodyNodes = remaining, trailingCommentDoc = accDoc }
    in
    go nodes P.empty False


-- Render a body-block child (BodyBlock) inside buildFlowDoc's
-- fold: peel its trailing inline comments, render the body via `renderBlockNode`,
-- then glue the comments back onto the result. Shared by both arms.
renderBodyBlockNode :
    BlockRule cost
    -> { doc : P.Doc cost, prevRow : Int, prevElided : Bool, separator : NextSeparator }
    -> Array LPNode
    -> Result String { doc : P.Doc cost, prevRow : Int, prevElided : Bool, separator : NextSeparator }
renderBodyBlockNode rule acc nodeChildren =
    let
        { bodyNodes, trailingCommentDoc } = peelTrailingComments True nodeChildren
    in
    renderBlockNode rule acc bodyNodes
        |> Result.map (\r -> { r | doc = P.concat r.doc trailingCommentDoc })


-- Render a block-style child node inside buildFlowDoc's fold: recurse
-- into the children, then join via joinBlock and produce the next acc.
renderBlockNode :
    BlockRule cost
    -> { doc : P.Doc cost, prevRow : Int, prevElided : Bool, separator : NextSeparator }
    -> Array LPNode
    -> Result String { doc : P.Doc cost, prevRow : Int, prevElided : Bool, separator : NextSeparator }
renderBlockNode rule acc nodeChildren =
    buildFlowDoc 0 nodeChildren
        |> Result.map (\childrenDoc ->
            { doc = joinBlock rule acc.separator acc.doc childrenDoc
            , prevRow = -1
            , prevElided = False
            , separator = rule.nextSep
            }
        )


{-| builds the flow, and handles SingleLineComment nodes correctly:

  - A comment on the same row as the preceding item is attached directly
    to it (no separator), producing e.g. "exposing -- comment".
  - A comment on a different row goes on its own line via a forced hardNl.
  - Either way, the comment appends hardNl so the next item always starts
    on a fresh line — indicated by `AlreadyTerminated` for the next item.
-}
buildFlowDoc : Int -> Array LPNode -> Result String (P.Doc cost)
buildFlowDoc indent nodes =
    buildFlowDocImpl indent False nodes


-- Like `buildFlowDoc`, but for a flow that continues on the *same line* as a
-- token the caller already emitted (e.g. a binop RHS after its operator, or
-- the body of a `( … )`). A leading single-line block comment there is part
-- of that line and stays inline, rather than being treated as a standalone
-- own-line comment that forces a break.
buildFlowDocInline : Int -> Array LPNode -> Result String (P.Doc cost)
buildFlowDocInline indent nodes =
    buildFlowDocImpl indent True nodes


-- `inlineStart` says whether the first node of this flow continues a line the
-- caller already started. It only affects a *leading single-line* block
-- comment: in an inline context it stays inline; otherwise (a block/vertical
-- context such as a `let` binding) it is standalone and forces the following
-- token onto its own line at the correct column. Multi-line block comments
-- always force the break regardless.
buildFlowDocImpl : Int -> Bool -> Array LPNode -> Result String (P.Doc cost)
buildFlowDocImpl indent inlineStart nodes =
    let
        -- separator: either "same line with space" or "new line with indent"
        flowSep accDoc nextDoc =
            P.concat accDoc (P.group (P.concat P.nl nextDoc))

        joinDoc sep accDoc itemDoc =
            when sep is
                FirstItem        -> itemDoc
                FlowSep          -> flowSep accDoc itemDoc
                HardNl           -> P.concat (P.concat accDoc P.hardNl) itemDoc
                AlreadyTerminated -> P.concat accDoc itemDoc

        foldResult =
            Array.foldl
                (\node accResult ->
                    when accResult is
                        Err e -> Err e
                        Ok acc ->
                            let
                                box = lpnBox node
                                nodeChildren = lpnChildren node
                            in
                            when box is
                                SingleLineComment loc ->
                                    let
                                        commentText = commentBoxDoc box
                                        docWithComment =
                                            when acc.separator is
                                                FirstItem ->
                                                    commentText
                                                AlreadyTerminated ->
                                                    -- Previous comment already ended its line with hardNl;
                                                    -- concatenate directly to avoid a blank line between
                                                    -- consecutive comments.
                                                    P.concat acc.doc commentText
                                                _ ->
                                                    if loc.start.row == acc.prevRow || acc.prevElided then
                                                        -- Same row as preceding item: attach with a SOFT
                                                        -- break — a space when it fits, otherwise its own
                                                        -- line. A hard space would give the flow no break
                                                        -- point here, forcing an *earlier* break (e.g. before
                                                        -- an elided `->`) so the comment trails a token that
                                                        -- moved down. Whether that earlier token then renders
                                                        -- on row N or N+1 flips the comment's own input row on
                                                        -- reparse, oscillating between layouts. The soft break
                                                        -- keeps the preceding token in place and moves only the
                                                        -- comment, which is stable across reformats.
                                                        --
                                                        -- `prevElided` also takes this branch: a comment that
                                                        -- directly trails a zero-width elided token (`->`, `:`,
                                                        -- `=`, …) is anchored at that token's *left-neighbour*
                                                        -- row, not where the token renders. If the token wraps
                                                        -- onto its own continuation line, the comment's own row
                                                        -- no longer equals that anchor — so a pure row test
                                                        -- would flip it to its own line on the next format even
                                                        -- though it fits beside the (wrapped) token. Soft-gluing
                                                        -- whenever it trails an elided token keeps the glue-when-
                                                        -- it-fits rendering stable across reformats.
                                                        P.concat acc.doc (P.group (P.concat P.nl commentText))
                                                    else
                                                        -- Different row: force a line break before the comment
                                                        P.concat acc.doc (P.concat P.hardNl commentText)
                                    in
                                    Ok { doc = P.concat docWithComment P.hardNl
                                       , prevRow = loc.start.row
                                       , prevElided = False
                                       , separator = AlreadyTerminated
                                       }

                                BlockComment loc ->
                                    let
                                        -- A block comment forces an own-line break (so the next
                                        -- token starts fresh at the right column) when it is
                                        -- multi-line, OR when it is a standalone leading comment
                                        -- in a vertical context — the first item of a flow that
                                        -- does not continue a line the caller already started
                                        -- (e.g. before a non-first `let` binding), OR when a
                                        -- previous comment already ended the line (AlreadyTerminated):
                                        -- a run of own-line comments must each stay on their own
                                        -- line, not glue the following token onto the last one.
                                        -- A single-line block comment that continues a line stays
                                        -- inline (`a * {- c -} b`, a binop RHS, a `( … )` body).
                                        standaloneLeading =
                                            (acc.separator == FirstItem && not inlineStart)
                                                || acc.separator == AlreadyTerminated
                                    in
                                    if isMultiLineCommentValue loc.value || standaloneLeading then
                                        let
                                            commentText = commentBoxDoc box
                                            docWithComment =
                                                when acc.separator is
                                                    FirstItem ->
                                                        commentText
                                                    AlreadyTerminated ->
                                                        P.concat acc.doc commentText
                                                    _ ->
                                                        if loc.start.row == acc.prevRow then
                                                            P.concat acc.doc (P.concat (P.text " ") commentText)
                                                        else
                                                            P.concat acc.doc (P.concat P.hardNl commentText)
                                        in
                                        Ok { doc = P.concat docWithComment P.hardNl
                                           , prevRow = loc.start.row
                                           , prevElided = False
                                           , separator = AlreadyTerminated
                                           }
                                    else
                                        -- Single-line block comment continuing a line: inline.
                                        when makePDoc box nodeChildren is
                                            Err e -> Err e
                                            Ok itemDoc ->
                                                Ok { doc = joinDoc acc.separator acc.doc itemDoc
                                                   , prevRow = -1
                                                   , prevElided = False
                                                   , separator = FlowSep
                                                   }

                                AllAcrossOrAllVertical bracket ->
                                    when makeAllAcrossOrAllVertical bracket nodeChildren is
                                        Err e -> Err e
                                        Ok itemDoc ->
                                            Ok { doc = joinDoc acc.separator acc.doc itemDoc
                                               , prevRow = -1
                                               , prevElided = False
                                               , separator = FlowSep
                                               }

                                IndentedBlock ->
                                    renderBlockNode indentedBlockRule acc nodeChildren

                                PipelineStep ->
                                    -- Peel a single leading line/block comment
                                    -- off the step so it renders at the step's
                                    -- own nesting level rather than inside the
                                    -- extra P.nest grenIndent applied to the
                                    -- args. This keeps the comment and `|>` at
                                    -- the same column, while continuation args
                                    -- are indented +4 from `|>`. Always force a
                                    -- hardNl after the comment so `|>` starts
                                    -- on the next line.
                                    --
                                    -- Also peel a single trailing line/block
                                    -- comment off the END of the step. Letting
                                    -- buildFlowDoc emit it would put the
                                    -- terminating hardNl at the +grenIndent
                                    -- continuation-arg level (= base + 2 *
                                    -- grenIndent), which leaves the next step's
                                    -- leading hardNl producing a blank line at
                                    -- that over-indented level. Render the
                                    -- trailing comment ourselves, glued to the
                                    -- last arg with a space, and let the next
                                    -- step's leading hardNl handle line
                                    -- termination at the correct outer indent.
                                    let
                                        { commentDoc, withoutLeading, hasComment } =
                                            -- Peel ALL leading comments, not just the first. Each
                                            -- renders own-line at the step's own column (the outer
                                            -- nest), so `|>` is the first token after them at that
                                            -- same column. Leaving a second leading comment inside
                                            -- `childrenDoc` (which carries an inner `nest grenIndent`)
                                            -- would let its own-line break push `|>` one level deeper
                                            -- — an inconsistent `|>` indent that varies with how many
                                            -- comments precede the step.
                                            let { leading, rest } = splitLeadingComments nodeChildren
                                            in
                                            { commentDoc =
                                                Array.foldl
                                                    (\c cdoc -> P.concat cdoc (P.concat (commentNodeDoc c) P.hardNl))
                                                    P.empty
                                                    leading
                                            , withoutLeading = rest
                                            , hasComment = not (Array.isEmpty leading)
                                            }

                                        { stepChildren, trailingCommentDoc, hasTrailing } =
                                            when Array.popLast withoutLeading is
                                                Just { last = lastChild, initial = initChildren } ->
                                                    if nodeIsComment lastChild then
                                                        { stepChildren = initChildren
                                                        , trailingCommentDoc =
                                                            P.concat (P.text " ") (commentNodeDoc lastChild)
                                                        , hasTrailing = True
                                                        }
                                                    else
                                                        { stepChildren = withoutLeading
                                                        , trailingCommentDoc = P.empty
                                                        , hasTrailing = False
                                                        }
                                                Nothing ->
                                                    { stepChildren = withoutLeading
                                                    , trailingCommentDoc = P.empty
                                                    , hasTrailing = False
                                                    }
                                    in
                                    when buildFlowDoc grenIndent stepChildren is
                                        Err e -> Err e
                                        Ok childrenDoc ->
                                            let
                                                -- Only add a blank line before a commented step if it
                                                -- follows another PipelineStep (separator = HardNl).
                                                blankLinePrefix =
                                                    when acc.separator is
                                                        HardNl ->
                                                            if hasComment then P.text "\n" else P.empty
                                                        _ ->
                                                            P.empty
                                                -- commentDoc (if any) fires at step level; childrenDoc
                                                -- (|> and args) is wrapped in P.nest grenIndent so
                                                -- continuation args break at |>-column + 4. The
                                                -- trailingCommentDoc (if any) is glued onto the end of
                                                -- the children with a leading space — it lives inside
                                                -- the same inner nest, but with NO trailing hardNl,
                                                -- so the next step's leading hardNl is the one that
                                                -- ends the line and re-establishes the outer indent.
                                                indentedDoc =
                                                    P.concat blankLinePrefix
                                                        (P.nest grenIndent
                                                            (P.concat P.hardNl
                                                                (P.concat commentDoc
                                                                    (P.concat childrenDoc trailingCommentDoc))))
                                                newDoc =
                                                    when acc.separator is
                                                        FirstItem -> P.concat commentDoc (P.concat childrenDoc trailingCommentDoc)
                                                        _         -> P.concat acc.doc indentedDoc
                                            in
                                            Ok { doc = newDoc
                                               , prevRow = -1
                                               , prevElided = False
                                               , separator = HardNl
                                               }

                                BodyBlock ->
                                    renderBodyBlockNode bodyBlockRule acc nodeChildren

                                WhenBranch ->
                                    -- Peel a single-line block comment off the END of the
                                    -- branch and glue it inline to the body with a space,
                                    -- rather than letting buildFlowDoc place it. Left in the
                                    -- flow it rides a soft break, so an overflowing comment
                                    -- drops onto its own line at the branch indent — one row
                                    -- *below* the body's last token, and dedented from it. On
                                    -- reparse that row sits past the declaration's range and
                                    -- the comment escapes to a top-level comment (column 1),
                                    -- non-idempotently. Gluing keeps it on the body's last
                                    -- row (even past the page width) so it stays inside the
                                    -- branch across reformats. The next branch's leading
                                    -- hardNl terminates the line.
                                    -- Peel *all* trailing block comments off the end (not just
                                    -- one): a branch body can end in a run of them, and any left
                                    -- in the flow rides a soft break and escapes on overflow. A
                                    -- trailing `--` is left in place (peelLineComments = False) —
                                    -- its own soft-break handling keeps it stable.
                                    let
                                        { bodyNodes, trailingCommentDoc } =
                                            peelTrailingComments False nodeChildren
                                    in
                                    when buildFlowDoc 0 bodyNodes is
                                        Err e -> Err e
                                        Ok bodyDoc ->
                                            let
                                                childrenDoc = P.concat bodyDoc trailingCommentDoc
                                                -- Always blank-separate consecutive branches,
                                                -- regardless of whether either body is multi-line.
                                                blankOrNewline =
                                                    P.concat (P.text "\n") P.hardNl
                                                newDoc =
                                                    when acc.separator is
                                                        FirstItem -> childrenDoc
                                                        -- A preceding comment has already ended its
                                                        -- line with hardNl, so attach the branch
                                                        -- directly to avoid inserting an extra blank
                                                        -- line between the comment and its pattern.
                                                        AlreadyTerminated -> P.concat acc.doc childrenDoc
                                                        _         -> P.concat acc.doc (P.concat blankOrNewline childrenDoc)
                                            in
                                            Ok { doc = newDoc
                                               , prevRow = -1
                                               , prevElided = False
                                               , separator = FlowSep
                                               }

                                SoftIndentedBlock ->
                                    renderBlockNode softIndentedBlockRule acc nodeChildren

                                EmptyLine ->
                                    -- A blank-line marker between `let` bindings,
                                    -- inserted by `VerticalSpace.insertLetBlankLines`.
                                    -- Emit one raw "\n" (not P.hardNl, which would
                                    -- re-emit indentation and leave trailing whitespace
                                    -- on the blank line — cf. the WhenBranch/PipelineStep
                                    -- blanks). The following binding's IndentedBlock
                                    -- supplies its own leading hardNl, so each EmptyLine
                                    -- nets exactly one blank line. Keep separator = HardNl
                                    -- so that binding still wraps onto its own line.
                                    Ok { doc = P.concat acc.doc (P.text "\n")
                                       , prevRow = -1
                                       , prevElided = False
                                       , separator = HardNl
                                       }

                                _ ->
                                    when makePDoc box nodeChildren is
                                        Err e -> Err e
                                        Ok itemDoc ->
                                            let
                                                prevRow =
                                                    when box is
                                                        UnbreakableText loc -> loc.start.row
                                                        _ -> -1

                                                -- The synthesized signature `->` is a zero-width
                                                -- `UnbreakableText` (start == end) built by
                                                -- `LPTHelpers.mkZeroWidthText`, anchored at the end of its
                                                -- `from` type — not where it renders. Its left neighbour is a
                                                -- whole type, which can fill the line and push the `->` onto a
                                                -- continuation row. A comment directly trailing it must then
                                                -- glue regardless of row (see the SingleLineComment branch).
                                                -- Scoped to `->` by value (cf. the `value == "in"` test in
                                                -- the boundary check): other elided tokens (`exposing`, `:`)
                                                -- precede a short neighbour or a bracketed block, where a
                                                -- comment on its own row legitimately stays own-line.
                                                prevElided =
                                                    when box is
                                                        UnbreakableText loc ->
                                                            loc.value == "->"
                                                                && loc.start.row == loc.end.row
                                                                && loc.start.col == loc.end.col
                                                        _ -> False
                                            in
                                            Ok { doc = joinDoc acc.separator acc.doc itemDoc
                                               , prevRow = prevRow
                                               , prevElided = prevElided
                                               , separator = FlowSep
                                               }
                )
                (Ok { doc = P.empty, prevRow = -1, prevElided = False, separator = FirstItem })
                nodes
    in
    when foldResult is
        Err e -> Err e
        Ok state -> Ok (P.nest indent state.doc)



-- True if the node is a DocComment (kept separate from nodeIsComment so
-- that line/block comments which appear in mid-flow positions don't accept
-- doc-comments by accident).
isDocCommentNode : LPNode -> Bool
isDocCommentNode node =
    when lpnBox node is
        DocComment _ -> True
        _ -> False

genericRenderResult : Maybe String -> Result String String
genericRenderResult maybeFormatted =
    when maybeFormatted is
        Just s -> Ok s
        Nothing -> Err "Failed to pretty-print"

makePDoc : LPBox -> Array LPNode -> Result String (P.Doc cost)
makePDoc box children =
    when box is
        UnbreakableText locs -> Ok (P.text locs.value)
        SynthesizedText s -> Ok (P.text s)
        AllAcrossOrAllVertical bracket ->
            makeAllAcrossOrAllVertical bracket children
        AlwaysVertical bracket ->
            listBoxesForBracket bracket children
        RecordUpdate { name, forceVertical } ->
            makeRecordUpdateDoc forceVertical name.value children
        EmptyBracketed loc ->
            -- An empty literal whose source spans more than the bare
            -- `{}` / `[]` / `()` only acquires children if a comment
            -- ended up placed inside it. Without children, render the
            -- bare literal; with comment children, render as
            -- `{ comment1 comment2 ... }` inline so the comments stay
            -- inside the brackets.
            let bs = bracketStrings loc.value
            in
            if Array.isEmpty children then
                Ok (P.text bs.empty)
            else
                let
                    commentDocs = Array.map commentNodeDoc children
                    body =
                        Array.foldl
                            (\d acc ->
                                if acc == P.empty then d
                                else P.concat acc (P.concat (P.text " ") d)
                            )
                            P.empty
                            commentDocs
                in
                Ok (P.concat (P.text bs.open) (P.concat body (P.concat (P.text " ") (P.text bs.close))))
        SingleLineComment locs -> Ok (lineComment locs.value)
        BlockComment _ -> Ok (commentBoxDoc box)
        AcrossThenIndent ->
            buildFlowDoc grenIndent children
        IfCondition ->
            makeIfConditionDoc children
        IndentedBlock ->
            buildFlowDoc 0 children
        PipelineStep ->
            buildFlowDoc 0 children
        Pipeline { forceVertical } ->
            makePipelineDoc forceVertical children
        Binop { forceVertical } ->
            makeBinopDoc forceVertical children
        BodyBlock ->
            buildFlowDoc 0 children
        WhenBranch ->
            buildFlowDoc 0 children
        SoftIndentedBlock ->
            buildFlowDoc 0 children
        ParenBlock ->
            when buildFlowDocInline 0 children is
                Err e -> Err e
                Ok innerDoc -> Ok (P.concat (P.text "(") (P.concat innerDoc (P.text ")")))
        OpAndRhs ->
            when Array.popFirst children is
                Just { first = opNode, rest = rhsNodes } ->
                    when lpnBox opNode is
                        UnbreakableText opLoc ->
                            when buildFlowDocInline 0 rhsNodes is
                                Err e -> Err e
                                Ok rhsDoc -> Ok (P.concat (P.text (opLoc.value ++ " ")) rhsDoc)
                        SynthesizedText opStr ->
                            when buildFlowDocInline 0 rhsNodes is
                                Err e -> Err e
                                Ok rhsDoc -> Ok (P.concat (P.text (opStr ++ " ")) rhsDoc)
                        _ -> Err "OpAndRhs: first child must be a text operator"
                Nothing -> Err "OpAndRhs: empty children"
        AlignedFlow ->
            when buildFlowDocInline 0 children is
                Err e -> Err e
                Ok innerDoc -> Ok (P.align innerDoc)
        PrefixGlue prefix ->
            when buildFlowDocInline 0 children is
                Err e -> Err e
                Ok innerDoc -> Ok (P.concat (P.text prefix.value) innerDoc)
        MultilineString located ->
            let
                tripleQuote = P.text "\"\"\""
                contentDoc =
                    Array.foldl
                        (\line acc -> P.concat acc (P.concat P.hardNl (P.text line)))
                        tripleQuote
                        located.value
            in
            -- Wrap the whole doc in P.align so internal hardNls land at the
            -- column where the opening `"""` is printed, rather than at the
            -- surrounding nest level. Gren's parser requires every content
            -- line AND the closing `"""` to be at the same column as the
            -- opening — without align, an opening that lands past the nest
            -- (because preceding tokens consumed columns) produces output
            -- that fails to re-parse.
            Ok (P.align (P.concat contentDoc (P.concat P.hardNl tripleQuote)))
        unexpected -> Err ("makePDoc: unexpected box type:\n" ++ lptToJson (lpnNode unexpected children))


-- Render a bracketed, comma-separated list of LPNode items, flat-or-vertical.
--
-- If any child is a SingleLineComment, delegates to listBoxesWithBrackets,
-- which always produces a multi-line layout (a line comment cannot live
-- inside a flat group). Otherwise the pretty-printer chooses flat or
-- one-item-per-line via the `P.group` in exposingListWithBrackets. (Callers
-- that want an unconditional vertical layout use `AlwaysVertical`, which routes
-- through listBoxesWithBrackets instead.)
makeAllAcrossOrAllVertical : ListBrackets -> Array LPNode -> Result String (P.Doc cost)
makeAllAcrossOrAllVertical brackets children =
    let
        bs = bracketStrings brackets
        hasComment = Array.any nodeIsComment children
    in
    if isUniformRecordArray brackets children then
        -- Uniform item layout for an array of record literals: a comment
        -- among the items rules out the flat form, exactly as in the
        -- generic path below.
        uniformRecordArrayDoc { allowFlat = not hasComment } children
    else if hasComment then
        listBoxesWithBrackets bs.open bs.close children
    else
        traverseArray makeListItemDoc children
            |> Result.map (\itemDocs ->
                exposingListWithBrackets bs.open bs.close bs.empty itemDocs
            )


{-| Does this bracketed literal get the *uniform item layout* treatment?

True for a `[ ... ]` array whose items are all record literals or record
updates. Such an array renders via `uniformRecordArrayDoc`, which couples
the items' flat-vs-expanded decision so that no record ever breaks across
lines while a sibling stays inline. Comments among the items don't
disqualify the array — they ride along in the vertical forms.
-}
isUniformRecordArray : ListBrackets -> Array LPNode -> Bool
isUniformRecordArray brackets children =
    when brackets is
        ListSquare ->
            let
                items = Array.keepIf (\n -> not (nodeIsComment n)) children
            in
            Array.length items > 0
                && Array.all
                    (\n ->
                        when lpnBox n is
                            AllAcrossOrAllVertical ListCurly -> True
                            AlwaysVertical ListCurly -> True
                            RecordUpdate _ -> True
                            _ -> False
                    )
                    items

        _ ->
            False


{-| Uniform item layout for an array of record literals and/or record
updates (see the README's "uniform item layout" section): every record
breaks the same way, so the array reads uniformly. The doc offers at most
three shapes:

  1. everything flat on one line — `[ { a = 1 }, { b = 2 } ]`
  2. vertical array, every record flat — one record per line
  3. vertical array, every record expanded — one field per line

and PrettyExpressive picks the cheapest that fits. There is deliberately
*no* shape where one record is expanded and a sibling is flat.

Idempotency rests on each shape being a fixed point under reparse:

  - Shape 1 reparses with no author breaks and re-fits, so it re-renders flat.
  - Shape 2 reparses as an author-vertical array of flat records
    (`AlwaysVertical ListSquare`, items `AllAcrossOrAllVertical ListCurly`),
    which lands back here with `allowFlat = False` and the same
    shape-2-vs-shape-3 cost comparison.
  - Shape 3 reparses with every record author-broken
    (`AlwaysVertical ListCurly`), whose docs contain `hardNl`; flattening
    them yields `failDoc`, so shapes 1 and 2 self-destruct (`concat`
    propagates failure, `choice` drops failing branches) and only shape 3
    remains.

That last mechanism also handles the trigger direction for free: an
author-broken record — or one that can't be flat at all (a comment inside
it, a multiline string) — invalidates every branch that would keep any
sibling inline, forcing the whole array to shape 3 with no explicit check.

`allowFlat` is False when the array was authored vertical (its verticality
is preserved, as everywhere else) or when a comment sits among the items.
-}
uniformRecordArrayDoc : { allowFlat : Bool } -> Array LPNode -> Result String (P.Doc cost)
uniformRecordArrayDoc { allowFlat } children =
    let
        bs = bracketStrings ListSquare

        verticalResult =
            Result.map2 P.choice
                (listBoxesWithBracketsUsing flatUniformItemDoc bs.open bs.close children)
                (listBoxesWithBracketsUsing expandedUniformItemDoc bs.open bs.close children)
    in
    if allowFlat then
        Result.map2
            (\itemDocs vertical ->
                P.choice
                    (P.flatten (exposingListWithBrackets bs.open bs.close bs.empty itemDocs))
                    vertical
            )
            (traverseArray makeListItemDoc children)
            verticalResult
    else
        verticalResult


{-| Render a uniform-array record item forced flat. An item that cannot be
flat (an author-broken record's `hardNl`, a comment inside it) flattens to
`failDoc`, which invalidates the whole containing branch — exactly the
degeneration the uniform layout wants.
-}
flatUniformItemDoc : LPNode -> Maybe (Result String (P.Doc cost))
flatUniformItemDoc node =
    listItemBoxDoc node
        |> Maybe.map (Result.map P.flatten)


{-| Render a uniform-array record item forced expanded (one field per
line), regardless of how it was authored. The `P.nest 2` matches
`listItemBoxDoc`'s handling of nested vertical literals, aligning the
record's continuation lines under its own first field. A record update is
forced expanded by rendering it with `forceVertical = True` — the exact doc
an author-broken update produces, which is what keeps the expanded shape a
fixed point under reparse.
-}
expandedUniformItemDoc : LPNode -> Maybe (Result String (P.Doc cost))
expandedUniformItemDoc node =
    when lpnBox node is
        AllAcrossOrAllVertical ListCurly ->
            Just (listBoxesForBracket ListCurly (lpnChildren node) |> Result.map (P.nest 2))

        RecordUpdate { name } ->
            Just (makeRecordUpdateDoc True name.value (lpnChildren node))

        _ ->
            listItemBoxDoc node


-- Map a Result-producing builder over each element, collecting the Ok values
-- into an array. Short-circuits on the first Err. The collect-or-fail traversal
-- that several doc builders need (over nodes, signature segments, binop
-- operands, pipeline steps).
traverseArray : (a -> Result e b) -> Array a -> Result e (Array b)
traverseArray build items =
    Array.foldl
        (\item acc ->
            acc |> Result.andThen (\collected ->
                build item |> Result.map (\b -> Array.pushLast b collected)
            )
        )
        (Ok [])
        items


bracketStrings : ListBrackets -> { open : String, close : String, empty : String }
bracketStrings brackets =
    when brackets is
        ListParen  -> { open = "( ", close = ")", empty = "()" }
        ListCurly  -> { open = "{ ", close = "}", empty = "{}" }
        ListSquare -> { open = "[ ", close = "]", empty = "[]" }

-- Shared per-box rendering for a list item, used by both the flat/vertical
-- bracket renderer (`makeListItemDoc`) and the comment-bearing always-vertical
-- renderer (`listBoxesWithBrackets`). Returns `Nothing` for a box that is not a
-- recognised list item, leaving the fallback to each caller (an error for the
-- plain path, a silent skip for the comment path).
--
-- A nested bracketed literal (`AllAcrossOrAllVertical` / `AlwaysVertical`) is
-- nested +2 — the width of the enclosing "[ " / ", " prefix — so its own
-- continuation lines align under its first element rather than the enclosing
-- list's items.
listItemBoxDoc : LPNode -> Maybe (Result String (P.Doc cost))
listItemBoxDoc node =
    let
        children = lpnChildren node
    in
    when lpnBox node is
        UnbreakableText loc ->
            Just (Ok (P.text loc.value))
        AcrossThenIndent ->
            Just (buildFlowDoc grenIndent children)
        ParenBlock ->
            Just (makePDoc ParenBlock children)
        AllAcrossOrAllVertical _ ->
            Just (makePDoc (lpnBox node) children |> Result.map (P.nest 2))
        AlwaysVertical bracket ->
            Just (listBoxesForBracket bracket children |> Result.map (P.nest 2))
        RecordUpdate { name, forceVertical } ->
            Just (makeRecordUpdateDoc forceVertical name.value children)
        -- An inline `when ... is`, a prefix-glued expr (`-1`), an empty literal
        -- (`[]` / `{}` / `()`), a synthesised keyword, a pipeline, or a binop
        -- chain as a list item: render inline; the enclosing list's break-or-flat
        -- decision still applies.
        AlignedFlow ->
            Just (makePDoc AlignedFlow children)
        PrefixGlue _ ->
            Just (makePDoc (lpnBox node) children)
        EmptyBracketed _ ->
            Just (makePDoc (lpnBox node) children)
        SynthesizedText _ ->
            Just (makePDoc (lpnBox node) children)
        Pipeline _ ->
            Just (makePDoc (lpnBox node) children)
        Binop _ ->
            Just (makePDoc (lpnBox node) children)
        _ ->
            Nothing


makeListItemDoc : LPNode -> Result String (P.Doc cost)
makeListItemDoc node =
    when listItemBoxDoc node is
        Just result -> result
        Nothing -> Err ("makeListItemDoc: unexpected box type:\n" ++ lptToJson node)

exposingListWithBrackets : String -> String -> String -> Array (P.Doc cost) -> P.Doc cost
exposingListWithBrackets open close empty items =
    when Array.popFirst items is
        Nothing ->
            P.text empty
        Just { first, rest } ->
            let
                firstDoc = P.concat (P.text open) first
                restDocs = Array.map (\d -> P.concat (P.text ", ") d) rest
                allDocs  = [ firstDoc ] ++ restDocs
                joined =
                    P.foldDoc
                        (\a b -> P.concat a (P.concat P.breakDoc b))
                        allDocs
            in
            P.group
                (P.concat joined (P.concat P.nl (P.text close)))


{-| Render a module/import `exposing ( ... )` list, coupling its "drop to the
next line" with its "go vertical" so the two happen together. The result is
**all-or-nothing**: either the whole list stays inline on the `exposing` line, or
it drops to the next line *and* breaks one item per line. There is no
intermediate "dropped onto its own line but still on one line" form.

The leading break (the drop) is baked into the *same* group as the item breaks,
so a single fit decision drives both. The returned doc starts with that leading
break (a space when flat, a newline when broken), so the caller glues it directly
after `exposing` rather than adding its own flow separator. The +4 indentation
comes from the enclosing flow's `P.nest`, so no nest is added here.

A comment among the items forces the vertical form (with no flat alternative),
matching the always-vertical comment-aware list rendering.
-}
makeExposingListDoc : Array LPNode -> Result String (P.Doc cost)
makeExposingListDoc children =
    if Array.any nodeIsComment children then
        listBoxesWithBrackets "( " ")" children
            |> Result.map (\body -> P.concat P.hardNl body)
    else
        traverseArray makeListItemDoc children
            |> Result.map (\itemDocs ->
                when Array.popFirst itemDocs is
                    Nothing ->
                        P.text " ()"
                    Just { first = firstItem, rest = restItems } ->
                        let
                            firstSeg = P.concat (P.text "( ") firstItem
                            restSegs =
                                Array.map
                                    (\d -> P.concat P.breakDoc (P.concat (P.text ", ") d))
                                    restItems
                            body =
                                Array.foldl (\seg acc -> P.concat acc seg) firstSeg restSegs
                            full =
                                P.concat body (P.concat P.nl (P.text ")"))
                        in
                        P.group (P.concat P.nl full)
            )


-- Render a comment box as just the source text it would produce: `--xxx`
-- for a SingleLineComment, `{-xxx-}` for a BlockComment, `{-|xxx-}` for a
-- DocComment. Returns P.empty for non-comment boxes; callers should only
-- pass a comment box.
--
-- A block comment whose body spans multiple lines is rendered with
-- `blockCommentDoc` so it is laid out (and re-indented) properly instead of
-- being smuggled through as flat text with embedded newlines.
commentBoxDoc : LPBox -> P.Doc cost
commentBoxDoc box =
    when box is
        SingleLineComment loc -> P.text ("--" ++ loc.value)
        BlockComment loc -> blockCommentDoc loc
        DocComment loc -> P.text ("{-|" ++ loc.value ++ "-}")
        _ -> P.empty


-- True if a comment body spans more than one source line.
isMultiLineCommentValue : String -> Bool
isMultiLineCommentValue value =
    String.contains "\n" value


-- Count leading space characters in a string.
leadingSpaceCount : String -> Int
leadingSpaceCount s =
    String.foldl
        (\c acc ->
            if acc.done then
                acc
            else if c == ' ' then
                { acc | count = acc.count + 1 }
            else
                { acc | done = True }
        )
        { count = 0, done = False }
        s
        |> .count


-- Render a block comment. A single-line body is emitted verbatim as flat
-- text. A multi-line body is split into physical lines, joined with
-- `P.hardNl`, and wrapped in `P.align`:
--
--   * The internal `hardNl`s make the doc unflattenable, so any enclosing
--     `P.group` is forced to its multi-line branch (a 3-line comment no
--     longer collapses a whole construct onto one line).
--   * Continuation lines are re-indented from a canonical anchor derived
--     *only from the body's own structure* — the smallest leading indent
--     among the content lines maps to `blockCommentBodyOffset`. `P.align`
--     then shifts the whole block under wherever the `{-` now prints. This
--     is whitespace-canonical: it no longer reads the input `{-` column
--     (`loc.start.col`), so perturbing the surrounding whitespace cannot
--     shift the body indentation.
--
-- Comment *content* indented past that base is preserved relative to it, so
-- internal structure (lists, ASCII art) keeps its relative shape.
--
-- Exception: when the author wrote the `{-` ALONE on its first line, the body
-- is kept verbatim — absolute columns, untouched — and only the `{-` moves.
-- That opener-alone form is the explicit, text-derived signal for "do not
-- re-indent my comment body" (see the verbatim branch below).
blockCommentDoc : Located String -> P.Doc cost
blockCommentDoc loc =
    if not (isMultiLineCommentValue loc.value) then
        P.text ("{-" ++ loc.value ++ "-}")
    else
        let
            fullText = "{-" ++ loc.value ++ "-}"
        in
        when Array.popFirst (String.split "\n" fullText) is
            Nothing ->
                P.text fullText
            Just { first = firstLine, rest = contLines } ->
                let
                    -- The body's base column: the smallest leading-space count
                    -- among continuation lines that carry content. Blank lines
                    -- and a closing `-}` alone on its own line are excluded so
                    -- they can't drag the base to column 0.
                    isContentLine line =
                        let t = String.trimLeft line
                        in t /= "" && t /= "-}"
                    contentCols =
                        contLines
                            |> Array.keepIf isContentLine
                            |> Array.map leadingSpaceCount
                    -- `{-` sits alone on its first line (nothing after the
                    -- opener). This is the author's signal — and the only
                    -- trigger — for verbatim mode below. It is a property of
                    -- the comment's own text, so the mode cannot flip when
                    -- the whitespace *around* the comment changes. (An earlier
                    -- trigger also compared the body's columns to the `{-`'s
                    -- source column; that read `loc.start.col`, so widening
                    -- the gap before the opener changed the rendering.)
                    openerAlone =
                        String.trimLeft (String.dropFirst 2 firstLine) == ""
                in
                if openerAlone then
                    -- Verbatim mode: the body is left exactly as written,
                    -- column for column — only the `{-` moves (to the
                    -- construct's indent). Protects ASCII art and hand-aligned
                    -- blocks. Body lines render at absolute columns (via
                    -- `reset`, so nesting doesn't shift them). The output's
                    -- opener is again alone on its line, so this re-enters
                    -- verbatim mode on reparse — a fixed point.
                    let
                        contDoc =
                            Array.foldl
                                (\line acc -> P.concat acc (P.concat P.hardNl (P.text line)))
                                P.empty
                                contLines
                    in
                    P.concat (P.text "{-") (P.reset contDoc)
                else
                    let
                        base =
                            contentCols
                                |> Array.minimum
                                |> Maybe.withDefault blockCommentBodyOffset
                        -- Map the base to `blockCommentBodyOffset` and keep any
                        -- deeper internal indentation relative to it. Lines shallower
                        -- than the base (a bare `-}`, blank lines) clamp to column 0.
                        reindent line =
                            let l = leadingSpaceCount line
                            in
                            String.repeat (max 0 (blockCommentBodyOffset + l - base)) " "
                                ++ String.dropFirst l line
                    in
                    Array.foldl
                        (\line acc -> P.concat acc (P.concat P.hardNl (P.text (reindent line))))
                        (P.text firstLine)
                        contLines
                        |> P.align


-- LPNode-form of commentBoxDoc.
commentNodeDoc : LPNode -> P.Doc cost
commentNodeDoc node = commentBoxDoc (lpnBox node)


-- Render a SingleLineComment's source text followed by a hardNl. The hardNl
-- makes the comment unflatten-able: a `--` consumes the rest of its line, so
-- any P.group containing one is forced into the broken layout. Use this
-- whenever the comment may be followed by more content in the surrounding
-- doc array.
lineComment : String -> P.Doc cost
lineComment s =
    P.concat (P.text ("--" ++ s)) P.hardNl


makeRecordUpdateDoc : Bool -> String -> Array LPNode -> Result String (P.Doc cost)
makeRecordUpdateDoc forceVertical baseName children =
    -- Skip any leading comment children so we can find the actual first field
    -- (the comment-bearing children get rendered as their own lines below).
    let
        { leading = commentsBefore, rest = fields } = splitLeadingComments children
    in
    when Array.popFirst fields is
        Nothing ->
            when Array.popFirst commentsBefore is
                Nothing -> Ok (P.text ("{ " ++ baseName ++ " }"))
                Just _ ->
                    Ok (P.vcat
                        ([P.text ("{ " ++ baseName)]
                        ++ Array.map (\c -> P.concat (P.text "    ") (commentNodeDoc c)) commentsBefore
                        ++ [P.text "}"]))
        Just { first = firstField, rest = restFields } ->
            -- Wrap each field's flow with P.align so that when the field value
            -- itself spans multiple lines (e.g. a nested record update), the
            -- continuation lines start at the column where the field content
            -- begins (just after the "    | " / "    , " prefix), giving a
            -- visual indent under the field name instead of leaking back out
            -- to the surrounding record's column.
            let
                fieldDoc field =
                    buildFlowDoc grenIndent (lpnChildren field)
                        |> Result.map P.align

                hasComment =
                    not (Array.isEmpty commentsBefore)
                        || Array.any nodeIsComment restFields
            in
            if forceVertical || hasComment then
                -- Always-vertical form: base on its own line, each field
                -- prefixed with `| ` / `, ` indented +4, close on its own line.
                -- Used when the author wrote the fields across rows, and
                -- whenever a comment is present (a comment cannot live in the
                -- inline form).
                let
                    leadingCommentLines =
                        Array.map (\c -> P.concat (P.text "    ") (commentNodeDoc c)) commentsBefore
                in
                when fieldDoc firstField is
                    Err e -> Err e
                    Ok firstFieldDoc ->
                        let
                            firstLine = P.concat (P.text "    | ") firstFieldDoc
                            restResult =
                                Array.foldl
                                    (\field accResult ->
                                        when accResult is
                                            Err e -> Err e
                                            Ok docs ->
                                                if nodeIsComment field then
                                                    Ok (Array.pushLast (P.concat (P.text "    ") (commentNodeDoc field)) docs)
                                                else
                                                    when fieldDoc field is
                                                        Err e -> Err e
                                                        Ok d ->
                                                            Ok (Array.pushLast (P.concat (P.text "    , ") d) docs)
                                    )
                                    (Ok (leadingCommentLines ++ [firstLine]))
                                    restFields
                        in
                        when restResult is
                            Err e -> Err e
                            Ok fieldLines ->
                                Ok (P.vcat ([P.text ("{ " ++ baseName)] ++ fieldLines ++ [P.text "}"]))
            else
                -- Fit-based form (no comments, author wrote it on one line): a
                -- group whose flat rendering is `{ base | a = 1, b = 2 }` and
                -- whose broken rendering is the vertical form above. The breaks
                -- are built so that flattening reproduces the inline spacing:
                -- `nl` before the first field (flattens to a space, giving
                -- ` | `), `breakDoc` before each subsequent field (flattens to
                -- empty, so its own `, ` prefix gives `, `), and `nl` before the
                -- closing `}`. The fields are nested +4 so the broken form is
                -- byte-identical to the vcat form above — keeping a single-line
                -- update that overflows idempotent with a multi-line-authored one.
                when fieldDoc firstField is
                    Err e -> Err e
                    Ok firstFieldDoc ->
                        traverseArray fieldDoc restFields
                            |> Result.map (\restDocs ->
                                let
                                    firstSeg = P.concat (P.text "| ") firstFieldDoc
                                    restSegs =
                                        Array.map
                                            (\d -> P.concat P.breakDoc (P.concat (P.text ", ") d))
                                            restDocs
                                    fieldsInner = Array.foldl (\seg acc -> P.concat acc seg) firstSeg restSegs
                                    fieldsPart = P.nest grenIndent (P.concat P.nl fieldsInner)
                                    inner =
                                        P.concat
                                            (P.text ("{ " ++ baseName))
                                            (P.concat fieldsPart (P.concat P.nl (P.text "}")))
                                in
                                P.group inner
                            )


{-| Build the `PrettyExpressive` `Doc` for a single root-child node without
resolving it to a string.

Dispatches on the node's `OriginalRows` `SyntaxType` (type aliases, type
unions, and the comment variants take dedicated builders; everything else
flows through `makeFlowIndentableDoc`). `EmptyLine` nodes produce
`P.empty`. Any other top-level box is an `Err` — only root children are
valid input.

Exposed for `Formatter.PExJson`, which serialises the per-declaration `Doc`
tree to JSON for the `--pex` debug flag.
-}
makePrettyLineDoc : LPNode -> Result String (P.Doc P.DefaultCostTuple)
makePrettyLineDoc node =
    let
        children = lpnChildren node
    in
    when lpnBox node is
        OriginalRows { stype = stype } ->
            when stype is
                StTypeAlias -> makeTypeAliasPrettyDoc children
                StTypeUnion -> makeTypeUnionPrettyDoc children
                StSingleLineComment -> makeCommentLineDoc_ children
                StBlockComment -> makeCommentLineDoc_ children
                StDocComment -> makeCommentLineDoc_ children
                StFunctionSignature -> makeSignaturePrettyDoc children
                StPort -> makeSignaturePrettyDoc children
                StModule -> makeExposingLineDoc children
                StImport -> makeExposingLineDoc children
                _ -> makeFlowIndentableDoc children
        EmptyLine ->
            Ok P.empty
        _ ->
            Err "Unexpected item in LPTree root children"


{-| Render a `module …` or `import …` line. When it ends in an `exposing ( … )`
list and the part before that list is all plain keyword/name tokens (the common
case: a plain `module`/`port module` or any `import`, but not an effect module's
`where { … }` block, and no comment in the header), render the header on a single
unbreakable line and glue the exposing list as a coupled all-or-nothing group via
`makeExposingListDoc`. This makes the line either fully on one line, or `header
exposing` then the list one-item-per-line — never the in-between "list dropped to
its own line but still flat" form, and never a break inside the header itself.

Anything that doesn't match (a `(..)` wildcard, an effect-module `where` block, a
comment in the header) falls back to the generic flow.
-}
makeExposingLineDoc : Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
makeExposingLineDoc children =
    when Array.popLast children is
        Just { last = lastNode, initial = headerNodes } ->
            let
                lastIsParenList =
                    when lpnBox lastNode is
                        AllAcrossOrAllVertical ListParen -> True
                        _ -> False
                headerAllLeaves =
                    Array.all
                        (\n ->
                            when lpnBox n is
                                UnbreakableText _ -> True
                                SynthesizedText _ -> True
                                _ -> False
                        )
                        headerNodes
            in
            if lastIsParenList && headerAllLeaves && not (Array.isEmpty headerNodes) then
                traverseArray (\n -> makePDoc (lpnBox n) (lpnChildren n)) headerNodes
                    |> Result.andThen (\headerDocs ->
                        makeExposingListDoc (lpnChildren lastNode)
                            |> Result.map (\listDoc ->
                                let
                                    -- Header tokens joined by hard spaces: no break
                                    -- point inside the header, so the only break is the
                                    -- exposing list's coupled drop.
                                    headerDoc =
                                        P.foldDoc
                                            (\a b -> P.concat a (P.concat (P.text " ") b))
                                            headerDocs
                                in
                                P.concat headerDoc (P.nest grenIndent listDoc)
                            )
                    )
            else
                makeFlowIndentableDoc children
        Nothing ->
            makeFlowIndentableDoc children


makeFlowIndentableDoc : Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
makeFlowIndentableDoc children =
    let
        { leading, rest } = splitLeadingComments children
    in
    buildFlowDoc grenIndent rest
        |> Result.map (\flowDoc ->
            let
                commentDocs = Array.map commentNodeDoc leading
            in
            if Array.isEmpty commentDocs then
                flowDoc
            else
                P.concat (P.vcat commentDocs) (P.concat P.hardNl flowDoc)
        )


-- True if `node` or any of its descendants is a line/block comment.
subtreeHasComment : LPNode -> Bool
subtreeHasComment node =
    nodeIsComment node || Array.any subtreeHasComment (lpnChildren node)


-- True for the synthesized signature/lambda `->`: a zero-width
-- `UnbreakableText` (start == end) built by `LPTHelpers.mkZeroWidthText`. These
-- are the top-level arrows of the signature's lambda chain; nested arrows live
-- inside a `ParenBlock` and never appear among a signature's direct children.
isArrowLeaf : LPNode -> Bool
isArrowLeaf node =
    when lpnBox node is
        UnbreakableText loc ->
            loc.value == "->"
                && loc.start.row == loc.end.row
                && loc.start.col == loc.end.col
        _ ->
            False


-- True for the zero-width `:` leaf that separates a signature's header
-- (`name :` / `port name :`) from its type. Record-type field colons are
-- `SynthesizedText` nested inside item containers, so the first top-level
-- `UnbreakableText ":"` is always the signature colon.
isColonLeaf : LPNode -> Bool
isColonLeaf node =
    when lpnBox node is
        UnbreakableText loc -> loc.value == ":"
        _ -> False


-- Split a signature's type nodes (everything after the `:`) into segments at
-- each top-level `->`: the first segment is the leading type, each later one
-- begins with its `->` so it renders as `-> NextType`.
splitSignatureSegments : Array LPNode -> Array (Array LPNode)
splitSignatureSegments nodes =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                Array.pushLast [node] acc
            else
                when Array.popLast acc is
                    Just { last = seg, initial = front } ->
                        Array.pushLast (Array.pushLast node seg) front
                    Nothing ->
                        [[node]]
        )
        []
        nodes


-- A segment's first content row, ignoring its leading `->` (which is anchored
-- at the *previous* segment's end, not where its own type sits). Used for
-- "signal B": if consecutive segments start on different rows the author wrote
-- the signature across lines, so it stays one-segment-per-line.
segContentFirstRow : Array LPNode -> Int
segContentFirstRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc
            else
                let r = firstRowInSubtree node
                in
                if acc < 0 then r else min acc r
        )
        -1
        seg


{-| Render a function/port signature with the author's one-line-vs-multi-line
layout (all-or-nothing, mirroring lists/records).

A signature the author wrote on one line stays inline when it fits and breaks
to one-segment-per-line on overflow; one written across rows stays
one-segment-per-line. Both the overflow form and the multi-line form are:

    foo :
        VeryLongType
        -> AnotherType
        -> ResultType

The fit-based `P.group`'s broken branch is byte-identical to the forced-vertical
form (same `nl` separators), so overflow == author-multi-line and formatting is
a fixed point.

Comment-bearing signatures fall back to the original fill renderer: the
all-or-nothing break points have no stable anchor for a trailing comment, and
the existing fill path already keeps arrow-comment placement idempotent.
-}
makeSignaturePrettyDoc : Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
makeSignaturePrettyDoc children =
    if Array.any subtreeHasComment children then
        makeFlowIndentableDoc children
    else
        let
            -- Header = everything up to and including the `:`; the rest is the
            -- type. (`name :` for a function, `port name :` for a port.)
            colonSplit =
                Array.foldl
                    (\node acc ->
                        if acc.afterColon then
                            { acc | typeNodes = Array.pushLast node acc.typeNodes }
                        else if isColonLeaf node then
                            { acc | header = Array.pushLast node acc.header, afterColon = True }
                        else
                            { acc | header = Array.pushLast node acc.header }
                    )
                    { header = [], typeNodes = [], afterColon = False }
                    children
        in
        if not colonSplit.afterColon then
            -- No colon found: not a real signature shape; render as a flow.
            makeFlowIndentableDoc children
        else
            let
                segments = splitSignatureSegments colonSplit.typeNodes
                forceVertical =
                    rowsSpanMultiple (Array.map segContentFirstRow segments)

                segDocsResult =
                    traverseArray (buildFlowDoc 0) segments
            in
            buildFlowDoc 0 colonSplit.header
                |> Result.andThen (\headerDoc ->
                    segDocsResult
                        |> Result.map (\segDocs ->
                            let
                                bodyInner =
                                    when Array.popFirst segDocs is
                                        Nothing -> P.empty
                                        Just { first = d0, rest = ds } ->
                                            Array.foldl
                                                (\d acc -> P.concat acc (P.concat P.nl d))
                                                d0
                                                ds
                                full =
                                    P.concat headerDoc
                                        (P.nest grenIndent (P.concat P.nl bodyInner))
                            in
                            groupUnlessForced forceVertical full
                        )
                )


-- True for a `PipelineStep` node (one `|> step` / `<| step`).
isPipelineStepNode : LPNode -> Bool
isPipelineStepNode node =
    when lpnBox node is
        PipelineStep -> True
        _ -> False


{-| Render a whole pipeline with the author's one-line-vs-multi-line layout.

`children` are the seed node(s) followed by the `PipelineStep` nodes. A pipeline
the author wrote on one line stays inline when it fits (`seed |> a |> b`); one
written across rows, or one that overflows, gets one step per line:

    seed
        |> step1
        |> step2

The fit-based `P.group`'s broken branch and the forced-vertical form are the
*same* doc (just grouped vs not), so overflow == author-multi-line and formatting
is a fixed point. A pipeline carrying any comment always renders through the
existing `PipelineStep` path (`buildFlowDoc 0 children`), whose comment-peeling
and blank-line logic stays untouched.
-}
makePipelineDoc : Bool -> Array LPNode -> Result String (P.Doc cost)
makePipelineDoc forceVertical children =
    if Array.any subtreeHasComment children then
        -- Comment-bearing pipeline: the intricate per-step comment handling
        -- lives in buildFlowDocImpl's PipelineStep case. Route there.
        buildFlowDoc 0 children
    else
        let
            -- No comments in this branch, so every non-step node is a seed node
            -- and they all precede the steps; `keepIf` preserves that order.
            seedNodes = Array.keepIf (\n -> not (isPipelineStepNode n)) children
            stepNodes = Array.keepIf isPipelineStepNode children
        in
        buildFlowDoc 0 seedNodes
            |> Result.andThen (\seedDoc ->
                -- `|> body` with continuation args nested +4 from the `|>` column
                -- — exactly the PipelineStep path's `buildFlowDoc grenIndent
                -- stepChildren`.
                traverseArray (\step -> buildFlowDoc grenIndent (lpnChildren step)) stepNodes
                    |> Result.map (\stepDocs ->
                        let
                            -- Step separator (see `authorSep`): a soft break inline,
                            -- an unflattenable hard break when forced, so an outer
                            -- `name = body` group can't collapse a multi-line pipeline
                            -- back onto the `=` line. Both render the same bytes when
                            -- broken, so fit-overflow == forced-vertical.
                            sep = authorSep forceVertical
                            -- Each step on its own line, indented +grenIndent from the seed.
                            stepsInner =
                                Array.foldl
                                    (\d acc -> P.concat acc (P.concat sep d))
                                    P.empty
                                    stepDocs
                            full =
                                P.concat seedDoc (P.nest grenIndent stepsInner)
                        in
                        groupUnlessForced forceVertical full
                    )
            )


-- Flatten the right-nested `OpAndRhs` structure of a Binop container back into
-- its operands (each a flow of LPNodes) and operator leaf nodes, in source
-- order. Inverse of `InsertExpressions.buildNestedOpAndRhs`. Used only on the
-- comment-free path; comments would otherwise live among these nodes.
flattenBinopNodes : Array LPNode -> { operands : Array (Array LPNode), ops : Array LPNode }
flattenBinopNodes children =
    when Array.popLast children is
        Nothing ->
            { operands = [], ops = [] }
        Just { last = lastNode, initial = operandNodes } ->
            when lpnBox lastNode is
                OpAndRhs ->
                    when Array.popFirst (lpnChildren lastNode) is
                        Just { first = opNode, rest = restChildren } ->
                            let inner = flattenBinopNodes restChildren
                            in
                            { operands = [operandNodes] ++ inner.operands
                            , ops = [opNode] ++ inner.ops
                            }
                        Nothing ->
                            { operands = [operandNodes], ops = [] }
                _ ->
                    { operands = [children], ops = [] }


{-| Render an `if` / `else if` condition: the children are `[if, …condition…,
then]`. Either it all fits on one line —

    if cond then

— or, when it doesn't, the condition drops to its own indented line and `then`
goes on a line flush with `if`:

    if
        cond
    then

The flat branch is fully flattened (`P.flatten` on the condition), so the choice
is genuinely all-on-one-line vs. the stacked form — the optimizer can't pick a
middle shape where the condition wraps but `then` stays glued to its last line.
-}
makeIfConditionDoc : Array LPNode -> Result String (P.Doc cost)
makeIfConditionDoc children =
    when Array.popFirst children is
        Nothing ->
            Err "if condition: no nodes"
        Just { first = ifNode, rest = afterIf } ->
            when Array.popLast afterIf is
                Nothing ->
                    Err "if condition: missing then"
                Just { initial = condNodes, last = thenNode } ->
                    makePDoc (lpnBox ifNode) (lpnChildren ifNode)
                        |> Result.andThen (\ifDoc ->
                            makePDoc (lpnBox thenNode) (lpnChildren thenNode)
                                |> Result.andThen (\thenDoc ->
                                    makePredicateDoc condNodes
                                        |> Result.map (\condDoc ->
                                            let
                                                flat =
                                                    P.concat ifDoc
                                                        (P.concat (P.text " ")
                                                            (P.concat (P.flatten condDoc)
                                                                (P.concat (P.text " ") thenDoc)))
                                                stacked =
                                                    P.concat ifDoc
                                                        (P.concat
                                                            (P.nest grenIndent (P.concat P.hardNl condDoc))
                                                            (P.concat P.hardNl thenDoc))
                                            in
                                            P.choice stacked flat
                                        )
                                )
                        )


{-| Render an `if` / `else if` predicate for the stacked form.

A binop predicate wraps the **precedence-aware** way — the same layout binops
use everywhere else: it breaks only at the lowest-precedence operators, one
operator-led group per line, indented +4 from the predicate's first line —

    if
        userIsActive
            && accountHasCredit
            && not isSuspended
    then

The predicate is rendered with `forceVertical = False` regardless of the
author's layout: the fit decision belongs to the surrounding `if … then`
choice, which is all-or-nothing, and a forced `hardNl` here would make the
flat arm unflattenable. Any other predicate shape (a call, a comparison) is
laid out by the ordinary flow renderer.
-}
makePredicateDoc : Array LPNode -> Result String (P.Doc cost)
makePredicateDoc condNodes =
    when Array.first condNodes is
        Just only ->
            if Array.length condNodes == 1 then
                when lpnBox only is
                    Binop _ ->
                        makeBinopDoc False (lpnChildren only)
                    _ ->
                        buildFlowDoc 0 condNodes
            else
                buildFlowDoc 0 condNodes
        Nothing ->
            buildFlowDoc 0 condNodes


-- The text of an operator leaf node (`UnbreakableText` / `SynthesizedText`).
opNodeText : LPNode -> String
opNodeText node =
    when lpnBox node is
        UnbreakableText loc -> loc.value
        SynthesizedText s -> s
        _ -> ""


{-| Render a non-pipeline binop chain with precedence-aware author layout.

A chain the author wrote on one line stays inline when it fits; otherwise it
breaks **only at its lowest-precedence operators** (operator-led, one group per
line), keeping tighter-binding sub-terms inline:

    baseScore
        + bonusPoints * multiplier
        - penaltyAmount

The fit-based `P.group` and the forced-vertical form share the broken doc (fit
uses `P.nl`, forced uses `P.hardNl` so an outer `name = body` group can't collapse
a multi-line chain), so overflow == author-multi-line and formatting is a fixed
point. A chain carrying any comment falls back to the `OpAndRhs` fill renderer
(`buildFlowDoc grenIndent children`), so wrapped operators indent +4 like the
precedence-aware form.
-}
makeBinopDoc : Bool -> Array LPNode -> Result String (P.Doc cost)
makeBinopDoc forceVertical children =
    if Array.any subtreeHasComment children then
        -- Comment-bearing chain: fall back to the fill renderer. Use a +4
        -- continuation indent (grenIndent), matching the precedence-aware form
        -- and the comment-bearing signature fallback, so wrapped operators sit
        -- under the first operand rather than back at its own column.
        buildFlowDoc grenIndent children
    else
        let
            flat = flattenBinopNodes children
        in
        when Array.popFirst flat.operands is
            Nothing ->
                Ok P.empty
            Just { first = operand0Nodes, rest = restOperands } ->
                if Array.isEmpty flat.ops then
                    buildFlowDoc 0 operand0Nodes
                else
                    -- Render every operand to a doc, then split at the chain's
                    -- minimum precedence into operator-led groups.
                    let
                        operandDocsResult =
                            traverseArray (buildFlowDoc 0) flat.operands
                        minPrec =
                            binopMinPrecedence (Array.map opNodeText flat.ops)
                    in
                    operandDocsResult
                        |> Result.map (\operandDocs ->
                            assembleBinopGroups forceVertical minPrec operandDocs flat.ops
                        )


-- Assemble the operand docs and operator nodes into the precedence-aware layout.
-- `operandDocs` has one more entry than `ops`; `ops[k]` sits between
-- `operandDocs[k]` and `operandDocs[k+1]`. Groups break at operators whose
-- precedence equals `minPrec` (= `binopMinPrecedence ops`); tighter
-- (higher-precedence) operators join their operands inline within a group. This
-- is the render-side twin of `InsertExpressions.binopForceVertical`, which
-- groups the operand *ranges* the same way to decide the forced-vertical flag.
assembleBinopGroups : Bool -> Int -> Array (P.Doc cost) -> Array LPNode -> P.Doc cost
assembleBinopGroups forceVertical minPrec operandDocs ops =
    let
        firstDoc =
            Array.first operandDocs |> Maybe.withDefault P.empty
        -- Pair each operator with the operand doc that follows it.
        paired =
            Array.map2
                (\op nextDoc -> { op = op, nextDoc = nextDoc })
                ops
                (Array.dropFirst 1 operandDocs)
        -- Fold left, accumulating the current group's inline doc and emitting a
        -- completed group (led by its lowest-precedence operator) each time we
        -- cross a minimum-precedence operator.
        state =
            Array.foldl
                (\pair acc ->
                    if binopPrecedence (opNodeText pair.op) == minPrec then
                        { firstGroup =
                            -- The first minimum-precedence operator closes group 0;
                            -- capture the accumulated `curDoc` (which may already hold
                            -- higher-precedence ops, e.g. `a * b` in `a * b + c`).
                            if acc.started then acc.firstGroup else acc.curDoc
                        , started = True
                        , segments =
                            if acc.started then
                                Array.pushLast { sep = acc.pendingSep, doc = acc.curDoc } acc.segments
                            else
                                acc.segments
                        , pendingSep = opNodeText pair.op
                        , curDoc = pair.nextDoc
                        }
                    else
                        { acc
                            | curDoc =
                                P.concat acc.curDoc
                                    (P.concat (P.text (" " ++ opNodeText pair.op ++ " ")) pair.nextDoc)
                        }
                )
                { firstGroup = firstDoc
                , started = False
                , segments = []
                , pendingSep = ""
                , curDoc = firstDoc
                }
                paired
        -- Close the final group.
        segments =
            Array.pushLast { sep = state.pendingSep, doc = state.curDoc } state.segments
        sep =
            authorSep forceVertical
        restInner =
            Array.foldl
                (\seg acc ->
                    P.concat acc
                        (P.concat sep (P.concat (P.text (seg.sep ++ " ")) seg.doc))
                )
                P.empty
                segments
        full =
            P.concat state.firstGroup (P.nest grenIndent restInner)
    in
    groupUnlessForced forceVertical full


makeTypeAliasPrettyDoc : Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
makeTypeAliasPrettyDoc =
    renderHeaderIndentedBodyDoc "type alias declaration is empty" makeTypeBodyDoc


makeTypeUnionPrettyDoc : Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
makeTypeUnionPrettyDoc =
    renderHeaderIndentedBodyDoc "type declaration is empty" makeUnionBodyDoc


renderHeaderIndentedBodyDoc : String -> (Array LPNode -> Result String (P.Doc P.DefaultCostTuple)) -> Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
renderHeaderIndentedBodyDoc emptyError buildBody children =
    when Array.popLast children is
        Nothing ->
            Err emptyError
        Just { initial = headerChildren, last = bodyBlock } ->
            buildFlowDoc 0 headerChildren
                |> Result.andThen (\headerDoc ->
                    buildBody (lpnChildren bodyBlock)
                        |> Result.map (\bodyDoc ->
                            P.concat headerDoc (P.nest grenIndent (P.concat P.hardNl bodyDoc))
                        )
                )


-- Render a top-level comment-line OriginalRows. Usually it holds a single
-- comment, but comment placement merges comments that share a source row (or
-- fall within a multi-line block comment's row span) into one OriginalRows —
-- e.g. `{- a -} {- b -}` on one line. So render every comment child: join two
-- block comments on the same row with a space, otherwise with a hardNl, and
-- always break after a `--` line comment (which consumes the rest of its line).
makeCommentLineDoc_ : Array LPNode -> Result String (P.Doc P.DefaultCostTuple)
makeCommentLineDoc_ children =
    let
        commentInfo node =
            when lpnBox node is
                SingleLineComment loc -> Just { row = loc.start.row, isLine = True }
                BlockComment loc -> Just { row = loc.start.row, isLine = False }
                DocComment loc -> Just { row = loc.start.row, isLine = False }
                _ -> Nothing
    in
    Array.foldl
        (\node accResult ->
            when accResult is
                Err e -> Err e
                Ok acc ->
                    when commentInfo node is
                        Nothing ->
                            Err "Unexpected node type in comment line"
                        Just info ->
                            let
                                commentDoc = commentNodeDoc node
                            in
                            when acc.doc is
                                Nothing ->
                                    Ok { doc = Just commentDoc, prevRow = info.row, prevLine = info.isLine }
                                Just prevDoc ->
                                    let
                                        separator =
                                            if acc.prevLine || info.row /= acc.prevRow then
                                                P.hardNl
                                            else
                                                P.text " "
                                    in
                                    Ok { doc = Just (P.concat prevDoc (P.concat separator commentDoc))
                                       , prevRow = info.row
                                       , prevLine = info.isLine
                                       }
        )
        (Ok { doc = Nothing, prevRow = -1, prevLine = False })
        children
        |> Result.andThen (\acc ->
            when acc.doc is
                Nothing -> Err "No nodes in comment line"
                Just d -> Ok d
        )


-- `listBoxesWithBrackets` keyed by a `ListBrackets` value rather than explicit
-- open/close strings — the shape every nested always-vertical literal needs.
listBoxesForBracket : ListBrackets -> Array LPNode -> Result String (P.Doc cost)
listBoxesForBracket bracket nodes =
    if isUniformRecordArray bracket nodes then
        -- An author-vertical array of record literals: stay vertical, but
        -- couple the records' flat-vs-expanded decision (uniform item layout).
        uniformRecordArrayDoc { allowFlat = False } nodes
    else
        let bs = bracketStrings bracket
        in listBoxesWithBrackets bs.open bs.close nodes


listBoxesWithBrackets : String -> String -> Array LPNode -> Result String (P.Doc cost)
listBoxesWithBrackets open close nodes =
    listBoxesWithBracketsUsing listItemBoxDoc open close nodes


-- The general form of `listBoxesWithBrackets`: render each item with the
-- given renderer instead of the default `listItemBoxDoc`. The uniform
-- record-array layout uses this to build the same comment-aware vertical
-- structure twice — once with every record forced flat, once with every
-- record forced expanded — and offer the pair as a single choice.
listBoxesWithBracketsUsing : (LPNode -> Maybe (Result String (P.Doc cost))) -> String -> String -> Array LPNode -> Result String (P.Doc cost)
listBoxesWithBracketsUsing itemRenderer open close nodes =
    let
        -- Reuse the shared list-item dispatch, tagging each rendered doc with its
        -- source row (so the fold can place trailing comments) and treating an
        -- unrecognised box as "skip" rather than an error — a comment-bearing
        -- list never errors on an item it can't classify, it just drops it.
        nodeItemDoc node =
            when itemRenderer node is
                Nothing ->
                    Ok Nothing
                Just result ->
                    let
                        row =
                            when lpnBox node is
                                UnbreakableText loc -> loc.start.row
                                _ -> lpnMaxRow node
                    in
                    result |> Result.map (\d -> Just { doc = d, row = row })

        foldResult =
            Array.foldl
                (\node accResult ->
                    when accResult is
                        Err e -> Err e
                        Ok acc ->
                            let
                                handleCommentNode commentRow =
                                    let
                                        commentDoc = commentNodeDoc node
                                    in
                                    if commentRow == acc.prevRow then
                                        -- Trailing the preceding item: attach with a SOFT break —
                                        -- a space when it fits, otherwise its own line. A hard
                                        -- space would put the comment on the item's line, so an
                                        -- overflowing trailing comment would re-wrap the item's
                                        -- value; on reparse the comment then sits on the value's
                                        -- wrapped row, the value un-wraps, and the layout
                                        -- oscillates. The soft break keeps the item's value laid
                                        -- out as if the comment were absent (it lands past the
                                        -- break), so only the comment moves — stable across
                                        -- reformats. Mirrors the trailing line-comment soft break
                                        -- in buildFlowDocImpl.
                                        let
                                            attached =
                                                when acc.pending is
                                                    Nothing ->
                                                        { doc = commentDoc, isComment = True }
                                                    Just e ->
                                                        { doc = P.concat e.doc (P.group (P.concat P.nl commentDoc))
                                                        , isComment = False
                                                        }
                                        in
                                        Ok { acc
                                            | lineDocs = acc.lineDocs ++ [ attached ]
                                            , pending  = Nothing
                                            }

                                    else
                                        let
                                            flushed =
                                                when acc.pending is
                                                    Nothing -> acc.lineDocs
                                                    Just e  -> acc.lineDocs ++ [ e ]
                                        in
                                        Ok { lineDocs = flushed ++ [ { doc = commentDoc, isComment = True } ]
                                           , pending  = Nothing
                                           , prevRow  = commentRow
                                           }
                            in
                            when lpnBox node is
                                SingleLineComment loc ->
                                    handleCommentNode loc.start.row

                                BlockComment loc ->
                                    handleCommentNode loc.start.row

                                _ ->
                                    when nodeItemDoc node is
                                        Err e -> Err e
                                        Ok Nothing -> Ok acc
                                        Ok (Just { doc, row }) ->
                                            let
                                                flushed =
                                                    when acc.pending is
                                                        Nothing -> acc.lineDocs
                                                        Just e  -> acc.lineDocs ++ [ e ]
                                            in
                                            Ok { lineDocs = flushed
                                               , pending  = Just { doc = doc, isComment = False }
                                               , prevRow  = row
                                               }
                )
                (Ok { lineDocs = [], pending = Nothing, prevRow = -1 })
                nodes
    in
    when foldResult is
        Err e -> Err e
        Ok state ->
            let
                allLineDocs =
                    when state.pending is
                        Nothing -> state.lineDocs
                        Just e  -> state.lineDocs ++ [ e ]

                prefixed =
                    let
                        { result } =
                            Array.foldl
                                (\{ doc, isComment } acc ->
                                    if isComment then
                                        { acc | result = acc.result ++ [ doc ] }
                                    else
                                        let
                                            prefixedDoc =
                                                if acc.seenText then
                                                    P.concat (P.text ", ") doc
                                                else
                                                    P.concat (P.text open) doc
                                        in
                                        { result = acc.result ++ [ prefixedDoc ]
                                        , seenText = True
                                        }
                                )
                                { result = [], seenText = False }
                                allLineDocs
                    in
                    result ++ [ P.text close ]
            in
            Ok (P.vcat prefixed)


