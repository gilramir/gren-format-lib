module Formatter.MakeRender
    exposing
        ( makePrettyResult
        , lptToRenderDocJson
        )

{-| Render a Logical Printing Tree to its final formatted source string.

Each `LPBox` constructor maps to a `Formatter.Render` `Doc` via `makePDoc`.
`makePrettyResult` is the main entry point. Unhandled box types surface as
`Err` rather than silently falling back, so every supported construct must
have an explicit case in `makePDoc`.

# Comments

Comments arrive in the LPT already woven into the right slots by
`Formatter.Comments`, so by the time `makePrettyResult` runs they're
just `LPNode`s interleaved with content at whatever depth they belong
to. What makes them tricky is that they can show up *anywhere* ‚Äî in a
top-level slot, mid-expression, between record fields, between a
function and its arguments, inside a pipeline step, inside an exposing
list ‚Äî and each surrounding context renders them slightly differently.

A handful of techniques carry the load:

  - **Unflattenability via `hardNl`.** A `--` line comment consumes the
    rest of its source line, so any `R.group` it appears in *must*
    resolve to the multi-line branch. Rendering a `SingleLineComment`
    as `--text` followed by `R.hardNl` makes any enclosing group
    unflatten-able by construction.

  - **Trailing vs. leading by row comparison.** Inside `buildFlowDoc` we
    track the source row of the preceding item. A comment whose row
    matches attaches to it with a space (`foo -- comment`); a comment
    on a different row gets a forced `hardNl` before it so it starts
    its own line.

  - **`AlreadyTerminated` separator state.** Because every line comment
    ends with a `hardNl`, the *next* item must not emit another
    newline-or-space separator. The flow-builder's `NextSeparator`
    carries an `AlreadyTerminated` value that suppresses the normal
    separator for one step.

  - **Container-specific peeling.** Some containers can't just let a
    leading comment ride along with the flow. A `PipelineStep`'s body
    is wrapped in an extra `+4` indent, so a leading comment is peeled
    off and emitted at the step's own column. `RecordUpdate` and the
    generic top-level builder peel leading comments via
    `splitLeadingComments` so they stand on their own lines above the
    first field or term.

  - **Forcing list layouts.** Bracketed lists can't put a `--` inside a
    flat group, so the presence of any comment in the children
    promotes the whole list to a vertical layout where each comment
    renders on its own line and never picks up a `, ` prefix.

  - **Top-level comment slots.** Comments that don't belong to any
    declaration sit at the LPT root as their own `OriginalRows` with
    `StSingleLineComment` / `StBlockComment` / `StDocComment`;
    `makePrettyLineDoc` dispatches them to a dedicated builder.

@docs makePrettyResult
-}

import Compiler.SourcePosition exposing (Located)

import Formatter.LogicalPrintingTree
    exposing
        ( LPBox(..)
        , LPNode
        , ListBrackets(..)
        , SyntaxType(..)
        , lpnBox
        , lpnChildren
        , lpnNode
        , firstRowInSubtree
        , lpnMaxRow
        , lpnLastPos
        , lpnFirstPos
        , lpnLastBracketEnd
        , lpnBracketStart
        )
import Formatter.LPTJson exposing (lptToJson)
import Formatter.LPTHelpers exposing (binopPrecedence, binopMinPrecedence)

import Formatter.Strings exposing (joinResultStrings)

import Formatter.Render as R exposing (Doc)
import Json.Encode as Json


-- How many spaces we indent
grenIndent : Int
grenIndent =
    4

-- Author-layout combinators, shared by the constructs that follow the author's
-- one-line-vs-multi-line choice (signatures, pipelines, binop chains). Layout is
-- author-driven, not fit-driven: a construct the author wrote on one line stays
-- inline, one they spread across rows stays vertical. `forceVertical` carries
-- that decision (made upstream from the source rows). Build the segment
-- separators with `authorSep forceVertical` and wrap the whole doc with
-- `inlineUnlessVertical forceVertical`.


-- Separator between author-layout segments. Vertical: an unflattenable hard
-- break (so an enclosing `name = body` group can't collapse a multi-line
-- construct back onto one line). Inline: a soft break ‚Äî it sits inside the
-- `R.group` that `inlineUnlessVertical` adds, which always renders flat, so the
-- break becomes a single space.
authorSep : Bool -> Doc
authorSep forceVertical =
    if forceVertical then
        R.hardNl

    else
        R.nl


-- Wrap an author-layout doc. Vertical: returned as-is so its hard breaks fire.
-- Inline: wrapped in `R.group`, which always renders flat (there is no
-- page-width test), forcing the whole doc onto one line.
inlineUnlessVertical : Bool -> Doc -> Doc
inlineUnlessVertical forceVertical full =
    if forceVertical then
        full

    else
        R.group full


-- True if the rows are not all equal ‚Äî i.e. the items they came from span more
-- than one source line, so the author wrote the construct across rows and it
-- should stay vertical. The Doc-side mirror of `InsertExpressions.itemsSpanRows`
-- (which decides the same thing at LPT-build time for lists, records, pipelines,
-- and binops); used here for unions and signatures, whose layout decision is
-- still taken at render time.
rowsSpanMultiple : Array Int -> Bool
rowsSpanMultiple rows =
    when Array.popFirst rows is
        Nothing ->
            False

        Just { first, rest } ->
            Array.any (\r -> r /= first) rest


-- Canonical hanging indent for a multi-line block comment's continuation
-- lines: the width of the `{- ` opener, so the body aligns under the first
-- content character of the first line.
blockCommentBodyOffset : Int
blockCommentBodyOffset =
    3


{-| Render a complete Logical Printing Tree to its formatted source string.

Renders each root child independently via `makePrettyLine` and joins the
results with a single newline. The caller is expected to pass the root
`LPNode` produced by `Formatter.MakeLogical`; `EmptyLine` children
contribute blank separators here. Returns `Err` if any child contains an
unhandled box construct.
-}
makePrettyResult : LPNode -> Result String String
makePrettyResult root =
    let
        -- Strip trailing whitespace from each rendered root child before the
        -- newline join. A child is one top-level item and never legitimately
        -- ends in whitespace ‚Äî vertical spacing between items comes entirely
        -- from `EmptyLine` children, and the join supplies the separators. The
        -- one way a child *can* end in whitespace is the artifact where a
        -- multi-line block comment is the last node of a flow (claimed as a
        -- declaration's trailing comment): `buildFlowDoc` appends a terminating
        -- `hardNl` to end the comment's line ‚Äî needed when another node
        -- follows, spurious when none does ‚Äî which inside the flow's `+4` nest
        -- re-emits the indent as a trailing-whitespace line. Trimming here
        -- removes it without disturbing the load-bearing hardNl for non-last
        -- comments. (Multi-line string interiors are never the trailing chars
        -- of a child ‚Äî the closing `"""` is ‚Äî so their spacing is untouched.)
        prettyLines =
            Array.map
                (\node -> Result.map String.trimRight (makePrettyLine node))
                (lpnChildren root)
    in
    joinResultStrings "\n" prettyLines


makePrettyLine : LPNode -> Result String String
makePrettyLine node =
    makePrettyLineDoc node
        |> Result.map R.render


-- True if the node is a line or block comment. (Doc comments are their own
-- top-level OriginalRows so they don't appear in mid-flow positions.)
nodeIsComment : LPNode -> Bool
nodeIsComment node =
    when lpnBox node is
        SingleLineComment _ ->
            True

        BlockComment _ ->
            True

        _ ->
            False


-- Take a prefix of comment nodes off `nodes`, returning the comments and
-- the remainder. Used wherever a container (top-level decl, record update,
-- pipeline step, ...) wants to render leading comments on their own lines
-- before the rest of its children.
splitLeadingComments : Array LPNode -> { leading : Array LPNode, rest : Array LPNode }
splitLeadingComments nodes =
    let
        step item acc =
            if acc.done then
                { acc | rest = Array.pushLast item acc.rest }

            else if nodeIsComment item then
                { acc | leading = Array.pushLast item acc.leading }

            else
                { leading = acc.leading, rest = [ item ], done = True }
    in
    Array.foldl step { leading = [], rest = [], done = False } nodes
        |> (\r -> { leading = r.leading, rest = r.rest })


makeUnionBodyDoc : Array LPNode -> Result String Doc
makeUnionBodyDoc nodes =
    let
        hasComment =
            Array.any nodeIsComment nodes

        variantNodes =
            Array.keepIf (\n -> not (nodeIsComment n)) nodes

        -- Signal B over the variants: a union the author wrote across rows stays
        -- one-variant-per-line; one written on a single line stays inline
        -- (`= A | B | C`), regardless of width ‚Äî layout is author-driven, not
        -- fit-driven. Mirrors the record/list rule. The inline `R.group` and the
        -- always-vertical `R.vcat` form are built to be byte-identical when
        -- flattened, so reformatting is a fixed point.
        variantsSpanRows =
            rowsSpanMultiple (Array.map firstRowInSubtree variantNodes)
    in
    if hasComment || variantsSpanRows then
        makeUnionBodyVertical nodes

    else
        traverseArray (\n -> buildFlowDoc 0 (lpnChildren n)) variantNodes
            |> Result.map
                (\docs ->
                    R.group (R.foldDoc (\a b -> R.concat a (R.concat R.nl b)) docs)
                )


-- Always-vertical union body: one variant per line via R.vcat, with comments
-- placed inline after the variant they trail or on their own line otherwise.
makeUnionBodyVertical : Array LPNode -> Result String Doc
makeUnionBodyVertical nodes =
    let
        placeComment row commentDoc acc =
            when Array.popLast acc.docs is
                Nothing ->
                    Ok { docs = [ commentDoc ], prevRow = row }

                Just { last = lastDoc, initial = initDocs } ->
                    if row == acc.prevRow then
                        Ok { docs = Array.pushLast (R.concat lastDoc (R.concat (R.text " ") commentDoc)) initDocs
                            , prevRow = row
                            }

                    else
                        Ok { docs = Array.pushLast commentDoc acc.docs
                            , prevRow = row
                            }

        result =
            Array.foldl
                (\node accResult ->
                    when accResult is
                        Err e ->
                            Err e

                        Ok acc ->
                            when lpnBox node is
                                SingleLineComment loc ->
                                    placeComment loc.start.row (commentNodeDoc node) acc

                                BlockComment loc ->
                                    placeComment loc.start.row (commentNodeDoc node) acc

                                _ ->
                                    when buildFlowDoc 0 (lpnChildren node) is
                                        Err e ->
                                            Err e

                                        Ok childDoc ->
                                            Ok { docs = Array.pushLast childDoc acc.docs
                                                -- Use the later of the last *positioned token* row and
                                                -- the last *bracket end* row. The last token row alone
                                                -- is wrong when the variant ends with a record payload:
                                                -- the closing `}` is not a positioned token, so
                                                -- `lpnLastPos` returns the last field value (one row
                                                -- above `}` when multi-line). A trailing comment on the
                                                -- `}` line would then fail the `row == prevRow` test and
                                                -- be placed on its own line, shifting it one row down on
                                                -- each reformat (non-idempotent). Adding the bracket
                                                -- end row ‚Äî set precisely by `lpnBracketNode` from the
                                                -- parser's `locType.end` ‚Äî covers that case without
                                                -- over-counting from multi-line block comments, whose
                                                -- end row widens `maxRow` but not `lastBracketEnd`.
                                                , prevRow =
                                                    let
                                                        tokenRow =
                                                            lpnLastPos node
                                                                |> Maybe.map (\p -> p.row)
                                                                |> Maybe.withDefault -1

                                                        bracketRow =
                                                            lpnLastBracketEnd node
                                                                |> Maybe.map (\p -> p.row)
                                                                |> Maybe.withDefault -1

                                                        maxR =
                                                            max tokenRow bracketRow
                                                    in
                                                    if maxR >= 0 then
                                                        maxR

                                                    else
                                                        firstRowInSubtree node
                                                }
                )
                (Ok { docs = [], prevRow = -1 })
                nodes
    in
    when result is
        Err e ->
            Err e

        Ok state ->
            Ok (R.vcat state.docs)


makeTypeBodyDoc : Array LPNode -> Result String (Doc)
makeTypeBodyDoc typeNodes =
    when Array.popFirst typeNodes is
        Nothing ->
            Ok R.empty

        Just { first = onlyNode, rest = rest } ->
            if Array.isEmpty rest then
                -- Render the single body node as-is. A record body now carries
                -- its own author-derived layout (`AllAcrossOrAllVertical` when
                -- written on one line, `AlwaysVertical` when written across
                -- rows ‚Äî see `Src.TRecord`), so it is no longer force-
                -- verticalized; a one-line-authored record sits inline on the
                -- body line, exactly like a non-record alias body
                -- (`type alias Id = Int`).
                makePDoc (lpnBox onlyNode) (lpnChildren onlyNode)

            else
                buildFlowDoc 0 typeNodes


{-| What separator to place before the next item.

  - `FirstItem` ‚Äî nothing precedes; emit no separator.
  - `FlowSep` ‚Äî normal flow: space or newline (via `group nl`).
  - `HardNl` ‚Äî after an `IndentedBlock`: forced newline.
  - `AlreadyTerminated` ‚Äî after a comment's `hardNl`: no extra separator.
-}
type NextSeparator
    = FirstItem
    | FlowSep
    | HardNl
    | AlreadyTerminated


-- The accumulator threaded through `buildFlowDocImpl`'s fold (and the per-box
-- node renderers it delegates to): the doc built so far, the source row of the
-- previous positioned leaf (`-1` if none), whether that leaf was an elided `->`
-- (see the `prevElided` note in the fold), and the separator to apply before the
-- next item.
type alias FlowAcc =
    { doc : Doc
    , prevRow : Int
    , prevElided : Bool
    , separator : NextSeparator
    }


-- Layout rule for a block-style child (IndentedBlock, BodyBlock, etc.):
--   `wrap` decorates the child doc (indenting, hardNl-prefixing, grouping‚Ä¶).
--   `bypassAlreadyTerminated = True` means the wrap is skipped when the
--     previous item ended its own line (no extra separator needed).
--   `nextSep` is the separator state to set after rendering this block.
type alias BlockRule =
    { wrap : Doc -> Doc
    , bypassAlreadyTerminated : Bool
    , nextSep : NextSeparator
    }


indentedBlockRule : BlockRule
indentedBlockRule =
    { wrap = \c -> R.nest grenIndent (R.concat R.hardNl c)
    , bypassAlreadyTerminated = False
    , nextSep = HardNl
    }


bodyBlockRule : BlockRule
bodyBlockRule =
    { wrap = \c -> R.concat R.hardNl c
    , bypassAlreadyTerminated = True
    , nextSep = FlowSep
    }


softIndentedBlockRule : BlockRule
softIndentedBlockRule =
    { wrap = \c -> R.group (R.nest grenIndent (R.concat R.nl c))
    , bypassAlreadyTerminated = False
    , nextSep = FlowSep
    }


-- Join a block's child doc onto the accumulator, honoring the rule's
-- FirstItem / AlreadyTerminated bypasses.
joinBlock : BlockRule -> NextSeparator -> Doc -> Doc -> Doc
joinBlock rule sep accDoc childDoc =
    when sep is
        FirstItem ->
            childDoc

        AlreadyTerminated ->
            if rule.bypassAlreadyTerminated then
                R.concat accDoc childDoc

            else
                -- The previous item (a comment) already ended its line with a
                -- hardNl, so applying the normal wrap ‚Äî which begins with its own
                -- nl/hardNl ‚Äî would emit a *second* newline: a whitespace-only
                -- blank line (the break re-emits the current indentation).
                -- Instead indent the child to the wrap's level without a leading
                -- break: `nest grenIndent` so the child's own line breaks land at
                -- +grenIndent, plus a literal run of spaces to push its first line
                -- there too (there is no leading break to do that). The two
                -- non-bypass rules (IndentedBlock, SoftIndentedBlock) both nest by
                -- exactly grenIndent, so this matches their broken form minus the
                -- spurious blank line.
                R.concat
                    accDoc
                    (R.nest
                        grenIndent
                        (R.concat (R.text (String.repeat grenIndent " ")) childDoc))

        _ ->
            R.concat accDoc (rule.wrap childDoc)


-- Peel a run of trailing single-line comments off the end of a block's
-- children, returning the remaining body nodes plus a doc that glues those
-- comments back on inline (each preceded by a space), in source order.
--
-- A comment left inside the block's flow rides a soft break, so an overflowing
-- line drops it onto its own line one row below the body's last token,
-- dedented; on reparse it sits past the body's range and re-attaches at the
-- enclosing level, the body collapses, and the layout oscillates
-- (non-idempotent). Gluing keeps the comment on the body's last row across
-- reformats.
--
-- `peelLineComments` selects the caller's rule:
--
--   * `True` (block bodies): also peel a trailing `--` comment. Because a `--`
--     consumes the rest of its line it may only be the *rightmost* glued
--     comment ‚Äî a second `--` to its left would swallow it, so peeling stops
--     there.
--   * `False` (when-branch bodies): peel only block comments; a trailing `--`
--     is left in the flow (its soft-break handling already keeps it stable).
--
-- Either way, block comments may be chained freely and a multi-line block
-- comment is left in place (it legitimately breaks the line).
peelTrailingComments : Bool -> Array LPNode -> { bodyNodes : Array LPNode, trailingCommentDoc : Doc }
peelTrailingComments peelLineComments nodes =
    let
        go remaining accDoc sawLineComment =
            when Array.popLast remaining is
                Just { last = lastChild, initial = initChildren } ->
                    let
                        keep =
                            { bodyNodes = remaining, trailingCommentDoc = accDoc }

                        glue newSawLineComment =
                            go
                                initChildren
                                (R.concat (R.text " ") (R.concat (commentNodeDoc lastChild) accDoc))
                                newSawLineComment
                    in
                    when lpnBox lastChild is
                        SingleLineComment _ ->
                            if peelLineComments && not sawLineComment then
                                glue True

                            else
                                keep

                        BlockComment loc ->
                            if isMultiLineCommentValue loc.value then
                                keep

                            else
                                glue sawLineComment

                        _ ->
                            keep

                Nothing ->
                    { bodyNodes = remaining, trailingCommentDoc = accDoc }
    in
    go nodes R.empty False


-- Render a body-block child (BodyBlock) inside buildFlowDoc's
-- fold: peel its trailing inline comments, render the body via `renderBlockNode`,
-- then glue the comments back onto the result. Shared by both arms.
renderBodyBlockNode : BlockRule -> FlowAcc -> Array LPNode -> Result String FlowAcc
renderBodyBlockNode rule acc nodeChildren =
    let
        { bodyNodes, trailingCommentDoc } =
            peelTrailingComments True nodeChildren
    in
    renderBlockNode rule acc bodyNodes
        |> Result.map (\r -> { r | doc = R.concat r.doc trailingCommentDoc })


-- Render a block-style child node inside buildFlowDoc's fold: recurse
-- into the children, then join via joinBlock and produce the next acc.
renderBlockNode : BlockRule -> FlowAcc -> Array LPNode -> Result String FlowAcc
renderBlockNode rule acc nodeChildren =
    buildFlowDoc 0 nodeChildren
        |> Result.map
            (\childrenDoc ->
                { doc = joinBlock rule acc.separator acc.doc childrenDoc
                , prevRow = -1
                , prevElided = False
                , separator = rule.nextSep
                }
            )


{-| Build the Doc for a pipeline step's children (the `|> func args...` part).

When ANY child forces multi-line rendering ‚Äî a lambda ParenBlock
(`isMultilineLambdaParenBlock`), a paren whose content spans rows due to an
AlwaysVertical or RecordUpdate inside (`isMultilineContentParenBlock`), or any
other node whose own rendered content contains a hard break (e.g. a record
argument with 2+ fields or a comment, per `anyChildForcesVertical`'s
per-node check) ‚Äî breaks it onto a new line.  For a lambda arg, the body
aligns under `(` and `)` closes on its own line.  For a non-lambda multiline
paren arg, `)` lands on its own line too.  For any other multiline arg (e.g. a
record), it renders via its own normal box.  Any arguments that follow also
each land on their own line at `|>` + 4:

    |> Array.foldl
        (\r acc ->
            body
        )
        0

    |> AST.TType
        { name = name
        , args = args
        }
        extraArg

When the multiline arg is the last one (no suffix), it closes the step.
Otherwise falls back to `buildFlowDoc grenIndent` (continuation args at `|>` + 4)
‚Äî note this never falls back to `buildFlowDocBroken`: `stepChildren` includes
the `|>`/`<|` operator token as its first item, and unlike a plain call's
`AcrossThenIndent`, this flow must keep the operator glued to the function
name even when a later argument forces vertical (the split below handles that
via preamble/trigger/suffix instead).  Called from both `renderPipelineStepNode`
(comment-bearing path) and the fast path in `makePipelineDoc` (comment-free
path) ‚Äî both wrap the result in an outer `R.nest grenIndent`, so the arg
lands at step-column + 4.
-}
buildStepChildrenDoc : Array LPNode -> Result String Doc
buildStepChildrenDoc stepChildren =
    let
        -- Scan left-to-right for the first node that must force a break: a
        -- multiline lambda ParenBlock, a ParenBlock with multiline content,
        -- or (new) any other multiline-forcing node ‚Äî a record argument
        -- being the common case, since a Call's lone-AcrossThenIndent
        -- wrapper is unwrapped directly into the step (see
        -- `MakeLogical`/`buildBodyDoc`), discarding the `checkContentVertical`
        -- decision that would normally catch it (see `flowChildForcesVertical`
        -- for why ParenBlock/comments are excluded from that last check ‚Äî
        -- they already have dedicated handling here and in the surrounding
        -- flow, respectively).
        -- Accumulator: { preamble, triggerAndSuffix }
        -- Before the trigger is found: preamble grows.
        -- After the trigger is found: triggerAndSuffix.suffix grows.
        splitResult =
            Array.foldl
                (\node acc ->
                    when acc.triggerAndSuffix is
                        Just state ->
                            { acc | triggerAndSuffix = Just { state | suffix = Array.pushLast node state.suffix } }

                        Nothing ->
                            if isMultilineLambdaParenBlock node || isMultilineContentParenBlock node || flowChildForcesVertical node then
                                { preamble = acc.preamble
                                , triggerAndSuffix = Just { trigger = node, suffix = [] }
                                }

                            else
                                { acc | preamble = Array.pushLast node acc.preamble }
                )
                { preamble = [], triggerAndSuffix = Nothing }
                stepChildren
    in
    when splitResult.triggerAndSuffix is
        Nothing ->
            buildFlowDoc grenIndent stepChildren

        Just { trigger, suffix } ->
            buildFlowDocInline 0 splitResult.preamble
                |> Result.andThen
                    (\preambleDoc ->
                        let
                            makeArgDoc =
                                if isMultilineLambdaParenBlock trigger then
                                    makeMultilineLambdaArgDoc (lpnChildren trigger)

                                else if isMultilineContentParenBlock trigger then
                                    makeMultilineParenArgDoc (lpnChildren trigger)

                                else
                                    makePDoc (lpnBox trigger) (lpnChildren trigger)
                        in
                        makeArgDoc
                            |> Result.andThen
                                (\triggerDoc ->
                                    let
                                        triggerPart =
                                            R.nest grenIndent (R.concat R.hardNl triggerDoc)
                                    in
                                    if Array.isEmpty suffix then
                                        Ok (R.concat preambleDoc triggerPart)

                                    else
                                        -- Use buildFlowDoc 0 so AlreadyTerminated tracks
                                        -- correctly across comments in the suffix (avoids
                                        -- a double hardNl when a SingleLineComment precedes
                                        -- the last arg).
                                        buildFlowDoc 0 suffix
                                            |> Result.map
                                                (\suffixDoc ->
                                                    R.concat
                                                        preambleDoc
                                                        (R.concat
                                                            triggerPart
                                                            (R.nest grenIndent (R.concat R.hardNl suffixDoc)))
                                                )
                                )
                    )


-- Render a `PipelineStep` child inside buildFlowDoc's fold.
--
-- Peel a single leading line/block comment off the step so it renders at the
-- step's own nesting level rather than inside the extra R.nest grenIndent
-- applied to the args. This keeps the comment and `|>` at the same column,
-- while continuation args are indented +4 from `|>`. Always force a hardNl
-- after the comment so `|>` starts on the next line.
--
-- Also peel ALL trailing inline block comments and at most one trailing
-- line comment off the END of the step.  Letting buildFlowDoc emit them
-- would put the terminating hardNl at the +grenIndent continuation-arg
-- level (= base + 2 * grenIndent), which leaves the next step's leading
-- hardNl producing a blank line at that over-indented level.  When a
-- multiline-lambda suffix feature places those comments into the suffix
-- they would land on their own line instead of inline ‚Äî triggering a
-- context-idempotency gap.  We use peelTrailingComments (which already
-- handles the multi-comment case) so the suffix is always free of
-- trailing inline comments; the next step's leading hardNl handles line
-- termination at the correct outer indent.
renderPipelineStepNode : FlowAcc -> Array LPNode -> Result String FlowAcc
renderPipelineStepNode acc nodeChildren =
    let
        { commentDoc, withoutLeading, hasComment } =
            -- Peel ALL leading comments, not just the first. Each
            -- renders own-line at the step's own column (the outer
            -- nest), so `|>` is the first token after them at that
            -- same column. Leaving a second leading comment inside
            -- `childrenDoc` (which carries an inner `nest grenIndent`)
            -- would let its own-line break push `|>` one level deeper
            -- ‚Äî an inconsistent `|>` indent that varies with how many
            -- comments precede the step.
            let
                { leading, rest } =
                    splitLeadingComments nodeChildren
            in
            { commentDoc = Array.foldl
                    (\c cdoc -> R.concat cdoc (R.concat (commentNodeDoc c) R.hardNl))
                    R.empty
                    leading
            , withoutLeading = rest
            , hasComment = not (Array.isEmpty leading)
            }

        peeled =
            peelTrailingComments True withoutLeading

        stepChildren =
            peeled.bodyNodes

        trailingCommentDoc =
            peeled.trailingCommentDoc
    in
    when buildStepChildrenDoc stepChildren is
        Err e ->
            Err e

        Ok childrenDoc ->
            let
                -- Only add a blank line before a commented step if it
                -- follows another PipelineStep (separator = HardNl).
                blankLinePrefix =
                    when acc.separator is
                        HardNl ->
                            if hasComment then
                                R.text "\n"

                            else
                                R.empty

                        _ ->
                            R.empty

                -- commentDoc (if any) fires at step level; childrenDoc
                -- (|> and args) is wrapped in R.nest grenIndent so
                -- continuation args break at |>-column + 4. The
                -- trailingCommentDoc (if any) is glued onto the end of
                -- the children with a leading space ‚Äî it lives inside
                -- the same inner nest, but with NO trailing hardNl,
                -- so the next step's leading hardNl is the one that
                -- ends the line and re-establishes the outer indent.
                indentedDoc =
                    R.concat
                        blankLinePrefix
                        (R.nest
                            grenIndent
                            (R.concat
                                R.hardNl
                                (R.concat
                                    commentDoc
                                    (R.concat childrenDoc trailingCommentDoc))))

                newDoc =
                    when acc.separator is
                        FirstItem ->
                            R.concat commentDoc (R.concat childrenDoc trailingCommentDoc)

                        _ ->
                            R.concat acc.doc indentedDoc
            in
            Ok { doc = newDoc
                , prevRow = -1
                , prevElided = False
                , separator = HardNl
                }


-- Render a `WhenBranch` child inside buildFlowDoc's fold.
--
-- Peel *all* trailing block comments off the END of the branch and glue them
-- inline to the body with a space, rather than letting buildFlowDoc place them.
-- Left in the flow a trailing block comment rides a soft break, so it drops onto
-- its own line at the branch indent ‚Äî one row *below* the body's last token, and
-- dedented. On reparse that row sits past the declaration's range and the
-- comment escapes to a top-level comment (column 1), non-idempotently. Gluing
-- keeps it on the body's last row, inside the branch, across reformats. A
-- trailing `--` is left in place (peelLineComments = False) ‚Äî its own soft-break
-- handling keeps it stable. The next branch's leading hardNl terminates the line.
renderWhenBranchNode : FlowAcc -> Array LPNode -> Result String FlowAcc
renderWhenBranchNode acc nodeChildren =
    let
        { bodyNodes, trailingCommentDoc } =
            peelTrailingComments False nodeChildren
    in
    when buildFlowDoc 0 bodyNodes is
        Err e ->
            Err e

        Ok bodyDoc ->
            let
                childrenDoc =
                    R.concat bodyDoc trailingCommentDoc

                -- Always blank-separate consecutive branches,
                -- regardless of whether either body is multi-line.
                blankOrNewline =
                    R.concat (R.text "\n") R.hardNl

                newDoc =
                    when acc.separator is
                        FirstItem ->
                            childrenDoc

                        -- A preceding comment has already ended its
                        -- line with hardNl, so attach the branch
                        -- directly to avoid inserting an extra blank
                        -- line between the comment and its pattern.
                        AlreadyTerminated ->
                            R.concat acc.doc childrenDoc

                        _ ->
                            R.concat acc.doc (R.concat blankOrNewline childrenDoc)
            in
            Ok { doc = newDoc
                , prevRow = -1
                , prevElided = False
                , separator = FlowSep
                }


-- Render a `SingleLineComment` child inside buildFlowDoc's fold. A comment on
-- the same row as the preceding item (or one trailing an elided `->`) glues with
-- a soft break; on a different row it forces an own-line break. Either way it
-- ends its line with a hardNl so the next item starts fresh (`AlreadyTerminated`).
renderSingleLineCommentNode : FlowAcc -> LPBox -> Located String -> FlowAcc
renderSingleLineCommentNode acc box loc =
    let
        commentText =
            commentBoxDoc box

        docWithComment =
            when acc.separator is
                FirstItem ->
                    commentText

                AlreadyTerminated ->
                    -- Previous comment already ended its line with hardNl;
                    -- concatenate directly to avoid a blank line between
                    -- consecutive comments.
                    R.concat acc.doc commentText

                _ ->
                    if loc.start.row == acc.prevRow || acc.prevElided then
                        -- Same row as preceding item: attach with a SOFT
                        -- break ‚Äî a space in flat context, otherwise its own
                        -- line. A hard space would give the flow no break
                        -- point here, forcing an *earlier* break (e.g. before
                        -- an elided `->`) so the comment trails a token that
                        -- moved down. Whether that earlier token then renders
                        -- on row N or N+1 flips the comment's own input row on
                        -- reparse, oscillating between layouts. The soft break
                        -- keeps the preceding token in place and moves only the
                        -- comment, which is stable across reformats.
                        --
                        -- `prevElided` also takes this branch: a comment that
                        -- directly trails a zero-width elided token (`->`, `:`,
                        -- `=`, ‚Ä¶) is anchored at that token's *left-neighbour*
                        -- row, not where the token renders. If the token wraps
                        -- onto its own continuation line, the comment's own row
                        -- no longer equals that anchor ‚Äî so a pure row test
                        -- would flip it to its own line on the next format even
                        -- though it fits beside the (wrapped) token. Soft-gluing
                        -- whenever it trails an elided token keeps the glue-when-
                        -- it-fits rendering stable across reformats.
                        R.concat acc.doc (R.group (R.concat R.nl commentText))

                    else
                        -- Different row: force a line break before the comment
                        R.concat acc.doc (R.concat R.hardNl commentText)
    in
    { doc = R.concat docWithComment R.hardNl
    , prevRow = loc.start.row
    , prevElided = False
    , separator = AlreadyTerminated
    }


{-| builds the flow, and handles SingleLineComment nodes correctly:

  - A comment on the same row as the preceding item is attached directly
    to it (no separator), producing e.g. "exposing -- comment".
  - A comment on a different row goes on its own line via a forced hardNl.
  - Either way, the comment appends hardNl so the next item always starts
    on a fresh line ‚Äî indicated by `AlreadyTerminated` for the next item.
-}
buildFlowDoc : Int -> Array LPNode -> Result String Doc
buildFlowDoc indent nodes =
    buildFlowDocImpl indent False False nodes


-- Like `buildFlowDoc`, but for a flow that continues on the *same line* as a
-- token the caller already emitted (e.g. a binop RHS after its operator, or
-- the body of a `( ‚Ä¶ )`). A leading single-line block comment there is part
-- of that line and stays inline, rather than being treated as a standalone
-- own-line comment that forces a break.
buildFlowDocInline : Int -> Array LPNode -> Result String Doc
buildFlowDocInline indent nodes =
    buildFlowDocImpl indent True False nodes


buildFlowDocBroken : Int -> Array LPNode -> Result String Doc
buildFlowDocBroken indent nodes =
    buildFlowDocImpl indent False True nodes


-- `inlineStart` says whether the first node of this flow continues a line the
-- caller already started. It only affects a *leading single-line* block
-- comment: in an inline context it stays inline; otherwise (a block/vertical
-- context such as a `let` binding) it is standalone and forces the following
-- token onto its own line at the correct column. Multi-line block comments
-- always force the break regardless.
buildFlowDocImpl : Int -> Bool -> Bool -> Array LPNode -> Result String Doc
buildFlowDocImpl indent inlineStart brokenFlow nodes =
    let
        -- separator: either "same line with space" or "new line with indent"
        flowSep accDoc nextDoc =
            if brokenFlow then
                R.concat accDoc (R.concat R.hardNl nextDoc)

            else
                R.concat accDoc (R.group (R.concat R.nl nextDoc))

        joinDoc sep accDoc itemDoc =
            when sep is
                FirstItem ->
                    itemDoc

                FlowSep ->
                    flowSep accDoc itemDoc

                HardNl ->
                    R.concat (R.concat accDoc R.hardNl) itemDoc

                AlreadyTerminated ->
                    R.concat accDoc itemDoc

        foldResult =
            Array.foldl
                (\node accResult ->
                    when accResult is
                        Err e ->
                            Err e

                        Ok acc ->
                            let
                                box =
                                    lpnBox node

                                nodeChildren =
                                    lpnChildren node
                            in
                            when box is
                                SingleLineComment loc ->
                                    Ok (renderSingleLineCommentNode acc box loc)

                                BlockComment loc ->
                                    let
                                        -- A block comment forces an own-line break (so the next
                                        -- token starts fresh at the right column) when it is
                                        -- multi-line, OR when it is a standalone leading comment
                                        -- in a vertical context ‚Äî the first item of a flow that
                                        -- does not continue a line the caller already started
                                        -- (e.g. before a non-first `let` binding), OR when a
                                        -- previous comment already ended the line (AlreadyTerminated):
                                        -- a run of own-line comments must each stay on their own
                                        -- line, not glue the following token onto the last one.
                                        -- A single-line block comment that continues a line stays
                                        -- inline (`a * {- c -} b`, a binop RHS, a `( ‚Ä¶ )` body).
                                        standaloneLeading =
                                            (acc.separator == FirstItem && not inlineStart)
                                                || acc.separator == AlreadyTerminated
                                    in
                                    if isMultiLineCommentValue loc.value || standaloneLeading then
                                        let
                                            commentText =
                                                commentBoxDoc box

                                            docWithComment =
                                                when acc.separator is
                                                    FirstItem ->
                                                        commentText

                                                    AlreadyTerminated ->
                                                        R.concat acc.doc commentText

                                                    _ ->
                                                        -- `|| acc.prevElided` mirrors
                                                        -- `renderSingleLineCommentNode`: a comment
                                                        -- directly trailing a zero-width elided token
                                                        -- (e.g. a signature's synthesized `->`) is
                                                        -- anchored at that token's left-neighbour row,
                                                        -- not where the token renders, so a pure row
                                                        -- test flips across reformats when the
                                                        -- neighbour wraps onto its own line.
                                                        if loc.start.row == acc.prevRow || acc.prevElided then
                                                            R.concat acc.doc (R.concat (R.text " ") commentText)

                                                        else
                                                            R.concat acc.doc (R.concat R.hardNl commentText)
                                        in
                                        Ok { doc = R.concat docWithComment R.hardNl
                                            , prevRow = loc.start.row
                                            , prevElided = False
                                            , separator = AlreadyTerminated
                                            }

                                    else
                                        -- Single-line block comment continuing a line: inline.
                                        when makePDoc box nodeChildren is
                                            Err e ->
                                                Err e

                                            Ok itemDoc ->
                                                Ok { doc = joinDoc acc.separator acc.doc itemDoc
                                                    , prevRow = -1
                                                    , prevElided = False
                                                    , separator = FlowSep
                                                    }

                                AllAcrossOrAllVertical bracket ->
                                    when makeAllAcrossOrAllVertical bracket nodeChildren is
                                        Err e ->
                                            Err e

                                        Ok itemDoc ->
                                            Ok { doc = joinDoc acc.separator acc.doc itemDoc
                                                , prevRow = -1
                                                , prevElided = False
                                                , separator = FlowSep
                                                }

                                IndentedBlock ->
                                    renderBlockNode indentedBlockRule acc nodeChildren

                                PipelineStep ->
                                    renderPipelineStepNode acc nodeChildren

                                BodyBlock ->
                                    renderBodyBlockNode bodyBlockRule acc nodeChildren

                                WhenBranch ->
                                    renderWhenBranchNode acc nodeChildren

                                SoftIndentedBlock ->
                                    renderBlockNode softIndentedBlockRule acc nodeChildren

                                EmptyLine ->
                                    -- A blank-line marker between `let` bindings,
                                    -- inserted by `VerticalSpace.insertLetBlankLines`.
                                    -- Emit one raw "\n" (not R.hardNl, which would
                                    -- re-emit indentation and leave trailing whitespace
                                    -- on the blank line ‚Äî cf. the WhenBranch/PipelineStep
                                    -- blanks). The following binding's IndentedBlock
                                    -- supplies its own leading hardNl, so each EmptyLine
                                    -- nets exactly one blank line. Keep separator = HardNl
                                    -- so that binding still wraps onto its own line.
                                    Ok { doc = R.concat acc.doc (R.text "\n")
                                        , prevRow = -1
                                        , prevElided = False
                                        , separator = HardNl
                                        }

                                _ ->
                                    when makePDoc box nodeChildren is
                                        Err e ->
                                            Err e

                                        Ok itemDoc ->
                                            let
                                                prevRow =
                                                    when box is
                                                        UnbreakableText loc ->
                                                            loc.start.row

                                                        _ ->
                                                            -1

                                                -- The synthesized signature `->` is a zero-width
                                                -- `UnbreakableText` (start == end) built by
                                                -- `LPTHelpers.mkZeroWidthText`, anchored at the end of its
                                                -- `from` type ‚Äî not where it renders. Its left neighbour is a
                                                -- whole type, which can fill the line and push the `->` onto a
                                                -- continuation row. A comment directly trailing it must then
                                                -- glue regardless of row (see the SingleLineComment branch).
                                                -- Scoped to `->` by value (cf. the `value == "in"` test in
                                                -- the boundary check): other elided tokens (`exposing`, `:`)
                                                -- precede a short neighbour or a bracketed block, where a
                                                -- comment on its own row legitimately stays own-line.
                                                prevElided =
                                                    when box is
                                                        UnbreakableText loc ->
                                                            loc.value == "->"
                                                                && loc.start.row == loc.end.row
                                                                && loc.start.col == loc.end.col

                                                        _ ->
                                                            False
                                            in
                                            Ok { doc = joinDoc acc.separator acc.doc itemDoc
                                                , prevRow = prevRow
                                                , prevElided = prevElided
                                                , separator = FlowSep
                                                }
                )
                (Ok { doc = R.empty, prevRow = -1, prevElided = False, separator = FirstItem })
                nodes
    in
    when foldResult is
        Err e ->
            Err e

        Ok state ->
            Ok (R.nest indent state.doc)


{-| True when `node`'s own rendered `Doc` contains a hard break ‚Äî i.e. its
content is forced multi-row regardless of how the surrounding flow was
written (a record argument with a comment, or one the author already spread
across rows).
-}
nodeForcesVertical : LPNode -> Bool
nodeForcesVertical node =
    when makePDoc (lpnBox node) (lpnChildren node) is
        Ok d ->
            R.hasHardBreak d

        Err _ ->
            False


{-| True when `node` forces vertical (`nodeForcesVertical`) in a way that
should make the *surrounding flow* also commit to one-item-per-line ‚Äî
excludes `ParenBlock` and comments, which already have dedicated handling
that keeps them glued to whatever precedes them:

  - A `ParenBlock` argument (e.g. `Array.map (\n -> if ‚Ä¶ )`) already decides
    its own internal layout via `MakeRender.makeParenBlockDoc`'s
    `checkContentVertical` ‚Äî that fix specifically keeps the surrounding
    call/step glued to `(` and only moves the closing `)`. Also matching
    it here would double up and instead pull the whole `(...)` onto its
    own line, undoing that.
  - A comment is already placed correctly by the flow's own comment-peeling
    logic (`buildFlowDocImpl`'s `SingleLineComment`/`BlockComment` cases,
    `renderPipelineStepNode`'s leading/trailing peeling, ‚Ä¶).
-}
flowChildForcesVertical : LPNode -> Bool
flowChildForcesVertical node =
    when lpnBox node is
        ParenBlock _ ->
            False

        _ ->
            not (nodeIsComment node) && nodeForcesVertical node


{-| True when any child forces the surrounding flow vertical (see
`flowChildForcesVertical`). Used by `AcrossThenIndent` (a function call) so
the whole argument list commits to one-argument-per-line the moment any
argument demands it, rather than pushing just that argument onto its own
line and leaving the rest glued to whatever follows.

The latter (local-only) fix is only correct on the *first* format: the
call's own `forceVertical` ‚Äî decided from the author's row layout ‚Äî then
sees the call visibly spanning multiple rows on reparse and flips to
`True`, breaking every argument the second time and producing a
non-idempotent result. Checking content up front avoids the flip: the
combined decision is already `True` on the first pass, so it stays `True`
on every subsequent one. Mirrors the `ParenBlock` fix (`checkContentVertical`
+ `R.hasHardBreak`) one level up, at the call itself.
-}
anyChildForcesVertical : Array LPNode -> Bool
anyChildForcesVertical children =
    Array.any flowChildForcesVertical children


makePDoc : LPBox -> Array LPNode -> Result String Doc
makePDoc box children =
    when box is
        UnbreakableText locs ->
            Ok (R.text locs.value)

        SynthesizedText s ->
            Ok (R.text s)

        AllAcrossOrAllVertical bracket ->
            makeAllAcrossOrAllVertical bracket children

        AlwaysVertical bracket ->
            listBoxesForBracket bracket children

        RecordUpdate { name, forceVertical } ->
            makeRecordUpdateDoc forceVertical name.value children

        EmptyBracketed loc ->
            -- An empty literal whose source spans more than the bare
            -- `{}` / `[]` / `()` only acquires children if a comment
            -- ended up placed inside it. Without children, render the
            -- bare literal; with comment children, render as
            -- `{ comment1 comment2 ... }` inline so the comments stay
            -- inside the brackets.
            let
                bs =
                    bracketStrings loc.value
            in
            if Array.isEmpty children then
                Ok (R.text bs.empty)

            else
                let
                    commentDocs =
                        Array.map commentNodeDoc children

                    body =
                        Array.foldl
                            (\d acc ->
                                if acc == R.empty then
                                    d

                                else
                                    R.concat acc (R.concat (R.text " ") d)
                            )
                            R.empty
                            commentDocs
                in
                Ok (R.concat (R.text bs.open) (R.concat body (R.concat (R.text " ") (R.text bs.close))))

        SingleLineComment locs ->
            Ok (lineComment locs.value)

        BlockComment _ ->
            Ok (commentBoxDoc box)

        AcrossThenIndent { forceVertical, checkContentVertical } ->
            if forceVertical || (checkContentVertical && anyChildForcesVertical children) then
                buildFlowDocBroken grenIndent children

            else
                buildFlowDoc grenIndent children

        WhenBranchPattern ->
            buildFlowDoc grenIndent children
                |> Result.map (\d -> R.concat d (R.text " ->"))

        IfCondition { forceVertical } ->
            makeIfConditionDoc forceVertical children

        IndentedBlock ->
            buildFlowDoc 0 children

        PipelineStep ->
            buildFlowDoc 0 children

        Pipeline { forceVertical, op } ->
            if op == "<|" then
                makeBackwardPipelineDoc forceVertical children

            else
                makePipelineDoc forceVertical children

        Binop { forceVertical } ->
            makeBinopDoc forceVertical children

        BodyBlock ->
            buildFlowDoc 0 children

        WhenBranch ->
            buildFlowDoc 0 children

        SoftIndentedBlock ->
            buildFlowDoc 0 children

        ParenBlock { forceVertical, checkContentVertical } ->
            makeParenBlockDoc { forceVertical = forceVertical, checkContentVertical = checkContentVertical } children

        OpAndRhs ->
            when Array.popFirst children is
                Just { first = opNode, rest = rhsNodes } ->
                    when lpnBox opNode is
                        UnbreakableText opLoc ->
                            when buildFlowDocInline 0 rhsNodes is
                                Err e ->
                                    Err e

                                Ok rhsDoc ->
                                    Ok (R.concat (R.text (opLoc.value ++ " ")) rhsDoc)

                        SynthesizedText opStr ->
                            when buildFlowDocInline 0 rhsNodes is
                                Err e ->
                                    Err e

                                Ok rhsDoc ->
                                    Ok (R.concat (R.text (opStr ++ " ")) rhsDoc)

                        _ ->
                            Err "OpAndRhs: first child must be a text operator"

                Nothing ->
                    Err "OpAndRhs: empty children"

        AlignedFlow ->
            when buildFlowDocInline 0 children is
                Err e ->
                    Err e

                Ok innerDoc ->
                    Ok (R.align innerDoc)

        WhenFlow { forceVertical } ->
            makeWhenFlowDoc forceVertical grenIndent children

        PrefixGlue prefix ->
            when buildFlowDocInline 0 children is
                Err e ->
                    Err e

                Ok innerDoc ->
                    Ok (R.concat (R.text prefix.value) innerDoc)

        Glue ->
            -- Children concatenated with no separator (a postfix accessor
            -- glued after a bracketed base). Each child renders on its own
            -- via the inline flow builder (a one-node flow emits no
            -- separators), then the docs are concatenated directly.
            Array.foldl
                (\child acc ->
                    when acc is
                        Err e ->
                            Err e

                        Ok accDoc ->
                            when buildFlowDocInline 0 [ child ] is
                                Err e ->
                                    Err e

                                Ok childDoc ->
                                    Ok (R.concat accDoc childDoc)
                )
                (Ok R.empty)
                children

        MultilineString located ->
            let
                tripleQuote =
                    R.text "\"\"\""

                contentDoc =
                    Array.foldl
                        (\line acc -> R.concat acc (R.concat R.hardNl (R.text line)))
                        tripleQuote
                        located.value
            in
            -- Wrap the whole doc in R.align so internal hardNls land at the
            -- column where the opening `"""` is printed, rather than at the
            -- surrounding nest level. Gren's parser requires every content
            -- line AND the closing `"""` to be at the same column as the
            -- opening ‚Äî without align, an opening that lands past the nest
            -- (because preceding tokens consumed columns) produces output
            -- that fails to re-parse.
            Ok (R.align (R.concat contentDoc (R.concat R.hardNl tripleQuote)))

        unexpected ->
            Err ("makePDoc: unexpected box type:\n" ++ lptToJson (lpnNode unexpected children))


-- Render a bracketed, comma-separated list of LPNode items.
--
-- If any child is a SingleLineComment, delegates to listBoxesWithBrackets,
-- which always produces a multi-line layout (a line comment cannot live
-- inside a flat group). Otherwise it renders inline on one line ‚Äî the
-- `R.group` in exposingListWithBrackets always renders flat. (A comment is the
-- only thing that forces this box vertical; callers that want an unconditional
-- vertical layout use `AlwaysVertical`, which routes through
-- listBoxesWithBrackets instead.)
makeAllAcrossOrAllVertical : ListBrackets -> Array LPNode -> Result String Doc
makeAllAcrossOrAllVertical brackets children =
    let
        bs =
            bracketStrings brackets

        hasComment =
            Array.any nodeIsComment children

        -- A Pipeline whose last PipelineStep has an IndentedBlock body renders
        -- with hardNl (see makeBackwardPipelineDoc, IndentedBlock arm). The
        -- parser sometimes assigns the `end` of a `let`-bodied lambda to the
        -- position of the following `,`, making itemsSpanRows return false even
        -- when the items are on separate source rows. Detect these pipelines
        -- here so we can switch to always-vertical before they inject hardNl
        -- into the flat group, producing non-idempotent output.
        hasVerticalPipeline =
            Array.any pipelineItemHasHardBreak children
    in
    if hasComment || hasVerticalPipeline then
        listBoxesWithBrackets bs.open bs.close children

    else
        traverseArray makeListItemDoc children
            |> Result.map
                (\itemDocs ->
                    exposingListWithBrackets bs.open bs.close bs.empty itemDocs
                )


pipelineItemHasHardBreak : LPNode -> Bool
pipelineItemHasHardBreak node =
    when lpnBox node is
        Pipeline _ ->
            let
                isPipelineStep c =
                    when lpnBox c is
                        PipelineStep ->
                            True

                        _ ->
                            False

                isIndentedBlock c =
                    when lpnBox c is
                        IndentedBlock ->
                            True

                        _ ->
                            False

                lastStep =
                    lpnChildren node
                        |> Array.keepIf isPipelineStep
                        |> Array.last
            in
            when lastStep is
                Nothing ->
                    False

                Just step ->
                    Array.any isIndentedBlock (lpnChildren step)

        _ ->
            False


-- Map a Result-producing builder over each element, collecting the Ok values
-- into an array. Short-circuits on the first Err. The collect-or-fail traversal
-- that several doc builders need (over nodes, signature segments, binop
-- operands, pipeline steps).
traverseArray : (a -> Result e b) -> Array a -> Result e (Array b)
traverseArray build items =
    Array.foldl
        (\item acc ->
            acc |> Result.andThen
                    (\collected ->
                        build item |> Result.map (\b -> Array.pushLast b collected)
                    )
        )
        (Ok [])
        items


bracketStrings : ListBrackets -> { open : String, close : String, empty : String }
bracketStrings brackets =
    when brackets is
        ListParen ->
            { open = "( ", close = ")", empty = "()" }

        ListCurly ->
            { open = "{ ", close = "}", empty = "{}" }

        ListSquare ->
            { open = "[ ", close = "]", empty = "[]" }


-- Shared per-box rendering for a list item, used by both the flat/vertical
-- bracket renderer (`makeListItemDoc`) and the comment-bearing always-vertical
-- renderer (`listBoxesWithBrackets`). Returns `Nothing` for a box that is not a
-- recognised list item, leaving the fallback to each caller (an error for the
-- plain path, a silent skip for the comment path).
--
-- A nested bracketed literal (`AllAcrossOrAllVertical` / `AlwaysVertical`) is
-- nested +2 ‚Äî the width of the enclosing "[ " / ", " prefix ‚Äî so its own
-- continuation lines align under its first element rather than the enclosing
-- list's items.
listItemBoxDoc : LPNode -> Maybe (Result String Doc)
listItemBoxDoc node =
    let
        children =
            lpnChildren node
    in
    when lpnBox node is
        UnbreakableText loc ->
            Just (Ok (R.text loc.value))

        AcrossThenIndent _ ->
            Just (buildFlowDoc grenIndent children)

        IndentedBlock ->
            -- A record field whose value is a lambda: the field flow renders at
            -- +0 so the lambda body's SoftIndentedBlock supplies the only +4
            -- (see folderInsertRecordField).
            Just (buildFlowDoc 0 children)

        ParenBlock payload ->
            Just (makePDoc (ParenBlock payload) children)

        AllAcrossOrAllVertical _ ->
            Just (makePDoc (lpnBox node) children |> Result.map (R.nest 2))

        AlwaysVertical bracket ->
            Just (listBoxesForBracket bracket children |> Result.map (R.nest 2))

        RecordUpdate { name, forceVertical } ->
            Just (makeRecordUpdateDoc forceVertical name.value children)

        -- An inline `when ... is`, a prefix-glued expr (`-1`), an empty literal
        -- (`[]` / `{}` / `()`), a synthesised keyword, a pipeline, or a binop
        -- chain as a list item: render inline; the enclosing list's break-or-flat
        -- decision still applies.
        AlignedFlow ->
            Just (makePDoc AlignedFlow children)

        WhenFlow _ ->
            Just (makePDoc (lpnBox node) children)

        PrefixGlue _ ->
            Just (makePDoc (lpnBox node) children)

        Glue ->
            Just (makePDoc (lpnBox node) children)

        EmptyBracketed _ ->
            Just (makePDoc (lpnBox node) children)

        SynthesizedText _ ->
            Just (makePDoc (lpnBox node) children)

        Pipeline _ ->
            Just (makePDoc (lpnBox node) children)

        Binop _ ->
            Just (makePDoc (lpnBox node) children)

        _ ->
            Nothing


makeListItemDoc : LPNode -> Result String Doc
makeListItemDoc node =
    when listItemBoxDoc node is
        Just result ->
            result

        Nothing ->
            Err ("makeListItemDoc: unexpected box type:\n" ++ lptToJson node)


exposingListWithBrackets : String -> String -> String -> Array Doc -> Doc
exposingListWithBrackets open close empty items =
    when Array.popFirst items is
        Nothing ->
            R.text empty

        Just { first, rest } ->
            let
                firstDoc =
                    R.concat (R.text open) first

                restDocs =
                    Array.map (\d -> R.concat (R.text ", ") d) rest

                allDocs =
                    [ firstDoc ] ++ restDocs

                joined =
                    R.foldDoc
                        (\a b -> R.concat a (R.concat R.breakDoc b))
                        allDocs
            in
            R.group
                (R.concat joined (R.concat R.nl (R.text close)))


{-| Render a module/import `exposing ( ... )` list, coupling its "drop to the
next line" with its "go vertical" so the two happen together. The result is
**all-or-nothing**: either the whole list stays inline on the `exposing` line, or
it drops to the next line *and* breaks one item per line. There is no
intermediate "dropped onto its own line but still on one line" form.

The leading break (the drop) is baked into the *same* group as the item breaks,
so a single fit decision drives both. The returned doc starts with that leading
break (a space when flat, a newline when broken), so the caller glues it directly
after `exposing` rather than adding its own flow separator. The +4 indentation
comes from the enclosing flow's `R.nest`, so no nest is added here.

`forceVertical` (read from the list's box type by the caller) requests the
vertical form for a list the author wrote across rows. A comment among the items
also forces it (with no flat alternative), matching the always-vertical
comment-aware list rendering.
-}
makeExposingListDoc : Bool -> Array LPNode -> Result String Doc
makeExposingListDoc forceVertical children =
    if Array.any nodeIsComment children || forceVertical then
        listBoxesWithBrackets "( " ")" children
            |> Result.map (\body -> R.concat R.hardNl body)

    else
        traverseArray makeListItemDoc children
            |> Result.map
                (\itemDocs ->
                    when Array.popFirst itemDocs is
                        Nothing ->
                            R.text " ()"

                        Just { first = firstItem, rest = restItems } ->
                            let
                                firstSeg =
                                    R.concat (R.text "(") firstItem

                                restSegs =
                                    Array.map
                                        (\d -> R.concat R.breakDoc (R.concat (R.text ", ") d))
                                        restItems

                                body =
                                    Array.foldl (\seg acc -> R.concat acc seg) firstSeg restSegs

                                full =
                                    R.concat body (R.text ")")
                            in
                            R.group (R.concat R.nl full)
                )


-- Render a comment box as just the source text it would produce: `--xxx`
-- for a SingleLineComment, `{-xxx-}` for a BlockComment, `{-|xxx-}` for a
-- DocComment. Returns R.empty for non-comment boxes; callers should only
-- pass a comment box.
--
-- A block comment whose body spans multiple lines is rendered with
-- `blockCommentDoc` so it is laid out (and re-indented) properly instead of
-- being smuggled through as flat text with embedded newlines.
commentBoxDoc : LPBox -> Doc
commentBoxDoc box =
    when box is
        SingleLineComment loc ->
            R.text ("--" ++ loc.value)

        BlockComment loc ->
            blockCommentDoc loc

        DocComment loc ->
            if String.isEmpty (String.trim loc.value) then
                R.text "{-| -}"

            else
                let
                    -- elm-format adds a blank line before -} for multi-line doc
                    -- comments (those whose content starts with a newline).
                    -- Single-line doc comments (`{-| Short description. -}`) are
                    -- left as-is.
                    normalizedValue =
                        if String.startsWith "\n" loc.value
                            && String.endsWith "\n" loc.value
                            && not (String.endsWith "\n\n" loc.value) then
                            loc.value ++ "\n"

                        else
                            loc.value
                in
                R.text ("{-|" ++ normalizedValue ++ "-}")

        _ ->
            R.empty


-- True if a comment body spans more than one source line.
isMultiLineCommentValue : String -> Bool
isMultiLineCommentValue value =
    String.contains "\n" value


-- Count leading space characters in a string.
leadingSpaceCount : String -> Int
leadingSpaceCount s =
    String.foldl
        (\c acc ->
            if acc.done then
                acc

            else if c == ' ' then
                { acc | count = acc.count + 1 }

            else
                { acc | done = True }
        )
        { count = 0, done = False }
        s
        |> .count


-- Render a block comment. A single-line body is emitted verbatim as flat
-- text. A multi-line body is split into physical lines, joined with
-- `R.hardNl`, and wrapped in `R.align`:
--
--   * The internal `hardNl`s make the doc unflattenable, so any enclosing
--     `R.group` is forced to its multi-line branch (a 3-line comment no
--     longer collapses a whole construct onto one line).
--   * Continuation lines are re-indented from a canonical anchor derived
--     *only from the body's own structure* ‚Äî the smallest leading indent
--     among the content lines maps to `blockCommentBodyOffset`. `R.align`
--     then shifts the whole block under wherever the `{-` now prints. This
--     is whitespace-canonical: it no longer reads the input `{-` column
--     (`loc.start.col`), so perturbing the surrounding whitespace cannot
--     shift the body indentation.
--
-- Comment *content* indented past that base is preserved relative to it, so
-- internal structure (lists, ASCII art) keeps its relative shape.
--
-- Exception: when the author wrote the `{-` ALONE on its first line, the body
-- is kept verbatim ‚Äî absolute columns, untouched ‚Äî and only the `{-` moves.
-- That opener-alone form is the explicit, text-derived signal for "do not
-- re-indent my comment body" (see the verbatim branch below).
blockCommentDoc : Located String -> Doc
blockCommentDoc loc =
    if not (isMultiLineCommentValue loc.value) then
        R.text ("{-" ++ loc.value ++ "-}")

    else
        let
            fullText =
                "{-" ++ loc.value ++ "-}"
        in
        when Array.popFirst (String.split "\n" fullText) is
            Nothing ->
                R.text fullText

            Just { first = firstLine, rest = contLines } ->
                let
                    -- The body's base column: the smallest leading-space count
                    -- among continuation lines that carry content. Blank lines
                    -- and a closing `-}` alone on its own line are excluded so
                    -- they can't drag the base to column 0.
                    isContentLine line =
                        let
                            t =
                                String.trimLeft line
                        in
                        t /= "" && t /= "-}"

                    contentCols =
                        contLines
                            |> Array.keepIf isContentLine
                            |> Array.map leadingSpaceCount

                    -- `{-` sits alone on its first line (nothing after the
                    -- opener). This is the author's signal ‚Äî and the only
                    -- trigger ‚Äî for verbatim mode below. It is a property of
                    -- the comment's own text, so the mode cannot flip when
                    -- the whitespace *around* the comment changes. (An earlier
                    -- trigger also compared the body's columns to the `{-`'s
                    -- source column; that read `loc.start.col`, so widening
                    -- the gap before the opener changed the rendering.)
                    openerAlone =
                        String.trimLeft (String.dropFirst 2 firstLine) == ""
                in
                if openerAlone then
                    -- Verbatim mode: the body is left exactly as written,
                    -- column for column ‚Äî only the `{-` moves (to the
                    -- construct's indent). Protects ASCII art and hand-aligned
                    -- blocks. Body lines render at absolute columns (via
                    -- `reset`, so nesting doesn't shift them). The output's
                    -- opener is again alone on its line, so this re-enters
                    -- verbatim mode on reparse ‚Äî a fixed point.
                    let
                        contDoc =
                            Array.foldl
                                (\line acc -> R.concat acc (R.concat R.hardNl (R.text line)))
                                R.empty
                                contLines
                    in
                    R.concat (R.text "{-") (R.reset contDoc)

                else
                    let
                        base =
                            contentCols
                                |> Array.minimum
                                |> Maybe.withDefault blockCommentBodyOffset

                        -- Map the base to `blockCommentBodyOffset` and keep any
                        -- deeper internal indentation relative to it. Blank lines
                        -- and a bare `-}` emit as-is (trimmed): `R.align` will
                        -- place them at the `{-` column, keeping `-}` aligned
                        -- with its opener. The formula would give them
                        -- `blockCommentBodyOffset` extra spaces, which is wrong.
                        reindent line =
                            let
                                t =
                                    String.trimLeft line
                            in
                            if t == "" || t == "-}" then
                                t

                            else
                                let
                                    l =
                                        leadingSpaceCount line
                                in
                                String.repeat (max 0 (blockCommentBodyOffset + l - base)) " "
                                    ++ String.dropFirst l line
                    in
                    Array.foldl
                        (\line acc -> R.concat acc (R.concat R.hardNl (R.text (reindent line))))
                        (R.text firstLine)
                        contLines
                        |> R.align


-- LPNode-form of commentBoxDoc.
commentNodeDoc : LPNode -> Doc
commentNodeDoc node =
    commentBoxDoc (lpnBox node)


-- Render a SingleLineComment's source text followed by a hardNl. The hardNl
-- makes the comment unflatten-able: a `--` consumes the rest of its line, so
-- any R.group containing one is forced into the broken layout. Use this
-- whenever the comment may be followed by more content in the surrounding
-- doc array.
lineComment : String -> Doc
lineComment s =
    R.concat (R.text ("--" ++ s)) R.hardNl


makeRecordUpdateDoc : Bool -> String -> Array LPNode -> Result String Doc
makeRecordUpdateDoc forceVertical baseName children =
    -- Skip any leading comment children so we can find the actual first field
    -- (the comment-bearing children get rendered as their own lines below).
    let
        { leading = commentsBefore, rest = fields } =
            splitLeadingComments children
    in
    when Array.popFirst fields is
        Nothing ->
            when Array.popFirst commentsBefore is
                Nothing ->
                    Ok (R.text ("{ " ++ baseName ++ " }"))

                Just _ ->
                    Ok (R.vcat
                            ([ R.text ("{ " ++ baseName) ]
                                ++ Array.map (\c -> R.concat (R.text "    ") (commentNodeDoc c)) commentsBefore
                                ++ [ R.text "}" ]))

        Just { first = firstField, rest = restFields } ->
            -- Wrap each field's flow with R.align so that when the field value
            -- itself spans multiple lines (e.g. a nested record update), the
            -- continuation lines start at the column where the field content
            -- begins (just after the "    | " / "    , " prefix), giving a
            -- visual indent under the field name instead of leaking back out
            -- to the surrounding record's column.
            let
                fieldDoc field =
                    -- A lambda field uses an IndentedBlock container so its body
                    -- block supplies the only +4; render its flow at +0 (mirrors
                    -- the list-item path in listItemBoxDoc). Every other field
                    -- flows at +4. R.align then anchors continuation lines under
                    -- the field content (see folderInsertRecordField).
                    let
                        flowIndent =
                            when lpnBox field is
                                IndentedBlock ->
                                    0

                                _ ->
                                    grenIndent
                    in
                    buildFlowDoc flowIndent (lpnChildren field)
                        |> Result.map R.align

                hasComment =
                    not (Array.isEmpty commentsBefore)
                        || Array.any nodeIsComment restFields
            in
            if forceVertical || hasComment then
                -- Always-vertical form: base on its own line, each field
                -- prefixed with `| ` / `, ` indented +4, close on its own line.
                -- Used when the author wrote the fields across rows, and
                -- whenever a comment is present (a comment cannot live in the
                -- inline form).
                let
                    leadingCommentLines =
                        Array.map (\c -> R.concat (R.text "    ") (commentNodeDoc c)) commentsBefore
                in
                when fieldDoc firstField is
                    Err e ->
                        Err e

                    Ok firstFieldDoc ->
                        let
                            firstLine =
                                R.concat (R.text "    | ") firstFieldDoc

                            restResult =
                                Array.foldl
                                    (\field accResult ->
                                        when accResult is
                                            Err e ->
                                                Err e

                                            Ok docs ->
                                                if nodeIsComment field then
                                                    Ok (Array.pushLast (R.concat (R.text "    ") (commentNodeDoc field)) docs)

                                                else
                                                    when fieldDoc field is
                                                        Err e ->
                                                            Err e

                                                        Ok d ->
                                                            Ok (Array.pushLast (R.concat (R.text "    , ") d) docs)
                                    )
                                    (Ok (leadingCommentLines ++ [ firstLine ]))
                                    restFields
                        in
                        when restResult is
                            Err e ->
                                Err e

                            Ok fieldLines ->
                                Ok (R.vcat ([ R.text ("{ " ++ baseName) ] ++ fieldLines ++ [ R.text "}" ]))

            else
                -- Inline form (no comments, author wrote it on one line): a group
                -- that always renders flat as `{ base | a = 1, b = 2 }`. The
                -- separators are built so that flattening reproduces the inline
                -- spacing: `nl` before the first field (flattens to a space,
                -- giving ` | `), `breakDoc` before each subsequent field
                -- (flattens to empty, so its own `, ` prefix gives `, `), and
                -- `nl` before the closing `}`. The fields are nested +4 so the
                -- ungrouped (vertical) rendering would be byte-identical to the
                -- vcat form above ‚Äî keeping the one-line and multi-line-authored
                -- updates a shared fixed point.
                when fieldDoc firstField is
                    Err e ->
                        Err e

                    Ok firstFieldDoc ->
                        traverseArray fieldDoc restFields
                            |> Result.map
                                (\restDocs ->
                                    let
                                        firstSeg =
                                            R.concat (R.text "| ") firstFieldDoc

                                        restSegs =
                                            Array.map
                                                (\d -> R.concat R.breakDoc (R.concat (R.text ", ") d))
                                                restDocs

                                        fieldsInner =
                                            Array.foldl (\seg acc -> R.concat acc seg) firstSeg restSegs

                                        fieldsPart =
                                            R.nest grenIndent (R.concat R.nl fieldsInner)

                                        inner =
                                            R.concat
                                                (R.text ("{ " ++ baseName))
                                                (R.concat fieldsPart (R.concat R.nl (R.text "}")))
                                    in
                                    R.group inner
                                )


{-| Build the `Formatter.Render` `Doc` for a single root-child node without
resolving it to a string.

Dispatches on the node's `OriginalRows` `SyntaxType` (type aliases, type
unions, and the comment variants take dedicated builders; everything else
flows through `makeFlowIndentableDoc`). `EmptyLine` nodes produce
`R.empty`. Any other top-level box is an `Err` ‚Äî only root children are
valid input.

Build the `Doc` for one root child without rendering it. Used internally
by `makePrettyLine` (via `makePrettyResult`) to render each top-level node.
-}
makePrettyLineDoc : LPNode -> Result String Doc
makePrettyLineDoc node =
    let
        children =
            lpnChildren node
    in
    when lpnBox node is
        OriginalRows { stype = stype } ->
            when stype is
                StTypeAlias ->
                    makeTypeAliasPrettyDoc children

                StTypeUnion ->
                    makeTypeUnionPrettyDoc children

                StSingleLineComment ->
                    makeCommentLineDoc_ children

                StBlockComment ->
                    makeCommentLineDoc_ children

                StDocComment ->
                    makeCommentLineDoc_ children

                StFunctionSignature ->
                    makeSignaturePrettyDoc children

                StPort ->
                    makeSignaturePrettyDoc children

                StModule ->
                    makeExposingLineDoc StModule children

                StImport ->
                    makeExposingLineDoc StImport children

                _ ->
                    makeFlowIndentableDoc children

        EmptyLine ->
            Ok R.empty

        _ ->
            Err "Unexpected item in LPTree root children"


{-| Render a `module ‚Ä¶` or `import ‚Ä¶` line. When it ends in an `exposing ( ‚Ä¶ )`
list and the part before that list is all plain keyword/name tokens (the common
case: a plain `module`/`port module` or any `import`, but not an effect module's
`where { ‚Ä¶ }` block, and no comment in the header), render the exposing list
as a coupled all-or-nothing group via `makeExposingListDoc`.

When the list stays flat, the whole line (header, `exposing`, and the list) is
one unbreakable line.

For a `module` line, `exposing` always stays glued to the header ‚Äî even when
the list goes vertical ‚Äî with the list indented +4 under the merged line
(matching elm-format's convention):

    module MyApp exposing
        ( Model
        , Msg
        )

For an `import` line, when the list goes vertical ‚Äî because the author wrote
it across rows, or because it carries a comment ‚Äî `exposing` itself still
drops to its own line indented +4 under the header, and the list indents +8:

    import Dict
        exposing
            ( Dict
            , empty
            )

Anything that doesn't match (a `(..)` wildcard, an effect-module `where` block,
a comment in the header) falls back to the generic flow.
-}
makeExposingLineDoc : SyntaxType -> Array LPNode -> Result String Doc
makeExposingLineDoc stype children =
    when Array.popLast children is
        Just { last = lastNode, initial = headerNodes } ->
            let
                -- The exposing list's author-layout decision is carried by its
                -- box type (set in MakeLogical.exposingListBox): an
                -- `AllAcrossOrAllVertical ListParen` was written inline, an
                -- `AlwaysVertical ListParen` across rows. `Nothing` means the
                -- last node isn't a paren list at all (a `(..)` wildcard, etc.).
                exposingForceVertical =
                    when lpnBox lastNode is
                        AllAcrossOrAllVertical ListParen ->
                            Just False

                        AlwaysVertical ListParen ->
                            Just True

                        _ ->
                            Nothing

                headerAllLeaves =
                    Array.all
                        (\n ->
                            when lpnBox n is
                                UnbreakableText _ ->
                                    True

                                SynthesizedText _ ->
                                    True

                                _ ->
                                    False
                        )
                        headerNodes

                joinWithSpaces docs =
                    R.foldDoc
                        (\a b -> R.concat a (R.concat (R.text " ") b))
                        docs
            in
            when exposingForceVertical is
                Just forceVertical ->
                    if headerAllLeaves && not (Array.isEmpty headerNodes) then
                        let
                            listChildren =
                                lpnChildren lastNode

                            listGoesVertical =
                                forceVertical || Array.any nodeIsComment listChildren

                            -- A module line always keeps `exposing` glued to
                            -- the header, even when the list goes vertical;
                            -- an import line drops `exposing` to its own line
                            -- in that case (see the doc comment above).
                            keepExposingGlued =
                                stype == StModule || not listGoesVertical
                        in
                        makeExposingListDoc forceVertical listChildren
                            |> Result.andThen
                                (\listDoc ->
                                    if keepExposingGlued then
                                        traverseArray (\n -> makePDoc (lpnBox n) (lpnChildren n)) headerNodes
                                            |> Result.map
                                                (\headerDocs ->
                                                    R.concat (joinWithSpaces headerDocs) (R.nest grenIndent listDoc)
                                                )

                                    else
                                        when Array.popLast headerNodes is
                                            Just { last = exposingNode, initial = preExposingNodes } ->
                                                traverseArray (\n -> makePDoc (lpnBox n) (lpnChildren n)) preExposingNodes
                                                    |> Result.andThen
                                                        (\preDocs ->
                                                            makePDoc (lpnBox exposingNode) (lpnChildren exposingNode)
                                                                |> Result.map
                                                                    (\exposingDoc ->
                                                                        R.concat
                                                                            (joinWithSpaces preDocs)
                                                                            (R.nest
                                                                                grenIndent
                                                                                (R.concat
                                                                                    R.hardNl
                                                                                    (R.concat
                                                                                        exposingDoc
                                                                                        (R.nest grenIndent listDoc))))
                                                                    )
                                                        )

                                            Nothing ->
                                                makeFlowIndentableDoc children
                                )

                    else
                        makeFlowIndentableDoc children

                Nothing ->
                    makeFlowIndentableDoc children

        Nothing ->
            makeFlowIndentableDoc children


makeFlowIndentableDoc : Array LPNode -> Result String Doc
makeFlowIndentableDoc children =
    let
        { leading, rest } =
            splitLeadingComments children
    in
    buildFlowDoc grenIndent rest
        |> Result.map
            (\flowDoc ->
                let
                    commentDocs =
                        Array.map commentNodeDoc leading
                in
                if Array.isEmpty commentDocs then
                    flowDoc

                else
                    R.concat (R.vcat commentDocs) (R.concat R.hardNl flowDoc)
            )


-- True if `node` or any of its descendants is a line/block comment.
subtreeHasComment : LPNode -> Bool
subtreeHasComment node =
    nodeIsComment node || Array.any subtreeHasComment (lpnChildren node)


-- True for the synthesized signature/lambda `->`: a zero-width
-- `UnbreakableText` (start == end) built by `LPTHelpers.mkZeroWidthText`. These
-- are the top-level arrows of the signature's lambda chain; nested arrows live
-- inside a `ParenBlock` and never appear among a signature's direct children.
isArrowLeaf : LPNode -> Bool
isArrowLeaf node =
    when lpnBox node is
        UnbreakableText loc ->
            loc.value == "->"
                && loc.start.row == loc.end.row
                && loc.start.col == loc.end.col

        _ ->
            False


-- True for the zero-width `:` leaf that separates a signature's header
-- (`name :` / `port name :`) from its type. Record-type field colons are
-- `SynthesizedText` nested inside item containers, so the first top-level
-- `UnbreakableText ":"` is always the signature colon.
isColonLeaf : LPNode -> Bool
isColonLeaf node =
    when lpnBox node is
        UnbreakableText loc ->
            loc.value == ":"

        _ ->
            False


-- Split a signature's type nodes (everything after the `:`) into segments at
-- each top-level `->`: the first segment is the leading type, each later one
-- begins with its `->` so it renders as `-> NextType`.
splitSignatureSegments : Array LPNode -> Array (Array LPNode)
splitSignatureSegments nodes =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                Array.pushLast [ node ] acc

            else
                when Array.popLast acc is
                    Just { last = seg, initial = front } ->
                        Array.pushLast (Array.pushLast node seg) front

                    Nothing ->
                        [ [ node ] ]
        )
        []
        nodes


-- A segment's first content row, ignoring its leading `->` (which is anchored
-- at the *previous* segment's end, not where its own type sits). Used for
-- "signal B" (see `segmentsBrokenAtBoundary`).
--
-- A segment that begins with a bracketed type (`{ ‚Ä¶ }`, `( ‚Ä¶ )`) starts where
-- its *opening bracket* sits, not at its first inner token: the bracket has no
-- leaf in the tree, so `firstRowInSubtree` alone would report the row of the
-- first field ‚Äî and a line break just inside the bracket would masquerade as a
-- break between `->` segments, flipping the whole signature to multi-line.
segContentFirstRow : Array LPNode -> Int
segContentFirstRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc

            else
                let
                    leafRow =
                        firstRowInSubtree node

                    r =
                        when lpnBracketStart node is
                            Just open ->
                                if leafRow < 0 then
                                    open.row

                                else
                                    min open.row leafRow

                            Nothing ->
                                leafRow
                in
                if acc < 0 then
                    r

                else
                    min acc r
        )
        -1
        seg


-- A segment's last content row, ignoring arrows (a following segment's `->`
-- is anchored at THIS segment's end and lives in the next segment's array).
segContentLastRow : Array LPNode -> Int
segContentLastRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc

            else
                max acc (lpnMaxRow node)
        )
        -1
        seg


-- "Signal B" for signatures: the author wrote the signature across lines iff
-- some segment *starts* on a row below the previous segment's *last* row ‚Äî
-- i.e. there is a line break BETWEEN two `->` parts. A break inside one
-- segment (inside a `{ ‚Ä¶ }` record, inside `( ‚Ä¶ )` parens, or between a type
-- and its argument) does not count: only a boundary break makes the signature
-- multi-line, matching the documented rule.
segmentsBrokenAtBoundary : Array (Array LPNode) -> Bool
segmentsBrokenAtBoundary segments =
    let
        folded =
            Array.foldl
                (\seg acc ->
                    let
                        first =
                            segContentFirstRow seg

                        last =
                            segContentLastRow seg
                    in
                    { broken = acc.broken
                            || (acc.prevLast >= 0 && first >= 0 && first > acc.prevLast)
                    , prevLast =
                        if last >= 0 then
                            last

                        else
                            acc.prevLast
                    }
                )
                { broken = False, prevLast = -1 }
                segments
    in
    folded.broken


{-| Render a function/port signature with the author's one-line-vs-multi-line
layout (all-or-nothing, mirroring lists/records).

A signature the author wrote on one line stays inline, regardless of width; one
written across rows stays one-segment-per-line. The multi-line form is:

    foo :
        VeryLongType
        -> AnotherType
        -> ResultType

The inline `R.group` (always flat) and the forced-vertical form share the same
`nl` separators, so they are byte-identical when flattened and formatting is a
fixed point.

A signature written on one row that carries a comment falls back to the
original fill renderer: the all-or-nothing break points have no stable anchor
for a trailing comment on an otherwise-inline signature. A signature the
author wrote *across* rows uses the canonical per-segment layout regardless of
whether it carries a comment ‚Äî a comment doesn't get its own, differently-shaped
signature than a comment-free one would; `buildFlowDoc` (used per header/segment
below) already places an embedded comment correctly within its segment.
-}
makeSignaturePrettyDoc : Array LPNode -> Result String Doc
makeSignaturePrettyDoc children =
    let
        -- Header = everything up to and including the `:`; the rest is the
        -- type. (`name :` for a function, `port name :` for a port.)
        colonSplit =
            Array.foldl
                (\node acc ->
                    if acc.afterColon then
                        { acc | typeNodes = Array.pushLast node acc.typeNodes }

                    else if isColonLeaf node then
                        { acc | header = Array.pushLast node acc.header, afterColon = True }

                    else
                        { acc | header = Array.pushLast node acc.header }
                )
                { header = [], typeNodes = [], afterColon = False }
                children
    in
    if not colonSplit.afterColon then
        -- No colon found: not a real signature shape; render as a flow.
        makeFlowIndentableDoc children

    else
        let
            segments =
                splitSignatureSegments colonSplit.typeNodes

            forceVertical =
                segmentsBrokenAtBoundary segments
        in
        if not forceVertical && Array.any subtreeHasComment children then
            makeFlowIndentableDoc children

        else
            let
                segDocsResult =
                    traverseArray (buildFlowDoc 0) segments
            in
            buildFlowDoc 0 colonSplit.header
                |> Result.andThen
                    (\headerDoc ->
                        segDocsResult
                            |> Result.map
                                (\segDocs ->
                                    let
                                        bodyInner =
                                            when Array.popFirst segDocs is
                                                Nothing ->
                                                    R.empty

                                                Just { first = d0, rest = ds } ->
                                                    Array.foldl
                                                        (\d acc -> R.concat acc (R.concat R.nl d))
                                                        d0
                                                        ds

                                        full =
                                            R.concat
                                                headerDoc
                                                (R.nest grenIndent (R.concat R.nl bodyInner))
                                    in
                                    inlineUnlessVertical forceVertical full
                                )
                    )


-- True for a `PipelineStep` node (one `|> step` / `<| step`).
isPipelineStepNode : LPNode -> Bool
isPipelineStepNode node =
    when lpnBox node is
        PipelineStep ->
            True

        _ ->
            False


-- True when `node` is a `ParenBlock` whose body is on a different row from
-- `->` ‚Äî i.e. the lambda was written multi-line by the author.  Shape:
--   ParenBlock [ AcrossThenIndent (\args ->), IndentedBlock (body) ]
-- Single-line lambdas carry `SoftIndentedBlock` as the second child and are
-- rendered inline as usual; only `IndentedBlock` gets the elm-format layout.
isMultilineLambdaParenBlock : LPNode -> Bool
isMultilineLambdaParenBlock node =
    when lpnBox node is
        ParenBlock _ ->
            when Array.popFirst (lpnChildren node) is
                Just { rest } ->
                    when Array.first rest is
                        Just secondChild ->
                            when lpnBox secondChild is
                                IndentedBlock ->
                                    True

                                _ ->
                                    False

                        Nothing ->
                            False

                Nothing ->
                    False

        _ ->
            False


-- True when a node's subtree contains a box that always produces HardNl ‚Äî
-- AlwaysVertical, RecordUpdate, or AllAcrossOrAllVertical-with-comment (which
-- switches to vertical rendering when it has comment children).  Used by
-- isMultilineContentParenBlock to detect parens whose content spans rows
-- without being a lambda (which isMultilineLambdaParenBlock already handles).
subtreeHasVertical : LPNode -> Bool
subtreeHasVertical node =
    when lpnBox node is
        AlwaysVertical _ ->
            True

        RecordUpdate _ ->
            True

        AllAcrossOrAllVertical _ ->
            -- This box goes vertical when it has comment children (see
            -- makeAllAcrossOrAllVertical).  Treat it as "will produce HardNl"
            -- so isMultilineContentParenBlock detects it correctly.
            Array.any nodeIsComment (lpnChildren node)
                || Array.any subtreeHasVertical (lpnChildren node)

        _ ->
            Array.any subtreeHasVertical (lpnChildren node)


-- True when `node` is a ParenBlock whose content subtree contains an
-- AlwaysVertical or RecordUpdate ‚Äî i.e. the paren content will span rows
-- at render time (unlike AllAcrossOrAllVertical, which stays inline when flat).
-- Used in buildStepChildrenDoc to break a non-lambda multiline paren arg onto
-- its own line within a pipeline step.
isMultilineContentParenBlock : LPNode -> Bool
isMultilineContentParenBlock node =
    when lpnBox node is
        ParenBlock _ ->
            Array.any subtreeHasVertical (lpnChildren node)

        _ ->
            False


{-| Render a whole pipeline with the author's one-line-vs-multi-line layout.

`children` are the seed node(s) followed by the `PipelineStep` nodes. A pipeline
the author wrote on one line stays inline (`seed |> a |> b`), regardless of
width; one written across rows gets one step per line:

    seed
        |> step1
        |> step2

The inline and forced-vertical forms are the *same* doc (just grouped vs not),
so they are byte-identical when flattened and formatting is a fixed point. A
pipeline carrying any comment always renders through the
existing `PipelineStep` path (`buildFlowDoc 0 children`), whose comment-peeling
and blank-line logic stays untouched.
-}
makePipelineDoc : Bool -> Array LPNode -> Result String Doc
makePipelineDoc forceVertical children =
    if Array.any subtreeHasComment children then
        -- Comment-bearing pipeline: the intricate per-step comment handling
        -- lives in buildFlowDocImpl's PipelineStep case. Route there.
        buildFlowDoc 0 children

    else
        let
            -- No comments in this branch, so every non-step node is a seed node
            -- and they all precede the steps; `keepIf` preserves that order.
            seedNodes =
                Array.keepIf (\n -> not (isPipelineStepNode n)) children

            stepNodes =
                Array.keepIf isPipelineStepNode children
        in
        buildFlowDoc 0 seedNodes
            |> Result.andThen
                (\seedDoc ->
                    -- `|> body` with continuation args nested +4 from the `|>` column
                    -- ‚Äî exactly the PipelineStep path's `buildFlowDoc grenIndent
                    -- stepChildren`.
                    traverseArray (\step -> buildStepChildrenDoc (lpnChildren step)) stepNodes
                        |> Result.map
                            (\stepDocs ->
                                let
                                    -- Step separator (see `authorSep`): a soft break inline,
                                    -- an unflattenable hard break when forced, so an outer
                                    -- `name = body` group can't collapse a multi-line pipeline
                                    -- back onto the `=` line. Both render the same bytes when
                                    -- broken, so fit-overflow == forced-vertical.
                                    sep =
                                        authorSep forceVertical

                                    -- Each step on its own line, indented +grenIndent from the seed.
                                    stepsInner =
                                        Array.foldl
                                            (\d acc -> R.concat acc (R.concat sep d))
                                            R.empty
                                            stepDocs

                                    full =
                                        R.concat seedDoc (R.nest grenIndent stepsInner)
                                in
                                inlineUnlessVertical forceVertical full
                            )
                )


{-| Render a `<|` (backward) pipeline with trailing-operator style.

`|>` is a leading operator: the operator starts each step line.
`<|` is a trailing operator: the operator ends the seed/previous-step line.

Comment-free, single lambda step (`seed <| \patterns -> body`):

    seed <| \patterns ->
        body

Comment-free, N non-lambda steps:

    seed <|
        body1 <|
        body2 <|
        bodyN

All step bodies land at `seed_col + 4`. Comment-bearing pipelines fall back to
`buildFlowDoc 0` (forward-leading style) so the intricate PipelineStep
comment-peeling logic stays untouched.

A single-line block comment `{- ‚Ä¶ -}` that sits between `<|` and the next
body token (i.e. on the *same row* as `<|`) must be rendered inline ‚Äî not
as a standalone comment ‚Äî so the pipeline doesn't gain a spurious HardNl
that changes `forceVertical` on the next reparse.  `buildBodyDoc` handles
this: it uses `buildFlowDocInline` (first item always inline) only when the
body literally starts with such a same-row single-line block comment.  All
other bodies fall through to the normal `buildFlowDoc`.
-}
buildBodyDoc : LPNode -> Array LPNode -> Result String Doc
buildBodyDoc opNode bodyNodes =
    let
        opRow =
            when lpnBox opNode is
                UnbreakableText loc ->
                    loc.end.row

                _ ->
                    -1

        startsWithSameRowInlineBlock =
            when Array.first bodyNodes is
                Just first ->
                    when lpnBox first is
                        BlockComment loc ->
                            not (isMultiLineCommentValue loc.value)
                                && loc.start.row == opRow

                        _ ->
                            False

                Nothing ->
                    False
    in
    if startsWithSameRowInlineBlock then
        buildFlowDocInline 0 bodyNodes

    else if anyChildForcesVertical bodyNodes then
        -- The step body is a call whose "lone AcrossThenIndent" wrapper was
        -- unwrapped directly into the step (see the doc comment above), which
        -- also discards its `checkContentVertical` decision ‚Äî recompute it
        -- here so a call-with-a-multiline-record body still breaks every
        -- argument onto its own line instead of leaving later ones glued.
        -- `grenIndent` (not the `0` the flat branches below use): the first
        -- body node (the function name) is placed by the caller's own `sep`
        -- outside this function, under the same outer `R.nest grenIndent` as
        -- this fold's result ‚Äî so this fold needs its own further +grenIndent
        -- for later arguments to land one level deeper than the function name,
        -- not at the same column as it.
        buildFlowDocBroken grenIndent bodyNodes

    else
        buildFlowDoc 0 bodyNodes


makeBackwardPipelineDoc : Bool -> Array LPNode -> Result String Doc
makeBackwardPipelineDoc forceVertical children =
    -- Fall back to forward-leading style only for comments at step boundaries:
    -- (1) a comment sibling directly between seed and a PipelineStep, or
    -- (2) a trailing comment at the very end of a PipelineStep's children.
    -- Comments nested inside the step body (e.g. in a list argument) do not
    -- affect how the operator is placed and should not trigger the fallback.
    let
        stepFirstIsComment stepNode =
            when Array.popFirst (lpnChildren stepNode) is
                Just { first = firstChild } ->
                    nodeIsComment firstChild

                Nothing ->
                    False

        stepLastIsComment stepNode =
            when Array.popLast (lpnChildren stepNode) is
                Just { last = lastChild } ->
                    nodeIsComment lastChild

                Nothing ->
                    False

        hasStepBoundaryComment =
            Array.any
                (\n ->
                    if isPipelineStepNode n then
                        -- Leading comment (before <|) or trailing comment (after body).
                        stepFirstIsComment n || stepLastIsComment n

                    else
                        -- Comment sibling between seed and step.
                        nodeIsComment n
                )
                children
    in
    -- Also fall back if any step has a non-<| operator. flattenPipeline merges
    -- mixed |>/<| chains into a single flat array; the outermost op tags the
    -- Pipeline, but individual steps may still carry |> ops that must render
    -- in forward-leading style.
    let
        stepOpIsBackward stepNode =
            when Array.popFirst (lpnChildren stepNode) is
                Just { first = opNode } ->
                    when lpnBox opNode is
                        UnbreakableText loc ->
                            loc.value == "<|"

                        _ ->
                            False

                Nothing ->
                    False

        allStepsBackward =
            Array.all stepOpIsBackward (Array.keepIf isPipelineStepNode children)
    in
    if hasStepBoundaryComment || not allStepsBackward then
        buildFlowDoc 0 children

    else
        let
            seedNodes =
                Array.keepIf (\n -> not (isPipelineStepNode n)) children

            stepNodes =
                Array.keepIf isPipelineStepNode children

            sep =
                authorSep forceVertical
        in
        buildFlowDoc 0 seedNodes
            |> Result.andThen
                (\seedDoc ->
                    -- Collect (opNode, bodyNodes) pairs for each step.
                    traverseArray
                        (\stepNode ->
                            when Array.popFirst (lpnChildren stepNode) is
                                Nothing ->
                                    Err "backward pipeline step has no children"

                                Just { first = opNode, rest = bodyNodes } ->
                                    Ok { op = opNode, body = bodyNodes }
                        )
                        stepNodes
                        |> Result.andThen (makeBackwardPipelineBodyDoc forceVertical seedDoc sep)
                )


-- Renders the step bodies of a backward (`<|`) pipeline once the seed and
-- separator are known. Split out of makeBackwardPipelineDoc because the
-- single-step (lambda vs non-lambda) and multi-step cases are each
-- substantial on their own.
makeBackwardPipelineBodyDoc : Bool -> Doc -> Doc -> Array { op : LPNode, body : Array LPNode } -> Result String Doc
makeBackwardPipelineBodyDoc forceVertical seedDoc sep allStepBodies =
    when Array.length allStepBodies is
        1 ->
            -- Single step: check for lambda (trailing SoftIndentedBlock).
            when Array.first allStepBodies is
                Nothing ->
                    Err "backward pipeline: empty body nodes array"

                Just { op = opNode, body = bodyNodes } ->
                    when Array.popLast bodyNodes is
                        Nothing ->
                            -- Non-lambda single step (empty body ‚Äî shouldn't happen).
                            buildBodyDoc opNode bodyNodes
                                |> Result.map
                                    (\bodyDoc ->
                                        inlineUnlessVertical
                                            forceVertical
                                            (R.concat
                                                seedDoc
                                                (R.concat
                                                    (R.text " <|")
                                                    (R.nest grenIndent (R.concat sep bodyDoc))))
                                    )

                        Just { last = lastNode, initial = headNodes } ->
                            when lpnBox lastNode is
                                SoftIndentedBlock ->
                                    -- Body authored inline (same row as `->`): keep
                                    -- the soft-break so a short lambda stays on one
                                    -- line (e.g. `f <| \x -> x + 1`).
                                    buildFlowDocInline 0 headNodes
                                        |> Result.andThen
                                            (\headDoc ->
                                                buildFlowDoc 0 (lpnChildren lastNode)
                                                    |> Result.map
                                                        (\bodyDoc ->
                                                            let
                                                                bodyBreak =
                                                                    if forceVertical then
                                                                        R.nest grenIndent (R.concat R.hardNl bodyDoc)

                                                                    else
                                                                        R.group (R.nest grenIndent (R.concat R.nl bodyDoc))
                                                            in
                                                            R.concat
                                                                seedDoc
                                                                (R.concat
                                                                    (R.text " <| ")
                                                                    (R.concat headDoc bodyBreak))
                                                        )
                                            )

                                IndentedBlock ->
                                    -- Body authored across rows (different row from
                                    -- `->`): elm-format style ‚Äî always break after
                                    -- `<|`, lambda header at seed+4, body at seed+8.
                                    buildFlowDocInline 0 headNodes
                                        |> Result.andThen
                                            (\headDoc ->
                                                buildFlowDoc 0 (lpnChildren lastNode)
                                                    |> Result.map
                                                        (\bodyDoc ->
                                                            R.concat
                                                                seedDoc
                                                                (R.concat
                                                                    (R.text " <|")
                                                                    (R.nest
                                                                        grenIndent
                                                                        (R.concat
                                                                            R.hardNl
                                                                            (R.concat
                                                                                headDoc
                                                                                (R.nest grenIndent (R.concat R.hardNl bodyDoc))))))
                                                        )
                                            )

                                _ ->
                                    -- Non-lambda single step.
                                    buildBodyDoc opNode bodyNodes
                                        |> Result.map
                                            (\bodyDoc ->
                                                inlineUnlessVertical
                                                    forceVertical
                                                    (R.concat
                                                        seedDoc
                                                        (R.concat
                                                            (R.text " <|")
                                                            (R.nest grenIndent (R.concat sep bodyDoc))))
                                            )

        _ ->
            -- Multiple steps: each body at seed_col + 4, operator
            -- trails the previous slot (seed or step body).
            traverseArray (\sBody -> buildBodyDoc sBody.op sBody.body) allStepBodies
                |> Result.map
                    (\bodyDocs ->
                        let
                            nBodies =
                                Array.length bodyDocs

                            stepsDoc =
                                Array.foldl
                                    (\bodyDoc { idx, doc } ->
                                        let
                                            isLast =
                                                idx == nBodies - 1

                                            bodyWithTrail =
                                                if isLast then
                                                    bodyDoc

                                                else
                                                    R.concat bodyDoc (R.text " <|")

                                            newDoc =
                                                if idx == 0 then
                                                    bodyWithTrail

                                                else
                                                    R.concat doc (R.concat sep bodyWithTrail)
                                        in
                                        { idx = idx + 1, doc = newDoc }
                                    )
                                    { idx = 0, doc = R.empty }
                                    bodyDocs
                                    |> .doc
                        in
                        inlineUnlessVertical
                            forceVertical
                            (R.concat
                                seedDoc
                                (R.concat
                                    (R.text " <|")
                                    (R.nest grenIndent (R.concat sep stepsDoc))))
                    )


-- Flatten the right-nested `OpAndRhs` structure of a Binop container back into
-- its operands (each a flow of LPNodes) and operator leaf nodes, in source
-- order. Inverse of `InsertExpressions.buildNestedOpAndRhs`. Used only on the
-- comment-free path; comments would otherwise live among these nodes.
flattenBinopNodes : Array LPNode -> { operands : Array (Array LPNode), ops : Array LPNode }
flattenBinopNodes children =
    when Array.popLast children is
        Nothing ->
            { operands = [], ops = [] }

        Just { last = lastNode, initial = operandNodes } ->
            when lpnBox lastNode is
                OpAndRhs ->
                    when Array.popFirst (lpnChildren lastNode) is
                        Just { first = opNode, rest = restChildren } ->
                            let
                                inner =
                                    flattenBinopNodes restChildren
                            in
                            { operands = [ operandNodes ] ++ inner.operands
                            , ops = [ opNode ] ++ inner.ops
                            }

                        Nothing ->
                            { operands = [ operandNodes ], ops = [] }

                _ ->
                    { operands = [ children ], ops = [] }


makeIfConditionDoc : Bool -> Array LPNode -> Result String Doc
makeIfConditionDoc forceVertical children =
    when Array.popFirst children is
        Nothing ->
            Err "if condition: no nodes"

        Just { first = ifNode, rest = afterIf } ->
            when Array.popLast afterIf is
                Nothing ->
                    Err "if condition: missing then"

                Just { initial = condNodes, last = thenNode } ->
                    makePDoc (lpnBox ifNode) (lpnChildren ifNode)
                        |> Result.andThen
                            (\ifDoc ->
                                makePDoc (lpnBox thenNode) (lpnChildren thenNode)
                                    |> Result.andThen
                                        (\thenDoc ->
                                            (if forceVertical then
                                              buildFlowDoc 0 condNodes

                                             else
                                              buildFlowDocInline 0 condNodes
                                            )
                                                |> Result.map
                                                    (\condDoc ->
                                                        if forceVertical then
                                                            R.concat
                                                                ifDoc
                                                                (R.concat
                                                                    (R.nest grenIndent (R.concat R.hardNl condDoc))
                                                                    (R.concat R.hardNl thenDoc))

                                                        else
                                                            R.concat
                                                                ifDoc
                                                                (R.concat
                                                                    (R.text " ")
                                                                    (R.concat
                                                                        condDoc
                                                                        (R.concat (R.text " ") thenDoc)))
                                                    )
                                        )
                            )


-- The text of an operator leaf node (`UnbreakableText` / `SynthesizedText`).
opNodeText : LPNode -> String
opNodeText node =
    when lpnBox node is
        UnbreakableText loc ->
            loc.value

        SynthesizedText s ->
            s

        _ ->
            ""


{-| Render a non-pipeline binop chain with precedence-aware author layout.

A chain the author wrote on one line stays inline, regardless of width; one
written across rows breaks **only at its lowest-precedence operators**
(operator-led, one group per line), keeping tighter-binding sub-terms inline:

    baseScore
        + bonusPoints * multiplier
        - penaltyAmount

The inline and forced-vertical forms share the same doc (inline uses `R.nl`,
forced uses `R.hardNl` so an outer `name = body` group can't collapse a
multi-line chain), so they are byte-identical when flattened and formatting is a
fixed point. A chain carrying any comment falls back to the `OpAndRhs` fill renderer
(`buildFlowDoc grenIndent children`), so wrapped operators indent +4 like the
precedence-aware form.
-}
makeBinopDoc : Bool -> Array LPNode -> Result String Doc
makeBinopDoc forceVertical children =
    if Array.any subtreeHasComment children then
        -- Comment-bearing chain: fall back to the fill renderer. Use a +4
        -- continuation indent (grenIndent), matching the precedence-aware form
        -- and the comment-bearing signature fallback, so wrapped operators sit
        -- under the first operand rather than back at its own column.
        buildFlowDoc grenIndent children

    else
        let
            flat =
                flattenBinopNodes children
        in
        when Array.popFirst flat.operands is
            Nothing ->
                Ok R.empty

            Just { first = operand0Nodes, rest = restOperands } ->
                if Array.isEmpty flat.ops then
                    buildFlowDoc 0 operand0Nodes

                else
                    -- Render every operand to a doc, then split at the chain's
                    -- minimum precedence into operator-led groups.
                    let
                        operandDocsResult =
                            traverseArray (buildFlowDoc 0) flat.operands

                        minPrec =
                            binopMinPrecedence (Array.map opNodeText flat.ops)
                    in
                    operandDocsResult
                        |> Result.map
                            (\operandDocs ->
                                assembleBinopGroups forceVertical minPrec operandDocs flat.ops
                            )


-- Assemble the operand docs and operator nodes into the precedence-aware layout.
-- `operandDocs` has one more entry than `ops`; `ops[k]` sits between
-- `operandDocs[k]` and `operandDocs[k+1]`. Groups break at operators whose
-- precedence equals `minPrec` (= `binopMinPrecedence ops`); tighter
-- (higher-precedence) operators join their operands inline within a group. This
-- is the render-side twin of `InsertExpressions.binopForceVertical`, which
-- groups the operand *ranges* the same way to decide the forced-vertical flag.
assembleBinopGroups : Bool -> Int -> Array Doc -> Array LPNode -> Doc
assembleBinopGroups forceVertical minPrec operandDocs ops =
    let
        firstDoc =
            Array.first operandDocs |> Maybe.withDefault R.empty

        -- Pair each operator with the operand doc that follows it.
        paired =
            Array.map2
                (\op nextDoc -> { op = op, nextDoc = nextDoc })
                ops
                (Array.dropFirst 1 operandDocs)

        -- Fold left, accumulating the current group's inline doc and emitting a
        -- completed group (led by its lowest-precedence operator) each time we
        -- cross a minimum-precedence operator.
        state =
            Array.foldl
                (\pair acc ->
                    if binopPrecedence (opNodeText pair.op) == minPrec then
                        { firstGroup =
                            -- The first minimum-precedence operator closes group 0;
                            -- capture the accumulated `curDoc` (which may already hold
                            -- higher-precedence ops, e.g. `a * b` in `a * b + c`).
                            if acc.started then
                                acc.firstGroup

                            else
                                acc.curDoc
                        , started = True
                        , segments =
                            if acc.started then
                                Array.pushLast { sep = acc.pendingSep, doc = acc.curDoc } acc.segments

                            else
                                acc.segments
                        , pendingSep = opNodeText pair.op
                        , curDoc = pair.nextDoc
                        }

                    else
                        { acc | curDoc = R.concat
                                acc.curDoc
                                (R.concat (R.text (" " ++ opNodeText pair.op ++ " ")) pair.nextDoc) }
                )
                { firstGroup = firstDoc
                , started = False
                , segments = []
                , pendingSep = ""
                , curDoc = firstDoc
                }
                paired

        -- Close the final group.
        segments =
            Array.pushLast { sep = state.pendingSep, doc = state.curDoc } state.segments

        sep =
            authorSep forceVertical

        restInner =
            Array.foldl
                (\seg acc ->
                    R.concat
                        acc
                        (R.concat sep (R.concat (R.text (seg.sep ++ " ")) seg.doc))
                )
                R.empty
                segments

        full =
            R.concat state.firstGroup (R.nest grenIndent restInner)
    in
    inlineUnlessVertical forceVertical full


makeTypeAliasPrettyDoc : Array LPNode -> Result String Doc
makeTypeAliasPrettyDoc =
    renderHeaderIndentedBodyDoc "type alias declaration is empty" makeTypeBodyDoc


makeTypeUnionPrettyDoc : Array LPNode -> Result String Doc
makeTypeUnionPrettyDoc =
    renderHeaderIndentedBodyDoc "type declaration is empty" makeUnionBodyDoc


renderHeaderIndentedBodyDoc : String -> (Array LPNode -> Result String Doc) -> Array LPNode -> Result String Doc
renderHeaderIndentedBodyDoc emptyError buildBody children =
    when Array.popLast children is
        Nothing ->
            Err emptyError

        Just { initial = headerChildren, last = bodyBlock } ->
            buildFlowDoc 0 headerChildren
                |> Result.andThen
                    (\headerDoc ->
                        buildBody (lpnChildren bodyBlock)
                            |> Result.map
                                (\bodyDoc ->
                                    R.concat headerDoc (R.nest grenIndent (R.concat R.hardNl bodyDoc))
                                )
                    )


-- Render a top-level comment-line OriginalRows. Usually it holds a single
-- comment, but comment placement merges comments that share a source row (or
-- fall within a multi-line block comment's row span) into one OriginalRows ‚Äî
-- e.g. `{- a -} {- b -}` on one line. So render every comment child: join two
-- block comments on the same row with a space, otherwise with a hardNl, and
-- always break after a `--` line comment (which consumes the rest of its line).
makeCommentLineDoc_ : Array LPNode -> Result String Doc
makeCommentLineDoc_ children =
    let
        commentInfo node =
            when lpnBox node is
                SingleLineComment loc ->
                    Just { row = loc.start.row, isLine = True }

                BlockComment loc ->
                    Just { row = loc.start.row, isLine = False }

                DocComment loc ->
                    Just { row = loc.start.row, isLine = False }

                _ ->
                    Nothing
    in
    Array.foldl
        (\node accResult ->
            when accResult is
                Err e ->
                    Err e

                Ok acc ->
                    when commentInfo node is
                        Nothing ->
                            Err "Unexpected node type in comment line"

                        Just info ->
                            let
                                commentDoc =
                                    commentNodeDoc node
                            in
                            when acc.doc is
                                Nothing ->
                                    Ok { doc = Just commentDoc, prevRow = info.row, prevLine = info.isLine }

                                Just prevDoc ->
                                    let
                                        separator =
                                            if acc.prevLine || info.row /= acc.prevRow then
                                                R.hardNl

                                            else
                                                R.text " "
                                    in
                                    Ok { doc = Just (R.concat prevDoc (R.concat separator commentDoc))
                                        , prevRow = info.row
                                        , prevLine = info.isLine
                                        }
        )
        (Ok { doc = Nothing, prevRow = -1, prevLine = False })
        children
        |> Result.andThen
            (\acc ->
                when acc.doc is
                    Nothing ->
                        Err "No nodes in comment line"

                    Just d ->
                        Ok d
            )


-- `listBoxesWithBrackets` keyed by a `ListBrackets` value rather than explicit
-- open/close strings ‚Äî the shape every nested always-vertical literal needs.
listBoxesForBracket : ListBrackets -> Array LPNode -> Result String Doc
listBoxesForBracket bracket nodes =
    let
        bs =
            bracketStrings bracket
    in
    listBoxesWithBrackets bs.open bs.close nodes


listBoxesWithBrackets : String -> String -> Array LPNode -> Result String Doc
listBoxesWithBrackets open close nodes =
    listBoxesWithBracketsUsing listItemBoxDoc open close nodes


-- The general form of `listBoxesWithBrackets`: render each item with the
-- given renderer instead of the default `listItemBoxDoc`. The uniform
-- record-array layout uses this to build the same comment-aware vertical
-- structure twice ‚Äî once with every record forced flat, once with every
-- record forced expanded ‚Äî and offer the pair as a single choice.
listBoxesWithBracketsUsing : (LPNode -> Maybe (Result String Doc)) -> String -> String -> Array LPNode -> Result String Doc
listBoxesWithBracketsUsing itemRenderer open close nodes =
    let
        -- Reuse the shared list-item dispatch, tagging each rendered doc with its
        -- source row (so the fold can place trailing comments) and treating an
        -- unrecognised box as "skip" rather than an error ‚Äî a comment-bearing
        -- list never errors on an item it can't classify, it just drops it.
        nodeItemDoc node =
            when itemRenderer node is
                Nothing ->
                    Ok Nothing

                Just result ->
                    let
                        row =
                            when lpnBox node is
                                UnbreakableText loc ->
                                    loc.start.row

                                _ ->
                                    lpnMaxRow node
                    in
                    result |> Result.map (\d -> Just { doc = d, row = row })

        foldResult =
            Array.foldl
                (\node accResult ->
                    when accResult is
                        Err e ->
                            Err e

                        Ok acc ->
                            let
                                handleCommentNode commentRow =
                                    let
                                        commentDoc =
                                            commentNodeDoc node
                                    in
                                    if commentRow == acc.prevRow then
                                        -- Trailing the preceding item: attach with a SOFT break ‚Äî
                                        -- a space in flat context, otherwise its own line. A hard
                                        -- space would put the comment on the item's line, so a
                                        -- trailing comment would re-wrap the item's
                                        -- value; on reparse the comment then sits on the value's
                                        -- wrapped row, the value un-wraps, and the layout
                                        -- oscillates. The soft break keeps the item's value laid
                                        -- out as if the comment were absent (it lands past the
                                        -- break), so only the comment moves ‚Äî stable across
                                        -- reformats. Mirrors the trailing line-comment soft break
                                        -- in buildFlowDocImpl.
                                        let
                                            attached =
                                                when acc.pending is
                                                    Nothing ->
                                                        { doc = commentDoc, isComment = True }

                                                    Just e ->
                                                        { doc = R.concat e.doc (R.group (R.concat R.nl commentDoc))
                                                        , isComment = False
                                                        }
                                        in
                                        Ok { acc
                                                | lineDocs = acc.lineDocs ++ [ attached ]
                                                , pending = Nothing
                                            }

                                    else
                                        let
                                            flushed =
                                                when acc.pending is
                                                    Nothing ->
                                                        acc.lineDocs

                                                    Just e ->
                                                        acc.lineDocs ++ [ e ]
                                        in
                                        Ok { lineDocs = flushed ++ [ { doc = commentDoc, isComment = True } ]
                                            , pending = Nothing
                                            , prevRow = commentRow
                                            }
                            in
                            when lpnBox node is
                                SingleLineComment loc ->
                                    handleCommentNode loc.start.row

                                BlockComment loc ->
                                    handleCommentNode loc.start.row

                                _ ->
                                    when nodeItemDoc node is
                                        Err e ->
                                            Err e

                                        Ok Nothing ->
                                            Ok acc

                                        Ok (Just { doc, row }) ->
                                            let
                                                flushed =
                                                    when acc.pending is
                                                        Nothing ->
                                                            acc.lineDocs

                                                        Just e ->
                                                            acc.lineDocs ++ [ e ]
                                            in
                                            Ok { lineDocs = flushed
                                                , pending = Just { doc = doc, isComment = False }
                                                , prevRow = row
                                                }
                )
                (Ok { lineDocs = [], pending = Nothing, prevRow = -1 })
                nodes
    in
    when foldResult is
        Err e ->
            Err e

        Ok state ->
            let
                allLineDocs =
                    when state.pending is
                        Nothing ->
                            state.lineDocs

                        Just e ->
                            state.lineDocs ++ [ e ]

                prefixed =
                    let
                        { result } =
                            Array.foldl
                                (\{ doc, isComment } acc ->
                                    if isComment then
                                        { acc | result = acc.result ++ [ doc ] }

                                    else
                                        let
                                            prefixedDoc =
                                                if acc.seenText then
                                                    R.concat (R.text ", ") doc

                                                else
                                                    R.concat (R.text open) doc
                                        in
                                        { result = acc.result ++ [ prefixedDoc ]
                                        , seenText = True
                                        }
                                )
                                { result = [], seenText = False }
                                allLineDocs
                    in
                    result ++ [ R.text close ]
            in
            Ok (R.vcat prefixed)


makeWhenFlowDoc : Bool -> Int -> Array LPNode -> Result String Doc
makeWhenFlowDoc forceVertical branchNest children =
    when Array.popLast children is
        Nothing ->
            Err "WhenFlow: empty children"

        Just { last = branchesBlock, initial = withoutBranches } ->
            when Array.popLast withoutBranches is
                Nothing ->
                    Err "WhenFlow: missing is node"

                Just { last = _, initial = headerNodes } ->
                    when Array.popFirst headerNodes is
                        Nothing ->
                            Err "WhenFlow: missing when node"

                        Just { rest = scrutineeNodes } ->
                            buildFlowDocInline 0 withoutBranches
                                |> Result.andThen
                                    (\flatHeaderDoc ->
                                        buildFlowDocInline 0 scrutineeNodes
                                            |> Result.andThen
                                                (\scrutineeDoc ->
                                                    buildFlowDoc 0 (lpnChildren branchesBlock)
                                                        |> Result.map
                                                            (\branchesContent ->
                                                                let
                                                                    headerDoc =
                                                                        if forceVertical then
                                                                            R.concat
                                                                                (R.text "when")
                                                                                (R.concat
                                                                                    (R.nest grenIndent (R.concat R.hardNl scrutineeDoc))
                                                                                    (R.concat R.hardNl (R.text "is")))

                                                                        else
                                                                            flatHeaderDoc

                                                                    branchesDoc =
                                                                        R.nest branchNest (R.concat R.hardNl branchesContent)
                                                                in
                                                                R.align (R.concat headerDoc branchesDoc)
                                                            )
                                                )
                                    )


{-| Render a multi-line lambda argument `(\args -> body)` in elm-format style:

    |> Task.andThen
        (\start ->
            body
        )

`R.align` anchors indent to `(`, the body is at `(` col + 4, and `)` is on
its own line at `(` col.  Called from `renderPipelineStepNode` after it detects
a trailing `isMultilineLambdaParenBlock` child and breaks it onto a new line.
-}
makeMultilineLambdaArgDoc : Array LPNode -> Result String Doc
makeMultilineLambdaArgDoc children =
    when Array.popFirst children is
        Nothing ->
            Err "multiline lambda paren: no children"

        Just { first = headNode, rest = afterHead } ->
            buildFlowDocInline 0 (lpnChildren headNode)
                |> Result.andThen
                    (\headDoc ->
                        when Array.first afterHead is
                            Nothing ->
                                Ok (R.align (R.concat (R.text "(") (R.concat headDoc (R.text ")"))))

                            Just bodyNode ->
                                buildFlowDoc 0 (lpnChildren bodyNode)
                                    |> Result.map
                                        (\bodyDoc ->
                                            R.align
                                                (R.concat
                                                    (R.text "(")
                                                    (R.concat
                                                        headDoc
                                                        (R.concat
                                                            (R.nest grenIndent (R.concat R.hardNl bodyDoc))
                                                            (R.concat R.hardNl (R.text ")")))))
                                        )
                    )


-- Render a non-lambda multiline ParenBlock arg: `(content\n)` with `)` on
-- its own line at the surrounding indent level.  Called from
-- buildStepChildrenDoc when the paren content has AlwaysVertical or
-- RecordUpdate structure (and the whole paren has already been broken onto
-- its own line via R.nest grenIndent (R.hardNl + ...)).
makeMultilineParenArgDoc : Array LPNode -> Result String Doc
makeMultilineParenArgDoc children =
    buildFlowDocInline 0 children
        |> Result.map
            (\innerDoc ->
                R.concat
                    (R.text "(")
                    (R.concat
                        innerDoc
                        (R.concat R.hardNl (R.text ")")))
            )


{-| Render a ParenBlock: inline for simple expressions, paren-block layout for
block-style content (when, if, let).  Block layout matches elm-format:

    x + (when y is        -- "when" immediately after "("
              Just n ->   -- branches at "(" + 2
                  n
          )               -- ")" on its own line at "(" column

When the parens will span multiple rows ‚Äî either because the author wrote
them that way (`parensForceVertical`, from the paren's own start/end row ‚Äî
see `LogicalPrintingTree.ParenBlock`) or because the content is *structurally*
forced vertical regardless of how it was written (an `if`/`when`/`let` body,
a comment, a multiline string ‚Äî anything whose rendered `Doc` contains a
`HardNl`, per `R.hasHardBreak`) ‚Äî and the content isn't already one of the
block-style/lambda shapes above, the same "content right after `(`, `)` on
its own line" layout applies generically:

    (Parser.oneOf
        [ a
        , b
        ]
    )

Both signals matter, and only for genuine `Src.Parens` (`checkContentVertical`):
`forceVertical` alone catches an author spreading otherwise-trivial content
across rows for no structural reason; `hasHardBreak` alone catches content
that's forced vertical by a rule unrelated to how the *parens* were
originally written (an `if` body always breaks even when the author crammed
the whole `(...)` onto one row) ‚Äî using only the source row-span there would
be a moving target: the first format spreads the content out, and reparsing
that *new* text sees the parens now spanning rows and flips the decision,
breaking idempotency. `checkContentVertical` is False for formatter-synthesized
parens (pattern/type wrapping): those must stay byte-identical to before this
rule existed, so a comment or multiline construct *inside* a synthesized wrap
must not pull its closing paren onto its own line. `R.align` anchors the
closing paren to whatever column `(` renders at (not necessarily a
`nest`-boundary column, e.g. mid-expression after other tokens).
-}
makeParenBlockDoc : { forceVertical : Bool, checkContentVertical : Bool } -> Array LPNode -> Result String Doc
makeParenBlockDoc parenFlags children =
    let
        innerDocResult =
            buildFlowDocInline 0 children

        inline =
            Result.map (\innerDoc -> R.concat (R.text "(") (R.concat innerDoc (R.text ")"))) innerDocResult

        -- Whether the content is *structurally* forced vertical (an if/when/let
        -- body, a comment, a multiline string, ‚Ä¶) regardless of how the parens
        -- themselves were written ‚Äî see the doc comment above for why this is
        -- ORed with `forceVertical` rather than used alone, and gated behind
        -- `checkContentVertical` rather than applied unconditionally.
        contentForcesVertical =
            if not parenFlags.checkContentVertical then
                False

            else
                when innerDocResult is
                    Ok innerDoc ->
                        R.hasHardBreak innerDoc

                    Err _ ->
                        False

        parensForceVertical =
            parenFlags.forceVertical

        -- Shared fallback for any content that isn't a when/if/let block:
        -- own-line `)` for a multiline lambda (checked first, by content
        -- shape) or when either verticality signal is set; otherwise flat.
        -- Reused by both the `UnbreakableText` (non-`let`) and catch-all
        -- match arms below ‚Äî a bare leaf like `Int` (a type's arrow chain
        -- has no wrapping container, unlike a Call/Binop) must get the same
        -- treatment as everything else, not silently skip it.
        genericFallback =
            -- If the second direct child is IndentedBlock, the lambda
            -- body is on a separate row ‚Äî put ) on its own line so the
            -- closing paren doesn't trail the body text.
            let
                isLambdaMultiline =
                    when Array.popFirst children is
                        Just { rest } ->
                            when Array.first rest is
                                Just secondChild ->
                                    when lpnBox secondChild is
                                        IndentedBlock ->
                                            True

                                        _ ->
                                            False

                                Nothing ->
                                    False

                        Nothing ->
                            False
            in
            if isLambdaMultiline then
                Result.map
                    (\innerDoc ->
                        R.concat
                            (R.text "(")
                            (R.concat
                                innerDoc
                                (R.concat R.hardNl (R.text ")")))
                    )
                    innerDocResult

            else if parensForceVertical || contentForcesVertical then
                Result.map
                    (\innerDoc ->
                        R.align
                            (R.concat
                                (R.text "(")
                                (R.concat
                                    innerDoc
                                    (R.concat R.hardNl (R.text ")"))))
                    )
                    innerDocResult

            else
                inline
    in
    when Array.first children is
        Nothing ->
            Ok (R.text "()")

        Just first ->
            when lpnBox first is
                WhenFlow { forceVertical } ->
                    makeWhenFlowDoc forceVertical 1 (lpnChildren first)
                        |> Result.map
                            (\whenDoc ->
                                R.align
                                    (R.concat
                                        (R.text "(")
                                        (R.concat
                                            whenDoc
                                            (R.concat R.hardNl (R.text ")"))))
                            )

                IfCondition _ ->
                    makeBlockInParenDoc children

                UnbreakableText loc ->
                    if loc.value == "let" then
                        makeBlockInParenDoc children

                    else
                        genericFallback

                _ ->
                    genericFallback


{-| Render if/else and let expressions inside a ParenBlock using the
paren-block layout: keyword at "("+1, bodies at "("+2, ")" at "(" column.
-}
makeBlockInParenDoc : Array LPNode -> Result String Doc
makeBlockInParenDoc children =
    Array.foldl
        (\node accResult ->
            when accResult is
                Err e ->
                    Err e

                Ok { doc, isFirst } ->
                    let
                        appendDoc d =
                            if isFirst then
                                Ok { doc = d, isFirst = False }

                            else
                                Ok { doc = R.concat doc d, isFirst = False }
                    in
                    when lpnBox node is
                        IndentedBlock ->
                            buildFlowDoc 0 (lpnChildren node)
                                |> Result.andThen
                                    (\bodyDoc ->
                                        appendDoc (R.nest 2 (R.concat R.hardNl bodyDoc))
                                    )

                        BodyBlock ->
                            buildFlowDoc 0 (lpnChildren node)
                                |> Result.andThen
                                    (\bodyDoc ->
                                        appendDoc (R.nest 1 (R.concat R.hardNl bodyDoc))
                                    )

                        EmptyLine ->
                            appendDoc (R.text "\n")

                        SynthesizedText s ->
                            appendDoc (R.nest 1 (R.concat R.hardNl (R.text s)))

                        IfCondition _ ->
                            makePDoc (lpnBox node) (lpnChildren node)
                                |> Result.andThen
                                    (\nodeDoc ->
                                        if isFirst then
                                            appendDoc nodeDoc

                                        else
                                            appendDoc (R.nest 1 (R.concat R.hardNl nodeDoc))
                                    )

                        _ ->
                            makePDoc (lpnBox node) (lpnChildren node)
                                |> Result.andThen
                                    (\nodeDoc ->
                                        if isFirst then
                                            appendDoc nodeDoc

                                        else
                                            appendDoc (R.concat R.hardNl nodeDoc)
                                    )
        )
        (Ok { doc = R.empty, isFirst = True })
        children
        |> Result.map
            (\{ doc } ->
                R.align
                    (R.concat
                        (R.text "(")
                        (R.concat
                            doc
                            (R.concat R.hardNl (R.text ")"))))
            )


{-| Serialize the Render.Doc tree for each top-level declaration to a JSON
array, one entry per root child.  Exposed for the `--render-doc` debug flag.
-}
lptToRenderDocJson : LPNode -> Result String String
lptToRenderDocJson root =
    Array.foldl
        (\child acc ->
            when acc is
                Err e ->
                    Err e

                Ok docs ->
                    when makePrettyLineDoc child is
                        Err e ->
                            Err e

                        Ok doc ->
                            Ok (Array.pushLast (R.docToJson doc) docs)
        )
        (Ok [])
        (lpnChildren root)
        |> Result.map (\values -> Json.encode 2 (Json.array identity values))
