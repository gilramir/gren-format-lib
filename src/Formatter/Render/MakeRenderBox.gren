module Formatter.Render.MakeRenderBox exposing (makePrettyLineBox)

{-| Box-model renderer ‚Äî the target of the Change-1 strangler rollout. It
renders an LPT node to elm-format's `Box` (Tab + prefix arithmetic), returning
`Err` for any construct not yet ported so the caller (`MakeRender.makePrettyLine`)
falls back to the legacy `Doc` renderer.

TRANCHE 1: top-level definitions whose body is a simple flow ‚Äî leaves, record /
array literals, and nested single-line flows. Everything else is `Err`. A
self-verify guard in `makePrettyLine` only *uses* Box output when it is
byte-identical to the `Doc` output, so this is regression-proof: a shape this
renderer gets wrong simply falls back.
-}

import Formatter.Render.Box as B exposing (Box(..))
import Formatter.Render.ElmStructure as E
import Formatter.Render.FlowPolicy as FP
import Formatter.Logical.LogicalPrintingTree exposing (LPBox(..), LPNode, ListBrackets(..), SyntaxType(..), lpnBox, lpnChildren, firstRowInSubtree, lpnMaxRow, lpnFirstPos, lpnBracketStart, lpnLastPos, lpnLastBracketEnd)
import Formatter.Logical.BinopPrecedence exposing (binopPrecedence, binopMinPrecedence)


grenIndent : Int
grenIndent =
    4


{-| Entry point: render one top-level root child to a Box, or Err to fall back. -}
makePrettyLineBox : LPNode -> Result String Box
makePrettyLineBox node =
    when lpnBox node is
        OriginalRows { stype = stype } ->
            when stype is
                StFunctionDeclaration ->
                    -- The tranche-1 blanket "comment child ‚Üí fall back" guard is
                    -- gone: `buildFlowBox`'s comment machinery (tranches 20‚Äì43)
                    -- places inline, standalone, and multi-line comments in a
                    -- funcDecl body directly. Anything it still can't do returns
                    -- Err from within the flow, so the self-verify guard covers it.
                    buildFlowBox grenIndent (lpnChildren node)

                StFunctionSignature ->
                    makeSignatureBox (lpnChildren node)

                StPort ->
                    makeSignatureBox (lpnChildren node)

                StTypeAlias ->
                    renderHeaderIndentedBody makeTypeAliasBody (lpnChildren node)

                StTypeUnion ->
                    renderHeaderIndentedBody makeUnionBodyBox (lpnChildren node)

                StSingleLineComment ->
                    makeCommentLineBox (lpnChildren node)

                StBlockComment ->
                    makeCommentLineBox (lpnChildren node)

                StDocComment ->
                    makeCommentLineBox (lpnChildren node)

                StModule ->
                    makeExposingLineBox StModule (lpnChildren node)

                StImport ->
                    makeExposingLineBox StImport (lpnChildren node)

                StInfixDecl ->
                    -- `infix left 6 (+) = add` ‚Äî a flat single-line leaf flow,
                    -- same shape as a funcDecl (both route through the Doc
                    -- renderer's `_ -> makeFlowIndentableDoc`).
                    buildFlowBox grenIndent (lpnChildren node)

        EmptyLine ->
            -- A top-level blank separator. The Doc renderer emits `R.empty`
            -- here (renders to ""); `B.blankLine` is `SingleLine (literal "")`,
            -- also "" after the join's trimRight ‚Äî byte-identical.
            Ok B.blankLine

        _ ->
            Err "box: root child not an OriginalRows funcDecl"


nodeIsComment : LPNode -> Bool
nodeIsComment node =
    when lpnBox node is
        SingleLineComment _ ->
            True

        BlockComment _ ->
            True

        DocComment _ ->
            True

        _ ->
            False


-- True when `node` or any descendant is a comment. Mirrors
-- `MakeRender.subtreeHasComment`; used to route a comment-bearing construct to
-- its comment-aware fallback rather than a comment-oblivious layout.
subtreeHasComment : LPNode -> Bool
subtreeHasComment node =
    nodeIsComment node || Array.any subtreeHasComment (lpnChildren node)


-- True when the subtree contains a bracketed literal (record/array/record-update)
-- that holds a comment among its direct children ‚Äî i.e. a comment that forces the
-- bracket multi-line (`{ a : Int {- c -} }`). Used by `makeSignatureBox` to fall
-- back on a comment nested in a signature's record type, which the Doc keeps glued
-- inline but `assembleFlow` would drop to its own line.
typeHasCommentBracket : LPNode -> Bool
typeHasCommentBracket node =
    let
        isBracketBox =
            when lpnBox node is
                AllAcrossOrAllVertical _ ->
                    True

                AlwaysVertical _ ->
                    True

                RecordUpdate _ ->
                    True

                _ ->
                    False
    in
    (isBracketBox && Array.any nodeIsComment (lpnChildren node))
        || Array.any typeHasCommentBracket (lpnChildren node)


-- ‚ïê‚ïê‚ïê BINOPS ‚ïê‚ïê‚ïê


{-| Flatten the nested `Binop`/`OpAndRhs` tree into a flat operand + operator
list. Mirrors `MakeRender.flattenBinopNodes`. Each operand is itself a flow
(array of nodes). -}
flattenBinopNodes : Array LPNode -> { operands : Array (Array LPNode), ops : Array LPNode }
flattenBinopNodes children =
    when Array.popLast children is
        Nothing ->
            { operands = [], ops = [] }

        Just { last = lastNode, initial = operandNodes } ->
            when lpnBox lastNode is
                OpAndRhs ->
                    when Array.popFirst (lpnChildren lastNode) is
                        Just { first = opNode, rest = restChildren } ->
                            let
                                inner =
                                    flattenBinopNodes restChildren
                            in
                            { operands = [ operandNodes ] ++ inner.operands
                            , ops = [ opNode ] ++ inner.ops
                            }

                        Nothing ->
                            { operands = [ operandNodes ], ops = [] }

                _ ->
                    { operands = [ children ], ops = [] }


opText : LPNode -> String
opText node =
    Maybe.withDefault "" (leafValue node)


{-| Render a binary-operator chain. Groups break at minimum-precedence
operators (tighter operators join inline within a group); the author's row
layout picks inline vs one-group-per-line (+4, operator-led). Mirrors
`MakeRender.makeBinopDoc` / `assembleBinopGroups`.

A multi-line operand (e.g. a `(when ‚Ä¶)` paren-block) is supported in the
forced-vertical, one-group-per-line layout: its group is composed via
`B.prefix (op ++ " ")`, which pads the operand's continuation lines by the
operator width so they align under where the operand's first char lands (the
Box form of `R.nest`/`R.align`). Any multi-line operand joined *inline* to a
higher-precedence sibling, and any multi-line operand in a non-vertical chain,
still returns Err and falls back. -}
makeBinopBox : Bool -> Array LPNode -> Result String Box
makeBinopBox forceVertical children =
    if Array.any subtreeHasComment children then
        -- A comment anywhere in the chain routes the Doc renderer AWAY from the
        -- precedence layout to its comment-aware flow fallback (`makeBinopDoc`'s
        -- `subtreeHasComment` branch): `buildFlowDoc grenIndent` when inline,
        -- `buildFlowDocBroken grenIndent` when forced vertical. Only the inline
        -- form is ported (the flat flow builder is comment-aware and, together
        -- with `OpAndRhs`, renders the chain on one line); a forced-vertical
        -- comment chain falls back.
        if forceVertical then
            buildFlowBoxBroken grenIndent children

        else
            buildFlowBox grenIndent children

    else
        let
            flat =
                flattenBinopNodes children
        in
        when Array.popFirst flat.operands is
            Nothing ->
                Err "box: empty binop"

            Just { first = operand0, rest = _ } ->
                if Array.isEmpty flat.ops then
                    buildFlowBox 0 operand0

                else
                    -- Render every operand to a Box (multi-line allowed).
                    traverseResult (buildFlowBox 0) flat.operands
                        |> Result.andThen
                            (\operandBoxes ->
                                assembleBinopBox forceVertical
                                    (binopMinPrecedence (Array.map opText flat.ops))
                                    operandBoxes
                                    (Array.map opText flat.ops)
                            )


-- Render an operator-precedence group (parts joined inline by higher-precedence
-- operators) to a single Box. A lone part is returned as-is (it may be
-- multi-line); two or more parts must all be single-line to inline-join.
renderBinopGroup : Array { op : String, box : Box } -> Result String Box
renderBinopGroup parts =
    when Array.popFirst parts is
        Nothing ->
            Err "box: empty binop group"

        Just { first = p0, rest } ->
            if Array.isEmpty rest then
                Ok p0.box

            else
                when B.isLine p0.box is
                    Err _ ->
                        Err "box: multi-line operand joined inline not ported"

                    Ok l0 ->
                        traverseResult
                            (\p ->
                                when B.isLine p.box is
                                    Ok l ->
                                        Ok [ B.space, B.literal p.op, B.space, l ]

                                    Err _ ->
                                        Err "box: multi-line operand joined inline not ported"
                            )
                            rest
                            |> Result.map
                                (\segs -> B.line (B.row (Array.flatten ([ [ l0 ] ] ++ segs))))


{-| Assemble the operand boxes + operator texts into the precedence-aware
layout. `ops[k]` sits between `operandBoxes[k]` and `operandBoxes[k+1]`. Groups
break at operators whose precedence == `minPrec`; tighter operators join inline
within a group. -}
assembleBinopBox : Bool -> Int -> Array Box -> Array String -> Result String Box
assembleBinopBox forceVertical minPrec operandBoxes ops =
    let
        firstBox =
            Maybe.withDefault (B.line (B.literal "")) (Array.first operandBoxes)

        paired =
            Array.map2 (\op nextBox -> { op = op, box = nextBox })
                ops
                (Array.dropFirst 1 operandBoxes)

        state =
            Array.foldl
                (\pair acc ->
                    if binopPrecedence pair.op == minPrec then
                        { firstGroup =
                            if acc.started then
                                acc.firstGroup

                            else
                                acc.curParts
                        , started = True
                        , segments =
                            if acc.started then
                                Array.pushLast { op = acc.pendingOp, parts = acc.curParts } acc.segments

                            else
                                acc.segments
                        , pendingOp = pair.op
                        , curParts = [ { op = "", box = pair.box } ]
                        }

                    else
                        { acc | curParts = Array.pushLast { op = pair.op, box = pair.box } acc.curParts }
                )
                { firstGroup = [ { op = "", box = firstBox } ]
                , started = False
                , segments = []
                , pendingOp = ""
                , curParts = [ { op = "", box = firstBox } ]
                }
                paired

        segments =
            Array.pushLast { op = state.pendingOp, parts = state.curParts } state.segments
    in
    renderBinopGroup state.firstGroup
        |> Result.andThen
            (\firstGroupBox ->
                traverseResult
                    (\seg -> Result.map (\b -> { op = seg.op, box = b }) (renderBinopGroup seg.parts))
                    segments
                    |> Result.andThen
                        (\segBoxes ->
                            if not forceVertical then
                                -- Inline: the chain flows on one line. Every group
                                -- must be single-line EXCEPT the very last operand,
                                -- which may be a multi-line node whose own lines break
                                -- below (a `"""‚Ä¶"""` literal opened mid-line). The Doc
                                -- keeps the whole chain concatenated and lets that
                                -- operand's `R.align` land its continuation under its
                                -- opening column; Box builds the single-line prefix
                                -- (`"a " ++ b ++`) and `B.prefix`es it onto the trailing
                                -- box, padding its continuation to the same column.
                                when B.isLine firstGroupBox is
                                    Err _ ->
                                        Err "box: multi-line operand in non-vertical binop not ported"

                                    Ok firstLine ->
                                        when Array.popLast segBoxes is
                                            Nothing ->
                                                Ok (B.line firstLine)

                                            Just { last = lastSeg, initial = initSegs } ->
                                                traverseResult
                                                    (\seg ->
                                                        when B.isLine seg.box is
                                                            Ok l ->
                                                                Ok [ B.space, B.literal seg.op, B.space, l ]

                                                            Err _ ->
                                                                Err "box: multi-line operand in non-vertical binop not ported"
                                                    )
                                                    initSegs
                                                    |> Result.andThen
                                                        (\initParts ->
                                                            when B.isLine lastSeg.box is
                                                                Ok lastLine ->
                                                                    -- All single-line: the whole chain on one row.
                                                                    Ok (B.line (B.row (Array.flatten ([ [ firstLine ] ] ++ initParts ++ [ [ B.space, B.literal lastSeg.op, B.space, lastLine ] ]))))

                                                                Err _ ->
                                                                    -- Trailing operand is multi-line: glue the
                                                                    -- single-line prefix onto its first line and
                                                                    -- pad its continuation to align (a mid-chain
                                                                    -- multi-line operand can't glue inline, so
                                                                    -- `initParts` above still Errs on those).
                                                                    let
                                                                        prefixRow =
                                                                            B.row (Array.flatten ([ [ firstLine ] ] ++ initParts ++ [ [ B.space, B.literal lastSeg.op, B.space ] ]))
                                                                    in
                                                                    Ok (B.prefix prefixRow lastSeg.box)
                                                        )

                            else
                                -- One group per line: firstGroup at base, each
                                -- later group `op group` at +4, operator-led.
                                Ok
                                    (B.stack1
                                        ([ firstGroupBox ]
                                            ++ Array.map (\seg -> B.indent (prefixOperator seg.op seg.box)) segBoxes
                                        )
                                    )
                        )
            )


-- Prepend `op ` to a group box. A single-line box becomes one line; a
-- multi-line box uses `B.prefix`, which pads its continuation lines by the
-- operator width so they align under the operand's first char.
prefixOperator : String -> Box -> Box
prefixOperator op box =
    when B.isLine box is
        Ok l ->
            B.line (B.row [ B.literal op, B.space, l ])

        Err _ ->
            B.prefix (B.row [ B.literal op, B.space ]) box


isOpAndRhsNode : LPNode -> Bool
isOpAndRhsNode node =
    when lpnBox node is
        OpAndRhs ->
            True

        _ ->
            False


{-| Render an `OpAndRhs` node (`op` + the right-hand side flow), mirroring
`MakeRender.makeOpAndRhsDoc`. Reached only from the comment-bearing binop flow
fallback (the comment-free path flattens `OpAndRhs` via `flattenBinopNodes`
instead). -}
makeOpAndRhsBox : Array LPNode -> Result String Box
makeOpAndRhsBox children =
    when Array.popFirst children is
        Nothing ->
            Err "box: empty OpAndRhs"

        Just { first = opNode, rest = rhsNodes } ->
            when leafValue opNode is
                Just op ->
                    -- Inline-start flow: a leading `{- c -}` in the rhs stays on
                    -- the operator's line (`* {- c -} 100`), mirroring the Doc's
                    -- `buildFlowDocInline 0` in `makeOpAndRhsDoc`. `prefixOperator`
                    -- glues `op ` onto the rhs ‚Äî its first line for a single-line
                    -- rhs, or (via `B.prefix`, padding continuation by the operator
                    -- width) the first line of a multi-line rhs such as an operand
                    -- with a trailing multi-line comment (`+ b {- multi‚Ä¶ -}`).
                    --
                    -- A rhs that also carries a NESTED `OpAndRhs` (a lower-precedence
                    -- continuation operand, `+ b {- c -} * 2`) can't use `B.prefix`:
                    -- the comment body must shift with the operator while the nested
                    -- operand must stay at the operator's base column ‚Äî a per-line
                    -- mix (`R.align` vs `R.nest`) the uniform prefix can't produce, so
                    -- a multi-line such rhs falls back.
                    buildFlowBoxInline 0 rhsNodes
                        |> Result.andThen
                            (\rhsBox ->
                                if not (isSingleLine rhsBox) && Array.any isOpAndRhsNode rhsNodes then
                                    Err "box: multi-line OpAndRhs with a continuation operand not ported"

                                else
                                    Ok (prefixOperator op rhsBox)
                            )

                Nothing ->
                    Err "box: OpAndRhs op is not a text leaf"


-- ‚ïê‚ïê‚ïê COMMENT LINES ‚ïê‚ïê‚ïê


{-| Render a standalone top-level comment-line item. Same-row block comments
join with a space; a `--` line comment (or a row change) starts a new line.
Mirrors `MakeRender.makeCommentLineDoc`. A multi-line block comment renders via
`multiLineBlockCommentBox` (the reindent stack) ‚Äî its verbatim (opener-alone)
sub-case still falls back, as in the Doc. -}
makeCommentLineBox : Array LPNode -> Result String Box
makeCommentLineBox children =
    traverseResult commentNodeToBox children
        |> Result.andThen
            (\infos ->
                when Array.popFirst infos is
                    Nothing ->
                        Err "box: empty comment line"

                    Just { first = first0, rest } ->
                        Array.foldl
                            (\info accResult ->
                                accResult
                                    |> Result.andThen
                                        (\acc ->
                                            if acc.prevLine || info.row /= acc.prevRow then
                                                -- New line: stack the comment below.
                                                Ok
                                                    { box = B.stack1 [ acc.box, info.box ]
                                                    , prevRow = info.row
                                                    , prevLine = info.isLine
                                                    }

                                            else
                                                -- Same-row block comment: join with a
                                                -- space onto the accumulator's last line.
                                                -- A multi-line comment never reaches here
                                                -- (it always changes the row), so the
                                                -- box is single-line.
                                                when B.isLine info.box is
                                                    Ok l ->
                                                        Ok
                                                            { box = B.addSuffix (B.row [ B.space, l ]) acc.box
                                                            , prevRow = info.row
                                                            , prevLine = info.isLine
                                                            }

                                                    Err _ ->
                                                        Err "box: multi-line comment cannot space-join"
                                        )
                            )
                            (Ok { box = first0.box, prevRow = first0.row, prevLine = first0.isLine })
                            rest
                            |> Result.map .box
            )


-- Render one comment node to a Box, tagging its source row and whether it is a
-- `--` line comment (which always terminates its line). Mirrors the comment arms
-- of `MakeRender.makeCommentLineDoc` (`commentNodeDoc`): a multi-line block
-- comment reindents via `multiLineBlockCommentBox` (its verbatim sub-case Errs
-- and falls back); a doc comment's body is emitted verbatim as a single literal
-- (safe ‚Äî it is a standalone root child ending in `-}`).
commentNodeToBox : LPNode -> Result String { box : Box, row : Int, isLine : Bool }
commentNodeToBox node =
    when lpnBox node is
        SingleLineComment loc ->
            Ok { box = B.line (B.literal ("--" ++ loc.value)), row = loc.start.row, isLine = True }

        BlockComment loc ->
            if String.contains "\n" loc.value then
                multiLineBlockCommentBox loc.value
                    |> Result.map (\b -> { box = b, row = loc.start.row, isLine = False })

            else
                Ok { box = B.line (B.literal ("{-" ++ loc.value ++ "-}")), row = loc.start.row, isLine = False }

        DocComment loc ->
            Ok { box = B.line (B.literal (docCommentString loc.value)), row = loc.start.row, isLine = False }

        _ ->
            Err "box: comment-line node not ported"


{-| Render one comment child of an otherwise-empty bracket (`{ {- c -} }`) as a
single inline `Line`. Only a single-line block comment fits inline; anything
else (multi-line block, `--` line comment) can't be glued onto the one-line
bracket, so it Errs rather than silently drop the comment. -}
emptyBracketedCommentLine : LPNode -> Result String B.Line
emptyBracketedCommentLine node =
    when lpnBox node is
        BlockComment loc ->
            if String.contains "\n" loc.value then
                Err "box: multi-line comment in empty bracket not ported"

            else
                Ok (B.literal ("{-" ++ loc.value ++ "-}"))

        _ ->
            Err "box: non-block comment in empty bracket not ported"


{-| Join `Line`s with a single space between each (`[a, b, c]` ‚Üí `a b c`). -}
spaceJoinLines : Array B.Line -> Array B.Line
spaceJoinLines lines =
    Array.foldl
        (\ln acc ->
            if Array.isEmpty acc then
                [ ln ]

            else
                Array.pushLast ln (Array.pushLast B.space acc)
        )
        []
        lines


-- Render a doc comment's body into its `{-| ‚Ä¶ -}` string, mirroring
-- `MakeRender.commentBoxDoc`'s DocComment arm: an empty body collapses to
-- `{-| -}`; a body that both starts and ends with a single `\n` (a multi-line
-- doc comment whose content begins on the next line) gains a trailing blank
-- line before `-}` (elm-format's convention).
docCommentString : String -> String
docCommentString value =
    if String.isEmpty (String.trim value) then
        "{-| -}"

    else
        let
            normalizedValue =
                if
                    String.startsWith "\n" value
                        && String.endsWith "\n" value
                        && not (String.endsWith "\n\n" value)
                then
                    value ++ "\n"

                else
                    value
        in
        "{-|" ++ normalizedValue ++ "-}"


blockCommentBodyOffset : Int
blockCommentBodyOffset =
    3


leadingSpaceCount : String -> Int
leadingSpaceCount s =
    (String.foldl
        (\c acc ->
            if acc.done then
                acc

            else if c == ' ' then
                { acc | count = acc.count + 1 }

            else
                { acc | done = True }
        )
        { count = 0, done = False }
        s
    ).count


{-| Render a multi-line block comment as a stack of lines, mirroring the reindent
branch of `MakeRender.blockCommentDoc`: the first line verbatim, each continuation
line reindented so the smallest content indent maps to `blockCommentBodyOffset`
(deeper indentation kept relative), a bare closing delimiter or blank line
trimmed. Box stacking supplies the `R.align` that anchors the block under wherever
the opener prints. The VERBATIM (opener-alone) branch renders the body at absolute
column 0 via `R.reset`, which Box's uniform-prefix stacking cannot reproduce, so
it returns Err and falls back.
-}
multiLineBlockCommentBox : String -> Result String Box
multiLineBlockCommentBox value =
    let
        fullText =
            "{-" ++ value ++ "-}"
    in
    when Array.popFirst (String.split "\n" fullText) is
        Nothing ->
            Ok (B.line (B.literal fullText))

        Just { first = firstLine, rest = contLines } ->
            let
                openerAlone =
                    String.trimLeft (String.dropFirst 2 firstLine) == ""
            in
            if openerAlone then
                Err "box: verbatim (opener-alone) multi-line block comment not ported"

            else
                let
                    isContentLine line =
                        let
                            t =
                                String.trimLeft line
                        in
                        t /= "" && t /= "-}"

                    base =
                        contLines
                            |> Array.keepIf isContentLine
                            |> Array.map leadingSpaceCount
                            |> Array.minimum
                            |> Maybe.withDefault blockCommentBodyOffset

                    reindent line =
                        let
                            t =
                                String.trimLeft line
                        in
                        if t == "" || t == "-}" then
                            t

                        else
                            let
                                l =
                                    leadingSpaceCount line
                            in
                            String.repeat (max 0 (blockCommentBodyOffset + l - base)) " "
                                ++ String.dropFirst l line

                    allLines =
                        [ firstLine ] ++ Array.map reindent contLines
                in
                Ok (B.stack1 (Array.map (\ln -> B.line (B.literal ln)) allLines))


-- ‚ïê‚ïê‚ïê TYPE ALIAS & UNION DECLARATIONS ‚ïê‚ïê‚ïê


{-| Header + indented body: `type alias Name =` / body, `type Name` / variants.
Mirrors `MakeRender.renderHeaderIndentedBodyDoc` ‚Äî header inline, body dropped
+4. -}
renderHeaderIndentedBody : (Array LPNode -> Result String Box) -> Array LPNode -> Result String Box
renderHeaderIndentedBody bodyRenderer children =
    when Array.popLast children is
        Nothing ->
            Err "box: empty declaration"

        Just { initial = header, last = bodyBlock } ->
            buildFlowBox 0 header
                |> Result.andThen
                    (\headerBox ->
                        bodyRenderer (lpnChildren bodyBlock)
                            |> Result.map
                                (\bodyBox -> B.stack1 [ headerBox, B.indent bodyBox ])
                    )


-- A type-alias body: a single type node (record, or a plain `= Int`-style
-- type) renders as-is; a multi-line function type (`->` segments) isn't ported
-- and falls back.
makeTypeAliasBody : Array LPNode -> Result String Box
makeTypeAliasBody nodes =
    buildFlowBox 0 nodes


{-| A union body: each variant (`= A`, `| B`) on its own line when the author
wrote them across rows, or inline `= A | B | C` when on one line. Mirrors
`MakeRender.makeUnionBodyDoc`. Comment-bearing unions fall back. -}
makeUnionBodyBox : Array LPNode -> Result String Box
makeUnionBodyBox nodes =
    let
        variantNodes =
            Array.keepIf (\n -> not (nodeIsComment n)) nodes

        vertical =
            Array.any nodeIsComment nodes
                || rowsSpanMultiple (Array.map firstRowInSubtree variantNodes)
    in
    if vertical then
        makeUnionBodyVerticalBox nodes

    else
        traverseResult (\n -> buildFlowBox 0 (lpnChildren n)) variantNodes
            |> Result.andThen
                (\variantBoxes ->
                    when joinInline variantBoxes is
                        Just l ->
                            Ok l

                        Nothing ->
                            Err "box: multi-line inline union not ported"
                )


{-| Always-vertical union body with comment siblings, mirroring
`MakeRender.makeUnionBodyVertical`: one variant per line; a comment on the same
row as the variant it trails is appended inline (`B.addSuffix`), one on its own
row renders on its own line. A variant's "last row" is `max(lpnLastPos,
lpnLastBracketEnd)` ‚Äî NOT `lpnMaxRow`, which a multi-line block comment inside the
variant would widen, shifting a trailing comment to its own line (non-idempotent).
A multi-line block-comment SIBLING (rare) falls back. -}
makeUnionBodyVerticalBox : Array LPNode -> Result String Box
makeUnionBodyVerticalBox nodes =
    let
        placeComment acc row commentText =
            when Array.popLast acc.boxes is
                Just { last = lastBox, initial } ->
                    if row == acc.prevRow && acc.prevRow >= 0 then
                        { acc
                            | boxes = Array.pushLast (B.addSuffix (B.row [ B.space, B.literal commentText ]) lastBox) initial
                            , prevRow = row
                        }

                    else
                        { acc | boxes = Array.pushLast (B.line (B.literal commentText)) acc.boxes, prevRow = row }

                Nothing ->
                    { acc | boxes = [ B.line (B.literal commentText) ], prevRow = row }

        variantLastRow node =
            let
                tokenRow =
                    lpnLastPos node |> Maybe.map (\p -> p.row) |> Maybe.withDefault -1

                bracketRow =
                    lpnLastBracketEnd node |> Maybe.map (\p -> p.row) |> Maybe.withDefault -1

                maxR =
                    max tokenRow bracketRow
            in
            if maxR >= 0 then
                maxR

            else
                firstRowInSubtree node
    in
    Array.foldl
        (\node accResult ->
            accResult
                |> Result.andThen
                    (\acc ->
                        when lpnBox node is
                            SingleLineComment loc ->
                                Ok (placeComment acc loc.start.row ("--" ++ loc.value))

                            BlockComment loc ->
                                if String.contains "\n" loc.value then
                                    -- A multi-line block comment SIBLING between
                                    -- variants renders on its own line via the
                                    -- reindent stack, mirroring the Doc path's
                                    -- `commentNodeDoc`. Same-row gluing of a
                                    -- multi-line comment onto a preceding variant
                                    -- (`B.addSuffix` appends only a single line)
                                    -- is not modelled, so that rare case falls back.
                                    if loc.start.row == acc.prevRow && acc.prevRow >= 0 then
                                        Err "box: same-row multi-line block-comment union sibling not ported"

                                    else
                                        multiLineBlockCommentBox loc.value
                                            |> Result.map
                                                (\cbox ->
                                                    { acc
                                                        | boxes = Array.pushLast cbox acc.boxes
                                                        , prevRow = loc.start.row
                                                    }
                                                )

                                else
                                    Ok (placeComment acc loc.start.row ("{-" ++ loc.value ++ "-}"))

                            _ ->
                                buildFlowBox 0 (lpnChildren node)
                                    |> Result.map
                                        (\childBox ->
                                            { boxes = Array.pushLast childBox acc.boxes, prevRow = variantLastRow node }
                                        )
                    )
        )
        (Ok { boxes = [], prevRow = -1 })
        nodes
        |> Result.andThen
            (\acc ->
                when Array.first acc.boxes is
                    Nothing ->
                        Err "box: union has no variants"

                    Just _ ->
                        Ok (B.stack1 acc.boxes)
            )


-- True when the given source rows are not all equal (the author spread items
-- across rows). Mirrors `MakeRender.rowsSpanMultiple`.
rowsSpanMultiple : Array Int -> Bool
rowsSpanMultiple rows =
    when Array.popFirst rows is
        Nothing ->
            False

        Just { first, rest } ->
            Array.any (\r -> r /= first) rest


-- ‚ïê‚ïê‚ïê PIPELINES ‚ïê‚ïê‚ïê


isPipelineStepNode : LPNode -> Bool
isPipelineStepNode node =
    when lpnBox node is
        PipelineStep ->
            True

        _ ->
            False


{-| Render a forward (`|>`) pipeline: seed then each `|> step` on its own line
at +4 (or inline `seed |> a |> b` when the author kept it on one line). Mirrors
`MakeRender.makePipelineDoc`. Backward (`<|`) pipelines, comment-bearing
pipelines (a comment node makes a step Err), and steps with a multi-line
argument (which elm-format relocates) fall back to Doc. -}
makePipelineBox : Bool -> String -> Array LPNode -> Result String Box
makePipelineBox forceVertical op children =
    if op == "<|" then
        makeBackwardPipelineBox forceVertical children

    else if op /= "|>" then
        Err "box: unknown pipeline operator not ported"

    else
        let
            seedNodes =
                Array.keepIf (\n -> not (isPipelineStepNode n)) children

            stepNodes =
                Array.keepIf isPipelineStepNode children
        in
        buildFlowBox 0 seedNodes
            |> Result.andThen
                (\seedBox ->
                    traverseResult renderPipelineStep stepNodes
                        |> Result.andThen
                            (\stepBoxes ->
                                if forceVertical then
                                    Ok (B.stack1 ([ seedBox ] ++ Array.map B.indent stepBoxes))

                                else
                                    when joinInline ([ seedBox ] ++ stepBoxes) is
                                        Just l ->
                                            Ok l

                                        Nothing ->
                                            Err "box: multi-line inline pipeline not ported"
                            )
                )


-- One `|> step`. Rendered via `buildFlowBox grenIndent`, mirroring the Doc's
-- `buildStepChildrenDoc`: the operator + function stay inline (`|> f`) and a
-- multi-line block argument (a record / array / `when` / `if` / `let` that forces
-- vertical) relocates to the next line at +4. A single-line step renders
-- identically at any flow indent, so this keeps the cases covered since tranche 8.
--
-- A multi-line step whose argument is a `ParenBlock` (a multi-line lambda `\x ->`,
-- a parens-with-multiline-content, or a direct `|> (\x -> ‚Ä¶)` operand) gets
-- elm-format-specific relocation in the Doc (`makeMultilineLambdaArgDoc` /
-- `makeMultilineParenArgDoc`, or stays glued) that `assembleFlow`'s generic block
-- drop doesn't reproduce ‚Äî so those fall back. A single-line ParenBlock argument
-- (`|> f (g x)`) is fine (it renders inline).
-- ‚ïê‚ïê‚ïê pipeline-step trigger classification (Box mirror of buildStepChildrenDoc) ‚ïê‚ïê‚ïê


{-| True when `node`'s rendered Box spans multiple rows ‚Äî the Box mirror of
`MakeRender.nodeForcesVertical` (`R.hasHardBreak`). -}
nodeForcesVerticalBox : LPNode -> Bool
nodeForcesVerticalBox node =
    when makePBox (lpnBox node) (lpnChildren node) is
        Ok b ->
            not (isSingleLine b)

        Err _ ->
            False


-- Mirror of `MakeRender.flowChildForcesVertical`: a non-comment node that
-- renders multi-line forces the surrounding flow vertical.
flowChildForcesVerticalBox : LPNode -> Bool
flowChildForcesVerticalBox node =
    not (nodeIsComment node) && nodeForcesVerticalBox node


-- Mirror of `MakeRender.subtreeHasVertical`: a subtree that always produces a
-- hard break (an AlwaysVertical/RecordUpdate, or a comment-bearing literal).
subtreeHasVerticalBox : LPNode -> Bool
subtreeHasVerticalBox node =
    when lpnBox node is
        AlwaysVertical _ ->
            True

        RecordUpdate _ ->
            True

        AllAcrossOrAllVertical _ ->
            Array.any nodeIsComment (lpnChildren node)
                || Array.any subtreeHasVerticalBox (lpnChildren node)

        _ ->
            Array.any subtreeHasVerticalBox (lpnChildren node)


-- Mirror of `MakeRender.isMultilineLambdaParenBlock`: a ParenBlock whose second
-- child is an `IndentedBlock` (the author wrote the lambda body on a later row).
isMultilineLambdaParenBlockBox : LPNode -> Bool
isMultilineLambdaParenBlockBox node =
    when lpnBox node is
        ParenBlock _ ->
            when Array.get 1 (lpnChildren node) is
                Just secondChild ->
                    when lpnBox secondChild is
                        IndentedBlock ->
                            True

                        _ ->
                            False

                Nothing ->
                    False

        _ ->
            False


-- Mirror of `MakeRender.isMultilineLambdaParenBlockAnyBody`: broader than the
-- above ‚Äî an `IndentedBlock` body, or a `SoftIndentedBlock` body that its own
-- content forces vertical. Used by the direct-operand guard.
isMultilineLambdaParenBlockAnyBodyBox : LPNode -> Bool
isMultilineLambdaParenBlockAnyBodyBox node =
    when lpnBox node is
        ParenBlock _ ->
            when Array.get 1 (lpnChildren node) is
                Just secondChild ->
                    when lpnBox secondChild is
                        IndentedBlock ->
                            True

                        SoftIndentedBlock ->
                            softIndentedBlockChildForcesVerticalBox (lpnChildren secondChild)

                        _ ->
                            False

                Nothing ->
                    False

        _ ->
            False


-- Mirror of `MakeRender.isMultilineContentParenBlock`: a ParenBlock whose
-- content subtree will span rows (contains an AlwaysVertical / RecordUpdate).
isMultilineContentParenBlockBox : LPNode -> Bool
isMultilineContentParenBlockBox node =
    when lpnBox node is
        ParenBlock _ ->
            Array.any subtreeHasVerticalBox (lpnChildren node)

        _ ->
            False


{-| Split a pipeline step's children at its *trigger* ‚Äî the first node that
`buildStepChildrenDoc` (the Doc) breaks onto its own line: a multi-line
lambda-argument paren, a multi-line content paren, or any other
multi-line-forcing node such as a record argument. A 1:1 mirror of the Doc's
left-to-right split, including the direct-operand-lambda exclusion (`|>
(\x -> ‚Ä¶)` stays glued to the operator). `Nothing` = no trigger. -}
splitStepTrigger : Array LPNode -> Maybe { preamble : Array LPNode, trigger : LPNode, suffix : Array LPNode }
splitStepTrigger stepChildren =
    (Array.foldl
        (\node acc ->
            when acc.split is
                Just s ->
                    { acc | split = Just { s | suffix = Array.pushLast node s.suffix } }

                Nothing ->
                    let
                        isDirectOperandLambda =
                            isMultilineLambdaParenBlockAnyBodyBox node
                                && Array.length acc.preamble <= 1
                    in
                    if
                        not isDirectOperandLambda
                            && (isMultilineLambdaParenBlockBox node
                                    || isMultilineContentParenBlockBox node
                                    || flowChildForcesVerticalBox node
                               )
                    then
                        { acc | split = Just { preamble = acc.preamble, trigger = node, suffix = [] } }

                    else
                        { acc | preamble = Array.pushLast node acc.preamble }
        )
        { preamble = [], split = Nothing }
        stepChildren
    ).split


-- One `|> step`, mirroring the Doc's `buildStepChildrenDoc`. A step with a
-- *trigger* (see `splitStepTrigger`) relocates it: the preamble (`|> fn ‚Ä¶`)
-- glues inline, the trigger drops to its own line at +grenIndent (relative to
-- the step's own base ‚Äî the pipeline assembler adds the step's +4 from the
-- seed), and any suffix args land below it at the same indent. The two
-- ParenBlock trigger kinds (`makeMultilineLambdaArgDoc` /
-- `makeMultilineParenArgDoc` on the Doc side) have paren-arg reshaping that
-- isn't ported, so they fall back. A multi-line step with NO trigger (a
-- direct-operand lambda paren that must stay glued to `|>`, or a
-- comment-bearing step needing the Doc's comment-peeling) also falls back.
renderPipelineStep : LPNode -> Result String Box
renderPipelineStep stepNode =
    let
        children =
            lpnChildren stepNode
    in
    when splitStepTrigger children is
        Nothing ->
            buildFlowBox grenIndent children
                |> Result.andThen
                    (\box ->
                        if isSingleLine box then
                            Ok box

                        else
                            Err "box: multi-line pipeline step without a trigger (direct-operand paren glue / comment-peeling) not ported"
                    )

        Just { preamble, trigger, suffix } ->
            if isMultilineLambdaParenBlockBox trigger || isMultilineContentParenBlockBox trigger then
                Err "box: paren-arg pipeline-step trigger not ported"

            else
                buildFlowBoxInline 0 preamble
                    |> Result.andThen
                        (\preambleBox ->
                            makePBox (lpnBox trigger) (lpnChildren trigger)
                                |> Result.andThen
                                    (\triggerBox ->
                                        if Array.isEmpty suffix then
                                            Ok (B.stack1 [ preambleBox, applyIndent grenIndent triggerBox ])

                                        else
                                            buildFlowBox 0 suffix
                                                |> Result.map
                                                    (\suffixBox ->
                                                        B.stack1
                                                            [ preambleBox
                                                            , applyIndent grenIndent triggerBox
                                                            , applyIndent grenIndent suffixBox
                                                            ]
                                                    )
                                    )
                        )


-- Get a box's sole line, or Err if it is multi-line.
boxLine : Box -> Result String B.Line
boxLine box =
    when B.isLine box is
        Ok l ->
            Ok l

        Err _ ->
            Err "box: expected single-line box"


{-| Render a backward (`<|`) pipeline. Mirrors `MakeRender.makeBackwardPipelineDoc`:
the `<|` trails the seed (or previous step body), and the next body drops to the
line below at +4 (inline when the author kept the whole chain on one row). A
lambda step body (`\x -> ‚Ä¶` authored across rows) breaks with the head at +4 and
its body at +8. A boundary comment, a mixed `|>`/`<|` chain, a multi-line
non-lambda body, or an inline (`SoftIndentedBlock`) lambda all fall back. -}
makeBackwardPipelineBox : Bool -> Array LPNode -> Result String Box
makeBackwardPipelineBox forceVertical children =
    let
        stepNodes =
            Array.keepIf isPipelineStepNode children

        seedNodes =
            Array.keepIf (\n -> not (isPipelineStepNode n)) children

        stepFirstIsComment stepNode =
            when Array.first (lpnChildren stepNode) is
                Just firstChild ->
                    nodeIsComment firstChild

                Nothing ->
                    False

        stepLastIsComment stepNode =
            when Array.last (lpnChildren stepNode) is
                Just lastChild ->
                    nodeIsComment lastChild

                Nothing ->
                    False

        hasBoundaryComment =
            Array.any
                (\n ->
                    if isPipelineStepNode n then
                        stepFirstIsComment n || stepLastIsComment n

                    else
                        nodeIsComment n
                )
                children

        -- The operator is the first NON-comment child (a step may lead with an
        -- own-line comment before `<|`).
        stepOpIsBackward stepNode =
            when Array.first (Array.keepIf (\n -> not (nodeIsComment n)) (lpnChildren stepNode)) is
                Just opNode ->
                    leafValue opNode == Just "<|"

                Nothing ->
                    False

        allBackward =
            Array.all stepOpIsBackward stepNodes
    in
    if not allBackward then
        Err "box: backward pipeline with mixed ops not ported"

    else if hasBoundaryComment then
        -- A comment at a step boundary (own-line leading comment before `<|`, or a
        -- trailing comment after a step body) switches to operator-LEADING layout,
        -- mirroring the Doc's `buildFlowDoc 0 children` fallback: seed on its own
        -- line, then each step at +4 as `<| body` with leading comments own-line
        -- above it and trailing comments glued to the body's last line.
        makeBackwardCommentedPipeline seedNodes stepNodes

    else
        buildFlowBox 0 seedNodes
            |> Result.andThen
                (\seedBox ->
                    boxLine seedBox
                        |> Result.andThen
                            (\seedLine ->
                                traverseResult
                                    (\stepNode ->
                                        when Array.popFirst (lpnChildren stepNode) is
                                            Just { rest = bodyNodes } ->
                                                Ok bodyNodes

                                            Nothing ->
                                                Err "box: backward pipeline step has no children"
                                    )
                                    stepNodes
                                    |> Result.andThen (assembleBackwardPipeline forceVertical seedLine)
                            )
                )


-- Split a run of leading comment nodes off the front of a step's children.
spanLeadingComments : Array LPNode -> { leading : Array LPNode, rest : Array LPNode }
spanLeadingComments nodes =
    let
        go remaining acc =
            when Array.popFirst remaining is
                Just { first, rest } ->
                    if nodeIsComment first then
                        go rest (Array.pushLast first acc)

                    else
                        { leading = acc, rest = remaining }

                Nothing ->
                    { leading = acc, rest = [] }
    in
    go nodes []


-- Split a run of trailing comment nodes off the end of a step's children.
spanTrailingComments : Array LPNode -> { body : Array LPNode, trailing : Array LPNode }
spanTrailingComments nodes =
    let
        go remaining acc =
            when Array.popLast remaining is
                Just { last, initial } ->
                    if nodeIsComment last then
                        go initial ([ last ] ++ acc)

                    else
                        { body = remaining, trailing = acc }

                Nothing ->
                    { body = [], trailing = acc }
    in
    go nodes []


-- Glue single-line trailing comments onto a box's last line, each with a space.
glueTrailingComments : Box -> Array LPNode -> Result String Box
glueTrailingComments box trailing =
    Array.foldl
        (\c accResult ->
            accResult
                |> Result.andThen
                    (\b ->
                        commentNodeBox c
                            |> Result.andThen
                                (\cbox ->
                                    when B.isLine cbox is
                                        Ok l ->
                                            Ok (B.addSuffix (B.row [ B.space, l ]) b)

                                        Err _ ->
                                            Err "box: multi-line trailing comment in backward pipeline not ported"
                                )
                    )
        )
        (Ok box)
        trailing


{-| Render a comment-bearing backward (`<|`) pipeline in operator-LEADING layout,
mirroring the Doc's `buildFlowDoc 0 children` fallback: the seed on its own line,
then each step at +grenIndent. A step renders as its leading comments (own line)
stacked above `<| body`, with trailing comments glued onto the body's last line. -}
makeBackwardCommentedPipeline : Array LPNode -> Array LPNode -> Result String Box
makeBackwardCommentedPipeline seedNodes stepNodes =
    buildFlowBox 0 seedNodes
        |> Result.andThen
            (\seedBox ->
                traverseResult renderCommentedBackwardStep stepNodes
                    |> Result.map
                        (\stepBoxLists ->
                            B.stack1 ([ seedBox ] ++ Array.map (applyIndent grenIndent) (Array.flatten stepBoxLists))
                        )
            )


renderCommentedBackwardStep : LPNode -> Result String (Array Box)
renderCommentedBackwardStep stepNode =
    let
        { leading, rest } =
            spanLeadingComments (lpnChildren stepNode)

        { body, trailing } =
            spanTrailingComments rest
    in
    traverseResult commentNodeBox leading
        |> Result.andThen
            (\leadingBoxes ->
                buildFlowBox 0 body
                    |> Result.andThen
                        (\bodyBox ->
                            glueTrailingComments bodyBox trailing
                                |> Result.map (\bodyWithTrailing -> leadingBoxes ++ [ bodyWithTrailing ])
                        )
            )


assembleBackwardPipeline : Bool -> B.Line -> Array (Array LPNode) -> Result String Box
assembleBackwardPipeline forceVertical seedLine stepBodies =
    when stepBodies is
        [ bodyNodes ] ->
            backwardSingleStep forceVertical seedLine bodyNodes

        _ ->
            backwardMultiStep forceVertical seedLine stepBodies


-- A single `seed <| body` step. A trailing `IndentedBlock` marks a lambda body
-- authored across rows (`\head` at +4, its body at +8); otherwise a plain body
-- drops to +4 (or stays inline when the chain isn't forced vertical).
backwardSingleStep : Bool -> B.Line -> Array LPNode -> Result String Box
backwardSingleStep forceVertical seedLine bodyNodes =
    when Array.popLast bodyNodes is
        Nothing ->
            Err "box: backward pipeline empty body"

        Just { last = lastNode, initial = headNodes } ->
            when lpnBox lastNode is
                IndentedBlock ->
                    -- Lambda authored across rows: seed <| \n head+4 \n body+8.
                    Result.map2
                        (\headBox bodyBox ->
                            B.stack1
                                [ B.line (B.row [ seedLine, B.literal " <|" ])
                                , B.indent headBox
                                , applyIndent (2 * grenIndent) bodyBox
                                ]
                        )
                        (buildFlowBox 0 headNodes)
                        (buildFlowBox 0 (lpnChildren lastNode))

                SoftIndentedBlock ->
                    Err "box: inline-lambda backward pipeline body not ported"

                _ ->
                    buildBackwardBodyBox bodyNodes
                        |> Result.andThen
                            (\bodyBox ->
                                if forceVertical then
                                    Ok
                                        (B.stack1
                                            [ B.line (B.row [ seedLine, B.literal " <|" ])
                                            , B.indent bodyBox
                                            ]
                                        )

                                else
                                    boxLine bodyBox
                                        |> Result.map
                                            (\bl -> B.line (B.row [ seedLine, B.literal " <| ", bl ]))
                            )


{-| Render a `<|` step body. Mirrors `MakeRender.buildBodyDoc`: a body that is a
call with a child that renders multi-line (e.g. a record argument) is a broken
call whose arguments land at +4 under the function name ‚Äî not a plain flow (which
would drop them at +0). Comment-leading bodies aren't ported (they fall back). -}
buildBackwardBodyBox : Array LPNode -> Result String Box
buildBackwardBodyBox bodyNodes =
    renderFlowItems bodyNodes
        |> Result.andThen
            (\items ->
                if Array.any .isBlock items then
                    assembleBrokenCall grenIndent items

                else
                    assembleFlow False 0 items
            )


-- Two or more `<|` steps. Inline `seed <| b0 <| b1 ‚Ä¶` when the author kept it on
-- one row; otherwise `seed <|` then each body at +4, the `<|` trailing the
-- previous body. Only single-line bodies are ported.
backwardMultiStep : Bool -> B.Line -> Array (Array LPNode) -> Result String Box
backwardMultiStep forceVertical seedLine stepBodies =
    traverseResult (\body -> buildFlowBox 0 body |> Result.andThen boxLine) stepBodies
        |> Result.map
            (\bodyLines ->
                if not forceVertical then
                    B.line
                        (B.row
                            (Array.flatten
                                ([ [ seedLine ] ]
                                    ++ Array.map (\bl -> [ B.literal " <| ", bl ]) bodyLines
                                )
                            )
                        )

                else
                    let
                        n =
                            Array.length bodyLines
                    in
                    B.stack1
                        ([ B.line (B.row [ seedLine, B.literal " <|" ]) ]
                            ++ Array.indexedMap
                                (\i bl ->
                                    B.indent
                                        (B.line
                                            (B.row
                                                (if i < n - 1 then
                                                    [ bl, B.literal " <|" ]

                                                 else
                                                    [ bl ]
                                                )
                                            )
                                        )
                                )
                                bodyLines
                        )
            )


-- ‚ïê‚ïê‚ïê IF ‚ïê‚ïê‚ïê


{-| Render an `if`/`else if` condition header: `if <cond> then` inline, or when
the author broke it, `if` / cond +4 / `then`. The branch bodies and `else`
keyword are siblings in the enclosing flow (an `if` is not a single node ‚Äî see
the flat `IfCondition`/`IndentedBlock`/`EmptyLine`/`else` sequence), assembled
by `assembleFlow`. Mirrors `MakeRender.makeIfConditionDoc`. -}
makeIfConditionBox : Bool -> Array LPNode -> Result String Box
makeIfConditionBox forceVertical children =
    when Array.popFirst children is
        Nothing ->
            Err "box: if-condition empty"

        Just { first = ifNode, rest = afterIf } ->
            when Array.popLast afterIf is
                Nothing ->
                    Err "box: if-condition missing then"

                Just { initial = condNodes, last = thenNode } ->
                    makePBox (lpnBox ifNode) (lpnChildren ifNode)
                        |> Result.andThen
                            (\ifBox ->
                                buildFlowBox 0 condNodes
                                    |> Result.andThen
                                        (\condBox ->
                                            makePBox (lpnBox thenNode) (lpnChildren thenNode)
                                                |> Result.andThen
                                                    (\thenBox ->
                                                        if forceVertical then
                                                            Ok (B.stack1 [ ifBox, B.indent condBox, thenBox ])

                                                        else
                                                            when joinInline [ ifBox, condBox, thenBox ] is
                                                                Just l ->
                                                                    Ok l

                                                                Nothing ->
                                                                    Err "box: multi-line if-condition not ported"
                                                    )
                                        )
                            )


-- ‚ïê‚ïê‚ïê RECORD UPDATE ‚ïê‚ïê‚ïê


{-| True when a record-update field's value is a *soft* node (not a hard block ‚Äî
`if`/`when`/`let`/lambda) that renders multi-line. The Doc keeps such a value's
first line glued to `= ` (soft `R.group` separator) and lets the value break
internally; Box's flat stacker drops the whole value to its own line, so these
fields diverge and the update must fall back. A hard-block value drops after `=`
in both renderers and is fine. A comment child (no meaningful value) returns
False. -}
recordFieldValueDrops : LPNode -> Bool
recordFieldValueDrops field =
    when Array.last (lpnChildren field) is
        Nothing ->
            False

        Just valueNode ->
            let
                isHardBlock =
                    when lpnBox valueNode is
                        BodyBlock ->
                            True

                        IndentedBlock ->
                            True

                        SoftIndentedBlock ->
                            True

                        WhenBranch ->
                            True

                        PipelineStep ->
                            True

                        EmptyLine ->
                            True

                        _ ->
                            False
            in
            if isHardBlock then
                False

            else
                when makePBox (lpnBox valueNode) (lpnChildren valueNode) is
                    Ok b ->
                        not (isSingleLine b)

                    Err _ ->
                        False


{-| Render a record update `{ base | f = v, ‚Ä¶ }` via elm's `extensionGroup`.
Each field node renders to a `name = value` box; the update expands (base on its
own line, `| `/`, `-prefixed fields at +4, closing `}`) when the author broke it
across rows or any field renders multi-line ‚Äî matching elm-format and the
Change-2 Doc renderer for `if`/`let`/`when`/simple/multi-field cases. (A
lambda-valued field deliberately differs from the Doc renderer ‚Äî Box drops the
`\arg ->` head like elm ‚Äî so those updates fall back via the self-verify guard.) -}
makeRecordUpdateBox : String -> Bool -> Array LPNode -> Result String Box
makeRecordUpdateBox baseName forceVertical children =
    if Array.any recordFieldValueDrops children then
        -- A field whose value is a *soft* multi-line node (a broken call or
        -- binop chain ‚Äî `| f = Array.map (\x -> ‚Ä¶) xs`) is kept glued to `= `
        -- by the Doc (its flow separator is a soft `R.group`, always flat ‚Üí a
        -- space) and broken only by the value's own internal layout. Box's flat
        -- stacker instead drops the whole value onto its own line, diverging, so
        -- the update falls back. (A *block* value ‚Äî `if`/`when`/`let`/lambda ‚Äî
        -- drops after `=` in BOTH renderers, so it is NOT gated here.) This gate
        -- is shared by the comment and non-comment paths: a comment-bearing
        -- update nested inside such a field must not let the outer update render
        -- via Box either.
        Err "box: record-update field with a soft multi-line value not ported"

    else if Array.any nodeIsComment children then
        -- A comment can't live in the inline (flat group) form, so a comment-
        -- bearing update is always vertical. Mirrors `makeRecordUpdateDoc`'s
        -- `hasComment ‚Üí vertical` branch: comment children render own-line at
        -- +4 (no `| `/`, ` prefix), the actual fields keep their prefixes.
        makeRecordUpdateVerticalBox baseName children

    else
        traverseResult (\node -> makePBox (lpnBox node) (lpnChildren node)) children
            |> Result.andThen
            (\fieldBoxes ->
                when Array.popFirst fieldBoxes is
                    Nothing ->
                        Ok (B.line (B.literal ("{ " ++ baseName ++ " }")))

                    Just { first = firstField, rest = restFields } ->
                        let
                            contentVertical =
                                Array.any (\b -> not (isSingleLine b)) fieldBoxes
                        in
                        Ok
                            (E.extensionGroup
                                (forceVertical || contentVertical)
                                (B.line (B.literal baseName))
                                firstField
                                restFields
                            )
            )


{-| Render a comment-bearing record update as the always-vertical form, mirroring
`makeRecordUpdateDoc`'s `hasComment` branch: base on its own line (`{ base`),
then each field prefixed `| ` (first) / `, ` (rest) and each comment child on its
own line ‚Äî all indented +4 ‚Äî and the closing `}` on its own line at the `{`
column. Comment children never carry a field prefix; the first *field* (not the
first child) gets the `| `. Box `stack1` + `B.indent` + `B.prefix` supply the
alignment the Doc gets from `R.align` around the `R.vcat`. A multi-line block
comment falls back via `commentNodeBox`'s verbatim guard. -}
-- True when a record-update field's value is forced onto its own line(s) by a
-- comment among the field's children (e.g. `gamma = {- c -} 3`). Both the Doc and
-- `buildFlowBox` drop such a value below `= `, so it composes with the field's
-- `| `/`, ` prefix ‚Äî unlike a soft broken-call/binop value the Doc keeps glued.
fieldValueDropsToOwnLine : LPNode -> Bool
fieldValueDropsToOwnLine node =
    Array.any nodeIsComment (lpnChildren node)


makeRecordUpdateVerticalBox : String -> Array LPNode -> Result String Box
makeRecordUpdateVerticalBox baseName children =
    let
        step node accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        if nodeIsComment node then
                            commentNodeBox node
                                |> Result.map
                                    (\cbox ->
                                        { acc | lines = Array.pushLast cbox acc.lines }
                                    )

                        else
                            -- Render the field's CHILDREN as a flow (`name =
                            -- value`), NOT `makePBox` on the field node ‚Äî a field
                            -- whose value is a broken call is an `AcrossOrVertical`
                            -- that `makePBox` would mis-render as a function
                            -- application (breaking `= value`). Mirrors
                            -- `makeRecordUpdateDoc`'s `fieldLine`: a lambda field
                            -- (IndentedBlock container) flows at +0 so its body
                            -- block supplies the only +4; every other field +4.
                            let
                                fieldFlowIndent =
                                    when lpnBox node is
                                        IndentedBlock ->
                                            0

                                        _ ->
                                            grenIndent
                            in
                            buildFlowBox fieldFlowIndent (lpnChildren node)
                                |> Result.andThen
                                    (\fieldBox ->
                                        let
                                            pref =
                                                if acc.seenField then
                                                    B.row [ B.punc ",", B.space ]

                                                else
                                                    B.row [ B.punc "|", B.space ]
                                        in
                                        -- A multi-line field value that DROPS to its
                                        -- own line (a leading own-line comment, or a
                                        -- block value) is rendered by `buildFlowBox`
                                        -- exactly as the Doc does, so it composes with
                                        -- the `| `/`, ` prefix. A multi-line value the
                                        -- Doc keeps GLUED to `= ` (a soft broken
                                        -- call/binop ‚Äî its flow separator is a flat
                                        -- `R.group` ‚Üí a space) still diverges (Box's
                                        -- flat stacker drops it), so those fall back.
                                        if isSingleLine fieldBox || fieldValueDropsToOwnLine node then
                                            Ok
                                                { lines = Array.pushLast (B.prefix pref fieldBox) acc.lines
                                                , seenField = True
                                                }

                                        else
                                            Err "box: multi-line field value in comment-bearing record update not ported"
                                    )
                    )
    in
    Array.foldl step (Ok { lines = [], seenField = False }) children
        |> Result.map
            (\acc ->
                B.stack1
                    [ B.prefix (B.row [ B.punc "{", B.space ]) (B.line (B.literal baseName))
                    , B.indent (B.stack1 acc.lines)
                    , B.line (B.punc "}")
                    ]
            )


-- ‚ïê‚ïê‚ïê WHEN ‚ïê‚ïê‚ïê


{-| Render a `when ‚Ä¶ is` expression. Header `when <subject> is` stays inline
unless the author broke it across rows (then `when` / subject +4 / `is`); each
branch sits at +4 (`branchNest`), blank-line separated. Mirrors
`MakeRender.makeWhenFlowDoc` + `renderWhenBranchNode`. -}
makeWhenFlowBox : Bool -> Array LPNode -> Result String Box
makeWhenFlowBox forceVertical children =
    when Array.popLast children is
        Nothing ->
            Err "box: when has no children"

        Just { last = branchesBlock, initial = withoutBranches } ->
            when Array.popLast withoutBranches is
                Nothing ->
                    Err "box: when missing is"

                Just { initial = headerNodes } ->
                    when Array.popFirst headerNodes is
                        Nothing ->
                            Err "box: when missing when"

                        Just { rest = scrutineeNodes } ->
                            let
                                headerResult =
                                    if forceVertical then
                                        buildFlowBox 0 scrutineeNodes
                                            |> Result.map
                                                (\scrut ->
                                                    B.stack1
                                                        [ B.line (B.keyword "when")
                                                        , B.indent scrut
                                                        , B.line (B.keyword "is")
                                                        ]
                                                )

                                    else
                                        buildFlowBox 0 withoutBranches

                                branchesResult =
                                    renderWhenBranchesBox (lpnChildren branchesBlock)
                            in
                            Result.map2
                                (\hdr brs -> B.stack1 [ hdr, B.indent brs ])
                                headerResult
                                branchesResult


{-| One `when` branch: `<pattern> ->` then the body indented +4. -}
makeWhenBranchBox : Array LPNode -> Result String Box
makeWhenBranchBox children =
    when Array.popFirst children is
        Just { first = patNode, rest = afterPat } ->
            when afterPat is
                [ bodyNode ] ->
                    Result.map2
                        (\patBox bodyBox -> B.stack1 [ patBox, B.indent bodyBox ])
                        (makePBox (lpnBox patNode) (lpnChildren patNode))
                        (makePBox (lpnBox bodyNode) (lpnChildren bodyNode))

                _ ->
                    Err "box: when-branch shape not ported (pattern + body only)"

        Nothing ->
            Err "box: empty when-branch"


{-| A `when` branch pattern, rendered as `<pattern> ->`. A multi-line pattern (a
record/array pattern the author spread across rows) gets ` ->` appended to its
last line ‚Äî mirroring the Doc's `R.concat (buildFlowDoc grenIndent children)
(R.text " ->")`; `B.addSuffix` appends to the last line for single- and
multi-line boxes alike. -}
makeWhenBranchPatternBox : Array LPNode -> Result String Box
makeWhenBranchPatternBox children =
    buildFlowBox grenIndent children
        |> Result.map (\box -> B.addSuffix (B.literal " ->") box)


-- Stack boxes with a blank line between each (consecutive `when` branches).
stackWithBlanks : Array Box -> Box
stackWithBlanks boxes =
    when Array.popFirst boxes is
        Nothing ->
            B.blankLine

        Just { first = b0, rest } ->
            B.stack1
                (Array.foldl (\b acc -> acc ++ [ B.blankLine, b ]) [ b0 ] rest)


{-| Render a `when`'s branch block ‚Äî the `WhenBranch` children stacked with a
blank line between each. A comment sibling that trails the previous branch's last
line (same source row) is appended onto it via `B.addSuffix`. A comment on its
own row LEADS the following branch: it is held in `pending` and stacked directly
above that branch (no blank line between comment and its pattern), matching the
Doc's `AlreadyTerminated` join. Single-line and multi-line block comments alike
are supported (the latter via `commentNodeBox`'s reindent stack). A same-row
multi-line comment (can't glue onto a last line), or a comment after the last
branch (no branch to lead), still fall back. -}
renderWhenBranchesBox : Array LPNode -> Result String Box
renderWhenBranchesBox children =
    let
        handleComment acc row node commentText isMulti =
            if row == acc.lastRow && acc.lastRow >= 0 then
                -- Trailing the previous branch on its last line.
                if isMulti then
                    Err "box: multi-line trailing comment between when-branches not ported"

                else
                    when Array.popLast acc.boxes is
                        Just { last = lastBox, initial } ->
                            Ok
                                { acc
                                    | boxes = Array.pushLast (B.addSuffix (B.row [ B.space, B.literal commentText ]) lastBox) initial
                                }

                        Nothing ->
                            Err "box: comment before first when-branch not ported"

            else
                -- Own line: this comment leads the next branch.
                commentNodeBox node
                    |> Result.map (\cbox -> { acc | pending = Array.pushLast cbox acc.pending })
    in
    Array.foldl
        (\child accResult ->
            accResult
                |> Result.andThen
                    (\acc ->
                        when lpnBox child is
                            WhenBranch ->
                                makeWhenBranchBox (lpnChildren child)
                                    |> Result.map
                                        (\bx ->
                                            let
                                                combined =
                                                    if Array.isEmpty acc.pending then
                                                        bx

                                                    else
                                                        B.stack1 (Array.pushLast bx acc.pending)
                                            in
                                            { boxes = Array.pushLast combined acc.boxes, lastRow = lpnMaxRow child, pending = [] }
                                        )

                            SingleLineComment loc ->
                                handleComment acc loc.start.row child ("--" ++ loc.value) False

                            BlockComment loc ->
                                handleComment acc loc.start.row child ("{-" ++ loc.value ++ "-}") (String.contains "\n" loc.value)

                            _ ->
                                Err "box: unexpected node among when-branches"
                    )
        )
        (Ok { boxes = [], lastRow = -1, pending = [] })
        children
        |> Result.andThen
            (\acc ->
                if not (Array.isEmpty acc.pending) then
                    Err "box: comment after last when-branch not ported"

                else
                    when Array.popFirst acc.boxes is
                        Nothing ->
                            Err "box: when has no branches"

                        Just _ ->
                            Ok (stackWithBlanks acc.boxes)
            )


-- ‚ïê‚ïê‚ïê SIGNATURES ‚ïê‚ïê‚ïê


{-| The literal text of a leaf node (`UnbreakableText` / `SynthesizedText`), or
Nothing for any structured node. Tranche-2 signatures handle only flat leaf
signatures; a nested type (record/paren/‚Ä¶) yields Nothing and falls back. -}
leafValue : LPNode -> Maybe String
leafValue node =
    when lpnBox node is
        UnbreakableText locs ->
            Just locs.value

        SynthesizedText s ->
            Just s

        _ ->
            Nothing


isArrowLeaf : LPNode -> Bool
isArrowLeaf node =
    leafValue node == Just "->"


isColonLeaf : LPNode -> Bool
isColonLeaf node =
    leafValue node == Just ":"


{-| Split a signature's type nodes at each top-level `->`: the first segment is
the leading type; each later one begins with its `->`. Mirrors
`MakeRender.splitSignatureSegments`. -}
splitSignatureSegments : Array LPNode -> Array (Array LPNode)
splitSignatureSegments nodes =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                Array.pushLast [ node ] acc

            else
                when Array.popLast acc is
                    Just { last = seg, initial = front } ->
                        Array.pushLast (Array.pushLast node seg) front

                    Nothing ->
                        [ [ node ] ]
        )
        []
        nodes


-- A segment's first / last content row, ignoring the leading arrow.
--
-- A segment beginning with a bracketed type (`{ ‚Ä¶ }`, `( ‚Ä¶ )`) starts where its
-- *opening bracket* sits, not at its first inner token ‚Äî the bracket has no leaf,
-- so `firstRowInSubtree` alone would report the first field's row, and a break
-- just inside the bracket would masquerade as a break between `->` segments,
-- flipping the whole signature to multi-line. Mirrors `segContentFirstRow`.
segFirstRow : Array LPNode -> Int
segFirstRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc

            else
                let
                    leafR =
                        firstRowInSubtree node

                    r =
                        when lpnBracketStart node is
                            Just open ->
                                if leafR < 0 then
                                    open.row

                                else
                                    min open.row leafR

                            Nothing ->
                                leafR
                in
                if acc < 0 then
                    r

                else if r < 0 then
                    acc

                else
                    min acc r
        )
        -1
        seg


segLastRow : Array LPNode -> Int
segLastRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc

            else
                max acc (lpnMaxRow node)
        )
        -1
        seg


{-| True when a signature segment contains a multi-line type record in a
non-head position ‚Äî the type-record drop will fire inside it, so the whole
signature must commit to the broken layout. The Box analogue of
`MakeRender.segmentHasDroppingRecord`: verticality comes from this renderer's
own box (`isSingleLine`; an unrenderable node counts as not-forcing, like the
Doc's `Err -> False`). -}
segmentHasDroppingRecordBox : Array LPNode -> Bool
segmentHasDroppingRecordBox segment =
    segment
        |> Array.indexedMap (\i n -> { i = i, n = n })
        |> Array.any
            (\{ i, n } ->
                i > 0
                    && FP.isTypeRecordLiteral n
                    && (when makePBox (lpnBox n) (lpnChildren n) is
                            Ok b ->
                                not (isSingleLine b)

                            Err _ ->
                                False
                       )
            )


{-| True when the author broke the type across rows at a `->` boundary (a later
segment starts on a row after the previous segment ended). Mirrors
`MakeRender.segmentsBrokenAtBoundary`. -}
signatureForceVertical : Array (Array LPNode) -> Bool
signatureForceVertical segments =
    (Array.foldl
        (\seg acc ->
            let
                first =
                    segFirstRow seg

                last =
                    segLastRow seg
            in
            { broken =
                acc.broken
                    || (acc.prevLast >= 0 && first >= 0 && first > acc.prevLast)
            , prevLast =
                if last >= 0 then
                    last

                else
                    acc.prevLast
            }
        )
        { broken = False, prevLast = -1 }
        segments
    ).broken


{-| Render a function/port signature, mirroring `MakeRender.makeSignaturePrettyDoc`.
Inline (header + type on one line) when the author kept it on one line; header on
line 1 with one `->` segment per line at +4 when the author broke it at an arrow
boundary. The header and each segment render via `buildFlowBox 0`, so nested types
(records, parens, function types) are handled ‚Äî anything `buildFlowBox` can't yet
render (or a deeper nested-record whose Tab arithmetic diverges from Doc) Errs and
falls back.

Comments: an inline signature that carries a comment renders via the Doc's
`makeFlowIndentableDoc` (`buildFlowBox grenIndent`), NOT the group flatten ‚Äî Box
mirrors that. A signature the author broke at a `->` renders per-segment either
way, and `buildFlowBox` places the segment's inline comments (tranche 20-26). -}
makeSignatureBox : Array LPNode -> Result String Box
makeSignatureBox children =
    let
        colonSplit =
            Array.foldl
                (\node acc ->
                    if acc.afterColon then
                        { acc | typeNodes = Array.pushLast node acc.typeNodes }

                    else if isColonLeaf node then
                        { acc | header = Array.pushLast node acc.header, afterColon = True }

                    else
                        { acc | header = Array.pushLast node acc.header }
                )
                { header = [], typeNodes = [], afterColon = False }
                children
    in
    if not colonSplit.afterColon then
        Err "box: signature has no colon"

    else
        let
            segments =
                splitSignatureSegments colonSplit.typeNodes

            -- Mirrors the Doc's `makeSignaturePrettyDoc`: a multi-segment type
            -- whose segment carries a dropping record commits to the
            -- fully-broken layout up front (`segmentHasDroppingRecordBox`), so
            -- the drop's extra rows can't flip the boundary-break decision on
            -- reparse (the item-3 fixed-point rule).
            forceVertical =
                signatureForceVertical segments
                    || (Array.length segments
                            > 1
                            && Array.any segmentHasDroppingRecordBox segments
                       )

            hasComment =
                Array.any subtreeHasComment children
        in
        if not forceVertical && hasComment && Array.any typeHasCommentBracket colonSplit.typeNodes then
            -- A comment INSIDE a record/bracket type (`foo : { a : Int {- c -} }`)
            -- renders that type multi-line. The Doc keeps it glued inline after
            -- `:` (its `}` aligns under the `{`). When the whole type is exactly
            -- that one record/bracket node, `B.prefix` glues it after the header
            -- and pads its continuation by the header's width ‚Äî reproducing the
            -- `R.align` the record carries, so `}` lands under `{`. A multi-node
            -- type (`{ ‚Ä¶ } -> ‚Ä¶`) would need `assembleFlow` to soft-glue a
            -- multi-line item, which it can't yet, so that still falls back.
            when colonSplit.typeNodes is
                [ single ] ->
                    buildFlowBox 0 colonSplit.header
                        |> Result.andThen
                            (\headerBox ->
                                when B.isLine headerBox is
                                    Ok headerLine ->
                                        buildFlowBox 0 colonSplit.typeNodes
                                            |> Result.map
                                                (\typeBox ->
                                                    -- A multi-line type RECORD drops below the
                                                    -- header at +4 (the Doc's type-record-drop,
                                                    -- `joinBracketLiteralFlowItem`) ‚Äî elm-format
                                                    -- drops every multi-line record type below
                                                    -- its head/`:`. Other bracket types (parens,
                                                    -- extensible records) keep the inline glue.
                                                    if FP.isTypeRecordLiteral single && not (isSingleLine typeBox) then
                                                        B.stack1 [ B.line headerLine, B.indent typeBox ]

                                                    else
                                                        B.prefix (B.row [ headerLine, B.space ]) typeBox
                                                )

                                    Err _ ->
                                        Err "box: multi-line header in comment-bearing signature not ported"
                            )

                _ ->
                    Err "box: comment inside a multi-node signature type not ported"

        else if not forceVertical && hasComment then
            -- Inline signature carrying a comment: the Doc routes to
            -- `makeFlowIndentableDoc` (`buildFlowDoc grenIndent`), NOT the group
            -- flatten, because a comment's break points have no stable inline
            -- anchor. Mirror that with `buildFlowBox grenIndent`; a `--`/own-line
            -- comment that forces a continuation is now indented +4 by
            -- `assembleFlow`.
            buildFlowBox grenIndent children

        else if not forceVertical then
            -- Inline, no comment: the whole signature on one line (the Doc's
            -- `R.group` of header + space-joined segments == one flow over all
            -- children). The Doc's `R.group` FLATTENS a segment the author broke
            -- inside a record type or parens (a break not at a `->` boundary)
            -- back onto the line; Box has no flatten, so if the flow comes back
            -- multi-line we fall back to Doc rather than emit the (wrong) broken
            -- form.
            buildFlowBox 0 children
                |> Result.andThen
                    (\box ->
                        when B.isLine box is
                            Ok _ ->
                                Ok box

                            Err _ ->
                                Err "box: inline signature broke inside a segment (Doc flattens, Box can't)"
                    )

        else
            -- Author broke at a `->`: header on line 1, one segment per line at
            -- +4. `buildFlowBox 0` renders each segment, placing any inline
            -- comment it carries.
            buildFlowBox 0 colonSplit.header
                |> Result.andThen
                    (\headerBox ->
                        traverseResult (buildFlowBox 0) segments
                            |> Result.map
                                (\segBoxes ->
                                    B.stack1 ([ headerBox ] ++ Array.map B.indent segBoxes)
                                )
                    )


-- The `Line` (not boxed) of the given leaf nodes joined by single spaces. Only
-- valid for all-leaf node arrays (caller must have checked `headerAllLeaves`);
-- a non-leaf renders as "".
leafLineRow : Array LPNode -> B.Line
leafLineRow nodes =
    B.row
        (Array.intersperse B.space
            (Array.map (\n -> B.literal (Maybe.withDefault "" (leafValue n))) nodes)
        )


-- ‚ïê‚ïê‚ïê MODULE & IMPORT LINES ‚ïê‚ïê‚ïê


{-| Render a `module ‚Ä¶` / `import ‚Ä¶` line, mirroring
`MakeRender.makeExposingLineDoc`. When it ends in an `exposing ( ‚Ä¶ )` list and
the header before the list is all plain leaf tokens, render the list as a
coupled all-or-nothing group; otherwise (a `(..)` wildcard, an effect-module
`where` block, a comment in the header) fall back to the generic flow.

For a `module` line, `exposing` always stays glued to the header even when the
list goes vertical (list indented +4). For an `import` line whose list goes
vertical, `exposing` drops to its own line (+4) with the list indented +8. -}
makeExposingLineBox : SyntaxType -> Array LPNode -> Result String Box
makeExposingLineBox stype children =
    when Array.popLast children is
        Just { last = lastNode, initial = headerNodes } ->
            let
                -- The exposing list's author-layout decision is carried by its
                -- box type: `AllAcrossOrAllVertical ListParen` = written inline,
                -- `AlwaysVertical ListParen` = across rows. Anything else means
                -- the last node isn't a paren list (`(..)` wildcard, etc.).
                exposingForceVertical =
                    when lpnBox lastNode is
                        AllAcrossOrAllVertical ListParen ->
                            Just False

                        AlwaysVertical ListParen ->
                            Just True

                        _ ->
                            Nothing

                headerAllLeaves =
                    Array.all (\n -> leafValue n /= Nothing) headerNodes
            in
            when exposingForceVertical is
                Just forceVertical ->
                    if headerAllLeaves && not (Array.isEmpty headerNodes) then
                        let
                            listChildren =
                                lpnChildren lastNode
                        in
                        let
                            hasComment =
                                Array.any nodeIsComment listChildren

                            -- A comment among the exposed names forces the list
                            -- vertical, exactly like the Doc's comment-aware
                            -- `makeExposingListDoc` (`Array.any nodeIsComment ||
                            -- forceVertical` ‚Üí `listBoxesWithBrackets "( " ")"`).
                            effectiveFV =
                                forceVertical || hasComment

                            -- A module line always keeps `exposing` glued; an
                            -- import line drops it only when the list is vertical.
                            keepExposingGlued =
                                stype == StModule || not effectiveFV

                            -- The `( ‚Ä¶ )` comment form is structurally the same
                            -- always-vertical list as a curly/square literal, so
                            -- reuse `commentBracketListBox` with `ListParen` (its
                            -- `( `/`, `/`)` prefixes match `listBoxesWithBrackets`).
                            listBoxResult =
                                if hasComment then
                                    commentBracketListBox ListParen listChildren

                                else
                                    makeExposingListBox forceVertical listChildren
                        in
                        listBoxResult
                            |> Result.andThen
                                (\listBox ->
                                    if keepExposingGlued then
                                        gluedExposingBox effectiveFV headerNodes listBox

                                    else
                                        droppedExposingBox headerNodes listBox
                                )

                    else
                        exposingLineFallback children

                Nothing ->
                    exposingLineFallback children

        Nothing ->
            exposingLineFallback children


-- The fallback path for a module/import line that isn't a plain leaf-header +
-- paren-list (a `(..)` wildcard, an effect-module `where` block, or a
-- comment-bearing header). Mirrors the Doc's `makeFlowIndentableDoc`
-- (`buildFlowDoc grenIndent`): a header the author broke across rows (a `--` line
-- comment before the list, a multi-line `{- -}`, or an effect-module `where`
-- block that wraps) indents its continuation +4, which `assembleFlow` now does
-- for an inline item on a fresh line after a comment/break.
exposingLineFallback : Array LPNode -> Result String Box
exposingLineFallback children =
    buildFlowBox grenIndent children


-- `exposing` stays glued to the header. Inline list: `header (a, b, c)` on one
-- line. Vertical list: header on line 1, list indented +4 beneath it.
gluedExposingBox : Bool -> Array LPNode -> Box -> Result String Box
gluedExposingBox forceVertical headerNodes listBox =
    if forceVertical then
        Ok (B.stack1 [ B.line (leafLineRow headerNodes), B.indent listBox ])

    else
        when B.isLine listBox is
            Ok listLine ->
                Ok (B.line (B.row [ leafLineRow headerNodes, B.space, listLine ]))

            Err _ ->
                Err "box: inline exposing list rendered multi-line"


-- `exposing` drops to its own line (import + vertical list): header on line 1,
-- `exposing` at +4, list at +8.
droppedExposingBox : Array LPNode -> Box -> Result String Box
droppedExposingBox headerNodes listBox =
    when Array.popLast headerNodes is
        Just { last = exposingNode, initial = preExposingNodes } ->
            Ok
                (B.stack1
                    [ B.line (leafLineRow preExposingNodes)
                    , B.indent
                        (B.stack1
                            [ B.line (leafLineRow [ exposingNode ])
                            , B.indent listBox
                            ]
                        )
                    ]
                )

        Nothing ->
            Err "box: exposing line missing exposing keyword"


{-| Render an exposing list's `( ‚Ä¶ )` body (no leading glue). Items are the
already-sorted exposed names (leaves). Inline: `(a, b, c)`. Vertical:

    ( a
    , b
    )

Mirrors `MakeRender.makeExposingListDoc` (the comment-free path). -}
makeExposingListBox : Bool -> Array LPNode -> Result String Box
makeExposingListBox forceVertical children =
    traverseResult (\n -> makePBox (lpnBox n) (lpnChildren n)) children
        |> Result.andThen
            (\itemBoxes ->
                when B.allSingles itemBoxes is
                    Err _ ->
                        Err "box: multi-line exposing item not ported"

                    Ok itemLines ->
                        if Array.isEmpty itemLines then
                            Ok (B.line (B.punc "()"))

                        else if forceVertical then
                            Ok (verticalExposingBox itemLines)

                        else
                            Ok
                                (B.line
                                    (B.row
                                        ([ B.punc "(" ]
                                            ++ Array.intersperse (B.row [ B.punc ",", B.space ]) itemLines
                                            ++ [ B.punc ")" ]
                                        )
                                    )
                                )
            )


verticalExposingBox : Array B.Line -> Box
verticalExposingBox itemLines =
    when Array.popFirst itemLines is
        Just { first, rest } ->
            B.stack1
                ([ B.prefix (B.row [ B.punc "(", B.space ]) (B.line first) ]
                    ++ Array.map (\l -> B.prefix (B.row [ B.punc ",", B.space ]) (B.line l)) rest
                    ++ [ B.line (B.punc ")") ]
                )

        Nothing ->
            B.line (B.punc "()")


{-| Render one LPT box to a Box. Err for unported constructs. -}
makePBox : LPBox -> Array LPNode -> Result String Box
makePBox box children =
    when box is
        UnbreakableText locs ->
            Ok (B.line (B.literal locs.value))

        SynthesizedText s ->
            Ok (B.line (B.literal s))

        AcrossOrVertical { forceVertical, checkContentVertical } ->
            renderFlowItems children
                |> Result.andThen
                    (\items ->
                        if forceVertical || (checkContentVertical && Array.any .isBlock items) then
                            -- A function application that must break: elm-format's
                            -- `ElmStructure.application`.
                            assembleBrokenCall grenIndent items

                        else
                            assembleFlow False grenIndent items
                    )

        BodyBlock ->
            buildFlowBox 0 children

        IndentedBlock ->
            buildFlowBox 0 children

        SoftIndentedBlock ->
            -- A lambda body: rendered inline when single-line, dropped +4 when
            -- multi-line ‚Äî the enclosing flow decides, via isBlockNode.
            buildFlowBox 0 children

        PrefixGlue prefix ->
            -- Glue a prefix onto its inner with no space: `\x`/`\[ ‚Ä¶ ]` (lambda
            -- args), `-x` (unary negation). Mirrors the Doc's `R.concat (R.text
            -- prefix) innerDoc` over `buildFlowDocInline`: `B.prefix` prepends the
            -- prefix to the inner's first line AND pads every continuation line by
            -- the prefix's width ‚Äî matching the `R.align` the inner (a multi-line
            -- array/record pattern) carries, so a lambda whose arg pattern spans
            -- rows (`\[ a {- c -}\n, b\n] -> ‚Ä¶`) aligns under the opening bracket.
            -- `buildFlowBoxInline` keeps a leading comment in the inner on-line.
            buildFlowBoxInline 0 children
                |> Result.map (\inner -> B.prefix (B.literal prefix.value) inner)

        AllAcrossOrAllVertical bracket ->
            makeLiteralBox False bracket children

        AlwaysVertical bracket ->
            makeLiteralBox True bracket children

        EmptyBracketed loc ->
            when bracketPunc loc.value is
                Just { left, right } ->
                    if Array.isEmpty children then
                        Ok (B.line (B.row [ B.punc left, B.punc right ]))

                    else
                        -- A bracket whose only content is a comment (`{ {- c -} }`,
                        -- `[ {- c -} ]`). Mirror makeEmptyBracketedDoc: the open
                        -- punc, a space, the comments space-joined, a space, the
                        -- close punc ‚Äî all on one line. Dropping the comment would
                        -- lose source content, so a comment we can't render inline
                        -- (multi-line block / `--` line) falls back via Err.
                        traverseResult emptyBracketedCommentLine children
                            |> Result.map
                                (\commentLines ->
                                    B.line
                                        (B.row
                                            (Array.flatten
                                                [ [ B.punc left, B.space ]
                                                , spaceJoinLines commentLines
                                                , [ B.space, B.punc right ]
                                                ]
                                            )
                                        )
                                )

                Nothing ->
                    Err "box: empty bracket kind not ported"

        Binop { forceVertical } ->
            makeBinopBox forceVertical children

        OpAndRhs ->
            makeOpAndRhsBox children

        RecordUpdate { name, forceVertical } ->
            makeRecordUpdateBox name.value forceVertical children

        IfCondition { forceVertical } ->
            makeIfConditionBox forceVertical children

        Pipeline { forceVertical, op } ->
            makePipelineBox forceVertical op children

        EmptyLine ->
            Ok B.blankLine

        WhenFlow { forceVertical } ->
            makeWhenFlowBox forceVertical children

        WhenBranch ->
            makeWhenBranchBox children

        WhenBranchPattern ->
            makeWhenBranchPatternBox children

        ParenBlock { forceVertical, checkContentVertical, isCallArgument } ->
            makeParenBlockBox { forceVertical = forceVertical, checkContentVertical = checkContentVertical, isCallArgument = isCallArgument } children

        MultilineString loc ->
            -- A `"""‚Ä¶"""` literal: opening `"""`, one line per content element,
            -- closing `"""`, stacked. The Doc renderer wraps the same sequence
            -- in `R.align` so continuation lines land at the opening `"""`'s
            -- column; Box stacking aligns to the box's column intrinsically
            -- when the flow indents it. A content line ending in whitespace, or
            -- an interior blank line, renders differently under Box's per-line
            -- trimRight and falls back via the self-verify guard.
            let
                quote =
                    B.line (B.literal "\"\"\"")

                contentLines =
                    Array.map (\s -> B.line (B.literal s)) loc.value
            in
            Ok (B.stack1 ([ quote ] ++ contentLines ++ [ quote ]))

        Glue ->
            makeGlueBox children

        SingleLineComment _ ->
            Err "box: construct not ported [SingleLineComment]"

        BlockComment _ ->
            Err "box: construct not ported [BlockComment]"

        DocComment _ ->
            Err "box: construct not ported [DocComment]"

        PipelineStep ->
            Err "box: construct not ported [PipelineStep]"

        AlignedFlow ->
            Err "box: construct not ported [AlignedFlow]"

        _ ->
            Err "box: construct not ported [other]"


{-| Render a `Glue`: children concatenated with no separator ‚Äî a postfix accessor
(`.field`) glued after a bracketed base (`(f 1).value`, `{ a = 1 }.a`). Mirrors
`MakeRender.makeGlueDoc` (concat with no separator). The base (first child) may be
multi-line ‚Äî the accessor glues onto its last line via `B.addSuffix` ‚Äî but every
following child (the `.field` accessors) must be single-line. -}
makeGlueBox : Array LPNode -> Result String Box
makeGlueBox children =
    when Array.popFirst children is
        Nothing ->
            Err "box: empty glue"

        Just { first, rest } ->
            makePBox (lpnBox first) (lpnChildren first)
                |> Result.andThen
                    (\baseBox ->
                        Array.foldl
                            (\child accR ->
                                accR
                                    |> Result.andThen
                                        (\acc ->
                                            makePBox (lpnBox child) (lpnChildren child)
                                                |> Result.andThen
                                                    (\childBox ->
                                                        when B.isLine childBox is
                                                            Ok l ->
                                                                Ok (B.addSuffix l acc)

                                                            Err _ ->
                                                                Err "box: multi-line glue suffix not ported"
                                                    )
                                        )
                            )
                            (Ok baseBox)
                            rest
                    )


{-| Render a `ParenBlock`. Mirrors `MakeRender.makeParenBlockDoc`, but only the
non-block shapes are ported: inline `(inner)` and the generic vertical form
`(inner` ‚Ä¶ `)` with the closing paren on its own line. A `when`/`if`/`let`
directly inside the parens uses elm-format's paren-block indentation
(keyword at `(`+1, bodies at `(`+2 or `(`+4, `)` at the `(` column) ‚Äî that
`R.align`/`R.nest` arithmetic isn't ported yet, so those fall back.

The Doc renderer wraps the vertical form in `R.align`, anchoring continuation
lines and the closing `)` to the `(` column. Box stacking is intrinsically
that align: the wrapped box's lines are all relative to its own origin, which
becomes the `(` column once the enclosing flow indents it. -}
makeParenBlockBox : { forceVertical : Bool, checkContentVertical : Bool, isCallArgument : Bool } -> Array LPNode -> Result String Box
makeParenBlockBox flags children =
    when Array.first children is
        Nothing ->
            Ok (B.line (B.punc "()"))

        Just first ->
            when lpnBox first is
                WhenFlow _ ->
                    makeWhenInParenBox flags.isCallArgument (lpnChildren first)

                IfCondition _ ->
                    makeBlockInParenBox flags.isCallArgument children

                UnbreakableText loc ->
                    if loc.value == "let" then
                        makeBlockInParenBox flags.isCallArgument children

                    else
                        parenGenericFallbackBox flags children

                _ ->
                    parenGenericFallbackBox flags children


{-| The non-block ParenBlock shapes: inline, or a generic vertical `(‚Ä¶\n)`. The
vertical form triggers on either verticality signal or a multi-line lambda body
(second child an `IndentedBlock`, or a `SoftIndentedBlock` whose sole bracket
literal renders vertical ‚Äî mirroring `makeParenBlockDoc`'s `isLambdaMultiline`). -}
parenGenericFallbackBox : { forceVertical : Bool, checkContentVertical : Bool, isCallArgument : Bool } -> Array LPNode -> Result String Box
parenGenericFallbackBox flags children =
    buildFlowBox 0 children
        |> Result.andThen
            (\innerBox ->
                let
                    contentForcesVertical =
                        flags.checkContentVertical && not (isSingleLine innerBox)

                    goVertical =
                        flags.forceVertical || contentForcesVertical || parenLambdaMultiline children
                in
                if goVertical then
                    if parenContentLeadsWithMultilinePrefixGlue children then
                        Ok (wrapParenVerticalPadded innerBox)

                    else if Array.any subtreeHasComment children && not (parenLambdaMultiline children) then
                        -- A comment forced this content multi-line via the
                        -- comment-aware flow builders' `B.prefix` glue (exact
                        -- character-width alignment, not a Tab stop), so the
                        -- paren's own `(` width must ride along on every
                        -- continuation line too ‚Äî same reasoning as the
                        -- bracket-pattern-lambda case above, just reached by a
                        -- different LPT shape (binop/call, not PrefixGlue).
                        -- Excludes the lambda-body case (`parenLambdaMultiline`):
                        -- its body is Tab-indented relative to the ambient
                        -- block, not the `(` column, even if a comment sits
                        -- somewhere inside it.
                        Ok (wrapParenVerticalPadded innerBox)

                    else
                        Ok (wrapParenVertical innerBox)

                else
                    when B.isLine innerBox is
                        Ok l ->
                            Ok (B.line (B.row [ B.punc "(", l, B.punc ")" ]))

                        Err _ ->
                            Err "box: inline paren over multi-line inner"
            )


{-| Glue `(` onto the inner box's first line and stack `)` as a new final line ‚Äî
the Box form of `R.align (concats [ "(", inner, hardNl, ")" ])`. -}
wrapParenVertical : Box -> Box
wrapParenVertical box =
    let
        withOpen =
            when box is
                SingleLine l ->
                    SingleLine (B.row [ B.punc "(", l ])

                Stack s ->
                    Stack { s | first = B.row [ B.punc "(", s.first ] }

                MustBreakBox l ->
                    MustBreakBox (B.row [ B.punc "(", l ])
    in
    B.andThen [ B.line (B.punc ")") ] withOpen


{-| Paren-wrap a box whose continuation lines are positioned RELATIVE to its
first line (an `R.align`-style inner ‚Äî a lambda whose parameter is a multi-line
bracket pattern, `(\{ ‚Ä¶ } ‚Ä¶)`). Unlike `wrapParenVertical` (which shifts only the
first line, correct for absolute-nested inners like binops/`when`/`if`), this pads
every continuation by the `(` width so the inner's alignment rides along and its
`,`/`}` stay under the opening bracket. `)` lands on its own line at the `(`
column. -}
wrapParenVerticalPadded : Box -> Box
wrapParenVerticalPadded box =
    B.andThen [ B.line (B.punc ")") ] (B.prefix (B.punc "(") box)


{-| Indent every line of a box by exactly `n` spaces (elm's `prefix` with a
run of spaces). Unlike `applyIndent`/`B.indent` (a column-sensitive `Tab`),
this is a fixed-width shift ‚Äî the Box form of the Doc renderer's `R.nest n`,
needed for the paren-block offsets (`(`+1, `(`+2) that don't fall on tab
stops. -}
blockIndentSpaces : Int -> Box -> Box
blockIndentSpaces n box =
    if n <= 0 then
        box

    else
        B.prefix (B.row (Array.repeat n B.space)) box


{-| A `when` directly inside parens: `(when ‚Ä¶ is`, branches at `(`+2 (or `(`+4
as a call argument), `)` on its own line at the `(` column. Mirrors the
`WhenFlow` arm of `MakeRender.makeParenBlockDoc` (which calls `makeWhenFlowDoc`
with `branchNest` 1/3 inside a second `R.align`). Only a single-line header is
ported; a forced-vertical `when` header falls back. -}
makeWhenInParenBox : Bool -> Array LPNode -> Result String Box
makeWhenInParenBox isCallArg children =
    when Array.popLast children is
        Nothing ->
            Err "box: when-in-paren has no children"

        Just { last = branchesBlock, initial = withoutBranches } ->
            let
                branchOffset =
                    if isCallArg then
                        4

                    else
                        2

                headerResult =
                    buildFlowBox 0 withoutBranches
                        |> Result.andThen
                            (\hdr ->
                                if isSingleLine hdr then
                                    Ok hdr

                                else
                                    Err "box: forced-vertical when-in-paren header not ported"
                            )

                branchesResult =
                    renderWhenBranchesBox (lpnChildren branchesBlock)
            in
            Result.map2
                (\hdr brs ->
                    wrapParenVertical (B.stack1 [ hdr, blockIndentSpaces branchOffset brs ])
                )
                headerResult
                branchesResult


{-| An `if`/`else` or `let` directly inside parens, using elm-format's
paren-block layout: keyword at `(`+1, bodies at `(`+2 (or `(`+4 as a call
argument), `else`/`in` and `else if` at `(`+1, `)` on its own line at the `(`
column. Mirrors `MakeRender.makeBlockInParenDoc`: the paren's direct children
are the flattened `if`/`let` pieces (an `IfCondition`/`let` head, `IndentedBlock`
bodies, `SynthesizedText` keywords, `EmptyLine` blanks). -}
makeBlockInParenBox : Bool -> Array LPNode -> Result String Box
makeBlockInParenBox isCallArg children =
    let
        bodyOffset =
            if isCallArg then
                4

            else
                2

        step node accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        let
                            push box =
                                { boxes = Array.pushLast box acc.boxes, isFirst = False }
                        in
                        when lpnBox node is
                            IndentedBlock ->
                                buildFlowBox 0 (lpnChildren node)
                                    |> Result.map (\b -> push (blockIndentSpaces bodyOffset b))

                            BodyBlock ->
                                buildFlowBox 0 (lpnChildren node)
                                    |> Result.map (\b -> push (blockIndentSpaces 1 b))

                            EmptyLine ->
                                Ok (push B.blankLine)

                            SynthesizedText s ->
                                Ok (push (blockIndentSpaces 1 (B.line (B.literal s))))

                            IfCondition _ ->
                                makePBox (lpnBox node) (lpnChildren node)
                                    |> Result.map
                                        (\b ->
                                            push
                                                (if acc.isFirst then
                                                    b

                                                 else
                                                    blockIndentSpaces 1 b
                                                )
                                        )

                            _ ->
                                makePBox (lpnBox node) (lpnChildren node)
                                    |> Result.map (\b -> push b)
                    )
    in
    Array.foldl step (Ok { boxes = [], isFirst = True }) children
        |> Result.map (\acc -> wrapParenVertical (B.stack1 acc.boxes))


{-| True when a paren's content is a lambda whose PARAMETER is a multi-line
bracket pattern (`(\{ ‚Ä¶ } ‚Ä¶)`, `(\[ ‚Ä¶ ] ‚Ä¶)`) ‚Äî the align-style case where the
paren must pad continuations (`wrapParenVerticalPadded`) so the pattern's `,`/`}`
stay under the opening bracket. A `\x -> <multi-line body>` lambda leads with a
single-line `PrefixGlue`, so it does not match ‚Äî its body is absolute-nested and
must NOT be padded. -}
parenContentLeadsWithMultilinePrefixGlue : Array LPNode -> Bool
parenContentLeadsWithMultilinePrefixGlue children =
    when Array.first children is
        Just first ->
            when lpnBox first is
                -- The paren content is usually a single `AcrossOrVertical` flow
                -- (`\{ ‚Ä¶ } param -> body`); descend into it to reach the leading
                -- `PrefixGlue`.
                AcrossOrVertical _ ->
                    parenContentLeadsWithMultilinePrefixGlue (lpnChildren first)

                PrefixGlue _ ->
                    when makePBox (lpnBox first) (lpnChildren first) is
                        Ok b ->
                            not (isSingleLine b)

                        Err _ ->
                            False

                _ ->
                    False

        Nothing ->
            False


{-| Mirror of `makeParenBlockDoc`'s `isLambdaMultiline`: the second direct child
is an `IndentedBlock` (lambda body on a separate row), or a `SoftIndentedBlock`
whose sole child is a bracket literal that itself renders vertical. -}
parenLambdaMultiline : Array LPNode -> Bool
parenLambdaMultiline children =
    when Array.popFirst children is
        Just { rest } ->
            when Array.first rest is
                Just second ->
                    when lpnBox second is
                        IndentedBlock ->
                            True

                        SoftIndentedBlock ->
                            softIndentedBlockChildForcesVerticalBox (lpnChildren second)

                        _ ->
                            False

                Nothing ->
                    False

        Nothing ->
            False


{-| Box mirror of `MakeRender.softIndentedBlockChildForcesVertical`: the sole
child is a record/array/update literal that renders multi-line. -}
softIndentedBlockChildForcesVerticalBox : Array LPNode -> Bool
softIndentedBlockChildForcesVerticalBox children =
    when Array.popFirst children is
        Just { first = only, rest } ->
            if not (Array.isEmpty rest) then
                False

            else
                let
                    isBracketLiteral =
                        when lpnBox only is
                            AlwaysVertical _ ->
                                True

                            AllAcrossOrAllVertical _ ->
                                True

                            RecordUpdate _ ->
                                True

                            _ ->
                                False
                in
                isBracketLiteral
                    && (when makePBox (lpnBox only) (lpnChildren only) is
                            Ok b ->
                                not (isSingleLine b)

                            Err _ ->
                                False
                       )

        Nothing ->
            False


{-| A record / array literal via elm's `group'`. `AllAcrossOrAllVertical`
(author wrote it inline) passes `forceMultiline = False` ‚Äî `group'` still
expands if a child is multi-line; `AlwaysVertical` (2+-field record, or author
across rows) passes `forceMultiline = True`. -}
makeLiteralBox : Bool -> ListBrackets -> Array LPNode -> Result String Box
makeLiteralBox forceMultiline bracket children =
    if Array.any nodeIsComment children then
        -- A line comment can't live inside a flat group, so a comment-bearing
        -- literal is always vertical. Mirrors `makeAllAcrossOrAllVertical` /
        -- `AlwaysVertical` delegating to `listBoxesWithBrackets` in the Doc.
        commentBracketListBox bracket children

    else
        traverseResult (\node -> makePBox (lpnBox node) (lpnChildren node)) children
            |> Result.andThen
                (\itemBoxes ->
                    when bracketPunc bracket is
                        Just { left, right } ->
                            Ok (E.groupBox True left "," right forceMultiline itemBoxes)

                        Nothing ->
                            Err "box: bracket kind not ported"
                )


{-| Render a comment-kind node (single-line `--`/`{- -}`, or a multi-line block
comment) to a Box. Mirrors the comment arms of `renderFlowItem`. -}
commentNodeBox : LPNode -> Result String Box
commentNodeBox node =
    when lpnBox node is
        SingleLineComment loc ->
            Ok (B.line (B.literal ("--" ++ loc.value)))

        BlockComment loc ->
            if String.contains "\n" loc.value then
                multiLineBlockCommentBox loc.value

            else
                Ok (B.line (B.literal ("{-" ++ loc.value ++ "-}")))

        _ ->
            Err "box: not a comment node"


{-| Render a bracketed literal that contains a comment child, as an always-
vertical list ‚Äî the Box mirror of `MakeRender.listBoxesWithBracketsUsing`'s
default (single-render) path. Each item is on its own line prefixed `{ `/`[ `
(first) or `, ` (rest); a comment on the same source row as the preceding item
trails it with a space, a comment on its own row gets its own line at the
bracket column; the closing bracket sits on its own line. Box stacking supplies
the alignment the Doc gets from `R.align`. The uniform record-array coupling
(a whole-list flat/expanded `P.choice`) is NOT reproduced ‚Äî those fall back. -}
commentBracketListBox : ListBrackets -> Array LPNode -> Result String Box
commentBracketListBox bracket nodes =
    when bracketPunc bracket is
        Nothing ->
            Err "box: bracket kind not ported"

        Just { left, right } ->
            let
                placeComment commentRow node acc =
                    commentNodeBox node
                        |> Result.andThen
                            (\cbox ->
                                if commentRow == acc.prevRow then
                                    -- Trailing the preceding item: attach with a
                                    -- single space (layout is author-driven, not
                                    -- width-driven). A multi-line trailing comment
                                    -- can't glue onto the last line, so fall back.
                                    when acc.pending is
                                        Nothing ->
                                            Ok
                                                { acc
                                                    | entries = Array.pushLast { box = cbox, isComment = True } acc.entries
                                                    , pending = Nothing
                                                }

                                        Just e ->
                                            when B.isLine cbox is
                                                Ok l ->
                                                    Ok
                                                        { acc
                                                            | entries = Array.pushLast { box = B.addSuffix (B.row [ B.space, l ]) e.box, isComment = False } acc.entries
                                                            , pending = Nothing
                                                        }

                                                Err _ ->
                                                    Err "box: multi-line trailing comment in bracket list not ported"

                                else
                                    let
                                        flushed =
                                            when acc.pending is
                                                Nothing ->
                                                    acc.entries

                                                Just e ->
                                                    Array.pushLast e acc.entries
                                    in
                                    Ok
                                        { entries = Array.pushLast { box = cbox, isComment = True } flushed
                                        , pending = Nothing
                                        , prevRow = commentRow
                                        }
                            )

                step node accResult =
                    when accResult is
                        Err e ->
                            Err e

                        Ok acc ->
                            when lpnBox node is
                                SingleLineComment loc ->
                                    placeComment loc.start.row node acc

                                BlockComment loc ->
                                    placeComment loc.start.row node acc

                                _ ->
                                    makePBox (lpnBox node) (lpnChildren node)
                                        |> Result.andThen
                                            (\box ->
                                                -- A multi-line item (a `when`/`if`/`let`
                                                -- whose branches are indented with `B.indent`
                                                -- = Tab) does not compose with the outer
                                                -- `[ `/`, ` prefix: the Tab snaps to the next
                                                -- multiple of 4 and swallows the prefix's
                                                -- 2-space pad, landing the body 2 columns too
                                                -- shallow. Fall back until the Tab-vs-prefix
                                                -- interaction is modelled. A field whose value
                                                -- is dropped to its own line BY A COMMENT
                                                -- (`, beta = {- c -} 2`) is exempt: like the
                                                -- record-update path (`fieldValueDropsToOwnLine`)
                                                -- its value flows at a fixed +4 that composes
                                                -- with the prefix. Single-line items (the common
                                                -- comment-bearing-literal case) are unaffected.
                                                if not (isSingleLine box) && not (fieldValueDropsToOwnLine node) then
                                                    Err "box: multi-line item in comment-bearing bracket list not ported"

                                                else
                                                    let
                                                        itemRow =
                                                            when lpnBox node is
                                                                UnbreakableText l ->
                                                                    l.start.row

                                                                _ ->
                                                                    lpnMaxRow node

                                                        flushed =
                                                            when acc.pending is
                                                                Nothing ->
                                                                    acc.entries

                                                                Just e ->
                                                                    Array.pushLast e acc.entries
                                                    in
                                                    Ok
                                                        { entries = flushed
                                                        , pending = Just { box = box, isComment = False }
                                                        , prevRow = itemRow
                                                        }
                                            )
            in
            Array.foldl step (Ok { entries = [], pending = Nothing, prevRow = -1 }) nodes
                |> Result.map
                    (\state ->
                        let
                            allEntries =
                                when state.pending is
                                    Nothing ->
                                        state.entries

                                    Just e ->
                                        Array.pushLast e state.entries

                            assembled =
                                Array.foldl
                                    (\entry acc ->
                                        if entry.isComment then
                                            { acc | boxes = Array.pushLast entry.box acc.boxes }

                                        else
                                            let
                                                pref =
                                                    if acc.seenText then
                                                        B.row [ B.punc ",", B.space ]

                                                    else
                                                        B.row [ B.punc left, B.space ]
                                            in
                                            { boxes = Array.pushLast (B.prefix pref entry.box) acc.boxes
                                            , seenText = True
                                            }
                                    )
                                    { boxes = [], seenText = False }
                                    allEntries
                        in
                        B.stack1 (Array.pushLast (B.line (B.punc right)) assembled.boxes)
                    )


bracketPunc : ListBrackets -> Maybe { left : String, right : String }
bracketPunc bracket =
    when bracket is
        ListCurly ->
            Just { left = "{", right = "}" }

        ListSquare ->
            Just { left = "[", right = "]" }

        ListParen ->
            -- A parenthesized list reached via the general list path rather than
            -- makeExposingLineBox ‚Äî i.e. a module/import exposing list whose
            -- header carries a comment, so makeExposingLineBox fell back to the
            -- flow. Rendered with inner spaces `( a, b )` (groupBox innerSpaces),
            -- matching the Doc's bracketStrings ListParen ‚Äî distinct from the
            -- comment-free `(a, b)` makeExposingListBox emits.
            Just { left = "(", right = ")" }


type alias FlowItem =
    { node : LPNode
    , box : Box
    , isBlock : Bool
    , startRow : Int
    , comment : Maybe { box : Box, isLineComment : Bool, multiLine : Bool }
    }


-- Render each flow node to a Box (Err if any is unported), tagging whether it
-- occupies its own block line, its start row, and ‚Äî for a comment ‚Äî the rendered
-- comment box so `assembleFlowImpl` can place it by row.
renderFlowItems : Array LPNode -> Result String (Array FlowItem)
renderFlowItems nodes =
    traverseResult renderFlowItem nodes


renderFlowItem : LPNode -> Result String FlowItem
renderFlowItem node =
    when lpnBox node is
        SingleLineComment loc ->
            Ok
                { node = node
                , box = B.blankLine
                , isBlock = False
                , startRow = loc.start.row
                , comment = Just { box = B.line (B.literal ("--" ++ loc.value)), isLineComment = True, multiLine = False }
                }

        BlockComment loc ->
            if String.contains "\n" loc.value then
                multiLineBlockCommentBox loc.value
                    |> Result.map
                        (\cbox ->
                            { node = node
                            , box = B.blankLine
                            , isBlock = False
                            , startRow = loc.start.row
                            , comment = Just { box = cbox, isLineComment = False, multiLine = True }
                            }
                        )

            else
                Ok
                    { node = node
                    , box = B.blankLine
                    , isBlock = False
                    , startRow = loc.start.row
                    , comment = Just { box = B.line (B.literal ("{-" ++ loc.value ++ "-}")), isLineComment = False, multiLine = False }
                    }

        _ ->
            makePBox (lpnBox node) (lpnChildren node)
                |> Result.map
                    (\box ->
                        { node = node
                        , box = box
                        , isBlock = isBlockNode node box
                        , startRow = nodeStartRow node
                        , comment = Nothing
                        }
                    )


nodeStartRow : LPNode -> Int
nodeStartRow node =
    when lpnFirstPos node is
        Just p ->
            p.row

        Nothing ->
            -1


isCommentItem : FlowItem -> Bool
isCommentItem item =
    item.comment /= Nothing


{-| Assemble a flow: inline nodes join on one line with single spaces; a single
trailing block node (BodyBlock / IndentedBlock / any multi-line node) drops to
its own line indented by `indent`. Shapes outside "inline* block?" are `Err`
(fall back) for now. -}
buildFlowBox : Int -> Array LPNode -> Result String Box
buildFlowBox indent nodes =
    renderFlowItems nodes
        |> Result.andThen (assembleFlow False indent)


{-| Like `buildFlowBox`, but for a flow that continues on the same line as a
token the caller already emitted (a binop/`OpAndRhs` rhs after its operator, a
`( ‚Ä¶ )` body). A leading single-line block comment there stays inline instead of
dropping to its own line. Mirrors `MakeRender.buildFlowDocInline` (`inlineStart`
= True). -}
buildFlowBoxInline : Int -> Array LPNode -> Result String Box
buildFlowBoxInline indent nodes =
    renderFlowItems nodes
        |> Result.andThen (assembleFlow True indent)


{-| Assemble a *broken* flow ‚Äî every item on its own line: the first at the base
column, each remaining item at +`indent`. Mirrors `MakeRender.buildFlowDocBroken`
(the `brokenFlow = True` path). Box already renders broken function applications
via `assembleBrokenCall`, so the one caller here is the forced-vertical
comment-bearing binop (`operand0` / `op ‚Ä¶ rest` at +4). Top-level comment items
aren't handled ‚Äî those flows fall back. -}
buildFlowBoxBroken : Int -> Array LPNode -> Result String Box
buildFlowBoxBroken indent nodes =
    renderFlowItems nodes
        |> Result.andThen (assembleBrokenWithComments indent)


{-| Assemble a broken flow (head at base, each following item at +`indent`) that
may carry comments. A comment trailing the preceding item on the same source row
glues onto that item's last line ‚Äî for a single-line item, its line plus a space
is prepended onto the comment box (`B.prefix`), so a multi-line comment's body
reindents under it (`f {- multi‚Ä¶ -}`, `+ b {- multi‚Ä¶ -}`). A comment on its own
row, or one trailing a multi-line item (no single last line to glue onto), isn't
modelled and falls back. Mirrors the comment-bearing `buildFlowDocBroken` path. -}
assembleBrokenWithComments : Int -> Array FlowItem -> Result String Box
assembleBrokenWithComments indent items =
    let
        step item accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        when item.comment is
                            Just c ->
                                when Array.popLast acc.entries is
                                    Just { last = lastBox, initial } ->
                                        if item.startRow == acc.lastRow && acc.lastRow >= 0 then
                                            when B.isLine lastBox is
                                                Ok l ->
                                                    Ok { acc | entries = Array.pushLast (B.prefix (B.row [ l, B.space ]) c.box) initial }

                                                Err _ ->
                                                    Err "box: comment trailing a multi-line item in broken flow not ported"

                                        else
                                            Err "box: own-line comment in broken flow not ported"

                                    Nothing ->
                                        Err "box: leading comment in broken flow not ported"

                            Nothing ->
                                Ok { acc | entries = Array.pushLast item.box acc.entries, lastRow = lpnMaxRow item.node }
                    )
    in
    Array.foldl step (Ok { entries = [], lastRow = -1 }) items
        |> Result.andThen
            (\acc ->
                when Array.popFirst acc.entries is
                    Nothing ->
                        Err "box: empty broken flow"

                    Just { first = head, rest } ->
                        Ok (B.stack1 ([ head ] ++ Array.map (applyIndent indent) rest))
            )


{-| A function application forced across lines ‚Äî elm-format's
`ElmStructure.application`. The first argument stays glued to the function on
the opening line only when both are single-line and share a source row;
otherwise the function stands alone. Every non-glued argument drops to its own
line at +`indent`. -}
assembleBrokenCall : Int -> Array FlowItem -> Result String Box
assembleBrokenCall indent items =
    if Array.any isCommentItem items then
        -- A comment-bearing broken call (`f {- c -} 1 {- c -} (g 2)`): no
        -- function+arg0 gluing (a comment between them already breaks the row),
        -- each arg on its own line at +indent, same-row comments glued on.
        assembleBrokenWithComments indent items

    else
        when Array.popFirst items is
            Nothing ->
                Err "box: empty call"

            Just { first = fnItem, rest = argItems } ->
                when Array.popFirst argItems is
                    Nothing ->
                        -- fn with no args ‚Äî nothing to break
                        Ok fnItem.box

                    Just { first = arg0Item, rest = laterArgs } ->
                        if shouldGlueBox fnItem arg0Item then
                            when joinInline [ fnItem.box, arg0Item.box ] is
                                Nothing ->
                                    Err "box: glue join failed"

                                Just glueLine ->
                                    if Array.isEmpty laterArgs then
                                        Ok glueLine

                                    else
                                        Ok (B.stack1 ([ glueLine ] ++ Array.map (\it -> applyIndent indent it.box) laterArgs))

                        else
                            Ok (B.stack1 ([ fnItem.box ] ++ Array.map (\it -> applyIndent indent it.box) argItems))


-- Both single-line and on the same source row ‚Üí keep glued on the opening line.
shouldGlueBox : FlowItem -> FlowItem -> Bool
shouldGlueBox fnItem arg0Item =
    isSingleLine fnItem.box
        && isSingleLine arg0Item.box
        && nodesShareStartRow fnItem.node arg0Item.node


nodesShareStartRow : LPNode -> LPNode -> Bool
nodesShareStartRow a b =
    when { pa = lpnFirstPos a, pb = lpnFirstPos b } is
        { pa = Just posA, pb = Just posB } ->
            posA.row == posB.row

        _ ->
            False


-- Join boxes horizontally on one line with single spaces, iff all single-line.
joinInline : Array Box -> Maybe Box
joinInline boxes =
    when B.allSingles boxes is
        Ok lines ->
            Just (B.line (B.row (Array.intersperse B.space lines)))

        Err _ ->
            Nothing


isBlockNode : LPNode -> Box -> Bool
isBlockNode node box =
    when lpnBox node is
        BodyBlock ->
            True

        IndentedBlock ->
            True

        _ ->
            not (isSingleLine box)


isSingleLine : Box -> Bool
isSingleLine box =
    when B.isLine box is
        Ok _ ->
            True

        Err _ ->
            False


{-| Which indent discipline a multi-line box's continuation lines carry ‚Äî
the static per-box-type alignment table (CutoverScope.md "Item 4 design"),
verified against the Doc renderer's source, not curve-fit. It decides which
primitive materializes a soft glue (the Doc's `FlowSep` `group nl`, which
always flattens to a space, so the item's first line joins the running line
and its continuation lines land per the item's own align/nest):

  - `AlignCarrying` ‚Äî the Doc wraps these in `R.align`, anchoring
    continuation lines at the item's printed start column: bracket literals
    (`listBoxesWithBrackets`) and multiline strings
    (`makeMultilineStringDoc`). Glue with `B.prefix`, which pads every
    continuation line by the glued prefix's exact character width. This is
    only sound because these boxes' continuation lines are punctuation- or
    verbatim-prefixed (`, item`, `}`, string content) ‚Äî NOT `Tab`-indented.
    `RecordUpdate` and `AlignedFlow` are align-carrying on the Doc side too,
    but their Box continuation lines carry `Tab`s, which `B.prefix`'s space
    padding quantizes to the next multiple of 4 (the census's "per-row
    exact-space indent" hard class) ‚Äî so they stay unclassified.
  - `NestCarrying` ‚Äî the Doc nests these relative to the flow's base, not
    the glue column: `AcrossOrVertical` (`buildFlowDoc grenIndent` /
    `buildCallDocBroken grenIndent`), `OpAndRhs` / `Glue` / `PrefixGlue`
    (inline flows at +0), and pipelines (steps at `R.nest grenIndent`).
    Glue first-line-only: the continuation lines already carry the item's
    own indent relative to the flow base, which the flow's final
    `applyIndent flowIndent` (its outer nest) completes.
  - `UnclassifiedCarrying` ‚Äî everything else must stay an `Err` fallback:
    guessing produces a Box-only layout, the exact divergence class the
    shared FlowPolicy core exists to prevent.

LOAD-BEARING invariant: any new `R.align`-carrying builder on the Doc side
must update this table (same class as the other Doc‚ÜîBox mirror comments).
-}
type SoftGlueAlignment
    = AlignCarrying
    | NestCarrying
    | UnclassifiedCarrying


softGlueAlignment : LPNode -> SoftGlueAlignment
softGlueAlignment node =
    when lpnBox node is
        AlwaysVertical _ ->
            AlignCarrying

        AllAcrossOrAllVertical _ ->
            AlignCarrying

        MultilineString _ ->
            AlignCarrying

        AcrossOrVertical _ ->
            NestCarrying

        OpAndRhs ->
            NestCarrying

        Glue ->
            NestCarrying

        PrefixGlue _ ->
            NestCarrying

        Pipeline _ ->
            NestCarrying

        _ ->
            UnclassifiedCarrying


-- True for a flow item whose node is a bracket LITERAL (record / array / record
-- update) ‚Äî the shapes that carry `R.align`, so a `B.prefix` glue of their first
-- line pads continuation lines to stay aligned under the opening bracket.
isSoftGlueLiteral : FlowItem -> Bool
isSoftGlueLiteral item =
    when lpnBox item.node is
        AlwaysVertical _ ->
            True

        AllAcrossOrAllVertical _ ->
            True

        RecordUpdate _ ->
            True

        _ ->
            False


-- True for a multi-line flow item onto whose last line the following inline
-- items glue ‚Äî a lambda's arg pattern or its whole head. In the Doc's
-- `buildFlowDoc` both are plain items that leave `FlowSep`, so the tokens after
-- them (`accumulatedSoFar ->`, `-> body`) ride onto the same line rather than
-- dropping. Box's flat stacker treats every multi-line node as a droppable
-- block, so those followers are instead gathered by `assembleFlowImpl`'s glue
-- path (`B.addSuffix` onto the block's last line). Two shapes:
--   ‚Ä¢ `PrefixGlue` ‚Äî a bare lambda-arg pattern (`\{ ‚Ä¶ }`, `\[ ‚Ä¶ ]`) whose
--     following params/arrow glue on (a MULTI-param lambda `\{‚Ä¶} p ->`).
--   ‚Ä¢ `AcrossOrVertical` ending in `->` ‚Äî a lambda HEAD (`\[ ‚Ä¶ ] ->`) built as
--     its own flow node with the body a sibling `SoftIndentedBlock`; a body kept
--     inline in source (`] -> a`) glues onto the arrow.
-- Scoped so a genuine call argument after a multi-line paren/record ‚Äî which
-- elm-format *drops* ‚Äî is untouched (a call/application AoV does not end in `->`).
isGlueablePrefixBlock : FlowItem -> Bool
isGlueablePrefixBlock item =
    item.isBlock
        && (when lpnBox item.node is
                PrefixGlue _ ->
                    True

                AcrossOrVertical _ ->
                    when Array.last (lpnChildren item.node) is
                        Just lastChild ->
                            isArrowLeaf lastChild

                        Nothing ->
                            False

                _ ->
                    False
           )


{-| Soft-glue a flow whose ONLY multi-line item is a bracket literal, mirroring
the Doc's `buildFlowDoc` (its `FlowSep` group flattens to a space, so every item
glues and the literal breaks internally): the single-line prefix items glue to
the literal's first line, its continuation pads to align under the bracket
(`B.prefix`), and any single-line suffix items (a trailing `=`) glue onto its
last line (`B.addSuffix`). Covers a multi-line record/array *pattern* function
argument (`multilineRecord { alpha\n, beta\n} =`), which `assembleFlowImpl`'s
flat stacker would instead drop to its own line. Returns Nothing (‚Üí general
assembler) unless the shape matches exactly: no comments/blank lines/hard blocks,
a non-empty single-line prefix, exactly one multi-line item, and it is a bracket
literal. Only reached from `assembleFlow` (the Doc's gluing `buildFlowDoc` path)
‚Äî a call whose record arg *drops* goes through `assembleBrokenCall` instead. -}
-- Render a prefix/suffix flow item to the single inline `Line` it contributes to
-- a soft-glue flow. A plain item uses its box (which must be single-line); a
-- single-line block-comment item (`{- c -}`) uses its rendered comment box, so a
-- trailing comment (`‚Ä¶ exposing (..) {- c -}`) glues onto the soft literal's last
-- line. A `--` line comment or a multi-line block comment can't glue inline, so it
-- Errs ‚Äî dropping the whole flow back to the general assembler.
flowItemInlineLine : FlowItem -> Result String B.Line
flowItemInlineLine item =
    let
        asLine box =
            when B.isLine box is
                Ok l ->
                    Ok l

                Err _ ->
                    Err "box: multi-line item in soft-glue flow"
    in
    when item.comment is
        Just c ->
            if c.isLineComment || c.multiLine then
                Err "box: non-inline comment in soft-glue flow"

            else
                asLine c.box

        Nothing ->
            asLine item.box


trySoftGlueFlow : Array FlowItem -> Maybe Box
trySoftGlueFlow items =
    if Array.any (\it -> isEmptyLine it.node) items then
        Nothing

    else
        let
            multiIdxs =
                Array.foldl
                    (\it acc -> { i = acc.i + 1, idxs = if isSingleLine it.box then acc.idxs else Array.pushLast acc.i acc.idxs })
                    { i = 0, idxs = [] }
                    items
        in
        when multiIdxs.idxs is
            [ idx ] ->
                let
                    softItem =
                        Array.get idx items

                    prefix =
                        Array.takeFirst idx items

                    suffix =
                        Array.dropFirst (idx + 1) items
                in
                when { s = softItem, pl = traverseResult flowItemInlineLine prefix, sl = traverseResult flowItemInlineLine suffix } is
                    { s = Just soft, pl = Ok prefixLines, sl = Ok suffixLines } ->
                        -- Require BOTH a non-empty single-line prefix AND a
                        -- non-empty single-line suffix. The suffix (a trailing
                        -- synthesized `=`) is what marks a funcDecl/`let`
                        -- destructuring HEADER ‚Äî where the Doc's `buildFlowDoc`
                        -- glues the pattern and appends `=` ‚Äî apart from a call
                        -- argument (`fn { record }`, no trailing token) where the
                        -- record instead DROPS to its own line (via the pipeline
                        -- trigger / broken-call path). Without this gate a
                        -- multi-line record call arg would be wrongly glued.
                        --
                        -- A multi-line TYPE record after a real head is the
                        -- policy's DropBlock (the type-record drop) ‚Äî the fold
                        -- must handle it, not this glue: a trailing comment
                        -- item (`} {- c -}`) would otherwise satisfy the
                        -- non-empty-suffix gate and wrongly glue a signature
                        -- segment's dropping record.
                        if isSoftGlueLiteral soft && not (Array.isEmpty prefixLines) && not (Array.isEmpty suffixLines) && not (FP.isTypeRecordLiteral soft.node) then
                            let
                                prefixLine =
                                    B.row (Array.intersperse B.space prefixLines)

                                glued =
                                    B.prefix (B.row [ prefixLine, B.space ]) soft.box
                            in
                            Just (B.addSuffix (B.row ([ B.space ] ++ Array.intersperse B.space suffixLines)) glued)

                        else
                            Nothing

                    _ ->
                        Nothing

            _ ->
                Nothing


assembleFlow : Bool -> Int -> Array FlowItem -> Result String Box
assembleFlow inlineStart flowIndent items =
    when trySoftGlueFlow items is
        Just box ->
            Ok box

        Nothing ->
            assembleFlowFallback inlineStart flowIndent items


assembleFlowFallback : Bool -> Int -> Array FlowItem -> Result String Box
assembleFlowFallback inlineStart flowIndent items =
    if inlineGluesToPrecedingBlock items then
        -- An inline token right after a block (no blank line between) generally
        -- must glue onto the block's last line (e.g. a multi-line record
        -- *pattern* arg `{ ‚Ä¶ } =`, where `=` trails the closing `}`) ‚Äî the flat
        -- stacker here can't append to a block's last line, so fall back. The
        -- one exception is `in` after the final `let` binding: `let ‚Ä¶ in` drops
        -- `in` to its own line, which the stacker does correctly. (`else` is
        -- always preceded by an `EmptyLine`, so it doesn't reach this test.)
        -- The `=` and `in` are both synthesized tokens (no source row), so this
        -- is decided by the token, not by row arithmetic.
        Err "box: inline token gluing to a preceding block not ported"

    else
        assembleFlowImpl inlineStart flowIndent items


isInKeyword : FlowItem -> Bool
isInKeyword item =
    leafValue item.node == Just "in"


-- True when a non-block, non-EmptyLine item (other than the `let ‚Ä¶ in` keyword)
-- immediately follows a block item and so must glue onto its last line ‚Äî which
-- the flat stacker can't do.
inlineGluesToPrecedingBlock : Array FlowItem -> Bool
inlineGluesToPrecedingBlock items =
    (Array.foldl
        (\item acc ->
            let
                isEmpty =
                    isEmptyLine item.node

                -- A multi-line `PrefixGlue` (lambda-arg pattern) is NOT counted as
                -- a preceding block: the Doc glues the tokens after it onto its last
                -- line, and `assembleFlowImpl` reproduces that with `B.addSuffix`, so
                -- an inline follower must not trip the fallback Err.
                isBlk =
                    item.isBlock && not isEmpty && not (isGlueablePrefixBlock item)

                isInline =
                    not item.isBlock && not isEmpty && not (isInKeyword item)
            in
            { prevBlock = isBlk
            , bad = acc.bad || (isInline && acc.prevBlock)
            }
        )
        { prevBlock = False, bad = False }
        items
    ).bad


{-| Pair each single-line block-comment item with an immediately following
type-record literal item, removing the comment from the item list and attaching
it to the record's entry ‚Äî the Box mirror of
`MakeRender.pairLeadingRecordComments`. `assembleFlowImpl`'s fold then decides
whether the pair drops together or replays the plain unpaired steps. Flows
containing an arrow (a function type's segments) pair too, exactly like the
Doc: the drop's reparse fixed point is guaranteed by `makeSignatureBox`
folding `segmentHasDroppingRecordBox` into the signature's own
`forceVertical` decision (the item-3 rule), mirroring
`MakeRender.segmentHasDroppingRecord`. -}
pairTypeRecordComments : Array FlowItem -> Array { item : FlowItem, leading : Maybe FlowItem }
pairTypeRecordComments items =
    let
        pairableComment it =
            when it.comment is
                Just c ->
                    not c.isLineComment && not c.multiLine

                Nothing ->
                    False

        -- NB Gren's `Array.get -1` wraps to the LAST element ‚Äî see the same
        -- guard in `MakeRender.pairLeadingRecordComments`: without it, a record
        -- at index 0 would pair with a comment TRAILING the flow and duplicate it.
        at i =
            if i < 0 then
                Nothing

            else
                Array.get i items
    in
    items
        |> Array.indexedMap (\i it -> { i = i, it = it })
        |> Array.mapAndKeepJust
            (\{ i, it } ->
                if
                    pairableComment it
                        && (at (i + 1)
                                |> Maybe.map (\n -> FP.isTypeRecordLiteral n.node)
                                |> Maybe.withDefault False
                           )
                then
                    -- Consumed: attached to the record that follows.
                    Nothing

                else
                    Just
                        { item = it
                        , leading =
                            if FP.isTypeRecordLiteral it.node then
                                at (i - 1)
                                    |> Maybe.andThen
                                        (\prev ->
                                            if pairableComment prev then
                                                Just prev

                                            else
                                                Nothing
                                        )

                            else
                                Nothing
                        }
            )


{-| Assemble a flow into a Box, taking every join decision from
`FlowPolicy.decide` ‚Äî the shared decision core both renderers consume (see
CutoverScope.md "Item 4 design", Phase 1). This fold keeps NO layout policy of
its own: it classifies each item into `ItemFacts`, asks the policy for a
`Placement`, and materializes that placement with Box primitives. A placement
this renderer cannot materialize yet returns `Err`, falling back to the Doc
renderer via the self-verify guard.

Materialization state: `curRow` is the line being assembled (single-line items
join space-separated); `rows` are the completed lines/blocks above it. The
first row sits at the flow's own column; every continuation row is indented by
`flowIndent` at the end (the Box form of the Doc's outer `R.nest indent`).
-}
assembleFlowImpl : Bool -> Int -> Array FlowItem -> Result String Box
assembleFlowImpl inlineStart flowIndent items =
    let
        config =
            { indent = flowIndent
            , inlineStart = inlineStart
            , brokenFlow = False
            }

        flushRow curRow rows =
            if Array.isEmpty curRow then
                rows

            else
                Array.pushLast (B.line (B.row (Array.intersperse B.space curRow))) rows

        -- Classify one flow item into the policy's fact vocabulary. The
        -- verticality facts come from this renderer's own IR (`isSingleLine`
        -- on the rendered box ‚Äî the Box analogue of the Doc's
        -- `R.hasHardBreak`).
        factsFor item =
            when item.comment is
                Just c ->
                    if c.isLineComment then
                        FP.LineCommentItem { startRow = item.startRow }

                    else
                        FP.BlockCommentItem { startRow = item.startRow, multiLine = c.multiLine }

                Nothing ->
                    when lpnBox item.node is
                        AllAcrossOrAllVertical _ ->
                            bracketFacts item

                        AlwaysVertical _ ->
                            bracketFacts item

                        IndentedBlock ->
                            FP.IndentedBlockItem

                        BodyBlock ->
                            FP.BodyBlockItem

                        SoftIndentedBlock ->
                            FP.SoftBlockItem { childForcesVertical = softBlockChildForcesVerticalBox item }

                        EmptyLine ->
                            FP.EmptyLineItem

                        UnbreakableText loc ->
                            FP.LeafItem { startRow = loc.start.row, isElidedArrow = isElidedArrow item.node }

                        _ ->
                            FP.LeafItem { startRow = -1, isElidedArrow = False }

        bracketFacts item =
            FP.BracketLiteralItem
                { forcesVertical = not (isSingleLine item.box)
                , isTypeRecord = FP.isTypeRecordLiteral item.node
                , closingRow =
                    lpnLastBracketEnd item.node
                        |> Maybe.map (\p -> p.row)
                        |> Maybe.withDefault -1
                }

        -- Glue a single line onto the last completed row's last line ‚Äî the
        -- materialization of a FlowSep-style join whose left side is a block
        -- (the Doc's `group nl` flattens to a space onto the running doc).
        -- Covers the ex-`glueable` lambda-pattern/lambda-head followers and a
        -- same-row comment gluing onto a dropped record's `}` line.
        glueOntoLastRow acc l next =
            when Array.popLast acc.rows is
                Just { last = lastBox, initial } ->
                    Ok
                        { rows = Array.pushLast (B.addSuffix (B.row [ B.space, l ]) lastBox) initial
                        , curRow = []
                        , state = next
                        }

                Nothing ->
                    Err "box: glue with nothing before"

        -- Materialize a comment item's placement. An own-line comment (the
        -- policy leaves `AlreadyTerminated`) flushes and stands alone; an
        -- inline one joins the current row. `GlueSpace` with an empty current
        -- row means the previous item was a block (a dropped record): glue
        -- onto its last line.
        placeCommentItem acc decision c =
            let
                ownLine box =
                    Ok
                        { rows = Array.pushLast box (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }
            in
            if c.multiLine then
                when decision.placement is
                    FP.AsFirst ->
                        -- In an inline-start flow (a PrefixGlue/paren body whose
                        -- box the caller embeds mid-line) the content following
                        -- the comment's own lines must be re-indented by the
                        -- ENCLOSING flow's nest ‚Äî which the Doc gets for free
                        -- (its hardNl re-indents at the outer nest) but this
                        -- box, once embedded as a first-row item, cannot: its
                        -- continuation lines are out of the enclosing
                        -- `flowIndent`'s reach. Fall back.
                        if inlineStart then
                            Err "box: leading multi-line comment in an inline-start flow not ported"

                        else
                            ownLine c.box

                    FP.GlueNoSep ->
                        ownLine c.box

                    FP.OwnLine ->
                        ownLine c.box

                    FP.GlueSpace ->
                        if Array.isEmpty acc.curRow then
                            Err "box: multi-line comment glue onto a block's last line not ported"

                        else
                            -- The comment's first line joins the current row and
                            -- its body flows below. `B.prefix` prepends the row
                            -- (plus a space) onto the comment box's first line
                            -- AND pads every continuation line by that width, so
                            -- the reindented comment body lands aligned under
                            -- the opening `{-`.
                            let
                                prefLine =
                                    B.row (Array.pushLast B.space (Array.intersperse B.space acc.curRow))
                            in
                            Ok
                                { rows = Array.pushLast (B.prefix prefLine c.box) acc.rows
                                , curRow = []
                                , state = decision.next
                                }

                    _ ->
                        Err "box: unexpected multi-line comment placement"

            else
                when B.isLine c.box is
                    Err _ ->
                        Err "box: single-line comment box was multi-line"

                    Ok l ->
                        if decision.next.separator == FP.AlreadyTerminated then
                            -- Line-terminating comment (a `--`, or a block
                            -- comment the policy put on its own line).
                            when decision.placement is
                                FP.AsFirst ->
                                    ownLine (B.line l)

                                FP.GlueNoSep ->
                                    ownLine (B.line l)

                                FP.OwnLine ->
                                    ownLine (B.line l)

                                FP.GlueSpace ->
                                    -- Same-row glue; the comment still ends the
                                    -- line.
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok
                                            { rows = flushRow (Array.pushLast l acc.curRow) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                _ ->
                                    Err "box: unexpected terminating comment placement"

                        else
                            -- Inline single-line block comment: joins the flow
                            -- like a token.
                            when decision.placement is
                                FP.AsFirst ->
                                    Ok { rows = acc.rows, curRow = [ l ], state = decision.next }

                                FP.GlueSpace ->
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                                FP.SoftSep ->
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                                FP.OwnLine ->
                                    Ok { rows = flushRow acc.curRow acc.rows, curRow = [ l ], state = decision.next }

                                _ ->
                                    Err "box: unexpected inline comment placement"

        -- Materialize a non-comment item's placement. `leading` carries a
        -- paired leading comment box for the type-record drop (it drops WITH
        -- the record, stacked directly above the `{` at the drop indent).
        placeNonComment acc decision leading item =
            when decision.placement is
                FP.AsFirst ->
                    -- First item of the flow: the bare item (the Doc's
                    -- FirstItem join applies no wrap).
                    when B.isLine item.box is
                        Ok l ->
                            Ok { rows = acc.rows, curRow = [ l ], state = decision.next }

                        Err _ ->
                            Ok { rows = Array.pushLast item.box acc.rows, curRow = [], state = decision.next }

                FP.GlueNoSep ->
                    -- Content begins on the fresh line the previous comment's
                    -- hardNl opened (the current row is empty after the
                    -- comment's flush).
                    when B.isLine item.box is
                        Ok l ->
                            Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                        Err _ ->
                            Ok { rows = Array.pushLast item.box (flushRow acc.curRow acc.rows), curRow = [], state = decision.next }

                FP.SoftSep ->
                    when B.isLine item.box is
                        Ok l ->
                            if Array.isEmpty acc.curRow then
                                glueOntoLastRow acc l decision.next

                            else
                                Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                        Err _ ->
                            -- The Doc soft-glues a multi-line non-block item's
                            -- first line onto the running line (its `group nl`
                            -- flattens to a space; inner hard breaks land per
                            -- the item's own align/nest ‚Äî see
                            -- `softGlueAlignment`, the static alignment table).
                            if Array.isEmpty acc.curRow then
                                -- The item follows a block (nothing on the
                                -- current row): its first line would have to
                                -- glue onto the block's last line.
                                Err "box: soft-glue of a multi-line item after a block not ported"

                            else
                                let
                                    prefLine =
                                        B.row (Array.pushLast B.space (Array.intersperse B.space acc.curRow))
                                in
                                when softGlueAlignment item.node is
                                    AlignCarrying ->
                                        Ok
                                            { rows = Array.pushLast (B.prefix prefLine item.box) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                    NestCarrying ->
                                        Ok
                                            { rows = Array.pushLast (B.mapFirstLine (\l -> B.row [ prefLine, l ]) identity item.box) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                    UnclassifiedCarrying ->
                                        Err "box: soft-glue of a multi-line item not ported"

                FP.OwnLine ->
                    when B.isLine item.box is
                        Ok l ->
                            Ok { rows = flushRow acc.curRow acc.rows, curRow = [ l ], state = decision.next }

                        Err _ ->
                            Ok { rows = Array.pushLast item.box (flushRow acc.curRow acc.rows), curRow = [], state = decision.next }

                FP.IndentNoBreak ->
                    -- Block after a line-terminating comment: the item lands on
                    -- the fresh line at +grenIndent, with no extra break.
                    Ok
                        { rows = Array.pushLast (applyIndent grenIndent item.box) (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }

                FP.BlockJoin { rule } ->
                    when rule is
                        FP.IndentedRule ->
                            Ok
                                { rows = Array.pushLast (applyIndent grenIndent item.box) (flushRow acc.curRow acc.rows)
                                , curRow = []
                                , state = decision.next
                                }

                        FP.BodyRule ->
                            Ok
                                { rows = Array.pushLast item.box (flushRow acc.curRow acc.rows)
                                , curRow = []
                                , state = decision.next
                                }

                        FP.SoftIndentedRule ->
                            -- The Doc's soft wrap is a group: flat content glues
                            -- onto the current line with a space; multi-line
                            -- content would soft-glue at +grenIndent (Phase 2).
                            when B.isLine item.box is
                                Ok l ->
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                                Err _ ->
                                    Err "box: soft-glue of a multi-line soft block not ported"

                FP.DropBlock rule ->
                    -- The type-record drop: the record (with its paired leading
                    -- comment stacked directly above the `{`, when present)
                    -- drops below the head. IndentedRule (unnested flow) lands
                    -- it at +grenIndent; BodyRule (the flow is already nested)
                    -- at the flow's continuation column.
                    let
                        dropIndent =
                            when rule is
                                FP.IndentedRule ->
                                    grenIndent

                                _ ->
                                    0

                        droppedBox =
                            when leading is
                                Just commentBox ->
                                    B.stack1 [ commentBox, item.box ]

                                Nothing ->
                                    item.box
                    in
                    Ok
                        { rows = Array.pushLast (applyIndent dropIndent droppedBox) (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }

                FP.BlankLineOnly ->
                    Ok
                        { rows = Array.pushLast B.blankLine (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }

                _ ->
                    Err "box: unexpected flow placement"

        step paired accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        let
                            item =
                                paired.item

                            decision =
                                FP.decide config acc.state (factsFor item)
                        in
                        when item.comment is
                            Just c ->
                                placeCommentItem acc decision c

                            Nothing ->
                                when paired.leading is
                                    Nothing ->
                                        placeNonComment acc decision Nothing item

                                    Just leadItem ->
                                        -- A single-line block comment paired with a
                                        -- type record (`pairTypeRecordComments`).
                                        -- When the policy drops the record, the
                                        -- comment drops WITH it; otherwise replay
                                        -- the exact unpaired steps (comment first,
                                        -- then re-decide the record against the
                                        -- state the comment left).
                                        when decision.placement is
                                            FP.DropBlock _ ->
                                                placeNonComment acc
                                                    decision
                                                    (leadItem.comment |> Maybe.map (\lc -> lc.box))
                                                    item

                                            _ ->
                                                when leadItem.comment is
                                                    Just lc ->
                                                        let
                                                            leadDecision =
                                                                FP.decide config acc.state (factsFor leadItem)
                                                        in
                                                        placeCommentItem acc leadDecision lc
                                                            |> Result.andThen
                                                                (\a ->
                                                                    let
                                                                        recDecision =
                                                                            FP.decide config a.state (factsFor item)
                                                                    in
                                                                    placeNonComment a recDecision Nothing item
                                                                )

                                                    Nothing ->
                                                        placeNonComment acc decision Nothing item
                    )
    in
    Array.foldl step
        (Ok { rows = [], curRow = [], state = FP.initialFlowState })
        (pairTypeRecordComments items)
        |> Result.andThen
            (\final ->
                let
                    allRows =
                        flushRow final.curRow final.rows
                in
                when Array.popFirst allRows is
                    Nothing ->
                        Err "box: empty flow"

                    Just { first, rest } ->
                        -- The first row sits at the flow's own column; every
                        -- continuation row is indented by `flowIndent`. This is
                        -- the Box form of the Doc's `R.nest indent` wrapping the
                        -- whole flow. Block rows already carry their own indent
                        -- (the placement applied it), so this brings them to
                        -- `flowIndent + ownIndent`.
                        Ok (B.stack1 ([ first ] ++ Array.map (applyIndent flowIndent) rest))
            )


-- The Box analogue of `MakeRender.softIndentedBlockChildForcesVertical`: a
-- `SoftIndentedBlock` whose SOLE child is a bracket literal (record, record
-- update, or array) that renders vertical switches from the soft glue to the
-- hard indented drop. The structural test is on the LPNode; the verticality
-- fact comes from this renderer's own box (single-line ‚áî the sole child is
-- single-line, since it is the block's only content).
softBlockChildForcesVerticalBox : FlowItem -> Bool
softBlockChildForcesVerticalBox item =
    when Array.popFirst (lpnChildren item.node) is
        Just { first = only, rest } ->
            if not (Array.isEmpty rest) then
                False

            else
                let
                    isBracketLiteral =
                        when lpnBox only is
                            AlwaysVertical _ ->
                                True

                            AllAcrossOrAllVertical _ ->
                                True

                            RecordUpdate _ ->
                                True

                            _ ->
                                False
                in
                isBracketLiteral && not (isSingleLine item.box)

        Nothing ->
            False


isEmptyLine : LPNode -> Bool
isEmptyLine node =
    when lpnBox node is
        EmptyLine ->
            True

        _ ->
            False


-- The synthesized signature `->` ‚Äî a zero-width `UnbreakableText` (start == end)
-- built by `LPTHelpers.mkZeroWidthText`, anchored at the end of its `from` type,
-- not where it renders. A comment directly trailing it must glue regardless of
-- source row (mirrors `MakeRender`'s `prevElided`, scoped to `->` by value: other
-- elided tokens precede a short neighbour or bracketed block where a comment on
-- its own row legitimately stays own-line).
isElidedArrow : LPNode -> Bool
isElidedArrow node =
    when lpnBox node is
        UnbreakableText loc ->
            loc.value == "->"
                && loc.start.row == loc.end.row
                && loc.start.col == loc.end.col

        _ ->
            False


{-| Apply `B.indent` (a Tab, advancing to the next multiple of 4) enough times
to reach `indent` columns from a multiple-of-4 origin. -}
applyIndent : Int -> Box -> Box
applyIndent indent box =
    if indent <= 0 then
        box

    else
        applyIndent (indent - 4) (B.indent box)


-- Traverse an Array with a Result-returning function, short-circuiting on Err.
traverseResult : (a -> Result e b) -> Array a -> Result e (Array b)
traverseResult f items =
    Array.foldl
        (\item acc ->
            acc
                |> Result.andThen
                    (\built ->
                        f item |> Result.map (\b -> Array.pushLast b built)
                    )
        )
        (Ok [])
        items
