module Formatter.Render.MakeRenderBox exposing (makePrettyLineBox)

{-| Box-model renderer ŌĆö the sole backend. It renders an LPT node to
elm-format's `Box` (Tab + prefix arithmetic), returning `Err` for any construct
it cannot render (the caller, `MakeRender.makePrettyLine`, surfaces that `Err`).

It handles every top-level definition kind: leaves, record / array literals,
flows and nested flows, blocks, pipelines, binops, `when`/`if`/`let`,
signatures, and comments ŌĆö each laid out to match elm-format.
-}

import Formatter.Render.Box as B exposing (Box(..))
import Formatter.Render.ElmStructure as E
import Formatter.Render.FlowPolicy as FP
import Formatter.Logical.LogicalPrintingTree exposing (LPBox(..), LPNode, ListBrackets(..), SyntaxType(..), lpnBox, lpnChildren, firstRowInSubtree, lpnMaxRow, lpnFirstPos, lpnBracketStart, lpnLastPos, lpnLastBracketEnd)
import Formatter.Logical.BinopPrecedence exposing (binopPrecedence, binopMinPrecedence)


grenIndent : Int
grenIndent =
    4


{-| Entry point: render one top-level root child to a Box, or Err to fall back. -}
makePrettyLineBox : LPNode -> Result String Box
makePrettyLineBox node =
    when lpnBox node is
        OriginalRows { stype = stype } ->
            when stype is
                StFunctionDeclaration ->
                    -- `buildFlowBox`'s comment machinery places inline,
                    -- standalone, and multi-line comments in a funcDecl body
                    -- directly. Anything it can't handle returns Err from within
                    -- the flow, which propagates to the caller.
                    buildFlowBox grenIndent (lpnChildren node)

                StFunctionSignature ->
                    makeSignatureBox (lpnChildren node)

                StPort ->
                    makeSignatureBox (lpnChildren node)

                StTypeAlias ->
                    renderHeaderIndentedBody makeTypeAliasBody (lpnChildren node)

                StTypeUnion ->
                    renderHeaderIndentedBody makeUnionBodyBox (lpnChildren node)

                StSingleLineComment ->
                    makeCommentLineBox (lpnChildren node)

                StBlockComment ->
                    makeCommentLineBox (lpnChildren node)

                StDocComment ->
                    makeCommentLineBox (lpnChildren node)

                StModule ->
                    makeExposingLineBox StModule (lpnChildren node)

                StImport ->
                    makeExposingLineBox StImport (lpnChildren node)

                StInfixDecl ->
                    -- `infix left 6 (+) = add` ŌĆö a flat single-line leaf flow,
                    -- same shape as a funcDecl (both render via `buildFlowBox`).
                    buildFlowBox grenIndent (lpnChildren node)

        EmptyLine ->
            -- A top-level blank separator. `B.blankLine` is `SingleLine (literal
            -- "")`, which renders to "" after the join's trimRight.
            Ok B.blankLine

        _ ->
            Err "box: root child not an OriginalRows funcDecl"


nodeIsComment : LPNode -> Bool
nodeIsComment node =
    when lpnBox node is
        SingleLineComment _ ->
            True

        BlockComment _ ->
            True

        DocComment _ ->
            True

        _ ->
            False


-- True when `node` or any descendant is a comment. Used to route a
-- comment-bearing construct to its comment-aware fallback rather than a
-- comment-oblivious layout.
subtreeHasComment : LPNode -> Bool
subtreeHasComment node =
    nodeIsComment node || Array.any subtreeHasComment (lpnChildren node)


-- True if the subtree contains a MULTI-LINE block comment ŌĆö the align-anchored
-- content that makes a nest-carrying first item's box heterogeneous (see the
-- AsFirst fence in `assembleFlowImpl`).
subtreeHasMultilineBlockComment : LPNode -> Bool
subtreeHasMultilineBlockComment node =
    when lpnBox node is
        BlockComment loc ->
            String.contains "\n" loc.value

        _ ->
            Array.any subtreeHasMultilineBlockComment (lpnChildren node)


-- True when the subtree contains a bracketed literal (record/array/record-update)
-- that holds a comment among its direct children ŌĆö i.e. a comment that forces the
-- bracket multi-line (`{ a : Int {- c -} }`). Used by `makeSignatureBox` to
-- detect a comment nested in a signature's record type, which elm-format keeps
-- glued inline but `assembleFlow` would otherwise drop to its own line.
typeHasCommentBracket : LPNode -> Bool
typeHasCommentBracket node =
    let
        isBracketBox =
            when lpnBox node is
                AllAcrossOrAllVertical _ ->
                    True

                AlwaysVertical _ ->
                    True

                RecordUpdate _ ->
                    True

                _ ->
                    False
    in
    (isBracketBox && Array.any nodeIsComment (lpnChildren node))
        || Array.any typeHasCommentBracket (lpnChildren node)


-- ŌĢÉŌĢÉŌĢÉ BINOPS ŌĢÉŌĢÉŌĢÉ


{-| Flatten the nested `Binop`/`OpAndRhs` tree into a flat operand + operator
list. Each operand is itself a flow (array of nodes). -}
flattenBinopNodes : Array LPNode -> { operands : Array (Array LPNode), ops : Array LPNode }
flattenBinopNodes children =
    when Array.popLast children is
        Nothing ->
            { operands = [], ops = [] }

        Just { last = lastNode, initial = operandNodes } ->
            when lpnBox lastNode is
                OpAndRhs ->
                    when Array.popFirst (lpnChildren lastNode) is
                        Just { first = opNode, rest = restChildren } ->
                            let
                                inner =
                                    flattenBinopNodes restChildren
                            in
                            { operands = [ operandNodes ] ++ inner.operands
                            , ops = [ opNode ] ++ inner.ops
                            }

                        Nothing ->
                            { operands = [ operandNodes ], ops = [] }

                _ ->
                    { operands = [ children ], ops = [] }


opText : LPNode -> String
opText node =
    Maybe.withDefault "" (leafValue node)


{-| Render a binary-operator chain. Groups break at minimum-precedence
operators (tighter operators join inline within a group); the author's row
layout picks inline vs one-group-per-line (+4, operator-led) ŌĆö matching
elm-format.

A multi-line operand (e.g. a `(when ŌĆ”)` paren-block) is supported in the
forced-vertical, one-group-per-line layout: its group is composed via
`B.prefix (op ++ " ")`, which pads the operand's continuation lines by the
operator width so they align under where the operand's first char lands. Any
multi-line operand joined *inline* to a higher-precedence sibling, and any
multi-line operand in a non-vertical chain, still returns Err. -}
makeBinopBox : Bool -> Array LPNode -> Result String Box
makeBinopBox forceVerticalArg children =
    let
        forceVertical =
            forceVerticalArg || bracketOperandForcesVertical children
    in
    if forceVertical then
        -- A forced-vertical chain ŌĆö whether or not it carries a comment ŌĆö renders
        -- with EVERY operator on its own line (`verticalBinopChainBox`), one
        -- comment-aware operand per segment. One renderer for both cases, so
        -- adding or removing a comment can never reflow the chain (the invariant
        -- the old two-path split risked). gren keeps a comment TRAILING the operand
        -- the author wrote it on (`++ beta {- c -}`) ŌĆö a deliberate divergence from
        -- elm-format, which re-homes it to lead the next operator (`{- c -} ++ b`).
        verticalBinopChainBox children
            |> Result.onError (\_ -> buildFlowBoxBroken grenIndent children)

    else if Array.any subtreeHasComment children then
        buildFlowBox grenIndent children

    else
        precedenceBinopBox children
            |> Result.onError (\_ -> buildFlowBox grenIndent children)


{-| True when a binop chain has a bracket-LITERAL operand (a record, array, or
record update) that renders multi-line ŌĆö either because the author broke it
across rows, or because a comment inside it forces it open. Such an operand
breaks the whole chain vertically (elm-format, and gren's own "multi-line content
opens the container" rule) instead of gluing the operator after the closing
`]`/`}`. A multi-line `"""ŌĆ”"""` string operand is deliberately NOT a bracket kind
and stays glued inline ŌĆö matching elm-format.

Decided HERE (render side, with comments already attached), keyed on the operand
node's own `spans-rows OR has-comment` ŌĆö not on the raw source layout of the
whole chain ŌĆö so inserting or removing a comment can never flip the decision (a
reparse fixed point). That is the same stability `commentAwareBinopBox` relies on:
a one-row bracket that a comment forces open reports `has-comment` in BOTH the
pre-break and post-break formats, so the chain breaks consistently. -}
bracketOperandForcesVertical : Array LPNode -> Bool
bracketOperandForcesVertical children =
    (flattenBinopNodes children).operands
        |> Array.any operandIsMultilineBracketLiteral


operandIsMultilineBracketLiteral : Array LPNode -> Bool
operandIsMultilineBracketLiteral operand =
    when Array.popFirst operand is
        Just { first = node, rest = rest } ->
            Array.isEmpty rest
                && isChainBreakingOperandBox (lpnBox node)
                && (nodeSpansRows node || subtreeHasComment node)

        Nothing ->
            False


{-| Operand box kinds whose multi-line form breaks a binop chain vertically: a
bracket literal (record / array / record update) or a parenthesized expression
(`(a\n+ b)`). A `MultilineString` is deliberately absent ŌĆö elm-format keeps a
multi-line string operand glued inline, and gren matches. -}
isChainBreakingOperandBox : LPBox -> Bool
isChainBreakingOperandBox box =
    when box is
        AllAcrossOrAllVertical _ ->
            True

        AlwaysVertical _ ->
            True

        RecordUpdate _ ->
            True

        ParenBlock _ ->
            True

        _ ->
            False


nodeSpansRows : LPNode -> Bool
nodeSpansRows node =
    when { f = lpnFirstPos node, l = lpnLastPos node } is
        { f = Just fp, l = Just lp } ->
            lp.row > fp.row

        _ ->
            False


-- The comment-aware flow: `buildFlowBox grenIndent` when inline,
{-| A forced-vertical binop chain: EVERY operator on its own line, the first
operand at the flow base and each following `op operand` indented +grenIndent.
Each operand renders comment-aware (`buildFlowBox 0`), so a comment the author
wrote trailing an operand rides that operand's segment line (`++ beta {- c -}`) ŌĆö
gren's uniform "a comment sticks to what it trails" rule. (elm-format instead
re-homes such a comment to lead the following operator; keeping it with the
operand is a deliberate divergence ŌĆö see the README.) Both comment-free and
comment-bearing chains use this one renderer, so adding or removing a comment
never reflows the chain. -}
verticalBinopChainBox : Array LPNode -> Result String Box
verticalBinopChainBox children =
    let
        flat =
            flattenBinopNodes children

        -- Render a run of own-line comment nodes to their own boxes.
        renderOwnLineComments nodes =
            traverseResult (\c -> buildFlowBox 0 [ c ]) nodes

        -- Render an operand's content: `buildFlowBoxInline` keeps a LEADING block
        -- comment glued on-line (`{- c -} 100`) rather than dropping the operand to
        -- its own row, matching how the operator segment should read.
        renderOperandContent nodes =
            buildFlowBoxInline 0 nodes
    in
    when Array.popFirst flat.operands is
        Just { first = op0nodes, rest = restOperands } ->
            let
                op0 =
                    splitTrailingOwnLineComments op0nodes

                segData =
                    Array.map2
                        (\op operandNodes -> { op = opText op, split = splitTrailingOwnLineComments operandNodes })
                        flat.ops
                        restOperands
            in
            renderOperandContent op0.content
                |> Result.andThen
                    (\firstBox ->
                        renderOwnLineComments op0.ownLine
                            |> Result.andThen
                                (\op0Comments ->
                                    traverseResult
                                        (\seg ->
                                            renderOperandContent seg.split.content
                                                |> Result.andThen
                                                    (\operandBox ->
                                                        renderOwnLineComments seg.split.ownLine
                                                            |> Result.map
                                                                (\segComments ->
                                                                    -- own-line comments lead the operator
                                                                    -- line's own follow-on comments trail it
                                                                    [ prefixOperator seg.op operandBox ] ++ segComments
                                                                )
                                                    )
                                        )
                                        segData
                                        |> Result.map
                                            (\segLineLists ->
                                                -- Every operator line + every own-line comment
                                                -- sits at +grenIndent; `firstBox` (operand0) at the base.
                                                let
                                                    indentedLines =
                                                        op0Comments ++ Array.flatten segLineLists
                                                in
                                                B.stack1 ([ firstBox ] ++ Array.map B.indent indentedLines)
                                            )
                                )
                    )

        Nothing ->
            Err "box: empty binop chain"


{-| Split an operand's node array into its content (the operand plus any INLINE
trailing comment, e.g. a block comment on the operand's own row) and the trailing
OWN-LINE comments (a `--` line comment, or a block comment the author put on a
later row). In a broken binop chain the content rides the operator line
(`++ beta {- inline -}`), while own-line comments render on their own line at the
operator indent (leading the next operator), matching how the author laid them
out. -}
splitTrailingOwnLineComments : Array LPNode -> { content : Array LPNode, ownLine : Array LPNode }
splitTrailingOwnLineComments nodes =
    let
        -- The operand's LAST rendered row, including a closing bracket the parser
        -- discards (`lpnLastBracketEnd`) ŌĆö so a comment on the `)`/`}` row of a
        -- multi-line paren/record operand counts as INLINE with it, not own-line
        -- (which would render it at the operator indent and then detach on reparse).
        contentRow =
            Array.foldl
                (\n acc ->
                    if nodeIsComment n then
                        acc

                    else
                        let
                            tokRow =
                                lpnLastPos n |> Maybe.map (\p -> p.row) |> Maybe.withDefault -1

                            brkRow =
                                lpnLastBracketEnd n |> Maybe.map (\p -> p.row) |> Maybe.withDefault -1
                        in
                        max acc (max tokRow brkRow)
                )
                -1
                nodes

        isOwnLineComment node =
            when lpnBox node is
                SingleLineComment _ ->
                    True

                BlockComment loc ->
                    loc.start.row > contentRow

                _ ->
                    False

        peeled =
            Array.foldr
                (\node acc ->
                    if acc.peeling && isOwnLineComment node then
                        { peeling = True, content = acc.content, ownLine = [ node ] ++ acc.ownLine }

                    else
                        { peeling = False, content = [ node ] ++ acc.content, ownLine = acc.ownLine }
                )
                { peeling = True, content = [], ownLine = [] }
                nodes
    in
    { content = peeled.content, ownLine = peeled.ownLine }


-- The inline layout: the whole chain on one line (`inlineBinopBox`), with a
-- multi-line trailing operand allowed to break below its opening column. `Err`
-- when a non-trailing operand is multi-line ŌĆö `makeBinopBox` catches that and
-- falls back to the comment-aware flow. (Forced-vertical chains never reach here;
-- they render one-operator-per-line via `verticalBinopChainBox`.)
precedenceBinopBox : Array LPNode -> Result String Box
precedenceBinopBox children =
    let
        flat =
            flattenBinopNodes children
    in
    when Array.popFirst flat.operands is
        Nothing ->
            Err "box: empty binop"

        Just { first = operand0, rest = _ } ->
            if Array.isEmpty flat.ops then
                buildFlowBox 0 operand0

            else
                -- Render every operand to a Box (multi-line allowed).
                traverseResult (buildFlowBox 0) flat.operands
                    |> Result.andThen
                        (\operandBoxes ->
                            assembleBinopBox
                                (binopMinPrecedence (Array.map opText flat.ops))
                                operandBoxes
                                (Array.map opText flat.ops)
                        )


-- Render an operator-precedence group (parts joined inline by higher-precedence
-- operators) to a single Box. A lone part is returned as-is (it may be
-- multi-line); two or more parts must all be single-line to inline-join.
renderBinopGroup : Array { op : String, box : Box } -> Result String Box
renderBinopGroup parts =
    when Array.popFirst parts is
        Nothing ->
            Err "box: empty binop group"

        Just { first = p0, rest } ->
            if Array.isEmpty rest then
                Ok p0.box

            else
                when B.isLine p0.box is
                    Err _ ->
                        Err "box: multi-line operand joined inline"

                    Ok l0 ->
                        traverseResult
                            (\p ->
                                when B.isLine p.box is
                                    Ok l ->
                                        Ok [ B.space, B.literal p.op, B.space, l ]

                                    Err _ ->
                                        Err "box: multi-line operand joined inline"
                            )
                            rest
                            |> Result.map
                                (\segs -> B.line (B.row (Array.flatten ([ [ l0 ] ] ++ segs))))


{-| Assemble the operand boxes + operator texts into the INLINE layout (the whole
chain on one line). `ops[k]` sits between `operandBoxes[k]` and
`operandBoxes[k+1]`. Groups break at operators whose precedence == `minPrec`;
tighter operators join inline within a group ŌĆö the grouping only matters for the
trailing-operand case. A forced-vertical chain never comes here (it renders
one-operator-per-line via `verticalBinopChainBox`). -}
assembleBinopBox : Int -> Array Box -> Array String -> Result String Box
assembleBinopBox minPrec operandBoxes ops =
    let
        firstBox =
            Maybe.withDefault (B.line (B.literal "")) (Array.first operandBoxes)

        paired =
            Array.map2 (\op nextBox -> { op = op, box = nextBox })
                ops
                (Array.dropFirst 1 operandBoxes)

        state =
            Array.foldl
                (\pair acc ->
                    if binopPrecedence pair.op == minPrec then
                        { firstGroup =
                            if acc.started then
                                acc.firstGroup

                            else
                                acc.curParts
                        , started = True
                        , segments =
                            if acc.started then
                                Array.pushLast { op = acc.pendingOp, parts = acc.curParts } acc.segments

                            else
                                acc.segments
                        , pendingOp = pair.op
                        , curParts = [ { op = "", box = pair.box } ]
                        }

                    else
                        { acc | curParts = Array.pushLast { op = pair.op, box = pair.box } acc.curParts }
                )
                { firstGroup = [ { op = "", box = firstBox } ]
                , started = False
                , segments = []
                , pendingOp = ""
                , curParts = [ { op = "", box = firstBox } ]
                }
                paired

        segments =
            Array.pushLast { op = state.pendingOp, parts = state.curParts } state.segments
    in
    renderBinopGroup state.firstGroup
        |> Result.andThen
            (\firstGroupBox ->
                traverseResult
                    (\seg -> Result.map (\b -> { op = seg.op, box = b }) (renderBinopGroup seg.parts))
                    segments
                    |> Result.andThen
                        (\segBoxes ->
                            -- Inline: the chain flows on one line. `Err` (rather
                            -- than a second fallback layout) when the first group
                            -- or a non-trailing group can't join inline ŌĆö the
                            -- caller (`makeBinopBox`) falls back to the same
                            -- comment-aware flow a comment anywhere in the chain
                            -- already routes through.
                            when inlineBinopBox firstGroupBox segBoxes is
                                Just box ->
                                    Ok box

                                Nothing ->
                                    Err "box: multi-line operand in non-vertical binop"
                        )
            )


-- The chain flows on one line. Every group must be single-line EXCEPT the
-- very last operand, which may be a multi-line node whose own lines break
-- below (a `"""ŌĆ”"""` literal opened mid-line). elm-format keeps the whole
-- chain concatenated and lets that operand's continuation land under its
-- opening column; Box builds the single-line prefix (`"a " ++ b ++`) and
-- `B.prefix`es it onto the trailing box, padding its continuation to the
-- same column. `Nothing` when the first group or a non-trailing group is
-- itself multi-line.
inlineBinopBox : Box -> Array { op : String, box : Box } -> Maybe Box
inlineBinopBox firstGroupBox segBoxes =
    when B.isLine firstGroupBox is
        Err _ ->
            Nothing

        Ok firstLine ->
            when Array.popLast segBoxes is
                Nothing ->
                    Just (B.line firstLine)

                Just { last = lastSeg, initial = initSegs } ->
                    Array.foldl
                        (\seg acc ->
                            when acc is
                                Nothing ->
                                    Nothing

                                Just parts ->
                                    when B.isLine seg.box is
                                        Ok l ->
                                            Just (Array.pushLast [ B.space, B.literal seg.op, B.space, l ] parts)

                                        Err _ ->
                                            Nothing
                        )
                        (Just [])
                        initSegs
                        |> Maybe.map
                            (\initParts ->
                                when B.isLine lastSeg.box is
                                    Ok lastLine ->
                                        -- All single-line: the whole chain on one row.
                                        B.line (B.row (Array.flatten ([ [ firstLine ] ] ++ initParts ++ [ [ B.space, B.literal lastSeg.op, B.space, lastLine ] ])))

                                    Err _ ->
                                        -- Trailing operand is multi-line: glue the
                                        -- single-line prefix onto its first line and
                                        -- pad its continuation to align.
                                        let
                                            prefixRow =
                                                B.row (Array.flatten ([ [ firstLine ] ] ++ initParts ++ [ [ B.space, B.literal lastSeg.op, B.space ] ]))
                                        in
                                        B.prefix prefixRow lastSeg.box
                            )


-- Prepend `op ` to a group box. A single-line box becomes one line; a
-- multi-line box uses `B.prefix`, which pads its continuation lines by the
-- operator width so they align under the operand's first char.
prefixOperator : String -> Box -> Box
prefixOperator op box =
    when B.isLine box is
        Ok l ->
            B.line (B.row [ B.literal op, B.space, l ])

        Err _ ->
            B.prefix (B.row [ B.literal op, B.space ]) box


isOpAndRhsNode : LPNode -> Bool
isOpAndRhsNode node =
    when lpnBox node is
        OpAndRhs ->
            True

        _ ->
            False


{-| Render an `OpAndRhs` node (`op` + the right-hand side flow). Reached only
from the comment-bearing binop flow (the comment-free path flattens `OpAndRhs`
via `flattenBinopNodes` instead). -}
makeOpAndRhsBox : Array LPNode -> Result String Box
makeOpAndRhsBox children =
    when Array.popFirst children is
        Nothing ->
            Err "box: empty OpAndRhs"

        Just { first = opNode, rest = rhsNodes } ->
            when leafValue opNode is
                Just op ->
                    -- Inline-start flow: a leading `{- c -}` in the rhs stays on
                    -- the operator's line (`* {- c -} 100`), via
                    -- `buildFlowBoxInline 0`. `prefixOperator` glues `op ` onto
                    -- the rhs ŌĆö its first line for a single-line rhs, or (via
                    -- `B.prefix`, padding continuation by the operator width) the
                    -- first line of a multi-line rhs such as an operand with a
                    -- trailing multi-line comment (`+ b {- multiŌĆ” -}`).
                    --
                    -- A rhs that also carries a NESTED `OpAndRhs` (a lower-precedence
                    -- continuation operand, `+ b {- mlbc -} * 2`) can't use `B.prefix`:
                    -- the comment body must shift with the operator while the nested
                    -- operand must stay at the operator's base column ŌĆö a per-line
                    -- mix of align vs ambient nest the uniform prefix can't produce.
                    -- The FOLD can, though: render the operator as the flow's own
                    -- first item ŌĆö the glued comment commits as its own
                    -- prefix-padded row (align preserved) and the nested group
                    -- lands on a fresh row at the flow's ambient column, matching
                    -- elm-format's `op ` + inline rhs.
                    buildFlowBoxInline 0 rhsNodes
                        |> Result.andThen
                            (\rhsBox ->
                                if not (isSingleLine rhsBox) && Array.any isOpAndRhsNode rhsNodes then
                                    buildFlowBoxInline 0 ([ opNode ] ++ rhsNodes)

                                else
                                    Ok (prefixOperator op rhsBox)
                            )

                Nothing ->
                    Err "box: OpAndRhs op is not a text leaf"


-- ŌĢÉŌĢÉŌĢÉ COMMENT LINES ŌĢÉŌĢÉŌĢÉ


{-| Render a standalone top-level comment-line item. Same-row block comments
join with a space; a `--` line comment (or a row change) starts a new line.
A multi-line block comment renders via `multiLineBlockCommentBox` (the reindent
stack). -}
makeCommentLineBox : Array LPNode -> Result String Box
makeCommentLineBox children =
    traverseResult commentNodeToBox children
        |> Result.andThen
            (\infos ->
                when Array.popFirst infos is
                    Nothing ->
                        Err "box: empty comment line"

                    Just { first = first0, rest } ->
                        Array.foldl
                            (\info accResult ->
                                accResult
                                    |> Result.andThen
                                        (\acc ->
                                            if acc.prevLine || info.row /= acc.prevRow then
                                                -- New line: stack the comment below.
                                                Ok
                                                    { box = B.stack1 [ acc.box, info.box ]
                                                    , prevRow = info.row
                                                    , prevLine = info.isLine
                                                    }

                                            else
                                                -- Same-row block comment: join with a
                                                -- space onto the accumulator's last line.
                                                -- A multi-line comment never reaches here
                                                -- (it always changes the row), so the
                                                -- box is single-line.
                                                when B.isLine info.box is
                                                    Ok l ->
                                                        Ok
                                                            { box = B.addSuffix (B.row [ B.space, l ]) acc.box
                                                            , prevRow = info.row
                                                            , prevLine = info.isLine
                                                            }

                                                    Err _ ->
                                                        Err "box: multi-line comment cannot space-join"
                                        )
                            )
                            (Ok { box = first0.box, prevRow = first0.row, prevLine = first0.isLine })
                            rest
                            |> Result.map .box
            )


-- Render one comment node to a Box, tagging its source row and whether it is a
-- `--` line comment (which always terminates its line): a multi-line block
-- comment reindents via `multiLineBlockCommentBox`; a doc comment's body is
-- emitted verbatim as a single literal (safe ŌĆö it is a standalone root child
-- ending in `-}`).
commentNodeToBox : LPNode -> Result String { box : Box, row : Int, isLine : Bool }
commentNodeToBox node =
    when lpnBox node is
        SingleLineComment loc ->
            Ok { box = B.line (B.literal ("--" ++ loc.value)), row = loc.start.row, isLine = True }

        BlockComment loc ->
            if String.contains "\n" loc.value then
                multiLineBlockCommentBox loc.value
                    |> Result.map (\b -> { box = b, row = loc.start.row, isLine = False })

            else
                Ok { box = B.line (B.literal ("{-" ++ loc.value ++ "-}")), row = loc.start.row, isLine = False }

        DocComment loc ->
            Ok { box = B.line (B.literal (docCommentString loc.value)), row = loc.start.row, isLine = False }

        _ ->
            -- unreachable: this function only ever runs on children of a
            -- comment-tagged OriginalRows, which Comments.gren/MakeLogical.gren
            -- always build as SingleLineComment, BlockComment, or DocComment.
            Err "unreachable: comment-line node"


{-| Render one comment child of an otherwise-empty bracket (`{ {- c -} }`) as a
single inline `Line`. Only a single-line block comment fits inline; anything
else (multi-line block, `--` line comment) can't be glued onto the one-line
bracket, so it Errs rather than silently drop the comment. -}
emptyBracketedCommentLine : LPNode -> Result String B.Line
emptyBracketedCommentLine node =
    when lpnBox node is
        BlockComment loc ->
            if String.contains "\n" loc.value then
                -- Not a crash: an `Err` here is the "can't fit the one-line form"
                -- signal that the `EmptyBracketed` arm catches and renders
                -- vertically instead (a multi-line block comment has no inline
                -- form).
                Err "box: empty-bracket comment is multi-line (caller renders vertically)"

            else
                Ok (B.literal ("{-" ++ loc.value ++ "-}"))

        _ ->
            -- Not a crash: same caught "no inline form" signal ŌĆö a `--` line
            -- comment can't sit inside a one-line `[ ŌĆ” ]`, so the caller drops to
            -- the vertical layout.
            Err "box: empty-bracket comment is a line comment (caller renders vertically)"


{-| Join `Line`s with a single space between each (`[a, b, c]` ŌåÆ `a b c`). -}
spaceJoinLines : Array B.Line -> Array B.Line
spaceJoinLines lines =
    Array.foldl
        (\ln acc ->
            if Array.isEmpty acc then
                [ ln ]

            else
                Array.pushLast ln (Array.pushLast B.space acc)
        )
        []
        lines


-- Render a doc comment's body into its `{-| ŌĆ” -}` string: an empty body
-- collapses to `{-| -}`; a body that both starts and ends with a single `\n`
-- (a multi-line doc comment whose content begins on the next line) gains a
-- trailing blank line before `-}` (elm-format's convention).
docCommentString : String -> String
docCommentString value =
    if String.isEmpty (String.trim value) then
        "{-| -}"

    else
        let
            normalizedValue =
                if
                    String.startsWith "\n" value
                        && String.endsWith "\n" value
                        && not (String.endsWith "\n\n" value)
                then
                    value ++ "\n"

                else
                    value
        in
        "{-|" ++ normalizedValue ++ "-}"


blockCommentBodyOffset : Int
blockCommentBodyOffset =
    3


leadingSpaceCount : String -> Int
leadingSpaceCount s =
    (String.foldl
        (\c acc ->
            if acc.done then
                acc

            else if c == ' ' then
                { acc | count = acc.count + 1 }

            else
                { acc | done = True }
        )
        { count = 0, done = False }
        s
    ).count


{-| Render a multi-line block comment as a stack of lines: the first line
verbatim, each continuation line reindented so the smallest content indent maps
to `blockCommentBodyOffset` (deeper indentation kept relative), a bare closing
delimiter or blank line trimmed. Box stacking anchors the block under wherever
the opener prints. This reindent applies to every multi-line block
comment, including the opener-alone form (the opener sitting on its own first
line) ŌĆö matching elm-format, which likewise reindents rather than preserving
the author's absolute columns.
-}
multiLineBlockCommentBox : String -> Result String Box
multiLineBlockCommentBox value =
    let
        fullText =
            "{-" ++ value ++ "-}"
    in
    when Array.popFirst (String.split "\n" fullText) is
        Nothing ->
            Ok (B.line (B.literal fullText))

        Just { first = firstLine, rest = contLines } ->
            let
                isContentLine line =
                    let
                        t =
                            String.trimLeft line
                    in
                    t /= "" && t /= "-}"

                base =
                    contLines
                        |> Array.keepIf isContentLine
                        |> Array.map leadingSpaceCount
                        |> Array.minimum
                        |> Maybe.withDefault blockCommentBodyOffset

                reindent line =
                    let
                        t =
                            String.trimLeft line
                    in
                    if t == "" || t == "-}" then
                        t

                    else
                        let
                            l =
                                leadingSpaceCount line
                        in
                        String.repeat (max 0 (blockCommentBodyOffset + l - base)) " "
                            ++ String.dropFirst l line

                allLines =
                    [ firstLine ] ++ Array.map reindent contLines
            in
            Ok (B.stack1 (Array.map (\ln -> B.line (B.literal ln)) allLines))


-- ŌĢÉŌĢÉŌĢÉ TYPE ALIAS & UNION DECLARATIONS ŌĢÉŌĢÉŌĢÉ


{-| Header + indented body: `type alias Name =` / body, `type Name` / variants ŌĆö
header inline, body dropped +4 (elm-format). -}
renderHeaderIndentedBody : (Array LPNode -> Result String Box) -> Array LPNode -> Result String Box
renderHeaderIndentedBody bodyRenderer children =
    when Array.popLast children is
        Nothing ->
            Err "box: empty declaration"

        Just { initial = header, last = bodyBlock } ->
            buildFlowBox 0 header
                |> Result.andThen
                    (\headerBox ->
                        bodyRenderer (lpnChildren bodyBlock)
                            |> Result.map
                                (\bodyBox -> B.stack1 [ headerBox, B.indent bodyBox ])
                    )


-- A type-alias body: a single type node (record, or a plain `= Int`-style
-- type) renders as-is; a multi-line function type (`->` segments) isn't ported
-- and falls back.
makeTypeAliasBody : Array LPNode -> Result String Box
makeTypeAliasBody nodes =
    buildFlowBox 0 nodes


{-| A union body: each variant (`= A`, `| B`) on its own line when the author
wrote them across rows, or inline `= A | B | C` when on one line. Comment-bearing
unions render vertically. -}
makeUnionBodyBox : Array LPNode -> Result String Box
makeUnionBodyBox nodes =
    let
        variantNodes =
            Array.keepIf (\n -> not (nodeIsComment n)) nodes

        vertical =
            Array.any nodeIsComment nodes
                || rowsSpanMultiple (Array.map firstRowInSubtree variantNodes)
    in
    if vertical then
        makeUnionBodyVerticalBox nodes

    else
        traverseResult (\n -> buildFlowBox 0 (lpnChildren n)) variantNodes
            |> Result.andThen
                (\variantBoxes ->
                    when joinInline variantBoxes is
                        Just l ->
                            Ok l

                        Nothing ->
                            -- A variant's payload is inherently multi-line (a
                            -- record type spread across rows) even though every
                            -- `|` sits on the same source row. Fall back to the
                            -- already-correct vertical (one-variant-per-line)
                            -- rendering, which handles a multi-line variant box
                            -- fine via B.stack1/B.prefix.
                            makeUnionBodyVerticalBox nodes
                )


{-| Always-vertical union body with comment siblings: one variant per line; a
comment on the same row as the variant it trails is appended inline
(`B.addSuffix`), one on its own
row renders on its own line. A variant's "last row" is `max(lpnLastPos,
lpnLastBracketEnd)` ŌĆö NOT `lpnMaxRow`, which a multi-line block comment inside the
variant would widen, shifting a trailing comment to its own line (non-idempotent).
A multi-line block-comment SIBLING (rare) falls back. -}
makeUnionBodyVerticalBox : Array LPNode -> Result String Box
makeUnionBodyVerticalBox nodes =
    let
        placeComment acc row commentBox =
            when Array.popLast acc.boxes is
                Just { last = lastBox, initial } ->
                    if row == acc.prevRow && acc.prevRow >= 0 then
                        { acc
                            | boxes = Array.pushLast (glueCommentSuffix commentBox lastBox) initial
                            , prevRow = row
                        }

                    else
                        { acc | boxes = Array.pushLast commentBox acc.boxes, prevRow = row }

                Nothing ->
                    { acc | boxes = [ commentBox ], prevRow = row }

        variantLastRow node =
            let
                tokenRow =
                    lpnLastPos node |> Maybe.map (\p -> p.row) |> Maybe.withDefault -1

                bracketRow =
                    lpnLastBracketEnd node |> Maybe.map (\p -> p.row) |> Maybe.withDefault -1

                maxR =
                    max tokenRow bracketRow
            in
            if maxR >= 0 then
                maxR

            else
                firstRowInSubtree node
    in
    Array.foldl
        (\node accResult ->
            accResult
                |> Result.andThen
                    (\acc ->
                        when lpnBox node is
                            SingleLineComment loc ->
                                commentNodeBox node
                                    |> Result.map (\cbox -> placeComment acc loc.start.row cbox)

                            BlockComment loc ->
                                -- Same-row: glue onto the preceding variant's last
                                -- line (multi-line comments padded under their start
                                -- by `glueCommentSuffix`). Own row: the comment box
                                -- (reindented if multi-line) stands on its own line.
                                commentNodeBox node
                                    |> Result.map (\cbox -> placeComment acc loc.start.row cbox)

                            _ ->
                                buildFlowBox 0 (lpnChildren node)
                                    |> Result.map
                                        (\childBox ->
                                            { boxes = Array.pushLast childBox acc.boxes, prevRow = variantLastRow node }
                                        )
                    )
        )
        (Ok { boxes = [], prevRow = -1 })
        nodes
        |> Result.andThen
            (\acc ->
                when Array.first acc.boxes is
                    Nothing ->
                        Err "box: union has no variants"

                    Just _ ->
                        Ok (B.stack1 acc.boxes)
            )


-- True when the given source rows are not all equal (the author spread items
-- across rows).
rowsSpanMultiple : Array Int -> Bool
rowsSpanMultiple rows =
    when Array.popFirst rows is
        Nothing ->
            False

        Just { first, rest } ->
            Array.any (\r -> r /= first) rest


-- ŌĢÉŌĢÉŌĢÉ PIPELINES ŌĢÉŌĢÉŌĢÉ


isPipelineStepNode : LPNode -> Bool
isPipelineStepNode node =
    when lpnBox node is
        PipelineStep ->
            True

        _ ->
            False


{-| Render a forward (`|>`) pipeline: seed then each `|> step` on its own line
at +4 (or inline `seed |> a |> b` when the author kept it on one line), matching
elm-format. A comment-bearing pipeline routes through the generic fold
(`buildFlowBox 0`), where the PipelineStepItem placement and
`renderPipelineStepChildren`'s peels handle each step's comments. Backward (`<|`)
pipelines have their own path. -}
makePipelineBox : Bool -> String -> Array LPNode -> Result String Box
makePipelineBox forceVertical op children =
    if op == "<|" then
        makeBackwardPipelineBox forceVertical children

    else if op /= "|>" then
        -- unreachable: Pipeline.op is only ever constructed as "|>" or "<|"
        -- (InsertExpressions.gren), and "<|" is handled by the branch above.
        Err "unreachable: pipeline operator"

    else if Array.any subtreeHasComment children then
        -- Comment-bearing forward pipeline: route through the generic fold ŌĆö
        -- the per-step comment handling (leading peel, trailing glue,
        -- blank-before-commented-step) lives in the fold's PipelineStepItem
        -- placement + the PipelineStep arm of `makePBox`.
        buildFlowBox 0 children

    else
        let
            seedNodes =
                Array.keepIf (\n -> not (isPipelineStepNode n)) children

            stepNodes =
                Array.keepIf isPipelineStepNode children
        in
        buildFlowBox 0 seedNodes
            |> Result.andThen
                (\seedBox ->
                    traverseResult renderPipelineStep stepNodes
                        |> Result.andThen
                            (\stepBoxes ->
                                if forceVertical then
                                    Ok (B.stack1 ([ seedBox ] ++ Array.map B.indent stepBoxes))

                                else
                                    when joinInline ([ seedBox ] ++ stepBoxes) is
                                        Just l ->
                                            Ok l

                                        Nothing ->
                                            -- A step is inherently multi-line (a
                                            -- multi-line string/record argument)
                                            -- even though the author kept the
                                            -- pipeline itself on one row. Fall back
                                            -- to the exact same comment-aware flow
                                            -- a comment anywhere in the pipeline
                                            -- already routes through above, rather
                                            -- than a second layout of our own that
                                            -- could disagree with it (the binop
                                            -- fallback took the shortcut of
                                            -- reproducing that layout locally and
                                            -- it silently diverged under a
                                            -- comment ŌĆö see commentAwareBinopBox).
                                            buildFlowBox 0 children
                            )
                )


-- One `|> step`. Rendered via `buildFlowBox grenIndent`: the operator + function
-- stay inline (`|> f`) and a multi-line block argument (a record / array /
-- `when` / `if` / `let` that forces vertical) relocates to the next line at +4.
-- A single-line step renders identically at any flow indent.
--
-- A multi-line step whose argument is a `ParenBlock` (a multi-line lambda `\x ->`,
-- a parens-with-multiline-content, or a direct `|> (\x -> ŌĆ”)` operand) gets
-- elm-format-specific relocation (`makeMultilineLambdaArgBox` /
-- `makeMultilineParenArgBox`, or stays glued) that `assembleFlow`'s generic block
-- drop doesn't reproduce ŌĆö so those take the trigger-split path. A single-line
-- ParenBlock argument (`|> f (g x)`) is fine (it renders inline).
-- ŌĢÉŌĢÉŌĢÉ pipeline-step trigger classification ŌĢÉŌĢÉŌĢÉ


{-| True when `node`'s rendered Box spans multiple rows. -}
nodeForcesVerticalBox : LPNode -> Bool
nodeForcesVerticalBox node =
    when makePBox (lpnBox node) (lpnChildren node) is
        Ok b ->
            not (isSingleLine b)

        Err _ ->
            False


-- A non-comment node that renders multi-line forces the surrounding flow
-- vertical.
flowChildForcesVerticalBox : LPNode -> Bool
flowChildForcesVerticalBox node =
    not (nodeIsComment node) && nodeForcesVerticalBox node


-- A subtree that always produces a hard break (an AlwaysVertical/RecordUpdate,
-- or a comment-bearing literal).
subtreeHasVerticalBox : LPNode -> Bool
subtreeHasVerticalBox node =
    when lpnBox node is
        AlwaysVertical _ ->
            True

        RecordUpdate _ ->
            True

        AllAcrossOrAllVertical _ ->
            Array.any nodeIsComment (lpnChildren node)
                || Array.any subtreeHasVerticalBox (lpnChildren node)

        _ ->
            Array.any subtreeHasVerticalBox (lpnChildren node)


-- A ParenBlock whose second child is an `IndentedBlock` (the author wrote the
-- lambda body on a later row).
isMultilineLambdaParenBlockBox : LPNode -> Bool
isMultilineLambdaParenBlockBox node =
    when lpnBox node is
        ParenBlock _ ->
            when Array.get 1 (lpnChildren node) is
                Just secondChild ->
                    when lpnBox secondChild is
                        IndentedBlock ->
                            True

                        _ ->
                            False

                Nothing ->
                    False

        _ ->
            False


-- Broader than the above ŌĆö an `IndentedBlock` body, or a `SoftIndentedBlock`
-- body that its own content forces vertical. Used by the direct-operand guard.
isMultilineLambdaParenBlockAnyBodyBox : LPNode -> Bool
isMultilineLambdaParenBlockAnyBodyBox node =
    when lpnBox node is
        ParenBlock _ ->
            when Array.get 1 (lpnChildren node) is
                Just secondChild ->
                    when lpnBox secondChild is
                        IndentedBlock ->
                            True

                        SoftIndentedBlock ->
                            softIndentedBlockChildForcesVerticalBox (lpnChildren secondChild)

                        _ ->
                            False

                Nothing ->
                    False

        _ ->
            False


-- A ParenBlock whose content subtree will span rows (contains an AlwaysVertical
-- / RecordUpdate).
isMultilineContentParenBlockBox : LPNode -> Bool
isMultilineContentParenBlockBox node =
    when lpnBox node is
        ParenBlock _ ->
            Array.any subtreeHasVerticalBox (lpnChildren node)

        _ ->
            False


{-| Split a pipeline step's children at its *trigger* ŌĆö the first node that
breaks onto its own line: a multi-line lambda-argument paren, a multi-line
content paren, or any other multi-line-forcing node such as a record argument.
A left-to-right split matching elm-format, including the direct-operand-lambda
exclusion (`|> (\x -> ŌĆ”)` stays glued to the operator). `Nothing` = no trigger. -}
splitStepTrigger : Array LPNode -> Maybe { preamble : Array LPNode, trigger : LPNode, suffix : Array LPNode }
splitStepTrigger stepChildren =
    (Array.foldl
        (\node acc ->
            when acc.split is
                Just s ->
                    { acc | split = Just { s | suffix = Array.pushLast node s.suffix } }

                Nothing ->
                    let
                        isDirectOperandLambda =
                            isMultilineLambdaParenBlockAnyBodyBox node
                                && Array.length acc.preamble <= 1
                    in
                    if
                        not isDirectOperandLambda
                            && (isMultilineLambdaParenBlockBox node
                                    || isMultilineContentParenBlockBox node
                                    || flowChildForcesVerticalBox node
                               )
                    then
                        { acc | split = Just { preamble = acc.preamble, trigger = node, suffix = [] } }

                    else
                        { acc | preamble = Array.pushLast node acc.preamble }
        )
        { preamble = [], split = Nothing }
        stepChildren
    ).split


{-| Render a relocated multi-line lambda argument `(\args ->` ŌĆ” `)` ŌĆö head glued
to `(`, body at `(` + grenIndent, `)` on its own line at the `(` column
(elm-format). elm-format anchors everything at the `(` column; here the box's
own origin IS that column (the caller drops the trigger box at its indent), so
plain stacking reproduces it. The `(` glue is FIRST-LINE-ONLY: the head flow's
own breaks (an own-line comment between lambda params) land at the align
level ŌĆö the `(` COLUMN, one left of the head's first character ŌĆö so the
head box's continuation rows must stay at the box origin, not be padded by
the `(` width (`B.prefix` put them one column deep ŌĆö KitchenComments'
destructuring-lambda-head comment). Align-carrying content INSIDE the head
(a multi-line pattern literal) already carries its own prefix-padding from
the head's inner fold, which survives the first-line glue untouched. -}
makeMultilineLambdaArgBox : Array LPNode -> Result String Box
makeMultilineLambdaArgBox children =
    let
        glueParen headBox =
            B.mapFirstLine (\l -> B.row [ B.punc "(", l ]) identity headBox
    in
    when Array.popFirst children is
        Nothing ->
            Err "box: multiline lambda paren: no children"

        Just { first = headNode, rest = afterHead } ->
            buildFlowBoxInline 0 (lpnChildren headNode)
                |> Result.andThen
                    (\headBox ->
                        when Array.first afterHead is
                            Nothing ->
                                Ok (B.addSuffix (B.punc ")") (glueParen headBox))

                            Just bodyNode ->
                                buildFlowBox 0 (lpnChildren bodyNode)
                                    |> Result.map
                                        (\bodyBox ->
                                            B.stack1
                                                [ glueParen headBox
                                                , applyIndent grenIndent bodyBox
                                                , B.line (B.punc ")")
                                                ]
                                        )
                    )


-- True when a ParenBlock's content is a lambda (`(\x -> ŌĆ”)`) rather than an
-- `if`/`when`/`let` ŌĆö identified by the first child's box (matching
-- `makeParenBlockBox`'s content dispatch). Guards the direct-operand lambda split
-- against mangling a paren-`if`/`when` (whose branches are also blocks).
parenContentIsLambdaHead : LPNode -> Bool
parenContentIsLambdaHead node =
    when Array.first (lpnChildren node) is
        Just headNode ->
            when lpnBox headNode is
                IfCondition _ ->
                    False

                WhenFlow _ ->
                    False

                UnbreakableText loc ->
                    loc.value /= "let"

                _ ->
                    True

        Nothing ->
            False


{-| Split a direct-operand multi-line lambda ParenBlock (`(\x -> body)`) into its
head line (`\x ->`) and rendered body box, for the soft-glue direct-operand
render. `Nothing` if it isn't a multi-line lambda paren, has a multi-line head
(a comment among the params), or fails to render ŌĆö those fall back. -}
directOperandLambdaSplit : LPNode -> Maybe { headLine : B.Line, bodyBox : Box }
directOperandLambdaSplit node =
    -- `isMultilineLambdaParenBlockAnyBodyBox` only checks the SECOND child is a
    -- block, which is also true for a paren-`if`/`when` (its first branch is a
    -- block) ŌĆö splitting one as `[head, body]` would drop the remaining
    -- branches. Require the FIRST child to be a lambda head (not an
    -- `if`/`when`/`let`), matching `makeParenBlockBox`'s content dispatch.
    if not (isMultilineLambdaParenBlockAnyBodyBox node) || not (parenContentIsLambdaHead node) then
        Nothing

    else
        when Array.popFirst (lpnChildren node) is
            Just { first = headNode, rest = afterHead } ->
                when Array.first afterHead is
                    Just bodyNode ->
                        when
                            { h = buildFlowBoxInline 0 (lpnChildren headNode)
                            , b = buildFlowBox 0 (lpnChildren bodyNode)
                            }
                        is
                            { h = Ok headBox, b = Ok bodyBox } ->
                                when B.isLine headBox is
                                    Ok headLine ->
                                        Just { headLine = headLine, bodyBox = bodyBox }

                                    Err _ ->
                                        Nothing

                            _ ->
                                Nothing

                    Nothing ->
                        Nothing

            Nothing ->
                Nothing


{-| Render a relocated non-lambda multi-line paren argument ŌĆö content glued to
`(`, `)` on its own line at the `(` column (elm-format). The vertical content
(an `AlwaysVertical` / bracket literal) aligns itself at the `(` + 1 column;
`B.prefix`'s exact-width padding produces that for punctuation-prefixed
continuation lines. -}
makeMultilineParenArgBox : Array LPNode -> Result String Box
makeMultilineParenArgBox children =
    buildFlowBoxInline 0 children
        |> Result.map
            (\innerBox ->
                B.stack1 [ B.prefix (B.punc "(") innerBox, B.line (B.punc ")") ]
            )


-- One `|> step`. A step with a *trigger* (see `splitStepTrigger`) relocates it:
-- the preamble (`|> fn ŌĆ”`) glues inline, the trigger drops to its own line at
-- +grenIndent (relative to the step's own base ŌĆö the pipeline assembler adds
-- the step's +4 from the seed), and any suffix args land below it at the same
-- indent. The trigger box dispatch: the two ParenBlock kinds get the paren-arg
-- reshaping, everything else its normal box. A multi-line step with NO trigger
-- (a direct-operand lambda paren that must stay glued to `|>`, or a
-- comment-bearing step needing comment-peeling) falls back.
renderPipelineStep : LPNode -> Result String Box
renderPipelineStep stepNode =
    renderPipelineStepChildren (lpnChildren stepNode)


{-| Render a pipeline step's children: peel ALL leading comments (each on its
own line above the `|>`, at the step's own column ŌĆö the caller's step wrap
indents the whole box), peel trailing inline comments off the END
(`peelTrailingCommentNodes`, glued onto the step's last line with a space),
then render the remaining children via the trigger split. Mid-flow comments
stay in the body and flow through the preamble/suffix folds. -}
renderPipelineStepChildren : Array LPNode -> Result String Box
renderPipelineStepChildren allChildren =
    let
        { leading, rest } =
            spanLeadingComments allChildren

        { bodyNodes, trailing } =
            peelTrailingCommentNodes rest
    in
    traverseResult commentNodeBox leading
        |> Result.andThen
            (\leadingBoxes ->
                stepBodyBox bodyNodes
                    |> Result.andThen (\bodyBox -> glueTrailingComments bodyBox trailing)
                    |> Result.map (\withTrailing -> B.stack1 (leadingBoxes ++ [ withTrailing ]))
            )


-- The comment-free core of a pipeline step: the trigger split over the body
-- children (leading/trailing comments already peeled by
-- `renderPipelineStepChildren`).
stepBodyBox : Array LPNode -> Result String Box
stepBodyBox children =
    when splitStepTrigger children is
        Nothing ->
            -- No relocatable trigger arg: render the step body as a plain flow.
            -- It can still be multi-line (e.g. a block comment among the tokens
            -- forces a break, as in `|> {- ŌĆ” -} Array.foldl (+) 0`) ŌĆö there is
            -- nothing to relocate, so `buildFlowBox` lays it out directly.
            buildFlowBox grenIndent children

        Just { preamble, trigger, suffix } ->
            let
                triggerBoxResult =
                    if isMultilineLambdaParenBlockBox trigger then
                        makeMultilineLambdaArgBox (lpnChildren trigger)

                    else if isMultilineContentParenBlockBox trigger then
                        makeMultilineParenArgBox (lpnChildren trigger)

                    else
                        makePBox (lpnBox trigger) (lpnChildren trigger)
            in
            buildFlowBoxInline 0 preamble
                |> Result.andThen
                    (\preambleBox ->
                        triggerBoxResult
                            |> Result.andThen
                                (\triggerBox ->
                                    if Array.isEmpty suffix then
                                        Ok (B.stack1 [ preambleBox, applyIndent grenIndent triggerBox ])

                                    else
                                        buildFlowBox 0 suffix
                                            |> Result.map
                                                (\suffixBox ->
                                                    B.stack1
                                                        [ preambleBox
                                                        , applyIndent grenIndent triggerBox
                                                        , applyIndent grenIndent suffixBox
                                                        ]
                                                )
                                )
                    )


-- Get a box's sole line, or Err if it is multi-line.
boxLine : Box -> Result String B.Line
boxLine box =
    when B.isLine box is
        Ok l ->
            Ok l

        Err _ ->
            Err "box: expected single-line box"


{-| Render a backward (`<|`) pipeline: the `<|` trails the seed (or previous step
body), and the next body drops to the line below at +4 (inline when the author
kept the whole chain on one row and every part is single-line). A multi-line
seed glues its `<|` onto its own last line; a multi-line body forces the +4 drop
even when the author kept `<|` on the seed row. A lambda step body (`\x -> ŌĆ”`
authored across rows) breaks with the head at +4 and its body at +8. A boundary
comment or a mixed `|>`/`<|` chain routes to the operator-leading fallbacks. -}
makeBackwardPipelineBox : Bool -> Array LPNode -> Result String Box
makeBackwardPipelineBox forceVertical children =
    let
        stepNodes =
            Array.keepIf isPipelineStepNode children

        seedNodes =
            Array.keepIf (\n -> not (isPipelineStepNode n)) children

        stepFirstIsComment stepNode =
            when Array.first (lpnChildren stepNode) is
                Just firstChild ->
                    nodeIsComment firstChild

                Nothing ->
                    False

        stepLastIsComment stepNode =
            when Array.last (lpnChildren stepNode) is
                Just lastChild ->
                    nodeIsComment lastChild

                Nothing ->
                    False

        hasBoundaryComment =
            Array.any
                (\n ->
                    if isPipelineStepNode n then
                        stepFirstIsComment n || stepLastIsComment n

                    else
                        nodeIsComment n
                )
                children

        -- The operator is the first NON-comment child (a step may lead with an
        -- own-line comment before `<|`).
        stepOpIsBackward stepNode =
            when Array.first (Array.keepIf (\n -> not (nodeIsComment n)) (lpnChildren stepNode)) is
                Just opNode ->
                    leafValue opNode == Just "<|"

                Nothing ->
                    False

        allBackward =
            Array.all stepOpIsBackward stepNodes
    in
    if not allBackward then
        -- A mixed `|>`/`<|` chain (flattenPipeline merges them into one flat
        -- array tagged by the outermost op) renders operator-LEADING via the
        -- generic flow fold (`buildFlowBox 0 children`) for the same
        -- `not allStepsBackward` case.
        buildFlowBox 0 children

    else if hasBoundaryComment then
        -- A comment at a step boundary (own-line leading comment before `<|`, or a
        -- trailing comment after a step body) switches to operator-LEADING layout:
        -- seed on its own line, then each step at +4 as `<| body` with leading
        -- comments own-line above it and trailing comments glued to the body's
        -- last line.
        makeBackwardCommentedPipeline seedNodes stepNodes

    else
        buildFlowBox 0 seedNodes
            |> Result.andThen
                (\seedBox ->
                    -- The seed is kept as a Box (not collapsed to a Line): a
                    -- multi-line seed (a broken record/array/parenthesized binop)
                    -- glues ` <|` onto its LAST line via `B.addSuffix`, so the
                    -- trailing-operator style extends to a multi-line seed the
                    -- same way it works for a single-line one.
                    traverseResult
                        (\stepNode ->
                            when Array.popFirst (lpnChildren stepNode) is
                                Just { rest = bodyNodes } ->
                                    Ok bodyNodes

                                Nothing ->
                                    Err "box: backward pipeline step has no children"
                        )
                        stepNodes
                        |> Result.andThen (assembleBackwardPipeline forceVertical seedBox)
                )


-- Split a run of leading comment nodes off the front of a step's children.
spanLeadingComments : Array LPNode -> { leading : Array LPNode, rest : Array LPNode }
spanLeadingComments nodes =
    let
        go remaining acc =
            when Array.popFirst remaining is
                Just { first, rest } ->
                    if nodeIsComment first then
                        go rest (Array.pushLast first acc)

                    else
                        { leading = acc, rest = remaining }

                Nothing ->
                    { leading = acc, rest = [] }
    in
    go nodes []


-- Split a run of trailing comment nodes off the end of a step's children.
spanTrailingComments : Array LPNode -> { body : Array LPNode, trailing : Array LPNode }
spanTrailingComments nodes =
    let
        go remaining acc =
            when Array.popLast remaining is
                Just { last, initial } ->
                    if nodeIsComment last then
                        go initial ([ last ] ++ acc)

                    else
                        { body = remaining, trailing = acc }

                Nothing ->
                    { body = [], trailing = acc }
    in
    go nodes []


-- Peel trailing comments off a block body / forward pipeline step: single-line
-- block comments freely and at most ONE `--` line comment ŌĆö the rightmost,
-- since a `--` consumes the rest of its line and a second one to its left would
-- swallow it. A multi-line block comment stops the peel (it legitimately breaks
-- the line and stays in the flow). Unlike `spanTrailingComments` (the backward-
-- pipeline helper, which takes every trailing comment), this keeps the discipline
-- that the peeled run is always inline-gluable (elm-format).
peelTrailingCommentNodes : Array LPNode -> { bodyNodes : Array LPNode, trailing : Array LPNode }
peelTrailingCommentNodes nodes =
    let
        go remaining acc sawLineComment =
            when Array.popLast remaining is
                Just { last, initial } ->
                    when lpnBox last is
                        SingleLineComment _ ->
                            if sawLineComment then
                                { bodyNodes = remaining, trailing = acc }

                            else
                                go initial ([ last ] ++ acc) True

                        BlockComment loc ->
                            if String.contains "\n" loc.value then
                                { bodyNodes = remaining, trailing = acc }

                            else
                                go initial ([ last ] ++ acc) sawLineComment

                        _ ->
                            { bodyNodes = remaining, trailing = acc }

                Nothing ->
                    { bodyNodes = remaining, trailing = acc }
    in
    go nodes [] False


-- Glue single-line trailing comments onto a box's last line, each with a space.
glueTrailingComments : Box -> Array LPNode -> Result String Box
glueTrailingComments box trailing =
    Array.foldl
        (\c accResult ->
            accResult
                |> Result.andThen
                    (\b ->
                        commentNodeBox c
                            |> Result.map (\cbox -> glueCommentSuffix cbox b)
                    )
        )
        (Ok box)
        trailing


{-| Render a comment-bearing backward (`<|`) pipeline in operator-LEADING layout:
the seed on its own line, then each step at +grenIndent. A step renders as its
leading comments (own line) stacked above `<| body`, with trailing comments glued
onto the body's last line. -}
makeBackwardCommentedPipeline : Array LPNode -> Array LPNode -> Result String Box
makeBackwardCommentedPipeline seedNodes stepNodes =
    buildFlowBox 0 seedNodes
        |> Result.andThen
            (\seedBox ->
                traverseResult renderCommentedBackwardStep stepNodes
                    |> Result.map
                        (\stepBoxLists ->
                            B.stack1 ([ seedBox ] ++ Array.map (applyIndent grenIndent) (Array.flatten stepBoxLists))
                        )
            )


renderCommentedBackwardStep : LPNode -> Result String (Array Box)
renderCommentedBackwardStep stepNode =
    let
        { leading, rest } =
            spanLeadingComments (lpnChildren stepNode)

        { body, trailing } =
            spanTrailingComments rest
    in
    traverseResult commentNodeBox leading
        |> Result.andThen
            (\leadingBoxes ->
                buildFlowBox 0 body
                    |> Result.andThen
                        (\bodyBox ->
                            glueTrailingComments bodyBox trailing
                                |> Result.map (\bodyWithTrailing -> leadingBoxes ++ [ bodyWithTrailing ])
                        )
            )


assembleBackwardPipeline : Bool -> Box -> Array (Array LPNode) -> Result String Box
assembleBackwardPipeline forceVertical seedBox stepBodies =
    when stepBodies is
        [ bodyNodes ] ->
            backwardSingleStep forceVertical seedBox bodyNodes

        _ ->
            backwardMultiStep forceVertical seedBox stepBodies


-- A single `seed <| body` step. A trailing `IndentedBlock` marks a lambda body
-- authored across rows (`\head` at +4, its body at +8); otherwise a plain body
-- drops to +4 (or stays inline when the chain isn't forced vertical).
backwardSingleStep : Bool -> Box -> Array LPNode -> Result String Box
backwardSingleStep forceVertical seedBox bodyNodes =
    when Array.popLast bodyNodes is
        Nothing ->
            Err "box: backward pipeline empty body"

        Just { last = lastNode, initial = headNodes } ->
            when lpnBox lastNode is
                IndentedBlock ->
                    -- Lambda authored across rows: seed <| \n head+4 \n body+8.
                    Result.map2
                        (\headBox bodyBox ->
                            B.stack1
                                [ B.addSuffix (B.literal " <|") seedBox
                                , B.indent headBox
                                , applyIndent (2 * grenIndent) bodyBox
                                ]
                        )
                        (buildFlowBox 0 headNodes)
                        (buildFlowBox 0 (lpnChildren lastNode))

                _ ->
                    -- Any inline body, including an inline lambda whose body
                    -- starts on the `->` row (a `SoftIndentedBlock`): render the
                    -- whole body flow and glue it after `<| ` (or, if forced
                    -- vertical, drop it +4 under `seed <|`). Only an
                    -- across-rows lambda (`IndentedBlock`, above) needs the
                    -- head/body split.
                    buildBackwardBodyBox bodyNodes
                        |> Result.andThen
                            (\bodyBox ->
                                -- A multi-line body drops to +4 under `seed <|`
                                -- exactly as the author-broken (`forceVertical`)
                                -- case does ŌĆö elm-format breaks the pipeline the
                                -- moment the body spans rows, even when the author
                                -- kept `<|` glued to the seed row.
                                if forceVertical || not (isSingleLine bodyBox) then
                                    Ok
                                        (B.stack1
                                            [ B.addSuffix (B.literal " <|") seedBox
                                            , B.indent bodyBox
                                            ]
                                        )

                                else
                                    boxLine bodyBox
                                        |> Result.map
                                            (\bl -> B.addSuffix (B.row [ B.literal " <| ", bl ]) seedBox)
                            )


{-| Render a `<|` step body: a body that is a call with a child that renders
multi-line (e.g. a record argument) is a broken call whose arguments land at +4
under the function name ŌĆö not a plain flow (which would drop them at +0).
Comment-leading bodies aren't ported (they fall back). -}
buildBackwardBodyBox : Array LPNode -> Result String Box
buildBackwardBodyBox bodyNodes =
    renderFlowItems bodyNodes
        |> Result.andThen
            (\items ->
                if Array.any .isBlock items then
                    assembleBrokenCall grenIndent items

                else
                    assembleFlow False 0 items
            )


-- Two or more `<|` steps. Inline `seed <| b0 <| b1 ŌĆ”` when the author kept it on
-- one row AND every body is single-line; otherwise `seed <|` then each body at
-- +4, the `<|` trailing the previous body. A multi-line body forces the vertical
-- form (elm-format breaks the chain the moment any body spans rows), and each
-- body is kept as a Box so a multi-line one glues its trailing `<|` onto its own
-- last line via `B.addSuffix`.
backwardMultiStep : Bool -> Box -> Array (Array LPNode) -> Result String Box
backwardMultiStep forceVertical seedBox stepBodies =
    traverseResult (\body -> buildFlowBox 0 body) stepBodies
        |> Result.andThen
            (\bodyBoxes ->
                let
                    effectiveVertical =
                        forceVertical || Array.any (\b -> not (isSingleLine b)) bodyBoxes
                in
                if not effectiveVertical then
                    -- Every body is single-line here, so `boxLine` cannot fail.
                    traverseResult boxLine bodyBoxes
                        |> Result.map
                            (\bodyLines ->
                                B.addSuffix
                                    (B.row
                                        (Array.flatten
                                            (Array.map (\bl -> [ B.literal " <| ", bl ]) bodyLines)
                                        )
                                    )
                                    seedBox
                            )

                else
                    let
                        n =
                            Array.length bodyBoxes
                    in
                    Ok
                        (B.stack1
                            ([ B.addSuffix (B.literal " <|") seedBox ]
                                ++ Array.indexedMap
                                    (\i bodyBox ->
                                        B.indent
                                            (if i < n - 1 then
                                                B.addSuffix (B.literal " <|") bodyBox

                                             else
                                                bodyBox
                                            )
                                    )
                                    bodyBoxes
                            )
                        )
            )


-- ŌĢÉŌĢÉŌĢÉ IF ŌĢÉŌĢÉŌĢÉ


{-| Render an `if`/`else if` condition header: `if <cond> then` inline, or when
the author broke it, `if` / cond +4 / `then`. The branch bodies and `else`
keyword are siblings in the enclosing flow (an `if` is not a single node ŌĆö see
the flat `IfCondition`/`IndentedBlock`/`EmptyLine`/`else` sequence), assembled
by `assembleFlow`. -}
makeIfConditionBox : Bool -> Array LPNode -> Result String Box
makeIfConditionBox forceVertical children =
    when Array.popFirst children is
        Nothing ->
            Err "box: if-condition empty"

        Just { first = ifNode, rest = afterIf } ->
            when Array.popLast afterIf is
                Nothing ->
                    Err "box: if-condition missing then"

                Just { initial = condNodes, last = thenNode } ->
                    makePBox (lpnBox ifNode) (lpnChildren ifNode)
                        |> Result.andThen
                            (\ifBox ->
                                -- Arm split: the author-broken form renders the
                                -- condition as a standalone flow; the inline form
                                -- continues the `if `-line, so a leading
                                -- single-line block comment stays inline
                                -- (`if {- c -} tertiaryBoolValue then`).
                                (if forceVertical then
                                    buildFlowBox 0 condNodes

                                 else
                                    buildFlowBoxInline 0 condNodes
                                )
                                    |> Result.andThen
                                        (\condBox ->
                                            makePBox (lpnBox thenNode) (lpnChildren thenNode)
                                                |> Result.andThen
                                                    (\thenBox ->
                                                        if forceVertical then
                                                            Ok (B.stack1 [ ifBox, B.indent condBox, thenBox ])

                                                        else
                                                            when joinInline [ ifBox, condBox, thenBox ] is
                                                                Just l ->
                                                                    Ok l

                                                                Nothing ->
                                                                    -- The condition is inherently multi-line (a
                                                                    -- record/array/string literal spanning rows)
                                                                    -- even though it starts on the same row as
                                                                    -- `if`. Fall back to the same layout used for
                                                                    -- an authored-vertical condition, which
                                                                    -- handles a multi-line condBox fine via
                                                                    -- B.indent.
                                                                    Ok (B.stack1 [ ifBox, B.indent condBox, thenBox ])
                                                    )
                                        )
                            )


-- ŌĢÉŌĢÉŌĢÉ RECORD UPDATE ŌĢÉŌĢÉŌĢÉ


{-| True when a record-update field's value is a *soft* node (not a hard block ŌĆö
`if`/`when`/`let`/lambda) that renders multi-line. Such a value is dropped onto
its own line below `name =` (elm-format's `equalsPair` rule ŌĆö a multi-line value
never glues to `= `), via `dropFieldValueBox`. A hard-block value already drops
after `=` through its own block box, and a single-line value stays glued, so
neither is covered here. A comment child (no meaningful value) returns False. -}
recordFieldValueDrops : LPNode -> Bool
recordFieldValueDrops field =
    when Array.popLast (lpnChildren field) is
        Nothing ->
            False

        Just { last = valueNode, initial = headNodes } ->
            if Array.any nodeIsComment headNodes then
                -- A comment before the value (`f = {- c -} ŌĆ”`) makes the head
                -- itself multi-line; the drop composition with the field prefix
                -- is a separate edge case, so leave it on the existing path.
                False

            else
                let
                    isHardBlock =
                        when lpnBox valueNode is
                            BodyBlock ->
                                True

                            IndentedBlock ->
                                True

                            SoftIndentedBlock ->
                                True

                            WhenBranch ->
                                True

                            PipelineStep ->
                                True

                            EmptyLine ->
                                True

                            _ ->
                                False
                in
                if isHardBlock then
                    False

                else
                    when makePBox (lpnBox valueNode) (lpnChildren valueNode) is
                        Ok b ->
                            not (isSingleLine b)

                        Err _ ->
                            False


{-| elm-format's `equalsPair` drop for a record-update field whose value is a
soft multi-line node: render `name =` on its own line and stack the value at
+grenIndent below it. The value's own box supplies its internal layout, so a
broken call `Array.map (\ŌĆ”) xs` becomes `name =` / `Array.map` / args. -}
dropFieldValueBox : Array LPNode -> Result String Box
dropFieldValueBox children =
    when Array.popLast children is
        Just { last = valueNode, initial = headNodes } ->
            Result.map2
                (\headBox valueBox -> B.stack1 [ headBox, applyIndent grenIndent valueBox ])
                (buildFlowBox 0 headNodes)
                (makePBox (lpnBox valueNode) (lpnChildren valueNode))

        Nothing ->
            Err "box: empty record-update field"


{-| Render one record-update field to a box: a soft multi-line value drops onto
its own line (`dropFieldValueBox`); everything else renders as the plain
`name = value` node. -}
renderUpdateFieldBox : LPNode -> Result String Box
renderUpdateFieldBox field =
    if recordFieldValueDrops field then
        dropFieldValueBox (lpnChildren field)

    else
        makePBox (lpnBox field) (lpnChildren field)


{-| Render a record update `{ base | f = v, ŌĆ” }` via elm's `extensionGroup`.
Each field node renders to a `name = value` box; the update expands (base on its
own line, `| `/`, `-prefixed fields at +4, closing `}`) when the author broke it
across rows or any field renders multi-line ŌĆö matching elm-format for
`if`/`let`/`when`/simple/multi-field cases. A lambda-valued field drops the
`\arg ->` head like elm-format. -}
makeRecordUpdateBox : String -> Bool -> Array LPNode -> Result String Box
makeRecordUpdateBox baseName forceVertical children =
    if Array.any nodeIsComment children then
        -- A comment can't live in the inline (flat group) form, so a comment-
        -- bearing update is always vertical: comment children render own-line at
        -- +4 (no `| `/`, ` prefix), the actual fields keep their prefixes.
        makeRecordUpdateVerticalBox baseName children

    else
        traverseResult renderUpdateFieldBox children
            |> Result.andThen
            (\fieldBoxes ->
                when Array.popFirst fieldBoxes is
                    Nothing ->
                        Ok (B.line (B.literal ("{ " ++ baseName ++ " }")))

                    Just { first = firstField, rest = restFields } ->
                        let
                            contentVertical =
                                Array.any (\b -> not (isSingleLine b)) fieldBoxes
                        in
                        Ok
                            (E.extensionGroup
                                (forceVertical || contentVertical)
                                (B.line (B.literal baseName))
                                firstField
                                restFields
                            )
            )


{-| Render a comment-bearing record update as the always-vertical form: base on
its own line (`{ base`), then each field prefixed `| ` (first) / `, ` (rest) and
each comment child on its own line ŌĆö all indented +4 ŌĆö and the closing `}` on its
own line at the `{` column (elm-format). Comment children never carry a field
prefix; the first *field* (not the first child) gets the `| `. Box `stack1` +
`B.indent` + `B.prefix` supply the alignment. A multi-line block comment falls
back via `commentNodeBox`'s verbatim guard. -}
-- True when a record-update field's value is forced onto its own line(s) by a
-- comment among the field's children (e.g. `gamma = {- c -} 3`). `buildFlowBox`
-- drops such a value below `= `, so it composes with the field's `| `/`, `
-- prefix ŌĆö unlike a soft broken-call/binop value, which stays glued (elm-format).
fieldValueDropsToOwnLine : LPNode -> Bool
fieldValueDropsToOwnLine node =
    Array.any nodeIsComment (lpnChildren node)


makeRecordUpdateVerticalBox : String -> Array LPNode -> Result String Box
makeRecordUpdateVerticalBox baseName children =
    let
        step node accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        if nodeIsComment node then
                            commentNodeBox node
                                |> Result.map
                                    (\cbox ->
                                        { acc | lines = Array.pushLast cbox acc.lines }
                                    )

                        else
                            -- Build the field's `name = value` box exactly as the
                            -- non-comment path does (`renderUpdateFieldBox`: a soft
                            -- broken-call/binop value drops via `dropFieldValueBox`,
                            -- everything else ŌĆö single-line, `if`/`let`/`when`, or a
                            -- lambda whose `\arg ->` head drops ŌĆö renders via
                            -- `makePBox`). The one exception is a comment WITHIN the
                            -- field (`gamma = {- c -} 3`): `makePBox` can't place it,
                            -- so that value flows through `buildFlowBox`, which drops
                            -- it below `= `. Either way the resulting box has the
                            -- `name =`-headed shape that the `| `/`, ` prefix pads
                            -- correctly, so no field value is unrenderable here.
                            let
                                fieldFlowIndent =
                                    when lpnBox node is
                                        IndentedBlock ->
                                            0

                                        _ ->
                                            grenIndent

                                fieldBoxResult =
                                    if fieldValueDropsToOwnLine node then
                                        buildFlowBox fieldFlowIndent (lpnChildren node)

                                    else
                                        renderUpdateFieldBox node
                            in
                            fieldBoxResult
                                |> Result.map
                                    (\fieldBox ->
                                        let
                                            pref =
                                                if acc.seenField then
                                                    B.row [ B.punc ",", B.space ]

                                                else
                                                    B.row [ B.punc "|", B.space ]
                                        in
                                        { lines = Array.pushLast (B.prefix pref fieldBox) acc.lines
                                        , seenField = True
                                        }
                                    )
                    )
    in
    Array.foldl step (Ok { lines = [], seenField = False }) children
        |> Result.map
            (\acc ->
                B.stack1
                    [ B.prefix (B.row [ B.punc "{", B.space ]) (B.line (B.literal baseName))
                    , B.indent (B.stack1 acc.lines)
                    , B.line (B.punc "}")
                    ]
            )


-- ŌĢÉŌĢÉŌĢÉ WHEN ŌĢÉŌĢÉŌĢÉ


{-| Render a `when ŌĆ” is` expression. Header `when <subject> is` stays inline
unless the author broke it across rows (then `when` / subject +4 / `is`); each
branch sits at +4 (`branchNest`), blank-line separated (elm-format). -}
makeWhenFlowBox : Bool -> Array LPNode -> Result String Box
makeWhenFlowBox forceVertical children =
    when Array.popLast children is
        Nothing ->
            Err "box: when has no children"

        Just { last = branchesBlock, initial = withoutBranches } ->
            when Array.popLast withoutBranches is
                Nothing ->
                    Err "box: when missing is"

                Just { initial = headerNodes } ->
                    when Array.popFirst headerNodes is
                        Nothing ->
                            Err "box: when missing when"

                        Just { rest = scrutineeNodes } ->
                            let
                                headerResult =
                                    if forceVertical then
                                        buildFlowBox 0 scrutineeNodes
                                            |> Result.map
                                                (\scrut ->
                                                    B.stack1
                                                        [ B.line (B.keyword "when")
                                                        , B.indent scrut
                                                        , B.line (B.keyword "is")
                                                        ]
                                                )

                                    else
                                        buildFlowBox 0 withoutBranches

                                branchesResult =
                                    renderWhenBranchesBox (lpnChildren branchesBlock)
                            in
                            Result.map2
                                (\hdr brs -> B.stack1 [ hdr, B.indent brs ])
                                headerResult
                                branchesResult


{-| One `when` branch: `<pattern> ->` then the body indented +4. -}
makeWhenBranchBox : Array LPNode -> Result String Box
makeWhenBranchBox children =
    when Array.popFirst children is
        Just { first = patNode, rest = afterPat } ->
            when afterPat is
                [ bodyNode ] ->
                    Result.map2
                        (\patBox bodyBox -> B.stack1 [ patBox, B.indent bodyBox ])
                        (makePBox (lpnBox patNode) (lpnChildren patNode))
                        (makePBox (lpnBox bodyNode) (lpnChildren bodyNode))

                _ ->
                    -- unreachable: a WhenBranch node is always built with exactly
                    -- two children (pattern, body) by folderInsertWhenBranch.
                    Err "unreachable: when-branch shape"

        Nothing ->
            Err "box: empty when-branch"


{-| A `when` branch pattern, rendered as `<pattern> ->`. A multi-line pattern (a
record/array pattern the author spread across rows) gets ` ->` appended to its
last line via `B.addSuffix`, which appends to the last line for single- and
multi-line boxes alike. -}
makeWhenBranchPatternBox : Array LPNode -> Result String Box
makeWhenBranchPatternBox children =
    buildFlowBox grenIndent children
        |> Result.map (\box -> B.addSuffix (B.literal " ->") box)


-- Stack boxes with a blank line between each (consecutive `when` branches).
stackWithBlanks : Array Box -> Box
stackWithBlanks boxes =
    when Array.popFirst boxes is
        Nothing ->
            B.blankLine

        Just { first = b0, rest } ->
            B.stack1
                (Array.foldl (\b acc -> acc ++ [ B.blankLine, b ]) [ b0 ] rest)


{-| Render a `when`'s branch block ŌĆö the `WhenBranch` children stacked with a
blank line between each. A comment sibling that trails the previous branch's last
line (same source row) is appended onto it via `B.addSuffix`. A comment on its
own row LEADS the following branch: it is held in `pending` and stacked directly
above that branch (no blank line between comment and its pattern), matching
elm-format. Single-line and multi-line block comments alike are supported (the
latter via `commentNodeBox`'s reindent stack). A same-row multi-line comment
(can't glue onto a last line), or a comment after the last branch (no branch to
lead), still fall back. -}
renderWhenBranchesBox : Array LPNode -> Result String Box
renderWhenBranchesBox children =
    let
        handleComment acc row node =
            if row == acc.lastRow && acc.lastRow >= 0 then
                -- Trailing the previous branch on its last line (multi-line
                -- comments padded under their start by `glueCommentSuffix`).
                commentNodeBox node
                    |> Result.andThen
                        (\cbox ->
                            when Array.popLast acc.boxes is
                                Just { last = lastBox, initial } ->
                                    Ok
                                        { acc
                                            | boxes = Array.pushLast (glueCommentSuffix cbox lastBox) initial
                                        }

                                Nothing ->
                                    -- unreachable: lastRow only ever becomes >= 0 in the
                                    -- same fold step that pushes onto boxes (the
                                    -- WhenBranch arm below), so boxes being empty here
                                    -- implies lastRow == -1 ŌĆö contradicting the guard
                                    -- above that required lastRow >= 0 to reach this arm.
                                    Err "unreachable: comment before first when-branch"
                        )

            else
                -- Own line: this comment leads the next branch.
                commentNodeBox node
                    |> Result.map (\cbox -> { acc | pending = Array.pushLast cbox acc.pending })
    in
    Array.foldl
        (\child accResult ->
            accResult
                |> Result.andThen
                    (\acc ->
                        when lpnBox child is
                            WhenBranch ->
                                makeWhenBranchBox (lpnChildren child)
                                    |> Result.map
                                        (\bx ->
                                            let
                                                combined =
                                                    if Array.isEmpty acc.pending then
                                                        bx

                                                    else
                                                        B.stack1 (Array.pushLast bx acc.pending)
                                            in
                                            { boxes = Array.pushLast combined acc.boxes, lastRow = lpnMaxRow child, pending = [] }
                                        )

                            SingleLineComment loc ->
                                handleComment acc loc.start.row child

                            BlockComment loc ->
                                handleComment acc loc.start.row child

                            EmptyLine ->
                                -- The blank-line marker that precedes an own-line
                                -- comment leading the next branch ([WB, EmptyLine,
                                -- comment, WB]). The one blank line between branch
                                -- boxes is supplied by `stackWithBlanks`, so the
                                -- marker is a no-op here. `lastRow` resets so
                                -- nothing glues across the blank. Any other
                                -- position (leading, or after a pending comment)
                                -- falls back.
                                if Array.isEmpty acc.pending && not (Array.isEmpty acc.boxes) then
                                    Ok { acc | lastRow = -1 }

                                else
                                    Err "box: unexpected blank line among when-branches"

                            _ ->
                                Err "box: unexpected node among when-branches"
                    )
        )
        (Ok { boxes = [], lastRow = -1, pending = [] })
        children
        |> Result.andThen
            (\acc ->
                if not (Array.isEmpty acc.pending) then
                    -- unreachable: `pending` holds own-line comments that LEAD the
                    -- next branch, and is drained by each `WhenBranch`. A comment
                    -- after the LAST branch never lands in the when's branch
                    -- children ŌĆö Comments.gren attaches a trailing own-line comment
                    -- as a following sibling `OriginalRows`, outside the `WhenFlow`
                    -- ŌĆö so `pending` is always empty here.
                    Err "unreachable: comment left pending after the last when-branch"

                else
                    when Array.popFirst acc.boxes is
                        Nothing ->
                            Err "box: when has no branches"

                        Just _ ->
                            Ok (stackWithBlanks acc.boxes)
            )


-- ŌĢÉŌĢÉŌĢÉ SIGNATURES ŌĢÉŌĢÉŌĢÉ


{-| The literal text of a leaf node (`UnbreakableText` / `SynthesizedText`), or
Nothing for any structured node. Tranche-2 signatures handle only flat leaf
signatures; a nested type (record/paren/ŌĆ”) yields Nothing and falls back. -}
leafValue : LPNode -> Maybe String
leafValue node =
    when lpnBox node is
        UnbreakableText locs ->
            Just locs.value

        SynthesizedText s ->
            Just s

        _ ->
            Nothing


isArrowLeaf : LPNode -> Bool
isArrowLeaf node =
    leafValue node == Just "->"


isColonLeaf : LPNode -> Bool
isColonLeaf node =
    leafValue node == Just ":"


{-| Split a signature's type nodes at each top-level `->`: the first segment is
the leading type; each later one begins with its `->`. -}
splitSignatureSegments : Array LPNode -> Array (Array LPNode)
splitSignatureSegments nodes =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                Array.pushLast [ node ] acc

            else
                when Array.popLast acc is
                    Just { last = seg, initial = front } ->
                        Array.pushLast (Array.pushLast node seg) front

                    Nothing ->
                        [ [ node ] ]
        )
        []
        nodes


-- A segment's first / last content row, ignoring the leading arrow.
--
-- A segment beginning with a bracketed type (`{ ŌĆ” }`, `( ŌĆ” )`) starts where its
-- *opening bracket* sits, not at its first inner token ŌĆö the bracket has no leaf,
-- so `firstRowInSubtree` alone would report the first field's row, and a break
-- just inside the bracket would masquerade as a break between `->` segments,
-- flipping the whole signature to multi-line.
segFirstRow : Array LPNode -> Int
segFirstRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc

            else
                let
                    leafR =
                        firstRowInSubtree node

                    r =
                        when lpnBracketStart node is
                            Just open ->
                                if leafR < 0 then
                                    open.row

                                else
                                    min open.row leafR

                            Nothing ->
                                leafR
                in
                if acc < 0 then
                    r

                else if r < 0 then
                    acc

                else
                    min acc r
        )
        -1
        seg


segLastRow : Array LPNode -> Int
segLastRow seg =
    Array.foldl
        (\node acc ->
            if isArrowLeaf node then
                acc

            else
                max acc (lpnMaxRow node)
        )
        -1
        seg


{-| True for a node that renders as a multi-line record TYPE ŌĆö either a plain
record literal (`FP.isTypeRecordLiteral`, `{ a : Int }`) or an extensible
record type, which reuses the `RecordUpdate` box the same way a record-update
EXPRESSION does (`{ r | a : Int }`; see `LogicalPrintingTree.gren`'s
`RecordUpdate` doc). Treating any `RecordUpdate` found here as a type is safe
only because every call site restricts `node` to a signature's TYPE position,
where `RecordUpdate` can never mean an update expression. -}
isDroppingSignatureRecordNode : LPNode -> Bool
isDroppingSignatureRecordNode node =
    FP.isTypeRecordLiteral node
        || (when lpnBox node is
                RecordUpdate _ ->
                    True

                _ ->
                    False
           )


{-| True when a signature segment contains a multi-line type record in a
non-head position ŌĆö the type-record drop will fire inside it, so the whole
signature must commit to the broken layout. Verticality comes from this
renderer's own box (`isSingleLine`; an unrenderable node counts as not-forcing,
i.e. `Err -> False`). The head position (`i == 0`) is included only when
`includeHead` is `True` ŌĆö a multi-segment type already gets head-position
coverage from `signatureForceVertical` (the row-break-between-segments check),
but a single-segment type (no `->` at all) has no such fallback, so its sole
segment must be checked at `i == 0` too. -}
segmentHasDroppingRecordBox : Bool -> Array LPNode -> Bool
segmentHasDroppingRecordBox includeHead segment =
    segment
        |> Array.indexedMap (\i n -> { i = i, n = n })
        |> Array.any
            (\{ i, n } ->
                (i > 0 || includeHead)
                    && isDroppingSignatureRecordNode n
                    && (when makePBox (lpnBox n) (lpnChildren n) is
                            Ok b ->
                                not (isSingleLine b)

                            Err _ ->
                                False
                       )
            )


{-| True when the author broke the type across rows at a `->` boundary (a later
segment starts on a row after the previous segment ended). -}
signatureForceVertical : Array (Array LPNode) -> Bool
signatureForceVertical segments =
    (Array.foldl
        (\seg acc ->
            let
                first =
                    segFirstRow seg

                last =
                    segLastRow seg
            in
            { broken =
                acc.broken
                    || (acc.prevLast >= 0 && first >= 0 && first > acc.prevLast)
            , prevLast =
                if last >= 0 then
                    last

                else
                    acc.prevLast
            }
        )
        { broken = False, prevLast = -1 }
        segments
    ).broken


{-| Render a function/port signature. Inline (header + type on one line) when the
author kept it on one line; header on line 1 with one `->` segment per line at +4
when the author broke it at an arrow boundary. The header and each segment render
via `buildFlowBox 0`, so nested types (records, parens, function types) are
handled ŌĆö anything `buildFlowBox` can't render Errs.

Comments: an inline signature that carries a comment renders via the
comment-aware flow (`buildFlowBox grenIndent`), NOT a flat group ŌĆö a comment's
break points have no stable inline anchor (elm-format). A signature the author
broke at a `->` renders per-segment either way, and `buildFlowBox` places the
segment's inline comments. -}
makeSignatureBox : Array LPNode -> Result String Box
makeSignatureBox children =
    let
        colonSplit =
            Array.foldl
                (\node acc ->
                    if acc.afterColon then
                        { acc | typeNodes = Array.pushLast node acc.typeNodes }

                    else if isColonLeaf node then
                        { acc | header = Array.pushLast node acc.header, afterColon = True }

                    else
                        { acc | header = Array.pushLast node acc.header }
                )
                { header = [], typeNodes = [], afterColon = False }
                children
    in
    if not colonSplit.afterColon then
        Err "box: signature has no colon"

    else
        let
            segments =
                splitSignatureSegments colonSplit.typeNodes

            hasComment =
                Array.any subtreeHasComment children

            -- A multi-segment type whose segment carries a dropping record
            -- commits to the fully-broken layout up front
            -- (`segmentHasDroppingRecordBox`), so the drop's extra rows can't
            -- flip the boundary-break decision on reparse (the idempotency
            -- fixed-point rule). A single-segment, comment-free type (no `->`)
            -- gets the same treatment at its segment's head position, since
            -- there's no second segment for `signatureForceVertical` to
            -- compare against ŌĆö this is gated on `not hasComment` because a
            -- comment-bearing single segment already has its own dedicated
            -- handling below (the `hasComment && typeHasCommentBracket`
            -- branch), which must run instead, not be preempted here.
            forceVertical =
                signatureForceVertical segments
                    || (Array.length segments
                            > 1
                            && Array.any (segmentHasDroppingRecordBox False) segments
                       )
                    || (Array.length segments
                            == 1
                            && not hasComment
                            && Array.any (segmentHasDroppingRecordBox True) segments
                       )
        in
        if not forceVertical && hasComment && Array.any typeHasCommentBracket colonSplit.typeNodes then
            -- A comment INSIDE a record/bracket type (`foo : { a : Int {- c -} }`)
            -- renders that type multi-line. elm-format keeps it glued inline after
            -- `:` (its `}` aligns under the `{`). When the whole type is exactly
            -- that one record/bracket node, `B.prefix` glues it after the header
            -- and pads its continuation by the header's width ŌĆö so the record's
            -- alignment holds and `}` lands under `{`. A multi-node type
            -- (`{ ŌĆ” } -> ŌĆ”`) goes through the generic comment-flow path below
            -- (see the `_` arm).
            when colonSplit.typeNodes is
                [ single ] ->
                    buildFlowBox 0 colonSplit.header
                        |> Result.andThen
                            (\headerBox ->
                                when B.isLine headerBox is
                                    Ok headerLine ->
                                        buildFlowBox 0 colonSplit.typeNodes
                                            |> Result.map
                                                (\typeBox ->
                                                    -- A multi-line type RECORD drops below the
                                                    -- header at +4 ŌĆö elm-format drops every
                                                    -- multi-line record type below its head/`:`.
                                                    -- Other bracket types (parens, extensible
                                                    -- records) keep the inline glue.
                                                    if FP.isTypeRecordLiteral single && not (isSingleLine typeBox) then
                                                        B.stack1 [ B.line headerLine, B.indent typeBox ]

                                                    else
                                                        B.prefix (B.row [ headerLine, B.space ]) typeBox
                                                )

                                    Err _ ->
                                        -- unreachable: colonSplit.header is always
                                        -- exactly [name, colon], two single-row
                                        -- leaves, so buildFlowBox can never return
                                        -- a multi-line headerBox here.
                                        Err "unreachable: multi-line signature header"
                            )

                _ ->
                    -- A multi-node comment-bearing type (`{ ŌĆ” } -> ŌĆ”`) renders
                    -- via the same generic comment-flow the `else if ŌĆ”
                    -- hasComment` arm below uses (`buildFlowBox grenIndent`).
                    -- (This was previously an `Err`; the earlier "breaks
                    -- idempotency" concern was about a *different*, reverted
                    -- layout, not this one ŌĆö the shipped output here is a proven
                    -- fixed point.)
                    buildFlowBox grenIndent children

        else if not forceVertical && hasComment then
            -- Inline signature carrying a comment: render via the comment-aware
            -- flow (`buildFlowBox grenIndent`), NOT a flat group, because a
            -- comment's break points have no stable inline anchor (elm-format);
            -- a `--`/own-line comment that forces a continuation is indented +4
            -- by `assembleFlow`.
            buildFlowBox grenIndent children

        else if not forceVertical then
            -- Inline, no comment: the whole signature on one line (one flow over
            -- all children). elm-format flattens a segment the author broke
            -- inside a record type or parens (a break not at a `->` boundary)
            -- back onto the line; Box has no flatten, so if the flow comes back
            -- multi-line we Err rather than emit the (wrong) broken form.
            buildFlowBox 0 children
                |> Result.andThen
                    (\box ->
                        when B.isLine box is
                            Ok _ ->
                                Ok box

                            Err _ ->
                                Err "box: inline signature segment unexpectedly broke across lines"
                    )

        else
            -- Author broke at a `->`: header on line 1, one segment per line at
            -- +4. `buildFlowBox 0` renders each segment, placing any inline
            -- comment it carries.
            buildFlowBox 0 colonSplit.header
                |> Result.andThen
                    (\headerBox ->
                        traverseResult (buildFlowBox 0) segments
                            |> Result.map
                                (\segBoxes ->
                                    B.stack1 ([ headerBox ] ++ Array.map B.indent segBoxes)
                                )
                    )


-- The `Line` (not boxed) of the given leaf nodes joined by single spaces. Only
-- valid for all-leaf node arrays (caller must have checked `headerAllLeaves`);
-- a non-leaf renders as "".
leafLineRow : Array LPNode -> B.Line
leafLineRow nodes =
    B.row
        (Array.intersperse B.space
            (Array.map (\n -> B.literal (Maybe.withDefault "" (leafValue n))) nodes)
        )


-- ŌĢÉŌĢÉŌĢÉ MODULE & IMPORT LINES ŌĢÉŌĢÉŌĢÉ


{-| Render a `module ŌĆ”` / `import ŌĆ”` line. When it ends in an `exposing ( ŌĆ” )`
list and the header before the list is all plain leaf tokens, render the list as
a coupled all-or-nothing group; otherwise (a `(..)` wildcard, an effect-module
`where` block, a comment in the header) fall back to the generic flow.

For BOTH `module` and `import` lines, `exposing` stays glued to the header even
when the list goes vertical (list indented +4). gren-format deliberately does
not drop an import's `exposing` to its own line the way elm-format does. -}
makeExposingLineBox : SyntaxType -> Array LPNode -> Result String Box
makeExposingLineBox stype children =
    when Array.popLast children is
        Just { last = lastNode, initial = headerNodes } ->
            let
                -- The exposing list's author-layout decision is carried by its
                -- box type: `AllAcrossOrAllVertical ListParen` = written inline,
                -- `AlwaysVertical ListParen` = across rows. Anything else means
                -- the last node isn't a paren list (`(..)` wildcard, etc.).
                exposingForceVertical =
                    when lpnBox lastNode is
                        AllAcrossOrAllVertical ListParen ->
                            Just False

                        AlwaysVertical ListParen ->
                            Just True

                        _ ->
                            Nothing

                headerAllLeaves =
                    Array.all (\n -> leafValue n /= Nothing) headerNodes
            in
            when exposingForceVertical is
                Just forceVertical ->
                    if headerAllLeaves && not (Array.isEmpty headerNodes) then
                        let
                            listChildren =
                                lpnChildren lastNode
                        in
                        let
                            hasComment =
                                Array.any nodeIsComment listChildren

                            -- A comment among the exposed names forces the list
                            -- vertical (elm-format): `Array.any nodeIsComment ||
                            -- forceVertical` routes to the always-vertical
                            -- bracketed list.
                            effectiveFV =
                                forceVertical || hasComment

                            -- The `( ŌĆ” )` comment form is structurally the same
                            -- always-vertical list as a curly/square literal, so
                            -- reuse `commentBracketListBox` with `ListParen` (its
                            -- `( `/`, `/`)` prefixes match `listBoxesWithBrackets`).
                            listBoxResult =
                                if hasComment then
                                    commentBracketListBox ListParen listChildren

                                else
                                    makeExposingListBox forceVertical listChildren
                        in
                        listBoxResult
                            |> Result.andThen
                                -- Both `module` and `import` keep `exposing`
                                -- glued to the header (list at +4); gren-format
                                -- does not drop an import's `exposing` to its
                                -- own line the way elm-format does.
                                (\listBox ->
                                    gluedExposingBox effectiveFV headerNodes listBox
                                )

                    else
                        exposingLineFallback children

                Nothing ->
                    exposingLineFallback children

        Nothing ->
            exposingLineFallback children


-- The fallback path for a module/import line that isn't a plain leaf-header +
-- paren-list (a `(..)` wildcard, an effect-module `where` block, or a
-- comment-bearing header): renders via the comment-aware flow
-- (`buildFlowBox grenIndent`). A header the author broke across rows (a `--` line
-- comment before the list, a multi-line `{- -}`, or an effect-module `where`
-- block that wraps) indents its continuation +4, which `assembleFlow` does for
-- an inline item on a fresh line after a comment/break.
exposingLineFallback : Array LPNode -> Result String Box
exposingLineFallback children =
    buildFlowBox grenIndent children


-- `exposing` stays glued to the header. Inline list: `header (a, b, c)` on one
-- line. Vertical list: header on line 1, list indented +4 beneath it.
gluedExposingBox : Bool -> Array LPNode -> Box -> Result String Box
gluedExposingBox forceVertical headerNodes listBox =
    if forceVertical then
        Ok (B.stack1 [ B.line (leafLineRow headerNodes), B.indent listBox ])

    else
        when B.isLine listBox is
            Ok listLine ->
                Ok (B.line (B.row [ leafLineRow headerNodes, B.space, listLine ]))

            Err _ ->
                Err "box: inline exposing list rendered multi-line"


{-| Render an exposing list's `( ŌĆ” )` body (no leading glue). Items are the
already-sorted exposed names (leaves). Inline: `(a, b, c)`. Vertical:

    ( a
    , b
    )

The comment-free exposing-list path. -}
makeExposingListBox : Bool -> Array LPNode -> Result String Box
makeExposingListBox forceVertical children =
    traverseResult (\n -> makePBox (lpnBox n) (lpnChildren n)) children
        |> Result.andThen
            (\itemBoxes ->
                when B.allSingles itemBoxes is
                    Err _ ->
                        -- unreachable: every exposed item is built as a single
                        -- UnbreakableText leaf (MakeLogical.gren's processExposed),
                        -- so itemBoxes are always single-line and B.allSingles
                        -- can never fail here.
                        Err "unreachable: multi-line exposing item"

                    Ok itemLines ->
                        if Array.isEmpty itemLines then
                            Ok (B.line (B.punc "()"))

                        else if forceVertical then
                            Ok (verticalExposingBox itemLines)

                        else
                            Ok
                                (B.line
                                    (B.row
                                        ([ B.punc "(" ]
                                            ++ Array.intersperse (B.row [ B.punc ",", B.space ]) itemLines
                                            ++ [ B.punc ")" ]
                                        )
                                    )
                                )
            )


verticalExposingBox : Array B.Line -> Box
verticalExposingBox itemLines =
    when Array.popFirst itemLines is
        Just { first, rest } ->
            B.stack1
                ([ B.prefix (B.row [ B.punc "(", B.space ]) (B.line first) ]
                    ++ Array.map (\l -> B.prefix (B.row [ B.punc ",", B.space ]) (B.line l)) rest
                    ++ [ B.line (B.punc ")") ]
                )

        Nothing ->
            B.line (B.punc "()")


{-| Render one LPT box to a Box. Err for unported constructs. -}
makePBox : LPBox -> Array LPNode -> Result String Box
makePBox box children =
    when box is
        UnbreakableText locs ->
            Ok (B.line (B.literal locs.value))

        SynthesizedText s ->
            Ok (B.line (B.literal s))

        AcrossOrVertical { forceVertical, checkContentVertical } ->
            renderFlowItems children
                |> Result.andThen
                    (\items ->
                        if forceVertical || (checkContentVertical && Array.any .isBlock items) then
                            -- A function application that must break: elm-format's
                            -- `ElmStructure.application`.
                            assembleBrokenCall grenIndent items

                        else
                            assembleFlow False grenIndent items
                    )

        BodyBlock ->
            buildFlowBox 0 children

        IndentedBlock ->
            buildFlowBox 0 children

        SoftIndentedBlock ->
            -- A lambda body: rendered inline when single-line, dropped +4 when
            -- multi-line ŌĆö the enclosing flow decides, via isBlockNode.
            buildFlowBox 0 children

        PrefixGlue prefix ->
            -- Glue a prefix onto its inner with no space: `\x`/`\[ ŌĆ” ]` (lambda
            -- args), `-x` (unary negation). `B.prefix` prepends the prefix to the
            -- inner's first line AND pads every continuation line by the prefix's
            -- width ŌĆö matching the alignment the inner (a multi-line array/record
            -- pattern) carries, so a lambda whose arg pattern spans rows
            -- (`\[ a {- c -}\n, b\n] -> ŌĆ”`) aligns under the opening bracket.
            -- `buildFlowBoxInline` keeps a leading comment in the inner on-line.
            buildFlowBoxInline 0 children
                |> Result.map (\inner -> B.prefix (B.literal prefix.value) inner)

        AllAcrossOrAllVertical bracket ->
            makeLiteralBox False bracket children

        AlwaysVertical bracket ->
            makeLiteralBox True bracket children

        EmptyBracketed loc ->
            when bracketPunc loc.value is
                Just { left, right } ->
                    if Array.isEmpty children then
                        Ok (B.line (B.row [ B.punc left, B.punc right ]))

                    else
                        -- A bracket whose only content is a comment (`{ {- c -} }`,
                        -- `[ {- c -} ]`): the open punc, a space, the comments
                        -- space-joined, a space, the close punc ŌĆö all on one line.
                        -- Only a single-line block comment fits this inline form;
                        -- a multi-line block comment or a `--` line comment can't
                        -- glue onto the one-line bracket, so it falls back to a
                        -- vertical layout (open punc, each comment indented on
                        -- its own line via the full comment Box, close punc) ŌĆö
                        -- dropping the comment would lose source content.
                        when traverseResult emptyBracketedCommentLine children is
                            Ok commentLines ->
                                Ok
                                    (B.line
                                        (B.row
                                            (Array.flatten
                                                [ [ B.punc left, B.space ]
                                                , spaceJoinLines commentLines
                                                , [ B.space, B.punc right ]
                                                ]
                                            )
                                        )
                                    )

                            Err _ ->
                                traverseResult commentNodeBox children
                                    |> Result.map
                                        (\commentBoxes ->
                                            B.stack1
                                                ([ B.line (B.punc left) ]
                                                    ++ Array.map B.indent commentBoxes
                                                    ++ [ B.line (B.punc right) ]
                                                )
                                        )

                Nothing ->
                    -- unreachable: ListBrackets has exactly 3 constructors
                    -- (ListParen/ListCurly/ListSquare); bracketPunc matches
                    -- all of them and always returns Just.
                    Err "unreachable: bracket kind"

        Binop { forceVertical } ->
            makeBinopBox forceVertical children

        OpAndRhs ->
            makeOpAndRhsBox children

        RecordUpdate { name, forceVertical } ->
            makeRecordUpdateBox name.value forceVertical children

        IfCondition { forceVertical } ->
            makeIfConditionBox forceVertical children

        Pipeline { forceVertical, op } ->
            makePipelineBox forceVertical op children

        EmptyLine ->
            Ok B.blankLine

        WhenFlow { forceVertical } ->
            makeWhenFlowBox forceVertical children

        WhenBranch ->
            makeWhenBranchBox children

        WhenBranchPattern ->
            makeWhenBranchPatternBox children

        ParenBlock { forceVertical, checkContentVertical, isCallArgument } ->
            makeParenBlockBox { forceVertical = forceVertical, checkContentVertical = checkContentVertical, isCallArgument = isCallArgument } children

        MultilineString loc ->
            -- A `"""ŌĆ”"""` literal: opening `"""`, one line per content element,
            -- closing `"""`, stacked. Box stacking aligns to the box's column
            -- intrinsically when the flow indents it, so continuation lines land
            -- at the opening `"""`'s column. Box applies per-line trimRight, so a
            -- content line ending in whitespace, or an interior blank line, is not
            -- preserved verbatim.
            let
                quote =
                    B.line (B.literal "\"\"\"")

                contentLines =
                    Array.map (\s -> B.line (B.literal s)) loc.value
            in
            Ok (B.stack1 ([ quote ] ++ contentLines ++ [ quote ]))

        Glue ->
            makeGlueBox children

        SingleLineComment _ ->
            -- unreachable: a comment node is handled before `makePBox` ŌĆö as its
            -- own top-level `OriginalRows` (via `commentNodeToBox`), and as a flow
            -- child by `renderFlowItem`'s own `SingleLineComment`/`BlockComment`
            -- arms. Only its `_ ->` arm calls `makePBox`, so a comment never
            -- reaches here.
            Err "unreachable: SingleLineComment never reaches makePBox"

        BlockComment _ ->
            -- unreachable: same as SingleLineComment above.
            Err "unreachable: BlockComment never reaches makePBox"

        DocComment _ ->
            -- unreachable: a DocComment is only ever the sole child of its own
            -- OriginalRows (MakeLogical.gren), dispatched through
            -- makeCommentLineBox / commentNodeToBox ŌĆö never through makePBox.
            Err "unreachable: DocComment never reaches makePBox"

        PipelineStep ->
            -- A `|> step` inside the generic fold (a comment-bearing pipeline
            -- routed to `buildFlowBox 0`). The step's own leading/trailing
            -- comments are peeled inside; the fold's PipelineStepItem placement
            -- supplies the +grenIndent step wrap and the blank-before-commented-
            -- step.
            renderPipelineStepChildren children

        AlignedFlow ->
            -- unreachable: no code path in InsertExpressions/InsertPatterns/
            -- InsertTypes/MakeLogical ever constructs an AlignedFlow box ŌĆö
            -- it's a defined-but-unused LPBox constructor.
            Err "unreachable: AlignedFlow is never constructed"

        _ ->
            -- unreachable: every LPBox constructor other than RootBox/
            -- OriginalRows is matched explicitly above. RootBox is the
            -- singular tree root and OriginalRows is always a direct child
            -- of RootBox ŌĆö neither is ever passed to makePBox as a child.
            Err "unreachable: construct never reaches makePBox"


{-| Render a `Glue`: children concatenated with no separator ŌĆö a postfix accessor
(`.field`) glued after a bracketed base (`(f 1).value`, `{ a = 1 }.a`). The base
(first child) may be multi-line ŌĆö the accessor glues onto its last line via
`B.addSuffix` ŌĆö but every following child (the `.field` accessors) must be
single-line. -}
makeGlueBox : Array LPNode -> Result String Box
makeGlueBox children =
    when Array.popFirst children is
        Nothing ->
            Err "box: empty glue"

        Just { first, rest } ->
            makePBox (lpnBox first) (lpnChildren first)
                |> Result.andThen
                    (\baseBox ->
                        Array.foldl
                            (\child accR ->
                                accR
                                    |> Result.andThen
                                        (\acc ->
                                            makePBox (lpnBox child) (lpnChildren child)
                                                |> Result.andThen
                                                    (\childBox ->
                                                        when B.isLine childBox is
                                                            Ok l ->
                                                                Ok (B.addSuffix l acc)

                                                            Err _ ->
                                                                -- unreachable: every non-base Glue child is
                                                                -- a freshly built plain-text ".field" leaf
                                                                -- (InsertExpressions.gren's insertAccess),
                                                                -- always single-line.
                                                                Err "unreachable: multi-line glue suffix"
                                                    )
                                        )
                            )
                            (Ok baseBox)
                            rest
                    )


{-| Render a `ParenBlock`: inline `(inner)`, the generic vertical form
`(inner` ŌĆ” `)` with the closing paren on its own line, and the block shapes.
A `when`/`if`/`let` directly inside the parens uses elm-format's paren-block
indentation (keyword at `(`+1, bodies at `(`+2 or `(`+4, `)` at the `(` column),
via `makeWhenInParenBox` / `makeBlockInParenBox`.

The vertical form anchors continuation lines and the closing `)` to the `(`
column. Box stacking is intrinsically that anchor: the wrapped box's lines are
all relative to its own origin, which becomes the `(` column once the enclosing
flow indents it. -}
makeParenBlockBox : { forceVertical : Bool, checkContentVertical : Bool, isCallArgument : Bool } -> Array LPNode -> Result String Box
makeParenBlockBox flags children =
    when Array.first children is
        Nothing ->
            Ok (B.line (B.punc "()"))

        Just first ->
            when lpnBox first is
                WhenFlow _ ->
                    makeWhenInParenBox flags.isCallArgument (lpnChildren first)

                IfCondition _ ->
                    makeBlockInParenBox flags.isCallArgument children

                UnbreakableText loc ->
                    if loc.value == "let" then
                        makeBlockInParenBox flags.isCallArgument children

                    else
                        parenGenericFallbackBox flags children

                _ ->
                    parenGenericFallbackBox flags children


{-| The non-block ParenBlock shapes: inline, or a generic vertical `(ŌĆ”\n)`. The
vertical form triggers on either verticality signal or a multi-line lambda body
(second child an `IndentedBlock`, or a `SoftIndentedBlock` whose sole bracket
literal renders vertical ŌĆö see `parenLambdaMultiline`). -}
parenGenericFallbackBox : { forceVertical : Bool, checkContentVertical : Bool, isCallArgument : Bool } -> Array LPNode -> Result String Box
parenGenericFallbackBox flags children =
    -- Inline-start via `buildFlowBoxInline 0 children`: the content continues the
    -- `(`-line, so a leading single-line block comment stays inline
    -- (`({- c -} expr)`).
    buildFlowBoxInline 0 children
        |> Result.andThen
            (\innerBox ->
                let
                    contentForcesVertical =
                        flags.checkContentVertical && not (isSingleLine innerBox)

                    goVertical =
                        flags.forceVertical || contentForcesVertical || parenLambdaMultiline children
                in
                if goVertical then
                    if parenContentLeadsWithMultilinePrefixGlue children then
                        Ok (wrapParenVerticalPadded innerBox)

                    else if Array.any subtreeHasComment children && not (parenLambdaMultiline children) then
                        -- A comment forced this content multi-line via the
                        -- comment-aware flow builders' `B.prefix` glue (exact
                        -- character-width alignment, not a Tab stop), so the
                        -- paren's own `(` width must ride along on every
                        -- continuation line too ŌĆö same reasoning as the
                        -- bracket-pattern-lambda case above, just reached by a
                        -- different LPT shape (binop/call, not PrefixGlue).
                        -- Excludes the lambda-body case (`parenLambdaMultiline`):
                        -- its body is Tab-indented relative to the ambient
                        -- block, not the `(` column, even if a comment sits
                        -- somewhere inside it.
                        Ok (wrapParenVerticalPadded innerBox)

                    else
                        Ok (wrapParenVertical innerBox)

                else
                    when B.isLine innerBox is
                        Ok l ->
                            Ok (B.line (B.row [ B.punc "(", l, B.punc ")" ]))

                        Err _ ->
                            -- A formatter-synthesized wrap (`checkContentVertical
                            -- = False`) around content a comment forced
                            -- multi-line: elm-format's inline form is a plain
                            -- `( inner )`, `)` glued onto the inner's last line.
                            -- When the inner is align-carrying (a bracket literal
                            -- / record ŌĆö its continuation lines anchor at its own
                            -- start column), the `(` width must ride along on
                            -- every continuation line (`B.prefix`) so the inner's
                            -- `,`/`}` stay under the opening bracket, not the `(`.
                            -- Otherwise (a nest-carrying inner) the continuation
                            -- lines belong at the ambient column, so only the
                            -- first line gets the `(` (`B.mapFirstLine`).
                            if parenInnerIsAlignCarrying children then
                                Ok (B.addSuffix (B.punc ")") (B.prefix (B.punc "(") innerBox))

                            else
                                Ok (B.addSuffix (B.punc ")") (B.mapFirstLine (\l -> B.row [ B.punc "(", l ]) identity innerBox))
            )


{-| Glue `(` onto the inner box's first line and stack `)` as a new final line,
anchoring both to the `(` column. -}
wrapParenVertical : Box -> Box
wrapParenVertical box =
    let
        withOpen =
            when box is
                SingleLine l ->
                    SingleLine (B.row [ B.punc "(", l ])

                Stack s ->
                    Stack { s | first = B.row [ B.punc "(", s.first ] }

                MustBreakBox l ->
                    MustBreakBox (B.row [ B.punc "(", l ])
    in
    B.andThen [ B.line (B.punc ")") ] withOpen


{-| Paren-wrap a box whose continuation lines are positioned RELATIVE to its
first line (an align-carrying inner ŌĆö a lambda whose parameter is a multi-line
bracket pattern, `(\{ ŌĆ” } ŌĆ”)`). Unlike `wrapParenVertical` (which shifts only the
first line, correct for absolute-nested inners like binops/`when`/`if`), this pads
every continuation by the `(` width so the inner's alignment rides along and its
`,`/`}` stay under the opening bracket. `)` lands on its own line at the `(`
column. -}
wrapParenVerticalPadded : Box -> Box
wrapParenVerticalPadded box =
    B.andThen [ B.line (B.punc ")") ] (B.prefix (B.punc "(") box)


{-| Indent every line of a box by exactly `n` spaces (elm's `prefix` with a
run of spaces). Unlike `applyIndent`/`B.indent` (a column-sensitive `Tab`),
this is a fixed-width shift ŌĆö needed for the paren-block offsets (`(`+1, `(`+2)
that don't fall on tab stops. -}
blockIndentSpaces : Int -> Box -> Box
blockIndentSpaces n box =
    if n <= 0 then
        box

    else
        B.prefix (B.row (Array.repeat n B.space)) box


{-| A `when` directly inside parens: `(when ŌĆ” is`, branches at `(`+2 (or `(`+4
as a call argument), `)` on its own line at the `(` column (elm-format). Only a
single-line header is ported; a forced-vertical `when` header falls back. -}
makeWhenInParenBox : Bool -> Array LPNode -> Result String Box
makeWhenInParenBox isCallArg children =
    when Array.popLast children is
        Nothing ->
            Err "box: when-in-paren has no children"

        Just { last = branchesBlock, initial = withoutBranches } ->
            let
                branchOffset =
                    if isCallArg then
                        4

                    else
                        2

                headerResult =
                    buildFlowBox 0 withoutBranches

                branchesResult =
                    renderWhenBranchesBox (lpnChildren branchesBlock)
            in
            Result.map2
                (\hdr brs ->
                    wrapParenVertical (B.stack1 [ hdr, blockIndentSpaces branchOffset brs ])
                )
                headerResult
                branchesResult


{-| An `if`/`else` or `let` directly inside parens, using elm-format's
paren-block layout: keyword at `(`+1, bodies at `(`+2 (or `(`+4 as a call
argument), `else`/`in` and `else if` at `(`+1, `)` on its own line at the `(`
column. The paren's direct children are the flattened `if`/`let` pieces (an
`IfCondition`/`let` head, `IndentedBlock` bodies, `SynthesizedText` keywords,
`EmptyLine` blanks). -}
makeBlockInParenBox : Bool -> Array LPNode -> Result String Box
makeBlockInParenBox isCallArg children =
    let
        bodyOffset =
            if isCallArg then
                4

            else
                2

        step node accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        let
                            push box =
                                { boxes = Array.pushLast box acc.boxes, isFirst = False }
                        in
                        when lpnBox node is
                            IndentedBlock ->
                                buildFlowBox 0 (lpnChildren node)
                                    |> Result.map (\b -> push (blockIndentSpaces bodyOffset b))

                            BodyBlock ->
                                buildFlowBox 0 (lpnChildren node)
                                    |> Result.map (\b -> push (blockIndentSpaces 1 b))

                            EmptyLine ->
                                Ok (push B.blankLine)

                            SynthesizedText s ->
                                Ok (push (blockIndentSpaces 1 (B.line (B.literal s))))

                            IfCondition _ ->
                                makePBox (lpnBox node) (lpnChildren node)
                                    |> Result.map
                                        (\b ->
                                            push
                                                (if acc.isFirst then
                                                    b

                                                 else
                                                    blockIndentSpaces 1 b
                                                )
                                        )

                            _ ->
                                makePBox (lpnBox node) (lpnChildren node)
                                    |> Result.map (\b -> push b)
                    )
    in
    Array.foldl step (Ok { boxes = [], isFirst = True }) children
        |> Result.map (\acc -> wrapParenVertical (B.stack1 acc.boxes))


{-| True when a paren's content is a lambda whose PARAMETER is a multi-line
bracket pattern (`(\{ ŌĆ” } ŌĆ”)`, `(\[ ŌĆ” ] ŌĆ”)`) ŌĆö the align-style case where the
paren must pad continuations (`wrapParenVerticalPadded`) so the pattern's `,`/`}`
stay under the opening bracket. A `\x -> <multi-line body>` lambda leads with a
single-line `PrefixGlue`, so it does not match ŌĆö its body is absolute-nested and
must NOT be padded. -}
parenContentLeadsWithMultilinePrefixGlue : Array LPNode -> Bool
parenContentLeadsWithMultilinePrefixGlue children =
    when Array.first children is
        Just first ->
            when lpnBox first is
                -- The paren content is usually a single `AcrossOrVertical` flow
                -- (`\{ ŌĆ” } param -> body`); descend into it to reach the leading
                -- `PrefixGlue`.
                AcrossOrVertical _ ->
                    parenContentLeadsWithMultilinePrefixGlue (lpnChildren first)

                PrefixGlue _ ->
                    when makePBox (lpnBox first) (lpnChildren first) is
                        Ok b ->
                            not (isSingleLine b)

                        Err _ ->
                            False

                _ ->
                    False

        Nothing ->
            False


{-| The second direct child is an `IndentedBlock` (lambda body on a separate
row), or a `SoftIndentedBlock` whose sole child is a bracket literal that itself
renders vertical. -}
parenLambdaMultiline : Array LPNode -> Bool
parenLambdaMultiline children =
    when Array.popFirst children is
        Just { rest } ->
            when Array.first rest is
                Just second ->
                    when lpnBox second is
                        IndentedBlock ->
                            True

                        SoftIndentedBlock ->
                            softIndentedBlockChildForcesVerticalBox (lpnChildren second)

                        _ ->
                            False

                Nothing ->
                    False

        Nothing ->
            False


{-| True when the sole child is a record/array/update literal that renders
multi-line. -}
softIndentedBlockChildForcesVerticalBox : Array LPNode -> Bool
softIndentedBlockChildForcesVerticalBox children =
    when Array.popFirst children is
        Just { first = only, rest } ->
            if not (Array.isEmpty rest) then
                False

            else
                let
                    isBracketLiteral =
                        when lpnBox only is
                            AlwaysVertical _ ->
                                True

                            AllAcrossOrAllVertical _ ->
                                True

                            RecordUpdate _ ->
                                True

                            _ ->
                                False
                in
                isBracketLiteral
                    && (when makePBox (lpnBox only) (lpnChildren only) is
                            Ok b ->
                                not (isSingleLine b)

                            Err _ ->
                                False
                       )

        Nothing ->
            False


{-| A record / array literal via elm's `group'`. `AllAcrossOrAllVertical`
(author wrote it inline) passes `forceMultiline = False` ŌĆö `group'` still
expands if a child is multi-line; `AlwaysVertical` (2+-field record, or author
across rows) passes `forceMultiline = True`. -}
makeLiteralBox : Bool -> ListBrackets -> Array LPNode -> Result String Box
makeLiteralBox forceMultiline bracket children =
    if Array.any nodeIsComment children then
        -- A line comment can't live inside a flat group, so a comment-bearing
        -- literal is always vertical (via `commentBracketListBox`).
        commentBracketListBox bracket children

    else
        traverseResult (\node -> makePBox (lpnBox node) (lpnChildren node)) children
            |> Result.andThen
                (\itemBoxes ->
                    when bracketPunc bracket is
                        Just { left, right } ->
                            Ok (E.groupBox True left "," right forceMultiline itemBoxes)

                        Nothing ->
                            -- unreachable: ListBrackets has exactly 3 constructors
                            -- (ListParen/ListCurly/ListSquare); bracketPunc matches
                            -- all of them and always returns Just.
                            Err "unreachable: bracket kind"
                )


{-| Glue a (possibly multi-line) comment box onto `base`'s last line with a
single space, via `B.addSuffixBox`. The space is folded into the base's last
line so the comment's continuation lines pad under the comment's start. `base`
itself may be multi-line ŌĆö the comment joins its last line. This is the one
operation every same-row trailing-comment site shares; a multi-line comment (or
a multi-line base) no longer needs to fall back. -}
glueCommentSuffix : Box -> Box -> Box
glueCommentSuffix commentBox base =
    B.addSuffixBox commentBox (B.addSuffix B.space base)


{-| Render a comment-kind node (single-line `--`/`{- -}`, or a multi-line block
comment) to a Box. Mirrors the comment arms of `renderFlowItem`. -}
commentNodeBox : LPNode -> Result String Box
commentNodeBox node =
    when lpnBox node is
        SingleLineComment loc ->
            Ok (B.line (B.literal ("--" ++ loc.value)))

        BlockComment loc ->
            if String.contains "\n" loc.value then
                multiLineBlockCommentBox loc.value

            else
                Ok (B.line (B.literal ("{-" ++ loc.value ++ "-}")))

        _ ->
            Err "box: not a comment node"


{-| Render a bracketed literal that contains a comment child, as an always-
vertical list. Each item is on its own line prefixed `{ `/`[ ` (first) or `, `
(rest); a comment on the same source row as the preceding item trails it with a
space, a comment on its own row gets its own line at the bracket column; the
closing bracket sits on its own line. Box stacking supplies the alignment
(elm-format). The uniform record-array coupling (a whole-list flat/expanded
choice) is NOT reproduced ŌĆö those fall back. -}
commentBracketListBox : ListBrackets -> Array LPNode -> Result String Box
commentBracketListBox bracket nodes =
    when bracketPunc bracket is
        Nothing ->
            -- unreachable: ListBrackets has exactly 3 constructors
            -- (ListParen/ListCurly/ListSquare); bracketPunc matches
            -- all of them and always returns Just.
            Err "unreachable: bracket kind"

        Just { left, right } ->
            let
                placeComment commentRow node acc =
                    commentNodeBox node
                        |> Result.andThen
                            (\cbox ->
                                if commentRow == acc.prevRow then
                                    -- Trailing the preceding item: attach with a
                                    -- single space (layout is author-driven, not
                                    -- width-driven). A multi-line trailing comment
                                    -- pads under its start via `glueCommentSuffix`.
                                    when acc.pending is
                                        Nothing ->
                                            Ok
                                                { acc
                                                    | entries = Array.pushLast { box = cbox, isComment = True } acc.entries
                                                    , pending = Nothing
                                                }

                                        Just e ->
                                            Ok
                                                { acc
                                                    | entries = Array.pushLast { box = glueCommentSuffix cbox e.box, isComment = False } acc.entries
                                                    , pending = Nothing
                                                }

                                else
                                    let
                                        flushed =
                                            when acc.pending is
                                                Nothing ->
                                                    acc.entries

                                                Just e ->
                                                    Array.pushLast e acc.entries
                                    in
                                    Ok
                                        { entries = Array.pushLast { box = cbox, isComment = True } flushed
                                        , pending = Nothing
                                        , prevRow = commentRow
                                        }
                            )

                step node accResult =
                    when accResult is
                        Err e ->
                            Err e

                        Ok acc ->
                            when lpnBox node is
                                SingleLineComment loc ->
                                    placeComment loc.start.row node acc

                                BlockComment loc ->
                                    placeComment loc.start.row node acc

                                _ ->
                                    makePBox (lpnBox node) (lpnChildren node)
                                        |> Result.andThen
                                            (\box ->
                                                -- A multi-line item (a `when`/`if`/`let`
                                                -- whose branches are indented with `B.indent`
                                                -- = Tab) does not compose with the outer
                                                -- `[ `/`, ` prefix: the Tab snaps to the next
                                                -- multiple of 4 and swallows the prefix's
                                                -- 2-space pad, landing the body 2 columns too
                                                -- shallow. Fall back until the Tab-vs-prefix
                                                -- interaction is modelled. A field whose value
                                                -- is dropped to its own line BY A COMMENT
                                                -- (`, beta = {- c -} 2`) is exempt: like the
                                                -- record-update path (`fieldValueDropsToOwnLine`)
                                                -- its value flows at a fixed +4 that composes
                                                -- with the prefix. Single-line items (the common
                                                -- comment-bearing-literal case) are unaffected.
                                                if False then
                                                    Err "unreachable"

                                                else
                                                    let
                                                        itemRow =
                                                            when lpnBox node is
                                                                UnbreakableText l ->
                                                                    l.start.row

                                                                _ ->
                                                                    lpnMaxRow node

                                                        flushed =
                                                            when acc.pending is
                                                                Nothing ->
                                                                    acc.entries

                                                                Just e ->
                                                                    Array.pushLast e acc.entries
                                                    in
                                                    Ok
                                                        { entries = flushed
                                                        , pending = Just { box = box, isComment = False }
                                                        , prevRow = itemRow
                                                        }
                                            )
            in
            Array.foldl step (Ok { entries = [], pending = Nothing, prevRow = -1 }) nodes
                |> Result.map
                    (\state ->
                        let
                            allEntries =
                                when state.pending is
                                    Nothing ->
                                        state.entries

                                    Just e ->
                                        Array.pushLast e state.entries

                            assembled =
                                Array.foldl
                                    (\entry acc ->
                                        if entry.isComment then
                                            { acc | boxes = Array.pushLast entry.box acc.boxes }

                                        else
                                            let
                                                pref =
                                                    if acc.seenText then
                                                        B.row [ B.punc ",", B.space ]

                                                    else
                                                        B.row [ B.punc left, B.space ]
                                            in
                                            { boxes = Array.pushLast (B.prefix pref entry.box) acc.boxes
                                            , seenText = True
                                            }
                                    )
                                    { boxes = [], seenText = False }
                                    allEntries
                        in
                        B.stack1 (Array.pushLast (B.line (B.punc right)) assembled.boxes)
                    )


bracketPunc : ListBrackets -> Maybe { left : String, right : String }
bracketPunc bracket =
    when bracket is
        ListCurly ->
            Just { left = "{", right = "}" }

        ListSquare ->
            Just { left = "[", right = "]" }

        ListParen ->
            -- A parenthesized list reached via the general list path rather than
            -- makeExposingLineBox ŌĆö i.e. a module/import exposing list whose
            -- header carries a comment, so makeExposingLineBox fell back to the
            -- flow. Rendered with inner spaces `( a, b )` (groupBox innerSpaces),
            -- matching elm-format's parenthesized-list spacing ŌĆö distinct from the
            -- comment-free `(a, b)` makeExposingListBox emits.
            Just { left = "(", right = ")" }


type alias FlowItem =
    { node : LPNode
    , box : Box
    , isBlock : Bool
    , startRow : Int
    , comment : Maybe { box : Box, isLineComment : Bool, multiLine : Bool }
    }


-- Render each flow node to a Box (Err if any is unported), tagging whether it
-- occupies its own block line, its start row, and ŌĆö for a comment ŌĆö the rendered
-- comment box so `assembleFlowImpl` can place it by row.
renderFlowItems : Array LPNode -> Result String (Array FlowItem)
renderFlowItems nodes =
    traverseResult renderFlowItem nodes


renderFlowItem : LPNode -> Result String FlowItem
renderFlowItem node =
    when lpnBox node is
        SingleLineComment loc ->
            Ok
                { node = node
                , box = B.blankLine
                , isBlock = False
                , startRow = loc.start.row
                , comment = Just { box = B.line (B.literal ("--" ++ loc.value)), isLineComment = True, multiLine = False }
                }

        BlockComment loc ->
            if String.contains "\n" loc.value then
                multiLineBlockCommentBox loc.value
                    |> Result.map
                        (\cbox ->
                            { node = node
                            , box = B.blankLine
                            , isBlock = False
                            , startRow = loc.start.row
                            , comment = Just { box = cbox, isLineComment = False, multiLine = True }
                            }
                        )

            else
                Ok
                    { node = node
                    , box = B.blankLine
                    , isBlock = False
                    , startRow = loc.start.row
                    , comment = Just { box = B.line (B.literal ("{-" ++ loc.value ++ "-}")), isLineComment = False, multiLine = False }
                    }

        _ ->
            makePBox (lpnBox node) (lpnChildren node)
                |> Result.map
                    (\box ->
                        { node = node
                        , box = box
                        , isBlock = isBlockNode node box
                        , startRow = nodeStartRow node
                        , comment = Nothing
                        }
                    )


nodeStartRow : LPNode -> Int
nodeStartRow node =
    when lpnFirstPos node is
        Just p ->
            p.row

        Nothing ->
            -1


isCommentItem : FlowItem -> Bool
isCommentItem item =
    item.comment /= Nothing


{-| Assemble a flow: inline nodes join on one line with single spaces; a single
trailing block node (BodyBlock / IndentedBlock / any multi-line node) drops to
its own line indented by `indent`. Shapes outside "inline* block?" are `Err`
(fall back) for now. -}
buildFlowBox : Int -> Array LPNode -> Result String Box
buildFlowBox indent nodes =
    renderFlowItems nodes
        |> Result.andThen (assembleFlow False indent)


{-| Like `buildFlowBox`, but for a flow that continues on the same line as a
token the caller already emitted (a binop/`OpAndRhs` rhs after its operator, a
`( ŌĆ” )` body). A leading single-line block comment there stays inline instead of
dropping to its own line (`inlineStart = True`). -}
buildFlowBoxInline : Int -> Array LPNode -> Result String Box
buildFlowBoxInline indent nodes =
    renderFlowItems nodes
        |> Result.andThen (assembleFlow True indent)


{-| Assemble a *broken* flow ŌĆö every item on its own line: the first at the base
column, each remaining item at +`indent` (the `brokenFlow = True` path). Box
already renders broken function applications via `assembleBrokenCall`, so the one
caller here is the forced-vertical comment-bearing binop (`operand0` /
`op ŌĆ” rest` at +4). Top-level comment items aren't handled ŌĆö those flows fall
back. -}
buildFlowBoxBroken : Int -> Array LPNode -> Result String Box
buildFlowBoxBroken indent nodes =
    renderFlowItems nodes
        |> Result.andThen (assembleBrokenWithComments indent)


{-| Assemble a broken flow (head at base, each following item at +`indent`) that
may carry comments. A comment trailing the preceding item on the same source row
glues onto that item's last line ŌĆö for a single-line item, its line plus a space
is prepended onto the comment box (`B.prefix`), so a multi-line comment's body
reindents under it (`f {- multiŌĆ” -}`, `+ b {- multiŌĆ” -}`). A comment on its own
row, or one trailing a multi-line item (no single last line to glue onto), isn't
modelled and falls back. -}
assembleBrokenWithComments : Int -> Array FlowItem -> Result String Box
assembleBrokenWithComments indent items =
    let
        step item accResult =
            accResult
                |> Result.andThen
                    (\acc ->
                        when item.comment is
                            Just c ->
                                when Array.popLast acc.entries is
                                    Just { last = lastBox, initial } ->
                                        if item.startRow == acc.lastRow && acc.lastRow >= 0 then
                                            -- Glue the comment onto the item's last
                                            -- line; the item may itself be multi-line
                                            -- (`glueCommentSuffix` joins its last line).
                                            Ok { acc | entries = Array.pushLast (glueCommentSuffix c.box lastBox) initial }

                                        else
                                            -- Own row: the comment stands as its
                                            -- own entry at the flow's +indent,
                                            -- with the next item starting on a
                                            -- fresh line (= its own entry here).
                                            -- After a comment nothing row-glues
                                            -- (the policy is AlreadyTerminated),
                                            -- so `lastRow` resets.
                                            Ok
                                                { acc
                                                    | entries = Array.pushLast c.box (Array.pushLast lastBox initial)
                                                    , lastRow = -1
                                                }

                                    Nothing ->
                                        -- Leading comment with no preceding
                                        -- entry to glue onto: it stands as the
                                        -- flow's first own-line entry. The
                                        -- mergedFirstStep block-comment glue
                                        -- (`{- c -} nextTerm`) is handled before
                                        -- the fold; this arm renders a
                                        -- first-position `--`/own-line comment on
                                        -- its own line. After a comment nothing
                                        -- row-glues, so `lastRow = -1`.
                                        Ok { acc | entries = [ c.box ], lastRow = -1 }

                            Nothing ->
                                Ok { acc | entries = Array.pushLast item.box acc.entries, lastRow = lpnMaxRow item.node }
                    )

        -- A leading single-line block comment in a broken flow glues onto the
        -- very next term (`{- c -} nextTerm`) when that term is a non-comment,
        -- single-line (non-force-vertical) node.
        mergedFirst =
            when { first = Array.first items, next = Array.get 1 items } is
                { first = Just firstItem, next = Just nextItem } ->
                    when firstItem.comment is
                        Just c ->
                            if
                                not c.isLineComment
                                    && not c.multiLine
                                    && not (isCommentItem nextItem)
                                    && isSingleLine nextItem.box
                            then
                                when B.isLine c.box is
                                    Ok cl ->
                                        Just
                                            { box = B.prefix (B.row [ cl, B.space ]) nextItem.box
                                            , remaining = Array.dropFirst 2 items
                                            }

                                    Err _ ->
                                        Nothing

                            else
                                Nothing

                        Nothing ->
                            Nothing

                _ ->
                    Nothing

        foldSetup =
            when mergedFirst is
                Just m ->
                    { seed = { entries = [ m.box ], lastRow = -1 }, foldItems = m.remaining }

                Nothing ->
                    { seed = { entries = [], lastRow = -1 }, foldItems = items }
    in
    Array.foldl step (Ok foldSetup.seed) foldSetup.foldItems
        |> Result.andThen
            (\acc ->
                when Array.popFirst acc.entries is
                    Nothing ->
                        Err "box: empty broken flow"

                    Just { first = head, rest } ->
                        Ok (B.stack1 ([ head ] ++ Array.map (applyIndent indent) rest))
            )


{-| A function application forced across lines ŌĆö elm-format's
`ElmStructure.application`. The first argument stays glued to the function on
the opening line only when both are single-line and share a source row;
otherwise the function stands alone. Every non-glued argument drops to its own
line at +`indent`. -}
assembleBrokenCall : Int -> Array FlowItem -> Result String Box
assembleBrokenCall indent items =
    let
        -- The fn+arg0 glue survives comments AFTER arg0 (`String.join " "
        -- -- c` keeps `" "` on the opening line, comments drop below with the
        -- args) ŌĆö only a comment IN the fn/arg0 positions blocks it, matching
        -- elm-format's `ElmStructure.application` glue gates.
        glueHead =
            when { fn = Array.get 0 items, arg0 = Array.get 1 items } is
                { fn = Just fnItem, arg0 = Just arg0Item } ->
                    if not (isCommentItem fnItem) && not (isCommentItem arg0Item) && shouldGlueBox fnItem arg0Item then
                        joinInline [ fnItem.box, arg0Item.box ]

                    else
                        Nothing

                _ ->
                    Nothing
    in
    when glueHead is
        Just glueLine ->
            let
                rest =
                    Array.dropFirst 2 items
            in
            if Array.isEmpty rest then
                -- Just `fn arg0` ŌĆö nothing forces a break after all.
                Ok glueLine

            else
                -- The rest (args and comments alike) assembles as a broken flow
                -- at +0 and the whole block shifts to +indent under the glued
                -- line.
                assembleBrokenWithComments 0 rest
                    |> Result.map (\restBox -> B.stack1 [ glueLine, applyIndent indent restBox ])

        Nothing ->
            -- No glue: head at the base column, every later item (and any
            -- same-row/own-line comment) per the broken-flow fold.
            assembleBrokenWithComments indent items


-- Both single-line and on the same source row ŌåÆ keep glued on the opening line.
shouldGlueBox : FlowItem -> FlowItem -> Bool
shouldGlueBox fnItem arg0Item =
    isSingleLine fnItem.box
        && isSingleLine arg0Item.box
        && nodesShareStartRow fnItem.node arg0Item.node


nodesShareStartRow : LPNode -> LPNode -> Bool
nodesShareStartRow a b =
    when { pa = lpnFirstPos a, pb = lpnFirstPos b } is
        { pa = Just posA, pb = Just posB } ->
            posA.row == posB.row

        _ ->
            False


-- Join boxes horizontally on one line with single spaces, iff all single-line.
joinInline : Array Box -> Maybe Box
joinInline boxes =
    when B.allSingles boxes is
        Ok lines ->
            Just (B.line (B.row (Array.intersperse B.space lines)))

        Err _ ->
            Nothing


isBlockNode : LPNode -> Box -> Bool
isBlockNode node box =
    when lpnBox node is
        BodyBlock ->
            True

        IndentedBlock ->
            True

        _ ->
            not (isSingleLine box)


isSingleLine : Box -> Bool
isSingleLine box =
    when B.isLine box is
        Ok _ ->
            True

        Err _ ->
            False


{-| Which indent discipline a multi-line box's continuation lines carry ŌĆö
the static per-box-type alignment table (CutoverScope.md "Item 4 design"),
verified against elm-format's layout, not curve-fit. It decides which
primitive materializes a soft glue (elm-format's flow separator flattens to a
space, so the item's first line joins the running line and its continuation
lines land per the item's own alignment):

  - `AlignCarrying` ŌĆö elm-format anchors these continuation lines at the item's
    printed start column: bracket literals and multiline strings. Glue with
    `B.prefix`, which pads every continuation line by the glued prefix's exact
    character width. This is only sound because these boxes' continuation lines
    are punctuation- or verbatim-prefixed (`, item`, `}`, string content) ŌĆö NOT
    `Tab`-indented.
  - `AlignCarryingTabbed` ŌĆö `RecordUpdate` and `AlignedFlow`: align-carrying
    too (anchored at the item's start column), but their Box continuation lines
    carry `Tab`s, which a bare `B.prefix`'s space padding would quantize to the
    next multiple of 4 (the census's "per-row exact-space indent" hard class).
    `B.freezeTabs` first rewrites those `Tab`s to the literal spaces they render
    to at their standalone columns, so the following `B.prefix` shifts every
    line by the prefix's exact width ŌĆö matching the align anchor.
  - `NestCarrying` ŌĆö nested relative to the flow's base, not the glue column:
    `AcrossOrVertical` (the flow fold / broken call at +grenIndent), `OpAndRhs`
    / `Glue` / `PrefixGlue` (inline flows at +0), and pipelines (steps at
    +grenIndent). Glue first-line-only: the continuation lines already carry the
    item's own indent relative to the flow base, which the flow's final
    `applyIndent flowIndent` (its outer nest) completes.
  - `UnclassifiedCarrying` ŌĆö everything else must stay an `Err` fallback:
    guessing produces a Box-only layout, the exact divergence class the
    shared FlowPolicy core exists to prevent.

LOAD-BEARING invariant: any new align-carrying builder must update this table.
-}
type SoftGlueAlignment
    = AlignCarrying
    | AlignCarryingTabbed
    | NestCarrying
    | UnclassifiedCarrying


{-| True when a paren's content leads with an align-carrying node (a bracket
literal / record / record update) ŌĆö the shapes whose continuation lines anchor
at their own start column, so wrapping them in `(` must pad every line (not just
the first) to keep `,`/`}` under the opening bracket. Leading single-line block
comments are skipped (they ride on the `(`-line). -}
parenInnerIsAlignCarrying : Array LPNode -> Bool
parenInnerIsAlignCarrying children =
    when Array.popFirst children is
        Just { first, rest } ->
            when lpnBox first is
                BlockComment _ ->
                    parenInnerIsAlignCarrying rest

                SingleLineComment _ ->
                    parenInnerIsAlignCarrying rest

                _ ->
                    when softGlueAlignment first is
                        AlignCarrying ->
                            True

                        AlignCarryingTabbed ->
                            True

                        _ ->
                            False

        Nothing ->
            False


softGlueAlignment : LPNode -> SoftGlueAlignment
softGlueAlignment node =
    when lpnBox node is
        AlwaysVertical _ ->
            AlignCarrying

        AllAcrossOrAllVertical _ ->
            AlignCarrying

        MultilineString _ ->
            AlignCarrying

        RecordUpdate _ ->
            AlignCarryingTabbed

        AlignedFlow ->
            AlignCarryingTabbed

        AcrossOrVertical _ ->
            NestCarrying

        OpAndRhs ->
            NestCarrying

        Glue ->
            NestCarrying

        PrefixGlue _ ->
            NestCarrying

        Pipeline _ ->
            NestCarrying

        _ ->
            UnclassifiedCarrying


-- True for a flow item whose node is a bracket LITERAL (record / array / record
-- update) ŌĆö the align-carrying shapes, so a `B.prefix` glue of their first line
-- pads continuation lines to stay aligned under the opening bracket.
isSoftGlueLiteral : FlowItem -> Bool
isSoftGlueLiteral item =
    when lpnBox item.node is
        AlwaysVertical _ ->
            True

        AllAcrossOrAllVertical _ ->
            True

        RecordUpdate _ ->
            True

        _ ->
            False


{-| Soft-glue a flow whose ONLY multi-line item is a bracket literal (elm-format
glues every item and lets the literal break internally): the single-line prefix
items glue to the literal's first line, its continuation pads to align under the
bracket (`B.prefix`), and any single-line suffix items (a trailing `=`) glue onto
its last line (`B.addSuffix`). Covers a multi-line record/array *pattern* function
argument (`multilineRecord { alpha\n, beta\n} =`), which `assembleFlowImpl`'s
flat stacker would instead drop to its own line. Returns Nothing (ŌåÆ general
assembler) unless the shape matches exactly: no comments/blank lines/hard blocks,
a non-empty single-line prefix, exactly one multi-line item, and it is a bracket
literal. Only reached from `assembleFlow` (the gluing flow path) ŌĆö a call whose
record arg *drops* goes through `assembleBrokenCall` instead. -}
-- Render a prefix/suffix flow item to the single inline `Line` it contributes to
-- a soft-glue flow. A plain item uses its box (which must be single-line); a
-- single-line block-comment item (`{- c -}`) uses its rendered comment box, so a
-- trailing comment (`ŌĆ” exposing (..) {- c -}`) glues onto the soft literal's last
-- line. A `--` line comment or a multi-line block comment can't glue inline, so it
-- Errs ŌĆö dropping the whole flow back to the general assembler.
flowItemInlineLine : FlowItem -> Result String B.Line
flowItemInlineLine item =
    let
        asLine box =
            when B.isLine box is
                Ok l ->
                    Ok l

                Err _ ->
                    Err "box: multi-line item in soft-glue flow"
    in
    when item.comment is
        Just c ->
            if c.isLineComment || c.multiLine then
                Err "box: non-inline comment in soft-glue flow"

            else
                asLine c.box

        Nothing ->
            asLine item.box


trySoftGlueFlow : Array FlowItem -> Maybe Box
trySoftGlueFlow items =
    if Array.any (\it -> isEmptyLine it.node) items then
        Nothing

    else
        let
            multiIdxs =
                Array.foldl
                    (\it acc -> { i = acc.i + 1, idxs = if isSingleLine it.box then acc.idxs else Array.pushLast acc.i acc.idxs })
                    { i = 0, idxs = [] }
                    items
        in
        when multiIdxs.idxs is
            [ idx ] ->
                let
                    softItem =
                        Array.get idx items

                    prefix =
                        Array.takeFirst idx items

                    suffix =
                        Array.dropFirst (idx + 1) items
                in
                when { s = softItem, pl = traverseResult flowItemInlineLine prefix, sl = traverseResult flowItemInlineLine suffix } is
                    { s = Just soft, pl = Ok prefixLines, sl = Ok suffixLines } ->
                        -- Require BOTH a non-empty single-line prefix AND a
                        -- non-empty single-line suffix. The suffix (a trailing
                        -- synthesized `=`) is what marks a funcDecl/`let`
                        -- destructuring HEADER ŌĆö where the flow glues the pattern
                        -- and appends `=` ŌĆö apart from a call argument
                        -- (`fn { record }`, no trailing token) where the
                        -- record instead DROPS to its own line (via the pipeline
                        -- trigger / broken-call path). Without this gate a
                        -- multi-line record call arg would be wrongly glued.
                        --
                        -- A multi-line TYPE record after a real head is the
                        -- policy's DropBlock (the type-record drop) ŌĆö the fold
                        -- must handle it, not this glue: a trailing comment
                        -- item (`} {- c -}`) would otherwise satisfy the
                        -- non-empty-suffix gate and wrongly glue a signature
                        -- segment's dropping record.
                        if isSoftGlueLiteral soft && not (Array.isEmpty prefixLines) && not (Array.isEmpty suffixLines) && not (FP.isTypeRecordLiteral soft.node) then
                            let
                                prefixLine =
                                    B.row (Array.intersperse B.space prefixLines)

                                glued =
                                    B.prefix (B.row [ prefixLine, B.space ]) soft.box
                            in
                            Just (B.addSuffix (B.row ([ B.space ] ++ Array.intersperse B.space suffixLines)) glued)

                        else
                            Nothing

                    _ ->
                        Nothing

            _ ->
                Nothing


assembleFlow : Bool -> Int -> Array FlowItem -> Result String Box
assembleFlow inlineStart flowIndent items =
    when trySoftGlueFlow items is
        Just box ->
            Ok box

        Nothing ->
            -- (The pre-Phase-1 "inline token gluing to a preceding block"
            -- guard is gone: the placement fold glues an inline follower onto
            -- a block's last line itself ŌĆö `glueOntoLastRow`'s `B.addSuffix`
            -- ŌĆö exactly where the policy decides a `SoftSep`/`GlueSpace`
            -- lands with an empty current row.)
            assembleFlowImpl inlineStart flowIndent items


{-| Pair each single-line block-comment item with an immediately following
type-record literal item, removing the comment from the item list and attaching
it to the record's entry. `assembleFlowImpl`'s fold then decides whether the
pair drops together or replays the plain unpaired steps. Flows containing an
arrow (a function type's segments) pair too: the drop's reparse fixed point is
guaranteed by `makeSignatureBox` folding `segmentHasDroppingRecordBox` into the
signature's own `forceVertical` decision (the idempotency rule). -}
pairTypeRecordComments : Array FlowItem -> Array { item : FlowItem, leading : Maybe FlowItem }
pairTypeRecordComments items =
    let
        pairableComment it =
            when it.comment is
                Just c ->
                    not c.isLineComment && not c.multiLine

                Nothing ->
                    False

        -- NB Gren's `Array.get -1` wraps to the LAST element: without this guard,
        -- a record at index 0 would pair with a comment TRAILING the flow and
        -- duplicate it.
        at i =
            if i < 0 then
                Nothing

            else
                Array.get i items
    in
    items
        |> Array.indexedMap (\i it -> { i = i, it = it })
        |> Array.mapAndKeepJust
            (\{ i, it } ->
                if
                    pairableComment it
                        && (at (i + 1)
                                |> Maybe.map (\n -> FP.isTypeRecordLiteral n.node)
                                |> Maybe.withDefault False
                           )
                then
                    -- Consumed: attached to the record that follows.
                    Nothing

                else
                    Just
                        { item = it
                        , leading =
                            if FP.isTypeRecordLiteral it.node then
                                at (i - 1)
                                    |> Maybe.andThen
                                        (\prev ->
                                            if pairableComment prev then
                                                Just prev

                                            else
                                                Nothing
                                        )

                            else
                                Nothing
                        }
            )


{-| Assemble a flow into a Box, taking every join decision from
`FlowPolicy.decide` ŌĆö the shared decision core (see CutoverScope.md "Item 4
design", Phase 1). This fold keeps NO layout policy of its own: it classifies
each item into `ItemFacts`, asks the policy for a `Placement`, and materializes
that placement with Box primitives. A placement this renderer cannot materialize
returns `Err`.

Materialization state: `curRow` is the line being assembled (single-line items
join space-separated); `rows` are the completed lines/blocks above it. The
first row sits at the flow's own column; every continuation row is indented by
`flowIndent` at the end (the outer nest wrapping the whole flow).
-}
assembleFlowImpl : Bool -> Int -> Array FlowItem -> Result String Box
assembleFlowImpl inlineStart flowIndent items =
    let
        config =
            { indent = flowIndent
            , inlineStart = inlineStart
            , brokenFlow = False
            }

        flushRow curRow rows =
            if Array.isEmpty curRow then
                rows

            else
                Array.pushLast (B.line (B.row (Array.intersperse B.space curRow))) rows

        -- Classify one flow item into the policy's fact vocabulary. The
        -- verticality facts come from this renderer's own IR (`isSingleLine`
        -- on the rendered box).
        factsFor item =
            when item.comment is
                Just c ->
                    if c.isLineComment then
                        FP.LineCommentItem { startRow = item.startRow }

                    else
                        FP.BlockCommentItem { startRow = item.startRow, multiLine = c.multiLine }

                Nothing ->
                    when lpnBox item.node is
                        AllAcrossOrAllVertical _ ->
                            bracketFacts item

                        AlwaysVertical _ ->
                            bracketFacts item

                        AcrossOrVertical _ ->
                            -- A call / flow that ENDS IN A CLOSING BRACKET
                            -- (`foo`ŌÅÄ`  [ ŌĆ” ]`): carry the bracket's row as
                            -- `prevRow` so a same-row trailing comment glues onto
                            -- that `]`/`}` line instead of dropping to its own line ŌĆö
                            -- the multi-line-comment counterpart of the bracket-
                            -- literal carry in `FlowPolicy` (without it the comment
                            -- reparses own-line and detaches, +4 Ōåö col-0). Gated on
                            -- ending in a bracket: a call ending in a plain token
                            -- (`decl x`, incl. one a comment inflated to multi-row)
                            -- keeps the `-1` catch-all, so a following body-leading
                            -- comment is unaffected.
                            when lpnLastBracketEnd item.node is
                                Just p ->
                                    FP.LeafItem { startRow = p.row, isElidedArrow = False }

                                Nothing ->
                                    FP.LeafItem { startRow = -1, isElidedArrow = False }

                        IndentedBlock ->
                            FP.IndentedBlockItem

                        BodyBlock ->
                            FP.BodyBlockItem

                        SoftIndentedBlock ->
                            FP.SoftBlockItem { childForcesVertical = softBlockChildForcesVerticalBox item }

                        EmptyLine ->
                            FP.EmptyLineItem

                        PipelineStep ->
                            FP.PipelineStepItem
                                { hasLeadingComment =
                                    Array.first (lpnChildren item.node)
                                        |> Maybe.map nodeIsComment
                                        |> Maybe.withDefault False
                                }

                        UnbreakableText loc ->
                            FP.LeafItem { startRow = loc.start.row, isElidedArrow = isElidedArrow item.node }

                        _ ->
                            FP.LeafItem { startRow = -1, isElidedArrow = False }

        bracketFacts item =
            FP.BracketLiteralItem
                { forcesVertical = not (isSingleLine item.box)
                , isTypeRecord = FP.isTypeRecordLiteral item.node
                , closingRow =
                    lpnLastBracketEnd item.node
                        |> Maybe.map (\p -> p.row)
                        |> Maybe.withDefault -1
                }

        -- Glue a single line onto the last completed row's last line ŌĆö the
        -- materialization of a soft-separator join whose left side is a block
        -- (the separator flattens to a space onto the running line).
        -- Covers the ex-`glueable` lambda-pattern/lambda-head followers and a
        -- same-row comment gluing onto a dropped record's `}` line.
        glueOntoLastRow acc l next =
            when Array.popLast acc.rows is
                Just { last = lastBox, initial } ->
                    Ok
                        { rows = Array.pushLast (B.addSuffix (B.row [ B.space, l ]) lastBox) initial
                        , curRow = []
                        , state = next
                        }

                Nothing ->
                    Err "box: glue with nothing before"

        -- Materialize a comment item's placement. An own-line comment (the
        -- policy leaves `AlreadyTerminated`) flushes and stands alone; an
        -- inline one joins the current row. `GlueSpace` with an empty current
        -- row means the previous item was a block (a dropped record): glue
        -- onto its last line.
        placeCommentItem acc decision c =
            let
                ownLine box =
                    Ok
                        { rows = Array.pushLast box (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }
            in
            if c.multiLine then
                when decision.placement is
                    FP.AsFirst ->
                        -- In an inline-start flow (a PrefixGlue/paren body whose
                        -- box the caller embeds mid-line) the content following
                        -- the comment's own lines must be re-indented by the
                        -- ENCLOSING flow's nest ŌĆö but this box, once embedded as a
                        -- first-row item, cannot: its continuation lines are out
                        -- of the enclosing `flowIndent`'s reach. Fall back.
                        ownLine c.box

                    FP.GlueNoSep ->
                        ownLine c.box

                    FP.OwnLine ->
                        ownLine c.box

                    FP.GlueSpace ->
                        if Array.isEmpty acc.curRow then
                            -- No current-row content: the previous item was a block
                            -- (e.g. a dropped record); glue the comment onto its
                            -- last emitted row. `glueCommentSuffix` joins that row's
                            -- last line and pads a multi-line comment's body under
                            -- its start.
                            when Array.popLast acc.rows is
                                Just { last = lastBox, initial } ->
                                    Ok
                                        { rows = Array.pushLast (glueCommentSuffix c.box lastBox) initial
                                        , curRow = []
                                        , state = decision.next
                                        }

                                Nothing ->
                                    Err "box: glue with nothing before"

                        else
                            -- The comment's first line joins the current row and
                            -- its body flows below. `B.prefix` prepends the row
                            -- (plus a space) onto the comment box's first line
                            -- AND pads every continuation line by that width, so
                            -- the reindented comment body lands aligned under
                            -- the opening `{-`.
                            let
                                prefLine =
                                    B.row (Array.pushLast B.space (Array.intersperse B.space acc.curRow))
                            in
                            Ok
                                { rows = Array.pushLast (B.prefix prefLine c.box) acc.rows
                                , curRow = []
                                , state = decision.next
                                }

                    _ ->
                        Err "box: unexpected multi-line comment placement"

            else
                when B.isLine c.box is
                    Err _ ->
                        Err "box: single-line comment box was multi-line"

                    Ok l ->
                        if decision.next.separator == FP.AlreadyTerminated then
                            -- Line-terminating comment (a `--`, or a block
                            -- comment the policy put on its own line).
                            when decision.placement is
                                FP.AsFirst ->
                                    ownLine (B.line l)

                                FP.GlueNoSep ->
                                    ownLine (B.line l)

                                FP.OwnLine ->
                                    ownLine (B.line l)

                                FP.GlueSpace ->
                                    -- Same-row glue; the comment still ends the
                                    -- line.
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok
                                            { rows = flushRow (Array.pushLast l acc.curRow) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                _ ->
                                    Err "box: unexpected terminating comment placement"

                        else
                            -- Inline single-line block comment: joins the flow
                            -- like a token.
                            when decision.placement is
                                FP.AsFirst ->
                                    Ok { rows = acc.rows, curRow = [ l ], state = decision.next }

                                FP.GlueSpace ->
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                                FP.SoftSep ->
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                                FP.OwnLine ->
                                    Ok { rows = flushRow acc.curRow acc.rows, curRow = [ l ], state = decision.next }

                                _ ->
                                    Err "box: unexpected inline comment placement"

        -- Materialize a non-comment item's placement. `leading` carries a
        -- paired leading comment box for the type-record drop (it drops WITH
        -- the record, stacked directly above the `{` at the drop indent).
        placeNonComment acc decision leading item =
            when decision.placement is
                FP.AsFirst ->
                    -- First item of the flow: the bare item (no wrap).
                    when B.isLine item.box is
                        Ok l ->
                            Ok { rows = acc.rows, curRow = [ l ], state = decision.next }

                        Err _ ->
                            if flowIndent > 0 && softGlueAlignment item.node == NestCarrying && subtreeHasMultilineBlockComment item.node then
                                -- A multi-line nest-carrying first item, in an
                                -- INDENTED flow, containing a multi-line block
                                -- comment: the comment's body lines are
                                -- align-anchored at their printed column
                                -- (`B.prefix` padding) while content on a fresh
                                -- line after it is ambient-anchored ŌĆö the ambient
                                -- lines take the flow's indent on top of the
                                -- item's own.
                                -- The first row escapes the final uniform
                                -- `applyIndent`, and no single per-box shift
                                -- satisfies both anchors (the post-mlbc
                                -- continuation-indent hard class, t42/t43 ŌĆö
                                -- MultilineBlockComments `#13`). Without an
                                -- mlbc the box is homogeneous and the bare
                                -- push is the proven materialization (broken
                                -- record-pattern headers, PatternLayoutByAuthor).
                                Ok { rows = Array.pushLast item.box acc.rows, curRow = [], state = decision.next }

                            else
                                Ok { rows = Array.pushLast item.box acc.rows, curRow = [], state = decision.next }

                FP.GlueNoSep ->
                    -- Content begins on the fresh line the previous comment
                    -- opened (the current row is empty after the comment's
                    -- flush).
                    when B.isLine item.box is
                        Ok l ->
                            Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                        Err _ ->
                            Ok { rows = Array.pushLast item.box (flushRow acc.curRow acc.rows), curRow = [], state = decision.next }

                FP.SoftSep ->
                    when B.isLine item.box is
                        Ok l ->
                            if Array.isEmpty acc.curRow then
                                glueOntoLastRow acc l decision.next

                            else
                                Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                        Err _ ->
                            -- Soft-glue a multi-line non-block item's first line
                            -- onto the running line (the separator flattens to a
                            -- space; inner hard breaks land per the item's own
                            -- alignment ŌĆö see `softGlueAlignment`, the static
                            -- alignment table).
                            if Array.isEmpty acc.curRow then
                                -- unreachable: an empty current row means the
                                -- previous item was a block (a multi-line operand).
                                -- The only multi-line items that soft-glue in this
                                -- inline flow are binop operands (pipelines render
                                -- via their own `PipelineStep` path; a `Src.Call`
                                -- with a multi-line arg goes to `assembleBrokenCall`).
                                -- A multi-line binop operand that is a bracket /
                                -- record / paren now forces the whole chain vertical
                                -- (`isChainBreakingOperandBox` ŌåÆ `verticalBinopChainBox`),
                                -- so a block never precedes another operand here.
                                Err "unreachable: multi-line item soft-glued after a block"

                            else
                                let
                                    prefLine =
                                        B.row (Array.pushLast B.space (Array.intersperse B.space acc.curRow))
                                in
                                when softGlueAlignment item.node is
                                    AlignCarrying ->
                                        Ok
                                            { rows = Array.pushLast (B.prefix prefLine item.box) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                    AlignCarryingTabbed ->
                                        -- Record update / aligned flow: the same
                                        -- align anchor as `AlignCarrying`, but the
                                        -- box's continuation lines carry `Tab`s.
                                        -- Freeze them to literal spaces first so
                                        -- `B.prefix` shifts by its exact width
                                        -- instead of the tab stops re-snapping to
                                        -- absolute multiples of 4.
                                        Ok
                                            { rows = Array.pushLast (B.prefix prefLine (B.freezeTabs item.box)) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                    NestCarrying ->
                                        Ok
                                            { rows = Array.pushLast (B.mapFirstLine (\l -> B.row [ prefLine, l ]) identity item.box) acc.rows
                                            , curRow = []
                                            , state = decision.next
                                            }

                                    UnclassifiedCarrying ->
                                        -- Direct-operand lambda `|> (\x -> ŌĆ”)`:
                                        -- glue `(` after the operator, body at +8
                                        -- (two Tabs ŌĆö the lambda body sits at the
                                        -- operator+8 column), and `)` on its own
                                        -- line aligned under the `(` (elm-format),
                                        -- three columns past the operator.
                                        when directOperandLambdaSplit item.node is
                                            Just { headLine, bodyBox } ->
                                                Ok
                                                    { rows =
                                                        Array.pushLast
                                                            (B.stack1
                                                                [ B.line (B.row [ prefLine, B.punc "(", headLine ])
                                                                , B.indent (B.indent bodyBox)
                                                                , B.prefix (B.row [ B.space, B.space, B.space ]) (B.line (B.punc ")"))
                                                                ]
                                                            )
                                                            acc.rows
                                                    , curRow = []
                                                    , state = decision.next
                                                    }

                                            Nothing ->
                                                -- A paren whose content is an
                                                -- align-carrying literal (a
                                                -- record-destructuring `as`
                                                -- pattern, `({ ŌĆ” } as name)`):
                                                -- the paren box already anchors
                                                -- its continuation lines at its
                                                -- own start column, so freeze its
                                                -- `Tab`s and `B.prefix`-glue it
                                                -- like any other align-carrying
                                                -- item.
                                                when lpnBox item.node is
                                                    ParenBlock _ ->
                                                        if parenInnerIsAlignCarrying (lpnChildren item.node) then
                                                            Ok
                                                                { rows = Array.pushLast (B.prefix prefLine (B.freezeTabs item.box)) acc.rows
                                                                , curRow = []
                                                                , state = decision.next
                                                                }

                                                        else
                                                            -- unreachable: a multi-line `ParenBlock` operand
                                                            -- of a binop now forces the whole chain vertical
                                                            -- (`isChainBreakingOperandBox` includes
                                                            -- `ParenBlock` ŌåÆ `verticalBinopChainBox`), so it
                                                            -- never soft-glues here; and a pipeline's paren
                                                            -- step renders via `PipelineStep`, not this flow.
                                                            -- Only a direct-operand lambda / align-carrying
                                                            -- `as`-paren (handled above) reaches the
                                                            -- `UnclassifiedCarrying` arm at all.
                                                            Err "unreachable: multi-line non-align paren soft-glued in a flow"

                                                    _ ->
                                                        -- unreachable: to reach here an item must be a
                                                        -- SoftSep (non-first, inline non-broken flow),
                                                        -- multi-line, `UnclassifiedCarrying`, and NOT a
                                                        -- `ParenBlock`. The only boxes that are both
                                                        -- `LeafItem` (the `_ ->` in `factsFor`) and
                                                        -- `UnclassifiedCarrying` are `IfCondition`,
                                                        -- `WhenFlow`, and a raw `Binop` ŌĆö none of which
                                                        -- can occupy this slot: a raw `Binop` is never a
                                                        -- flow sibling (`flattenBinopNodes` turns nested
                                                        -- operators into `OpAndRhs`/`NestCarrying`), and a
                                                        -- multi-line `when`/`if` operand only ever gets
                                                        -- there by spanning source rows, which forces the
                                                        -- binop vertical and routes it to the broken
                                                        -- assembler (`assembleBrokenWithComments`), never
                                                        -- this inline `SoftSep`. A `when`/`if` following an
                                                        -- operator is wrapped `OpAndRhs` (`NestCarrying`,
                                                        -- handled above), not a bare `SoftSep` item.
                                                        Err "unreachable: multi-line non-paren unclassified soft-glue item"

                FP.OwnLine ->
                    when B.isLine item.box is
                        Ok l ->
                            Ok { rows = flushRow acc.curRow acc.rows, curRow = [ l ], state = decision.next }

                        Err _ ->
                            Ok { rows = Array.pushLast item.box (flushRow acc.curRow acc.rows), curRow = [], state = decision.next }

                FP.IndentNoBreak ->
                    -- Block after a line-terminating comment: the item lands on
                    -- the fresh line at +grenIndent, with no extra break.
                    Ok
                        { rows = Array.pushLast (applyIndent grenIndent item.box) (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }

                FP.BlockJoin { rule, blankBefore } ->
                    let
                        -- A commented pipeline step following another step gets
                        -- a blank line above its comment (the policy's
                        -- `blankBefore` flag).
                        rowsBefore =
                            if blankBefore then
                                Array.pushLast B.blankLine (flushRow acc.curRow acc.rows)

                            else
                                flushRow acc.curRow acc.rows
                    in
                    when rule is
                        FP.IndentedRule ->
                            Ok
                                { rows = Array.pushLast (applyIndent grenIndent item.box) rowsBefore
                                , curRow = []
                                , state = decision.next
                                }

                        FP.BodyRule ->
                            Ok
                                { rows = Array.pushLast item.box rowsBefore
                                , curRow = []
                                , state = decision.next
                                }

                        FP.SoftIndentedRule ->
                            -- Soft wrap: flat content glues onto the current line
                            -- with a space. (`blankBefore` never accompanies a soft
                            -- rule ŌĆö the policy only sets it on the pipeline step's
                            -- IndentedRule ŌĆö so the glue paths ignore `rowsBefore`.)
                            when B.isLine item.box is
                                Ok l ->
                                    if Array.isEmpty acc.curRow then
                                        glueOntoLastRow acc l decision.next

                                    else
                                        Ok { rows = acc.rows, curRow = Array.pushLast l acc.curRow, state = decision.next }

                                Err _ ->
                                    -- A multi-line soft-block body (a lambda body
                                    -- that started on the `->` row but wraps): drop
                                    -- it to its own line at +grenIndent, like the
                                    -- IndentedRule arm above. This matches elm-format
                                    -- for a call/binop body; a triple-quoted `"""ŌĆ”"""`
                                    -- body drops too (elm-format keeps that one inline
                                    -- ŌĆö a small divergence, but dropping every
                                    -- multi-line lambda body uniformly is consistent
                                    -- and always renders, whereas gluing the string
                                    -- inline mis-aligns once the lambda is itself
                                    -- nested in a paren/call).
                                    Ok
                                        { rows = Array.pushLast (applyIndent grenIndent item.box) (flushRow acc.curRow acc.rows)
                                        , curRow = []
                                        , state = decision.next
                                        }

                FP.DropBlock rule ->
                    -- The type-record drop: the record (with its paired leading
                    -- comment stacked directly above the `{`, when present)
                    -- drops below the head. IndentedRule (unnested flow) lands
                    -- it at +grenIndent; BodyRule (the flow is already nested)
                    -- at the flow's continuation column.
                    let
                        dropIndent =
                            when rule is
                                FP.IndentedRule ->
                                    grenIndent

                                _ ->
                                    0

                        droppedBox =
                            when leading is
                                Just commentBox ->
                                    B.stack1 [ commentBox, item.box ]

                                Nothing ->
                                    item.box
                    in
                    Ok
                        { rows = Array.pushLast (applyIndent dropIndent droppedBox) (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }

                FP.BlankLineOnly ->
                    Ok
                        { rows = Array.pushLast B.blankLine (flushRow acc.curRow acc.rows)
                        , curRow = []
                        , state = decision.next
                        }

                _ ->
                    Err "box: unexpected flow placement"

        step paired accResult =
            accResult |> Result.andThen (stepUnwrapped paired)

        stepUnwrapped paired acc =
            let
                item =
                    paired.item

                decision =
                    FP.decide config acc.state (factsFor item)
            in
            when item.comment is
                Just c ->
                    placeCommentItem acc decision c

                Nothing ->
                    when paired.leading is
                        Nothing ->
                            placeNonComment acc decision Nothing item

                        Just leadItem ->
                            -- A single-line block comment paired with a
                            -- type record (`pairTypeRecordComments`).
                            -- When the policy drops the record, the
                            -- comment drops WITH it; otherwise replay
                            -- the exact unpaired steps (comment first,
                            -- then re-decide the record against the
                            -- state the comment left).
                            when decision.placement is
                                FP.DropBlock _ ->
                                    placeNonComment acc
                                        decision
                                        (leadItem.comment |> Maybe.map (\lc -> lc.box))
                                        item

                                _ ->
                                    when leadItem.comment is
                                        Just lc ->
                                            let
                                                leadDecision =
                                                    FP.decide config acc.state (factsFor leadItem)
                                            in
                                            placeCommentItem acc leadDecision lc
                                                |> Result.andThen
                                                    (\a ->
                                                        let
                                                            recDecision =
                                                                FP.decide config a.state (factsFor item)
                                                        in
                                                        placeNonComment a recDecision Nothing item
                                                    )

                                        Nothing ->
                                            placeNonComment acc decision Nothing item
    in
    Array.foldl step
        (Ok { rows = [], curRow = [], state = FP.initialFlowState })
        (pairTypeRecordComments items)
        |> Result.andThen
            (\final ->
                let
                    allRows =
                        flushRow final.curRow final.rows
                in
                when Array.popFirst allRows is
                    Nothing ->
                        Err "box: empty flow"

                    Just { first, rest } ->
                        -- The first row sits at the flow's own column; every
                        -- continuation row is indented by `flowIndent`, the outer
                        -- nest wrapping the whole flow. Block rows already carry
                        -- their own indent (the placement applied it), so this
                        -- brings them to `flowIndent + ownIndent`.
                        Ok (B.stack1 ([ first ] ++ Array.map (applyIndent flowIndent) rest))
            )


-- A `SoftIndentedBlock` whose SOLE child is a bracket literal (record, record
-- update, or array) that renders vertical switches from the soft glue to the
-- hard indented drop. The structural test is on the LPNode; the verticality
-- fact comes from this renderer's own box (single-line Ōćö the sole child is
-- single-line, since it is the block's only content).
softBlockChildForcesVerticalBox : FlowItem -> Bool
softBlockChildForcesVerticalBox item =
    when Array.popFirst (lpnChildren item.node) is
        Just { first = only, rest } ->
            if not (Array.isEmpty rest) then
                False

            else
                let
                    isBracketLiteral =
                        when lpnBox only is
                            AlwaysVertical _ ->
                                True

                            AllAcrossOrAllVertical _ ->
                                True

                            RecordUpdate _ ->
                                True

                            _ ->
                                False
                in
                isBracketLiteral && not (isSingleLine item.box)

        Nothing ->
            False


isEmptyLine : LPNode -> Bool
isEmptyLine node =
    when lpnBox node is
        EmptyLine ->
            True

        _ ->
            False


-- The synthesized signature `->` ŌĆö a zero-width `UnbreakableText` (start == end)
-- built by `LPTHelpers.mkZeroWidthText`, anchored at the end of its `from` type,
-- not where it renders. A comment directly trailing it must glue regardless of
-- source row (scoped to `->` by value: other elided tokens precede a short
-- neighbour or bracketed block where a comment on its own row legitimately stays
-- own-line).
isElidedArrow : LPNode -> Bool
isElidedArrow node =
    when lpnBox node is
        UnbreakableText loc ->
            loc.value == "->"
                && loc.start.row == loc.end.row
                && loc.start.col == loc.end.col

        _ ->
            False


{-| Apply `B.indent` (a Tab, advancing to the next multiple of 4) enough times
to reach `indent` columns from a multiple-of-4 origin. -}
applyIndent : Int -> Box -> Box
applyIndent indent box =
    if indent <= 0 then
        box

    else
        applyIndent (indent - 4) (B.indent box)


-- Traverse an Array with a Result-returning function, short-circuiting on Err.
traverseResult : (a -> Result e b) -> Array a -> Result e (Array b)
traverseResult f items =
    Array.foldl
        (\item acc ->
            acc
                |> Result.andThen
                    (\built ->
                        f item |> Result.map (\b -> Array.pushLast b built)
                    )
        )
        (Ok [])
        items
