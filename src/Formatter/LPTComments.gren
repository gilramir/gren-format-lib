module Formatter.LPTComments exposing (..)

import Dict

import Compiler.Ast.Source as Src
import Compiler.Parse.Context as Ctx

import Formatter.LogicalPrintingTree exposing (LPBox(..),
    ListBrackets(..))

import Formatter.SingleRootTree as SRT exposing (SingleRootTree)

lptAddComments: Ctx.Context -> SingleRootTree LPBox -> Result String (SingleRootTree LPBox)
lptAddComments ctx lpTree =
    let
        -- Each value is an Array Comment; We con't want an Array (Array
        -- Comment); fold them all into a single Array Comment
        comments = Array.foldl (\arrayC acc -> acc ++ arrayC ) [] (Dict.values ctx.comments)
    in
    Array.foldl
        (\comment acc ->
            when acc is
                Err err ->
                    Err err

                Ok currentTree ->
                    lptAddComment comment currentTree
        )
        (Ok lpTree)
        comments

type CommentInsertionPoint
    = ExistingNode { id : Int, lpBox : LPBox }
    | NewNode { row: Int }

lptAddComment: Ctx.Comment -> SingleRootTree LPBox -> Result String (SingleRootTree LPBox)
lptAddComment comment lpTree =
    Err "foo"
