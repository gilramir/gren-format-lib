module BackwardPipeline exposing (..)

-- A backward pipeline (<|) uses a trailing operator style: the <| operator
-- trails the seed (or previous step), and the step body goes on the next line
-- indented +4. One written on a line that overflows breaks this way.
shout : String -> String
shout name =
    String.toUpper <| String.append "Greetings and salutations, " <| String.append name "!!!"


-- A short backward pipeline the author wrote on one line stays inline.
five : Int
five = identity <| 5


-- A backward pipeline the author wrote across rows stays one step per line
-- even though it would fit on one line.
keptVertical : String -> String
keptVertical name =
    String.toUpper
        <| String.append name "!"
