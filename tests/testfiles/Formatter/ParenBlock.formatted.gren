module ParenBlock exposing (..)


-- when as a binop operand: forces the operator onto its own line, matching elm-format
a x =
    List.length x
        + (when x is
            Just _ ->
                1

            Nothing ->
                0
          )


-- if/else as a binop operand: forces the operator onto its own line, matching elm-format
b x =
    1
        + (if x then
            2

           else
            3
          )


-- else-if chain as a binop operand
c x =
    1
        + (if x == 1 then
            "one"

           else if x == 2 then
            "two"

           else
            "other"
          )


-- let as a binop operand: forces the operator onto its own line, matching elm-format
d x =
    1
        + (let
            y =
                2
           in
           y + x
          )
