module LeadingGluedComment exposing (..)

{- x -} {- y -} import Apple
{- a multiline block comment
   glued before an import -} import Mango
{- single-line block comment glued before an import -} import Zebra


{- a leading block comment glued to a top-level
   function, which used to over-indent -} myFunc x =
    x + 1
