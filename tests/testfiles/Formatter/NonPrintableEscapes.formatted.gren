module NonPrintableEscapes exposing (..)


-- Non-printable ASCII control characters in string literals must be re-escaped.
escPrefix =
    "\u{001b}["


nullChar =
    "\u{0000}"


bell =
    "\u{0007}"


del =
    "\u{007f}"


-- Control characters whose lowercase hex spans the remaining code-point digits
-- (a, d, e) — none is one of the specially-escaped chars (tab/newline/CR).
sub =
    "\u{001a}"


groupSep =
    "\u{001d}"


shiftOut =
    "\u{000e}"
