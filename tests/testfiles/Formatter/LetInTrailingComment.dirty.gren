module LetInTrailingComment exposing (..)


foldOverAttributes reducerFunction initialAccumulatorValue branchAttributesArray =
    let
        accumulatorAfterAttributes =
            Array.foldl reducerFunction initialAccumulatorValue branchAttributesArrayValueHere {- trailing the last binding, before in -}
    in
    accumulatorAfterAttributes


withTrailingLineComment someArgumentValue =
    let
        firstComputedResult =
            computeSomethingReasonablyLong someArgumentValue secondArgumentValueHere thirdArgumentValue -- trailing line comment
    in
    firstComputedResult


bodyLeadingComment someArgumentValue =
    let
        someBinding =
            someArgumentValue + 1
    in
    -- leading comment of the let body, after in
    someBinding
