module LetCommentedSignatureVariants exposing (..)


-- A block comment, or multiple single-line comments, before a let-binding
-- type signature must not cause a spurious blank line between the signature
-- and its definition.
run : Int -> Int
run n =
    let
        {- Triples the value. -}
        triple : Int -> Int
        triple x =
            x * 3

        -- First comment.
        -- Second comment.
        double : Int -> Int
        double x =
            x * 2
    in
    triple (double n)
