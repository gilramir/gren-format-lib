module {- comment between `module` keyword and module name -} ModuleHeaderComments exposing {- comment between module name and `exposing` -} {- comment between `exposing` and `(` -} ( bar, foo )

-- single-line comment before the first import
import Array

-- comments inside an import without an `as` alias
import Dict exposing {- comment between import module name and `exposing` -} ( Dict )

-- comments inside an import without an `as`, using `exposing`
import Math exposing (..) {- between Math and `exposing` -}


foo : Int -> Int
foo x =
    x


bar : Int -> Int
bar x =
    x
