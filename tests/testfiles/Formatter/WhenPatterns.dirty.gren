module WhenPatterns exposing (..)

-- Variable pattern
varPat x =
    when x is
        n -> n

-- Wildcard
wildcard x =
    when x is
        _ -> 0

-- Integer literal
intLit x =
    when x is
        0 -> "zero"
        1 -> "one"
        _ -> "other"

-- String literal
strLit x =
    when x is
        "hello" -> "greeting"
        _ -> "other"

-- Char literal
charLit x =
    when x is
        'a' -> "ay"
        _ -> "other"

-- Constructor with no payload
ctorNoPayload x =
    when x is
        Nothing -> 0
        Just n -> n

-- Constructor with payload
ctorPayload x =
    when x is
        Just n -> n
        Nothing -> 0

-- Nested constructors
nestedCtor x =
    when x is
        Just (Just n) -> n
        _ -> 0

-- Alias pattern
aliasPat x =
    when x is
        (Just n) as whole -> whole
        _ -> Nothing

-- Record pattern (shorthand)
recordPat x =
    when x is
        { name, value } -> name

-- Array patterns
arrayPat x =
    when x is
        [] -> "empty"
        [ a ] -> "one"
        [ a, b ] -> "two"
        _ -> "many"
