module TODO exposing (..)

-- REVISIT (partially resolved): a multi-line TYPE record following a head/`:`
-- in a flow now DROPS to its own line at +4 (elm-format's rule; see the
-- type-record-drop in MakeRender.joinBracketLiteralFlowItem) even when a comment
-- shares the flow — the drop leaves `separator = FlowSep`, so a comment trailing
-- the dropped record's `}` glues onto that line (`} {- c -}`) as a reparse fixed
-- point instead of oscillating +4 ↔ column 0.
--
-- RESIDUAL divergence from elm-format: a comment that *leads* the record (between
-- the head/`:` and the record) stays glued to the head line here, whereas
-- elm-format drops it onto its own line above the record at the record's indent:
--
--     typeAppWithComment : HasIdentifier          -- elm-format
--         {- note -}
--         { payload : String
--         , … }
--
-- Matching that needs the comment moved below the head AND proven a reparse fixed
-- point (the leading-comment placement work). These declarations pin the current
-- (glued-leading-comment) layout; regenerate them if that is ever closed. See
-- README "Comparison with elm-format", point 12.


-- comment in the flow of a type application whose record arg spans rows
typeAppWithComment : HasIdentifier {- note -}
    { payload : String
    , flags : Int
    }
typeAppWithComment =
    something


-- comment in the flow of a record-type field whose value spans rows
fieldValueWithComment :
    { tracing : {- t -}
        { isEnabled : Bool
        , sinks : Int
        }
    , scheduler : Int
    }
fieldValueWithComment =
    something
