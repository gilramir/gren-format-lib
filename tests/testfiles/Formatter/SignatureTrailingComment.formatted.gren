module SignatureTrailingComment exposing (..)


fold : (a -> accumulatorValue -> accumulatorValue) -> accumulatorValue -> Tree a -> accumulatorValue
{- trailing a long wrapping signature -}
fold reducerFunction initialAccumulatorValue currentTreeNode =
    currentTreeNode


afterRecordClose : { a : Int, b : String }
{- after the record-type closing brace -}
afterRecordClose =
    { a = 1, b = "x" }


withLineComment : Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int -> Int
-- trailing single-line comment
withLineComment a b c d e f g h i j =
    a


insideRecordType : { a : Int {- inside the record type, before its close -}
                   }
insideRecordType =
    { a = 1 }
