module ParenBlockTabStops exposing (..)


binShortOp =
    someLongLeftOperandHere
        && (if cond then
                aaaaa

            else
                bbbbb
           )


negatedBlock =
    -(if cond then
        aaaaa

      else
        bbbbb
     )


directOperandPipe =
    values
        |> (\n ->
                if n then
                    aaaaa

                else
                    bbbbb
           )


nestedParenPipeCallArg =
    fn
        ((if cond then
            one

          else
            two
         )
            |> gn
        )
        last


nestedParenBinopCallArg =
    fn
        ((if cond then
            one

          else
            two
         )
            + rest
        )
        last


nestedParenPipeWhen =
    fn
        ((when sel is
            Just w ->
                w

            Nothing ->
                0
         )
            |> gn
        )
        last


nestedParenPipeLet =
    fn
        ((let
            q =
                one
          in
          q
         )
            |> gn
        )
        last


brokenBinopAfterShortOp =
    someLongLeftOperandHere
        && (aaa
                ++ bbb
           )


brokenBinopAfterAppend =
    x
        ++ (aaa
                ++ bbb
           )


brokenBinopDirectOperandPipe =
    seed
        |> (aaa
                ++ bbb
           )


brokenRecordDirectOperandPipe =
    seed
        |> ({ a = 1
            , b = 2
            }
           )
