module PipelineLayoutByAuthor exposing (..)

-- Author wrote it on one line and it fits: stays inline.
inlineFits = items |> List.map double |> List.first

-- Author wrote it on one line but it overflows: one step per line.
overflows = someInitialCollection |> List.map transformEachElement |> List.keepIf passesPredicate |> List.first

-- Author wrote it across rows: kept one step per line even though it fits.
keptVertical =
    items
        |> List.map double
        |> List.first
