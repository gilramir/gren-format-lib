module CommentsPipeline exposing ( foo )


-- Comments between pipeline lines should have a single space
-- before them to make them easier to read
findPreferredLanguage : Array String -> Maybe String
findPreferredLanguage preferredLanguages =
    preferredLanguages
        -- 0. Convert to 2 chars only
        |> Array.map (\lang -> String.takeFirst 2 lang)

        -- 1. Filter the list to include only our languages
        |> Array.keepIf (\lang -> Array.member lang getSupportedLanguages)

        -- 2. Take the first element of the resulting list
        |> Array.first
