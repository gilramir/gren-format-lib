module LetBindingComments exposing (..)


-- Regression guard: a standalone block comment before a NON-FIRST `let`
-- binding must render on its own line, with the binding starting fresh at the
-- binding column. Both single-line and multi-line block comments previously
-- glued the following binding onto the comment's `-}` line, producing output
-- that no longer parsed.
single x =
    let
        first =
            x + 1

        {- standalone single-line block comment -}
        second =
            first + 1
    in
    second


multi x =
    let
        first =
            x + 1

        {- standalone
           multi-line
           block comment -}
        second =
            first + 1
    in
    second
