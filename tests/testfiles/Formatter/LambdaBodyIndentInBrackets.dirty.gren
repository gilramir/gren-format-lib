module LambdaBodyIndentInBrackets exposing (inArray, nested, inArrayMulti, recordFieldDropsLambda)


inArray =
    [ \q ->
        q + one
    ]


nested =
    \a ->
        \b ->
            b + one


inArrayMulti =
    [ \q ->
        q + one
    , \r ->
        r + two
    ]


recordFieldDropsLambda =
    { fld = \q ->
        q + one
    }
