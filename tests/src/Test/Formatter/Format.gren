module Test.Formatter.Format exposing (suites)

import Bytes
import Expect exposing (Expectation)
import FileSystem
import FileSystem.Path as Path
import Task exposing (Task)
import Test.Runner.UnitNode as U

import Array.Builder as Builder
import Compiler.Ast.Source as Src
import Compiler.Parse.Module as PM
import Compiler.Parse.Context as Context
import Compiler.Ast.Compare as AstCompare
import Formatter as PPrint
import String.Parser.Advanced as Parser

import UnifiedDiff exposing (unifiedDiffStrings)
import Change1.RecordUpdateSlice as Change1RU


suites : FileSystem.Permission -> Array U.Suite
suites fsPerm =
    [ importSuite fsPerm
    , expressionSuite fsPerm
    , declarationSuite fsPerm
    , commentsSuite fsPerm
    , kitchenSinkSuite fsPerm
    , change1SliceSuite fsPerm
    ]


{-| Change-1 first slice: the record-update examples built with the ported
elm-format Box model must render byte-identical to `elm-format` — with no
hand-tuned column arithmetic. This is the go/no-go signal for Change 1. -}
change1SliceSuite : FileSystem.Permission -> U.Suite
change1SliceSuite fsPerm =
    U.suite
        { name = "Change 1 slice"
        , setUpSuite = U.noSuiteFixture
        , tearDownSuite = U.noTearDown
        , setUp = U.noFixture
        , tearDown = U.noTearDown
        , tests =
            [ U.test "record update via Box model matches elm-format byte-for-byte" <|
                \_ ->
                    readTestFile fsPerm "RecordUpdateSlice.expected.gren"
                        |> Task.map
                            (\expected ->
                                Expect.equal Change1RU.rendered expected
                                    |> Expect.onFail (unifiedDiffStrings expected Change1RU.rendered)
                            )
            ]
        }


{-| Format a dirty fixture and return the result.

`Task.fail` propagates genuine I/O failures (missing file) → test Errored.
Parse and format failures ride the success channel as `Err message` and become
`Expect.fail` in `assertPretty` → test Failed, with the message printed verbatim.
-}
runPrettyPrinter : FileSystem.Permission -> String -> Task String (Result String { ast : Src.Module, rendered : String })
runPrettyPrinter fsPerm filename =
    readTestFile fsPerm filename
        |> Task.map
            (\fileContent ->
                let
                    parser =
                        Parser.succeed (\ast payload -> { ast = ast, payload = payload })
                            |> Parser.keep PM.parser
                            |> Parser.keep Parser.getPayload
                in
                when Parser.run parser Context.empty fileContent is
                    Ok { ast = ast, payload = payload } ->
                        when PPrint.prettyPrint ast payload is
                            Ok rendered ->
                                Ok { ast = ast, rendered = rendered ++ "\n" }

                            Err errorString ->
                                Err errorString

                    Err errorString ->
                        Err (PM.errorsToString fileContent errorString)
            )


readTestFile : FileSystem.Permission -> String -> Task String String
readTestFile fsPerm filename =
    (Path.join <| Array.map Path.fromPosixString [ "testfiles", "Formatter", filename ])
        |> FileSystem.readFile fsPerm
        |> Task.mapError (\fsErr -> FileSystem.errorToString fsErr)
        |> Task.map Bytes.toString
        |> Task.andThen
            (\ms ->
                when ms is
                    Just s ->
                        Task.succeed s

                    Nothing ->
                        Task.fail "Failed to decode bytes"
            )


assertPretty : FileSystem.Permission -> String -> String -> U.Test {}
assertPretty fsPerm testDescription filenameBase =
    U.test testDescription <|
        \_ ->
            runPrettyPrinter fsPerm (filenameBase ++ ".dirty.gren")
                |> Task.andThen
                    (\formatResult ->
                        when formatResult is
                            Err message ->
                                Task.succeed (Expect.fail message)

                            Ok { ast = ast1, rendered = rendered } ->
                                readTestFile fsPerm (filenameBase ++ ".formatted.gren")
                                    |> Task.map
                                        (\expectedFormatting ->
                                            Expect.all
                                                [ \_ ->
                                                        Expect.equal rendered expectedFormatting
                                                            |> Expect.onFail (unifiedDiffStrings expectedFormatting rendered)
                                                , \_ ->
                                                        checkAstEquivalence ast1 rendered
                                                , \_ ->
                                                        checkIdempotent expectedFormatting
                                                ]
                                                {}
                                        )
                    )


checkAstEquivalence : Src.Module -> String -> Expectation
checkAstEquivalence ast1 rendered =
    let
        reparser =
            Parser.succeed (\ast payload -> { ast = ast, payload = payload })
                |> Parser.keep PM.parser
                |> Parser.keep Parser.getPayload
    in
    when Parser.run reparser Context.empty rendered is
        Err errs ->
            Expect.fail ("Could not reparse formatted output: " ++ PM.errorsToString rendered errs)

        Ok { ast = ast2, payload = _ } ->
            when AstCompare.compareModules ast1 ast2 is
                Ok {} ->
                    Expect.pass

                Err explanation ->
                    Expect.fail ("AST mismatch: " ++ explanation)


-- Parse a source string into its Module AST and parse Context, or an error.
parseModuleAndContext : String -> Result String { ast : Src.Module, context : Context.Context }
parseModuleAndContext source =
    let
        parser =
            Parser.succeed (\ast payload -> { ast = ast, payload = payload })
                |> Parser.keep PM.parser
                |> Parser.keep Parser.getPayload
    in
    when Parser.run parser Context.empty source is
        Ok { ast = ast, payload = payload } ->
            Ok { ast = ast, context = payload }

        Err errs ->
            Err (PM.errorsToString source errs)


-- Two parse Contexts are exactly equal when their indentation state and their
-- full comment streams (position + text) match.
contextsExactlyEqual : Context.Context -> Context.Context -> Bool
contextsExactlyEqual a b =
    a.indent == b.indent
        && a.lineStart == b.lineStart
        && Builder.toArray a.comments == Builder.toArray b.comments


{-| Idempotency check: re-format the already-formatted source and require the
result to be **textually identical**. Formatting must be a true fixed point.

When the text differs we additionally compare the parsed Module and Context to
classify the failure: a Module/Context difference means a declaration moved or a
comment shifted; matching Module+Context but different text means pure-whitespace
non-idempotency. Either way the unified diff is shown.
-}
checkIdempotent : String -> Expectation
checkIdempotent formatted =
    when parseModuleAndContext formatted is
        Err err ->
            Expect.fail ("Could not parse the formatted file: " ++ err)

        Ok first ->
            when PPrint.prettyPrint first.ast first.context is
                Err err ->
                    Expect.fail ("Could not re-format the formatted file: " ++ err)

                Ok reRendered0 ->
                    let
                        reRendered =
                            reRendered0 ++ "\n"
                    in
                    if reRendered == formatted then
                        Expect.pass

                    else
                        let
                            classification =
                                when parseModuleAndContext reRendered is
                                    Err err ->
                                        "re-formatted output no longer parses: " ++ err

                                    Ok second ->
                                        let
                                            moduleOk =
                                                first.ast == second.ast

                                            contextOk =
                                                contextsExactlyEqual first.context second.context
                                        in
                                        if not moduleOk && not contextOk then
                                            "Module and Context differ"

                                        else if not moduleOk then
                                            "Module differs"

                                        else if not contextOk then
                                            "Context differs"

                                        else
                                            "whitespace only (Module and Context unchanged)"
                        in
                        Expect.fail
                            ("Formatting is not idempotent ("
                                ++ classification
                                ++ ") — re-formatting the formatted output changed it:\n"
                                ++ unifiedDiffStrings formatted reRendered)


importSuite : FileSystem.Permission -> U.Suite
importSuite fsPerm =
    U.suite
        { name = "Import Statements"
        , setUpSuite = U.noSuiteFixture
        , tearDownSuite = U.noTearDown
        , setUp = U.noFixture
        , tearDown = U.noTearDown
        , tests = [ assertPretty fsPerm "import with comments" "ImportWithComments"
            , assertPretty fsPerm "exposed operators wrapped in parens" "ExposedOperator"
            , assertPretty fsPerm "module line wraps exposing list to one indented line" "ModuleLineWrap"
            , assertPretty fsPerm "module line wraps exposing list to one item per line" "ModuleLineVertical"
            , assertPretty fsPerm "import forms: plain, alias, exposing, combined" "Imports"
            , assertPretty fsPerm "exposing lists: flat stays flat, vertical stays vertical" "ExposingListLayoutByAuthor"
            , assertPretty fsPerm "a module's exposing list sorts operators, then types, then values, alphabetically within each group" "ExposingListSort"
            , assertPretty fsPerm "an import's exposing list sorts the same way as a module's" "ImportExposingListSort"
            , assertPretty fsPerm "a blank-line-separated leading comment in an exposing list still travels with its name, not treated as a section barrier" "ExposingListSortCommentBarrier"
            , assertPretty fsPerm "import statements sort alphabetically only within a run with no blank line or comment between them; blank lines and own-line comments are boundaries that split groups and never move" "ImportGroupSort"
            , assertPretty fsPerm "a comment trailing an import on its own source row travels with it within its group, unlike an own-line comment" "ImportGroupSortTrailingComment"
            , assertPretty fsPerm "<| lambda body indents +4 per level, not +8" "BackwardPipelineLambda"
            , assertPretty fsPerm "when/if/let as a binop operand forces the operator onto its own line, matching elm-format" "ParenBlock"
            , assertPretty fsPerm "when/if/let inside parens as a call argument: paren-block layout at ( + 4, matching elm-format" "ParenBlockCallArg"
            ]
        }


expressionSuite : FileSystem.Permission -> U.Suite
expressionSuite fsPerm =
    U.suite
        { name = "Expressions"
        , setUpSuite = U.noSuiteFixture
        , tearDownSuite = U.noTearDown
        , setUp = U.noFixture
        , tearDown = U.noTearDown
        , tests = [ assertPretty fsPerm "simple arithmetic" "SimpleArithmetic"
            , assertPretty fsPerm "when expression" "WhenExpression"
            , assertPretty fsPerm "if expression" "IfExpression"
            , assertPretty fsPerm "stacked if predicate wraps precedence-aware" "IfPredicate"
            , assertPretty fsPerm "let expression" "LetExpression"
            , assertPretty fsPerm "records" "Records"
            , assertPretty fsPerm "lambdas and calls" "LambdasAndCalls"
            , assertPretty fsPerm "a lambda whose body is a forced-vertical record/update/array drops its bracket to its own line, matching elm-format" "LambdaBracketBody"
            , assertPretty fsPerm "a lambda's comment-forced-vertical record-update body still drops its bracket when the lambda is itself a call argument (regression guard for a nest/reparse oscillation)" "LambdaBracketBodyNestedInCall"
            , assertPretty fsPerm "a lambda whose body is if/when/let drops the body to its own line under -> (elm-format), and as a call argument the whole (...) relocates onto its own line; a bare paren-lambda pipeline operand stays glued to |>" "CallArgBlockRelocation"
            , assertPretty fsPerm "function calls including wrapping" "FunctionCalls"
            , assertPretty fsPerm "parenthesized expressions" "ParenWrapped"
            , assertPretty fsPerm "closing paren on its own line when parens span multiple rows, incl. content-forced verticality" "ParenClosingLine"
            , assertPretty fsPerm "a multiline record call argument drops to its own line instead of gluing to the function/constructor name" "RecordArgOwnLine"
            , assertPretty fsPerm "redundant parens around a call argument are stripped; load-bearing ones stay" "RedundantArgParens"
            , assertPretty fsPerm "nested containers in list" "NestedContainersInList"
            , assertPretty fsPerm "array items that are too long to fit inline" "ArrayLongRecordItems"
            , assertPretty fsPerm "uniform item layout: records in an array all break together or not at all" "UniformRecordArray"
            , assertPretty fsPerm "uniform item layout: record updates couple like record literals" "UniformUpdateArray"
            , assertPretty fsPerm "list layout follows author: one line stays inline, multi-line stays one-per-line" "ListLayoutByAuthor"
            , assertPretty fsPerm "record + record-update layout follows author: one line inline, multi-line one-per-line" "RecordLayoutByAuthor"
            , assertPretty fsPerm "record type (alias, extensible, annotation) layout follows author" "RecordTypeLayoutByAuthor"
            , assertPretty fsPerm "record/array pattern layout follows author" "PatternLayoutByAuthor"
            , assertPretty fsPerm "union variant layout follows author: one line inline, multi-line one-per-line" "UnionLayoutByAuthor"
            , assertPretty fsPerm "pipeline layout follows author: one line inline, multi-line one-per-line" "PipelineLayoutByAuthor"
            , assertPretty fsPerm "binop layout follows author: precedence-aware split, lowest-precedence operators break first" "BinopLayoutByAuthor"
            , assertPretty fsPerm "when branch body indentation" "WhenBranchBody"
            , assertPretty fsPerm "when branch patterns" "WhenPatterns"
            , assertPretty fsPerm "when-branch record-destructuring pattern written flat stays flat" "WhenRecordPatternFlat"
            , assertPretty fsPerm "when-branch record-destructuring pattern written across rows aligns fields under the opening brace (regression guard for the nest/column mismatch fix)" "WhenRecordPatternVertical"
            , assertPretty fsPerm "named wildcard (anything) patterns keep their name" "AnythingPatterns"
            , assertPretty fsPerm "constructor-with-payload argument keeps its parens" "CtorArgPattern"
            , assertPretty fsPerm "constructor application as a record-field value / array element needs no parens (blocked on compiler-common pattern-parser fix, see error0617.md)" "CtorAppNestedPattern"
            , assertPretty fsPerm "record field value indentation" "RecordFieldValue"
            , assertPretty fsPerm "let def body indentation" "LetDefBody"
            , assertPretty fsPerm "let destructure pattern too long to fit on one line" "LetDestructLong"
            , assertPretty fsPerm "let destructure of a ctor-with-payload or as-alias keeps its parens" "LetDestructParens"
            , assertPretty fsPerm "pipeline step argument indentation" "PipelineArgIndent"
            , assertPretty fsPerm "multi-line lambda arg in pipeline step uses elm-format style" "PipelineLambdaArg"
            , assertPretty fsPerm "backward pipeline (<|) treated like forward pipeline (|>)" "BackwardPipeline"
            , assertPretty fsPerm "string escape sequences preserved" "StringEscapes"
            , assertPretty fsPerm "non-printable ASCII in strings escaped as \\u{XXXX}" "NonPrintableEscapes"
            , assertPretty fsPerm "string and char escape sequences in when patterns" "StringAndCharPatterns"
            , assertPretty fsPerm "multiline (triple-quoted) strings preserved" "MultilineString"
            , assertPretty fsPerm "lambda with record and array destructure patterns" "LambdaPatterns"
            , assertPretty fsPerm "binary operators, negation, hex literals" "BinaryOps"
            , assertPretty fsPerm "extensible record types in signatures and aliases" "ExtensibleRecords"
            , assertPretty fsPerm "constructor argument that is an as-alias keeps its parens" "CtorAsPattern"
            , assertPretty fsPerm "multi-line string opened mid-line aligns content to opening column" "MultilineStringInline"
            , assertPretty fsPerm "let-binding type signature is preserved; every binding drops its body to the next line" "LetBindingSignature"
            , assertPretty fsPerm "a comment before a let-binding signature does not insert a blank between the signature and its definition" "LetCommentedSignature"
            , assertPretty fsPerm "block comment or multiple single-line comments before a let-binding signature do not insert a blank between signature and definition" "LetCommentedSignatureVariants"
            , assertPretty fsPerm "one blank line is forced between let bindings regardless of authored blanks; a comment or signature sticks to the binding below it" "LetBlankLines"
            , assertPretty fsPerm "a wrapped infix declaration leaves no phantom row gap below it" "InfixWrapped"
            , assertPretty fsPerm "only a break between -> parts makes a signature multi-line; breaks inside a record type or parens do not" "SignatureSegmentBreaks"
            , assertPretty fsPerm "a multi-line block comment claimed as a declaration's trailing comment leaves no trailing-whitespace line" "ClaimedMultilineComment"
            , assertPretty fsPerm "two blank lines are forced before every top-level declaration unit (function/alias/union/port), regardless of authored blanks; the unit begins at its doc comment, else signature, else declaration" "ForcedDeclBlankLines"
            , assertPretty fsPerm "float literals round-trip (decimal stays decimal, scientific stays scientific)" "FloatLiterals"
            , assertPretty fsPerm "as-pattern inside record-field destructure keeps its parens" "RecordFieldAsPattern"
            , assertPretty fsPerm "doc comment body with non-BMP code points round-trips" "DocCommentWithEmoji"
            , assertPretty fsPerm "record update base can be a parenthesized call" "RecordUpdateComplexBase"
            , assertPretty fsPerm "record update expands uniformly for single- and multi-field block values (matches elm-format's extensionGroup); a single-field block value no longer stays compact, and the field value anchors at `| ` + 4 not field-content + 4; the lambda-head-drop is a documented remaining divergence" "RecordUpdateExtension"
            , assertPretty fsPerm "TRACKED elm-format divergence (uniform-4 vs prefix-width): short-op `&&` branch offset, `-(` negation offset, and the direct-operand `|>` closing paren all sit at gren's uniform indent, not elm-format's token-width-dependent column" "PrefixAnchorDivergence"
            , assertPretty fsPerm "TRACKED suspected bug: a bare `if` as a direct list item over-indents its branches and its `else` does not line up under `if` (elm-format keeps `else` under `if`)" "BareIfListItem"
            , assertPretty fsPerm "multi-line string content escapes backslashes and embedded triple quotes" "MultilineStringContent"
            , assertPretty fsPerm "negation of parenthesized expression keeps `-` outside the parens" "NegateParens"
            , assertPretty fsPerm "field access glues directly to a paren/record/qualified-name base with no space (compiler-common#27)" "PostfixAccess"
            ]
        }


declarationSuite : FileSystem.Permission -> U.Suite
declarationSuite fsPerm =
    U.suite
        { name = "Declarations"
        , setUpSuite = U.noSuiteFixture
        , tearDownSuite = U.noTearDown
        , setUp = U.noFixture
        , tearDown = U.noTearDown
        , tests = [ assertPretty fsPerm "type aliases" "TypeAlias"
            , assertPretty fsPerm "union types" "TypeUnion"
            , assertPretty fsPerm "type signatures" "TypeSignature"
            , assertPretty fsPerm "ports" "Ports"
            , assertPretty fsPerm "effect module where { command = ... } renders each binding as one field" "EffectModuleWhere"
            ]
        }


commentsSuite : FileSystem.Permission -> U.Suite
commentsSuite fsPerm =
    U.suite
        { name = "Comments"
        , setUpSuite = U.noSuiteFixture
        , tearDownSuite = U.noTearDown
        , setUp = U.noFixture
        , tearDown = U.noTearDown
        , tests = [ assertPretty fsPerm "comments in pipeliens" "CommentsPipeline"
            , assertPretty fsPerm "comments everywhere" "CommentsEverywhere"
            , assertPretty fsPerm "consecutive comments in when branch" "ConsecutiveCommentsInBranch"
            , assertPretty fsPerm "when expressions as items in a commented array are preserved" "WhenInCommentedArray"
            , assertPretty fsPerm "type union variant comments and type-syntax positions in signatures" "TypeComments"
            , assertPretty fsPerm "port declarations with comments in every header position" "PortComments"
            , assertPretty fsPerm "effect module with comments around top-level decls" "EffectModuleComments"
            , assertPretty fsPerm "module/import header keyword-gap comments" "ModuleHeaderComments"
            , assertPretty fsPerm "array patterns, ctor patterns, and when-branch pattern comments" "PatternComments"
            , assertPretty fsPerm "backward pipeline and operator-rhs gap comments" "PipelineAndGlueComments"
            , assertPretty fsPerm "doc/line/block adjacency and inter-declaration comments" "EdgeCaseComments"
            , assertPretty fsPerm "previously-mishandled comment placements (bugs A–K)" "TrickyComments"
            , assertPretty fsPerm "standalone block comment before a non-first let binding" "LetBindingComments"
            , assertPretty fsPerm "multiple comments sharing a top-level comment line" "AdjacentTopLevelComments"
            , assertPretty fsPerm "own-line comment before a container's closing bracket stays inside" "BracketTrailingComments"
            , assertPretty fsPerm "comment trailing a signature's last token stays glued inline" "SignatureTrailingComment"
            , assertPretty fsPerm "comment trailing the last let binding routes after `in` (not own-line, which would oscillate)" "LetInTrailingComment"
            , assertPretty fsPerm "comment trailing a non-last let binding's value sits at the bindings-block indent" "BetweenLetBindingsComment"
            , assertPretty fsPerm "comment after a wrapping module exposing list stays glued to the module line" "ModuleExposingTrailingComment"
            , assertPretty fsPerm "comment on the module line's own row stays glued inline" "ModuleLineFloatingComment"
            , assertPretty fsPerm "comment trailing a non-last when-branch body (nested in if/let) sits between branches, no blank" "BetweenWhenBranchesComment"
            -- Regression guards for the 2026-05-24 fuzzer-found idempotency fixes.
            , assertPretty fsPerm "trailing comment after a multi-line union variant stays on the variant's last row" "UnionVariantTrailingComment"
            , assertPretty fsPerm "own-line comment below the last union variant attaches at the variant indent" "UnionTrailingOwnLineComment"
            , assertPretty fsPerm "trailing comment on the closing `}` of a record-payload union variant stays there across reformats" "UnionRecordPayloadTrailingComment"
            , assertPretty fsPerm "long trailing comment in a bracket list glues inline regardless of length" "BracketListOverflowComment"
            , assertPretty fsPerm "comment in an empty-bracket body slot is not absorbed into the brackets" "EmptyBracketTrailingComment"
            , assertPretty fsPerm "comments inside a record update and before its closing brace" "RecordUpdateFieldComment"
            , assertPretty fsPerm "trailing comment on a long when-branch body glues inline regardless of length" "WhenBranchTrailingComment"
            , assertPretty fsPerm "single-line comment around the arrow of a wrapping signature soft-breaks" "SignatureArrowLineComment"
            , assertPretty fsPerm "comment after the exposing list of a vertical effect-module where block" "EffectModuleFxWhereComment"
            , assertPretty fsPerm "comment spaced too far from the handler name falls out of an effect-module where block" "EffectModuleWideSpacingComment"
            , assertPretty fsPerm "comment on an item in a multi-line import exposing list" "ImportExposingMultilineComment"
            , assertPretty fsPerm "multi-line module-header comment that wraps the module name to a continuation row" "HeaderCommentNameWrap"
            , assertPretty fsPerm "comment between a vertical module exposing list and the first declaration" "ModuleVerticalExposingComment"
            , assertPretty fsPerm "canonical rendering of comments at elided-token positions" "Ambiguous"
            , assertPretty fsPerm "canonical rendering of a comment in an effect-module where block" "AmbiguousEffectModule"
            -- Regression guards for the 2026-06-06 column-attachment fixes.
            , assertPretty fsPerm "comment trailing the then-body routes to leading the else-body" "ThenElseBoundaryComment"
            , assertPretty fsPerm "own-line comment before a record pattern's closing brace stays inside" "RecordPatternTrailingComment"
            , assertPretty fsPerm "trailing comment on a long, author-broken binop chain keeps the chain's first split" "BinopChainTrailingComment"
            , assertPretty fsPerm "trailing comment below a wrapped import stays at the continuation indent" "ImportTrailingComment"
            , assertPretty fsPerm "trailing comments below a pipeline's last step stay at the step indent" "PipelineTrailingComment"
            ]
        }


kitchenSinkSuite : FileSystem.Permission -> U.Suite
kitchenSinkSuite fsPerm =
    U.suite
        { name = "Kitchen sink"
        , setUpSuite = U.noSuiteFixture
        , tearDownSuite = U.noTearDown
        , setUp = U.noFixture
        , tearDown = U.noTearDown
        , tests = [ assertPretty fsPerm "every AST construct in one file" "KitchenSink"
            , assertPretty fsPerm "comments at every position in one file" "KitchenComments"
            , assertPretty fsPerm "3-line block comments at every round-tripping position" "MultilineBlockComments"
            , assertPretty fsPerm "3-line block comment in an effect-module where block" "MultilineEffectModule"
            , assertPretty fsPerm "block comment body re-indented from its own structure, not the open column" "BlockCommentBodyIndent"
            , assertPretty fsPerm "block comment with closing -} on its own line aligns -} with the opening {-" "BlockCommentClosingAlign"
            , assertPretty fsPerm "block comment closing -} indented at body level (l == base) is re-anchored to the {- column" "BlockCommentCloserIndented"
            , assertPretty fsPerm "trailing comment placement (inline vs own line) is preserved, not normalized" "CommentPlacement"
            , assertPretty fsPerm "a variety of constructs near, at, and past the 100-column page width" "PageWidth"
            , assertPretty fsPerm "empty literal ([] / {}) as an item inside a bracketed list" "EmptyBracketInList"
            , assertPretty fsPerm "block-bodied record field values: lambda inline (body +4), if/let/when dropped" "RecordFieldBlockValues"
            ]
        }
