module Change1.ElmStructure exposing
    ( equalsPair
    , definition
    , extensionGroup
    )

{-| Faithful port of the `ElmStructure.hs` combinators needed for the Change-1
record-update slice: `equalsPair`, `definition`, `extensionGroup`. Each maps a
construct to one uniform shape; verticality is driven by the `forceMultiline`
argument (author intent), NOT a page-width fit search.
-}

import Change1.Box as B exposing (Box(..), Line)


{-| Formats as `left = right`, or when multi-line:

    left =
        right
-}
equalsPair : String -> Bool -> Box -> Box -> Box
equalsPair symbol forceMultiline left right =
    when { fm = forceMultiline, l = left, r = right } is
        { fm = False, l = SingleLine left_, r = SingleLine right_ } ->
            B.line (B.row [ left_, B.space, B.punc symbol, B.space, right_ ])

        { l = SingleLine left_, r = MustBreakBox right_ } ->
            B.mustBreak (B.row [ left_, B.space, B.punc symbol, B.space, right_ ])

        { l = SingleLine left_, r = right_ } ->
            B.stack1
                [ B.line (B.row [ left_, B.space, B.punc symbol ])
                , B.indent right_
                ]

        { l = left_, r = right_ } ->
            B.stack1
                [ left_
                , B.indent (B.line (B.punc symbol))
                , B.indent right_
                ]


{-| A definition `name args = body`. Simplified `application` for the LHS: the
name and its (single-line) argument boxes joined with spaces on one line, which
is all the record-update slice needs. -}
definition : Box -> Array Box -> Box -> Box
definition nameBox argBoxes body =
    let
        lhsLine =
            when B.allSingles ([ nameBox ] ++ argBoxes) is
                Ok lines_ ->
                    B.line (B.row (Array.intersperse B.space lines_))

                Err _ ->
                    -- LHS always single-line in the slice
                    nameBox
    in
    -- A top-level definition always drops its body onto the next line
    -- (elm-format never keeps `name args = body` on one line).
    equalsPair "=" True lhsLine body


{-| Record update. Single line `{ base | f = v, ... }` when everything fits on
one line and not forced; otherwise the expanded

    { base
        | first
        , rest0
    }
-}
extensionGroup : Bool -> Box -> Box -> Array Box -> Box
extensionGroup multiline base first rest =
    when { m = multiline, b = B.isLine base, fs = B.allSingles ([ first ] ++ rest) } is
        { m = False, b = Ok base_, fs = Ok fields_ } ->
            B.line
                (B.row
                    ([ B.punc "{"
                     , B.space
                     , base_
                     , B.space
                     , B.punc "|"
                     , B.space
                     ]
                        ++ Array.intersperse (B.row [ B.punc ",", B.space ]) fields_
                        ++ [ B.space, B.punc "}" ]
                    )
                )

        _ ->
            B.stack1
                [ B.prefix (B.row [ B.punc "{", B.space ]) base
                , B.indent
                    (B.stack1
                        ([ B.prefix (B.row [ B.punc "|", B.space ]) first ]
                            ++ Array.map (B.prefix (B.row [ B.punc ",", B.space ])) rest
                        )
                    )
                , B.line (B.punc "}")
                ]
