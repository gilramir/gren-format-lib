{-| Construct an initial container with a long, mostly-static record literal. -}
initialContainer : String -> Int -> Container
initialContainer identifierArgument generatedAtMillisArgument =
    { identifier = identifierArgument
    , generatedAtMillis = generatedAtMillisArgument
    , payload = ""
    , flags =
        { isReady = False
        , isVerified = False
        , isPersisted = False
        , isShadowBanned = False
        , isQuarantined = False
        }
    , nestedConfiguration =
        { retryCount = 0
        , exponentialBackoffMillis = 100
        , jitterMillis = 25
        , maxAttempts = 5
        }
    , recentMessages = []
    }


{-| Demonstrates a heavily-nested let / when / if, with record destructuring,
    record update, pipelines, function composition, and lambdas. -}
processConfiguration : Configuration -> Container -> Result String Container
processConfiguration
        { tracing = tracingSection
        , scheduler = schedulerSection
        , featureFlags = featureFlagDefinitions
        } ({ identifier, flags, nestedConfiguration } as incomingContainer) =
    let
        tracingDecision =
            if
                tracingSection.isEnabled
                    && Array.length tracingSection.sinks > 0
            then
                let
                    chosenSink =
                        tracingSection.sinks
                            |> Array.keepIf
                                (\{ kind, endpoint } ->
                                    not (String.isEmpty endpoint)
                                        && kind /= "noop")
                            |> Array.map
                                (\sinkConfig ->
                                    { sinkConfig
                                        | endpoint =
                                              String.trim sinkConfig.endpoint
                                        , kind = String.toLower sinkConfig.kind
                                        , headers =
                                              Array.map
                                                  (\headerEntry ->
                                                      { headerEntry | headerName
                                                          =
                                                          String.toLower
                                                              headerEntry.headerName
                                                      }) sinkConfig.headers
                                    })
                            |> Array.first
                in
                when chosenSink is
                    Just
                    { kind = sinkKind
                    , endpoint = sinkEndpoint
                    , headers = sinkHeaders
                    } ->
                        if String.startsWith "https://" sinkEndpoint then
                            Ok
                                { kind = sinkKind
                                , endpoint = sinkEndpoint
                                , header_count = Array.length sinkHeaders
                                }
                        else if String.startsWith "http://" sinkEndpoint then
                            Err
                                ("refusing to use plaintext sink: "
                                    ++ sinkEndpoint)
                        else
                            Err
                                ("unknown scheme in tracing sink endpoint: "
                                    ++ sinkEndpoint)

                    Nothing ->
                        Err "tracing enabled but no usable sinks configured"
            else
                Ok { kind = "disabled", endpoint = "", header_count = 0 }
        schedulerDecision =
            when schedulerSection.overrides is
                [] ->
                    schedulerSection.defaultTickMillis

                [ singleOverride ] ->
                    Math.max schedulerSection.defaultTickMillis
                        singleOverride.tickMillis

                _ ->
                    schedulerSection.overrides
                        |> Array.map .tickMillis
                        |> Array.foldl Math.max
                            schedulerSection.defaultTickMillis
        rolloutDecision flagName =
            featureFlagDefinitions
                |> Array.findFirst
                    (\{ flagName = candidateFlagName } ->
                        candidateFlagName == flagName)
                |> Maybe.map
                    (\{ isOn, rolloutPercent } -> isOn && rolloutPercent >= 50)
                |> Maybe.withDefault False
        updateFlagsForConfigDecision currentFlags =
            { currentFlags
                | isReady = currentFlags.isReady || rolloutDecision "auto-ready"
                , isVerified =
                      currentFlags.isVerified
                          && not (rolloutDecision "always-unverified")
                , isPersisted = rolloutDecision "persist-on-config"
                , isShadowBanned =
                      currentFlags.isShadowBanned
                          || (rolloutDecision "shadow-everyone"
                              && not (rolloutDecision "shadow-bypass"))
                , isQuarantined = currentFlags.isQuarantined
            }
    in
    when tracingDecision is
        Ok tracingSummary ->
            let
                updatedContainer =
                    { incomingContainer
                        | flags = updateFlagsForConfigDecision flags
                        , nestedConfiguration =
                              { nestedConfiguration
                                  | exponentialBackoffMillis =
                                        Math.max
                                            nestedConfiguration.exponentialBackoffMillis
                                            schedulerDecision
                                  , jitterMillis =
                                        nestedConfiguration.jitterMillis
                                            + (schedulerDecision // 10)
                                  , maxAttempts =
                                        if
                                            rolloutDecision "aggressive-retry"
                                        then
                                            nestedConfiguration.maxAttempts * 2
                                        else
                                            nestedConfiguration.maxAttempts
                              }
                        , payload =
                              String.join " | "
                                  [ identifier
                                  , tracingSummary.kind
                                  , String.fromInt schedulerDecision
                                  , String.fromInt tracingSummary.header_count
                                  ]
                    }
            in
            { ok = Just updatedContainer
            , err = Nothing
            , annotations =
                [ { source = "processConfiguration"
                  , severity = 0
                  , message = "ok"
                  }
                ]
            }
                |> Ok

        Err errorMessageForTracing ->
            Err errorMessageForTracing


{-| Stress-tests record-update formatting at multiple nesting levels:
    single-field updates, multi-field updates, and updates whose field
    values are themselves record updates — all appearing inside lambdas,
    let bindings, if/then/else branches, and when branches. -}
applyOverlays : Int -> Bool -> Container -> Container
applyOverlays leadingOverridePriority tracingIsEnabled
        ({ flags, nestedConfiguration } as startingContainer) =
    let
        -- Single-field update bound to a name in let.
        containerWithBumpedTimestamp =
            { startingContainer | generatedAtMillis =
                startingContainer.generatedAtMillis + 1
            }
        -- Single-field update inside a let that uses an if/then/else for the new field value.
        containerWithConditionallyTrimmedPayload =
            { containerWithBumpedTimestamp | payload =
                if String.length startingContainer.payload > 80 then
                    String.left 80 startingContainer.payload ++ "…"
                else
                    startingContainer.payload
            }
        -- A lambda whose body is a multi-field update; one of the field
        -- values is itself a multi-field record update inline.
        applyTracingDecision =
            \receivedContainer ->
                if tracingIsEnabled then
                        { receivedContainer
                            | identifier =
                                  receivedContainer.identifier ++ "+tracing"
                            , payload = "tracing=on"
                            , flags =
                                  { flags
                                      | isReady = True
                                      , isVerified = True
                                      , isShadowBanned = False
                                  }
                        }
                    else
                        { receivedContainer
                            | identifier =
                                  receivedContainer.identifier ++ "-tracing"
                            , flags =
                                  { flags
                                      | isReady = False
                                      , isVerified = False
                                  }
                        }
        -- When-branch arms produce updates of different shapes. The wildcard
        -- arm contains updates that are deeply nested: a multi-field update
        -- whose field values include TWO inline multi-field record updates
        -- (one of which itself contains an inline if/then/else for one of
        -- its field values).
        adjustForLeadingOverridePriority =
            when leadingOverridePriority is
                0 ->
                    -- Single-field update whose value is itself a single-field update.
                    { containerWithConditionallyTrimmedPayload | flags =
                        { flags | isQuarantined = True }
                    }

                1 ->
                    -- Multi-field update with two simple scalar values.
                    { containerWithConditionallyTrimmedPayload
                        | identifier = startingContainer.identifier ++ "/p1"
                        , payload = "priority=1"
                    }

                _ ->
                    { containerWithConditionallyTrimmedPayload
                        | nestedConfiguration =
                              { nestedConfiguration
                                  | retryCount = leadingOverridePriority
                                  , exponentialBackoffMillis =
                                        nestedConfiguration.exponentialBackoffMillis
                                            * 2
                                  , jitterMillis =
                                        if leadingOverridePriority > 10 then
                                            nestedConfiguration.jitterMillis * 3
                                        else
                                            nestedConfiguration.jitterMillis + 1
                                  , maxAttempts =
                                        Math.max nestedConfiguration.maxAttempts
                                            leadingOverridePriority
                              }
                        , flags =
                              { flags
                                  | isPersisted = leadingOverridePriority > 5
                                  , isQuarantined = leadingOverridePriority < 0
                                  , isShadowBanned =
                                        leadingOverridePriority > 100
                              }
                        , payload =
                              "priority="
                                  ++ String.fromInt leadingOverridePriority
                    }
    in
    -- A pipeline whose intermediate steps each thread through an update lambda.
    adjustForLeadingOverridePriority
        |> applyTracingDecision
        |>
            (\penultimateContainer ->
                { penultimateContainer | generatedAtMillis =
                    penultimateContainer.generatedAtMillis
                        + leadingOverridePriority
                })


{-| Pipelines (both directions), function composition (both directions),
    operator references, negation, and a Math.pow tower. -}
transform : Array Int -> Int
transform inputValues =
    let
        addOne = (+) 1
        doubleThenIncrement = ((*) 2) >> addOne
        decrementThenHalve = addOne << negate << (\n -> n // 2)
    in
    inputValues
        |> Array.map (doubleThenIncrement >> decrementThenHalve)
        |> Array.keepIf (\n -> n > -10 && n < 10000)
        |> Array.map
            (\n ->
                if Math.modBy 2 n == 0 then
                        n * n
                    else
                        -n)
        |> Array.foldl (+) 0
        |>
            (\result ->
                if result < 0 then
                        -result
                    else
                        result)
        |> identity <| 0


{-| A right-folding traversal that nests when/if/let to show the formatter how
    aggressively it can collapse them. Uses long argument names to push lines
    near the 100-char threshold; the body intentionally has lines over 150
    chars before formatting. -}
fold :
    (a -> accumulatorValue -> accumulatorValue)
    -> accumulatorValue
    -> Tree a
    -> accumulatorValue
fold reducerFunction initialAccumulatorValue currentTreeNode =
    when currentTreeNode is
        Empty ->
            initialAccumulatorValue

        Leaf solitaryLeafValue ->
            reducerFunction solitaryLeafValue initialAccumulatorValue

        Branch
        { label = branchLabelString
        , attributes = branchAttributesArray
        , children = branchChildrenArray
        } ->
            let
                accumulatorAfterAttributes =
                    Array.foldl
                        (\{ attrName = nameOfAttribute
                            , attrValueAsString = valueOfAttributeAsString
                            } accumulatedSoFar ->
                            reducerFunction
                                (Debug.todo "fold attribute"
                                    :: nameOfAttribute
                                    :: valueOfAttributeAsString
                                    :: []) accumulatedSoFar)
                        initialAccumulatorValue branchAttributesArray
            in
            Array.foldl
                (\childTreeNode innerAccumulator ->
                    fold reducerFunction innerAccumulator childTreeNode)
                accumulatorAfterAttributes branchChildrenArray

        Cons { headValue, leftSubtree, rightSubtree } ->
            let
                accumulatorAfterLeft =
                    fold reducerFunction initialAccumulatorValue leftSubtree
                accumulatorAfterCurrentValue =
                    reducerFunction headValue accumulatorAfterLeft
            in
            fold reducerFunction accumulatorAfterCurrentValue rightSubtree


{-| Demonstrates lambdas with destructuring patterns, as-patterns, qualified
    constructors, negation, parens, and a backward-pipeline chain. -}
traverseDeeply :
    Tree { firstNameString : String, lastNameString : String, ageInYears : Int }
    -> Array String
traverseDeeply rootTree =
    let
        formatPersonRecord =
            \({ firstNameString, lastNameString, ageInYears } as personRecord)
                ->
                if ageInYears < 0 then
                        "invalid:" ++ firstNameString
                    else if ageInYears == 0 then
                        String.toUpper
                            <| String.append firstNameString
                            <| String.append " "
                            <| lastNameString
                    else
                        String.join " "
                            [ firstNameString
                            , lastNameString
                            , "(" ++ String.fromInt ageInYears ++ ")"
                            ]
        gatherNames currentTree =
            when currentTree is
                Empty ->
                    []

                Leaf personRecord ->
                    [ formatPersonRecord personRecord ]

                Branch { children = childrenArray } ->
                    childrenArray |> Array.flatMap gatherNames

                Cons
                { headValue = headPersonRecord
                , leftSubtree = leftSubtreeOfNames
                , rightSubtree = rightSubtreeOfNames
                } ->
                    let
                        leftCollected = gatherNames leftSubtreeOfNames
                        rightCollected = gatherNames rightSubtreeOfNames
                    in
                    [ formatPersonRecord headPersonRecord ]
                        ++ leftCollected
                        ++ rightCollected
    in
    gatherNames rootTree
        |> Array.map String.trim
        |> Array.keepIf (\nameLine -> not (String.isEmpty nameLine))
        |> Array.map (\formattedNameLine -> "- " ++ formattedNameLine)


-- A function that uses `as` aliases in patterns, qualified constructors in
-- when, and an exhaustive when over a union with payload destructuring.
classifyTree : Tree a -> String
classifyTree tree =
    when tree is
        Empty ->
            "empty"

        Leaf _ as wholeLeafNode ->
            String.append "leaf:" (Debug.toString wholeLeafNode)

        Branch ({ label } as wholeBranchPayload) ->
            String.append "branch:" label
                ++ "/"
                ++ Debug.toString wholeBranchPayload

        Cons { leftSubtree = Empty, rightSubtree = Empty } ->
            "single-cons"

        Cons _ ->
            "wide-cons"


-- Exercises literal patterns (Int / Char / String), qualified-constructor
-- patterns, multi-element array patterns, let-destructure bindings, and
-- qualified types in signatures.
interpretMicroCommand :
    Decode.Decoder Int
    -> String
    -> Array Char
    -> Maybe Int
    -> { handled : Bool, replyCode : Int }
interpretMicroCommand decoderForPayload commandText commandCharacters
        optionalRetryHint =
    let
        -- let-destructure (Destruct binding) splits a static record into two
        -- locally-bound names without going through a fresh name first.
        { defaultReplyCode, fallbackReplyCode }
        = { defaultReplyCode = 0, fallbackReplyCode = -1 }
        codeFromCharacterArray =
            when commandCharacters is
                -- single-char array pattern with literal Char pattern
                [ 'q' ] ->
                    1
                -- 3-element array pattern with literal Char and two PVars
                [ '#', firstDigitCharacter, secondDigitCharacter ] ->
                    2
                -- 4-element array pattern (all PVars)
                [ firstChar, secondChar, thirdChar, fourthChar ] ->
                    3

                _ ->
                    defaultReplyCode
        codeFromCommandText =
            when commandText is
                "skip" ->
                    100

                "halt" ->
                    200

                _ ->
                    when String.length commandText is
                        0 ->
                            0

                        1 ->
                            1

                        _ ->
                            fallbackReplyCode
        codeFromRetryHint =
            when optionalRetryHint is
                Maybe.Just retryAttemptNumber ->
                    retryAttemptNumber

                Maybe.Nothing ->
                    when String.uncons commandText is
                        Just { first = '?', rest = _ } ->
                            42

                        _ ->
                            fallbackReplyCode
    in
    { handled = codeFromCharacterArray > 0
    , replyCode =
        codeFromCharacterArray + codeFromCommandText + codeFromRetryHint
    }


-- Operator section / partial application of binops, used inside a pipeline.
sumOfSquaredOddIntegersUpTo : Int -> Int
sumOfSquaredOddIntegersUpTo upperBoundInclusive =
    Array.range 1 upperBoundInclusive
        |> Array.keepIf (\candidateInt -> Math.modBy 2 candidateInt /= 0)
        |> Array.map (\candidateInt -> candidateInt * candidateInt)
        |> Array.foldl (+) 0


-- Infix usage with mixed precedence, deliberately overflowing 150 columns
-- before formatting:
overflowingMathExpression : Int -> Int -> Int -> Int -> Int
overflowingMathExpression alphaCoefficient betaCoefficient gammaCoefficient
        deltaCoefficient =
    alphaCoefficient * betaCoefficient
        + gammaCoefficient * deltaCoefficient
        - (alphaCoefficient
            + betaCoefficient
            + gammaCoefficient
            + deltaCoefficient) * 2
        + 0xCAFEBABE


-- An if/else-if/else chain that should each break to its own line.
classifyTemperatureReading : Float -> String
classifyTemperatureReading temperatureInCelsius =
    if temperatureInCelsius < -40.0 then
        "deadly cold"
    else if temperatureInCelsius < 0.0 then
        "freezing"
    else if temperatureInCelsius < 10.0 then
        "cold"
    else if temperatureInCelsius < 25.0 then
        "comfortable"
    else if temperatureInCelsius < 40.0 then
        "hot"
    else
        "deadly hot"
