{-| A kitchen-sink module that exercises every Gren construct the formatter
    should know about. This module is intentionally over-stuffed and silly —
    the goal is to give the pretty-printer something to chew on, not to be
    real code.

# Types
@docs Tree, Result, Container, Configuration

# Constructors
@docs initialContainer, processConfiguration

# Transformations
@docs transform, fold, traverseDeeply

# Ports
@docs port_out_message, port_in_message
-}

import Array exposing ( Array )
import Dict
import Json.Decode as Decode exposing
    ( Decoder
    , decodeString
    , field
    , int
    , string
    )
import Json.Encode as Encode
import Math
import Result.Extra as ResultExtra
import String exposing ( fromInt, toInt, toUpper, toLower, trim, words )
import Task exposing ( Task )

infix left 6 (+) = add
infix left 6 (-) = sub
infix left 7 (*) = mul
infix non 4 (==) = eq
infix right 5 (<|) = apL

-- A simple line comment introducing the next section.
{- A multi-line block comment that should be preserved as-is even though
   it contains things that look almost like   code:
       let x = 1
           y = 2
       in x + y
-}

port port_out_message : String -> Cmd msg

port port_in_message : (String -> msg) -> Sub msg

{-| A tree where each node carries a label, an array of attribute pairs, and an array of child trees. The Empty case represents a missing branch. -}
type Tree a
    = Empty
    | Leaf a
    | Branch
        { label : String
        , attributes : Array { attrName : String, attrValueAsString : String }
        , children : Array (Tree a)
        }
    | Cons { headValue : a, leftSubtree : Tree a, rightSubtree : Tree a }

{-| Generic result-style type using qualified names everywhere. -}
type alias Result errorType successType =
    { ok : Maybe successType
    , err : Maybe errorType
    , annotations : Array { source : String, severity : Int, message : String }
    }

{-| An extensible record alias used as the basis for many other records. -}
type alias HasIdentifier r =
    { r | identifier : String, generatedAtMillis : Int }

type alias Container =
    HasIdentifier
    { payload : String
    , flags :
        { isReady : Bool
        , isVerified : Bool
        , isPersisted : Bool
        , isShadowBanned : Bool
        , isQuarantined : Bool
        }
    , nestedConfiguration :
        { retryCount : Int
        , exponentialBackoffMillis : Int
        , jitterMillis : Int
        , maxAttempts : Int
        }
    , recentMessages : Array
        { author : String
        , timestampMillis : Int
        , body : String
        , replyToIdentifier : Maybe String
        }
    }

{-| A configuration record with deeply nested option groups. -}
type alias Configuration =
    { tracing :
        { isEnabled : Bool
        , sinks : Array
            { kind : String
            , endpoint : String
            , headers : Array { headerName : String, headerValue : String }
            }
        }
    , scheduler :
        { defaultTickMillis : Int
        , overrides : Array { lane : String, tickMillis : Int, priority : Int }
        }
    , featureFlags : Array
        { flagName : String, isOn : Bool, rolloutPercent : Int }
    }

-- A short single-line value definition (no type signature).
piApprox = 3.141592653589793


-- A hex literal, character literal, and a multiline string literal.
magicByteSequenceAsHex : Int
magicByteSequenceAsHex =
    0xDEADBEEF


sentinelCharacterValue : Char
sentinelCharacterValue =
    '\u{2603}'


-- Non-ASCII characters inside a string literal must round-trip unchanged.
thankYouInKorean : String
thankYouInKorean =
    "감사함니다"


multiLineLicenseBanner : String
multiLineLicenseBanner =
