module BinopLayoutByAuthor exposing (..)

-- Author wrote it on one line and it fits: stays inline.
inlineFits = width * height + margin

-- Author wrote it on one line but it overflows: breaks only at the lowest
-- precedence operators, keeping tighter sub-terms (here `*`) inline.
mixedOverflow =
    baseScoreValue + bonusPointsEarned * difficultyMultiplier - penaltyDeduction + streakBonusAmount * weightFactor

-- Uniform precedence overflowing: one operator per line.
concatOverflow =
    "Order " ++ orderIdentifier ++ " for " ++ customerName ++ " totalling " ++ formattedAmount

-- Three precedence levels: breaks at the lowest (||), keeps && and == groups inline.
threeLevels =
    alphaController || betaController && gammaController == deltaController || epsilonController

-- Author wrote it across rows: kept split even though it would fit.
keptVertical =
    alpha
        + beta
