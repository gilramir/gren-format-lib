module WhenBranchBody exposing (..)

-- Simple bodies that fit inline: unchanged
simple msg =
    when msg is
        Increment ->
            model + 1

        Decrement ->
            model - 1

        Reset ->
            0

-- Record body that must wrap: body should be indented +4 from the pattern
withRecord msg model =
    when msg is
        ChangeLanguage lang ->
            { model = { model | tr = getTranslationPack lang, uiLang = lang }
            , command = Cmd.none
            }

        NoOp ->
            { model = model, command = Cmd.none }

-- Array body that must wrap
withArray msg =
    when msg is
        LoadItems ->
            [ firstItem
            , secondItem
            , thirdItem
            , fourthItem
            , fifthItem
            , sixthItem
            , seventhItem
            ]

        ClearItems ->
            []
