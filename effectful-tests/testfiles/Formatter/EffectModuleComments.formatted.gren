effect module {- comment between `effect module` keywords and module name -}
    EffectModuleComments where { command = MyCmd } exposing (..)

-- single-line comment before an import
import Task

{-| Doc comment on the command type of an effect module. -}
type MyCmd msg
    = MyCmd (Task.Task Never msg)

{- block comment between two top-level declarations of an effect module -}


-- comment before the cmdMap function
cmdMap : (a -> b) -> MyCmd a -> MyCmd b
cmdMap f MyCmd task =
    MyCmd (Task.map f task)
