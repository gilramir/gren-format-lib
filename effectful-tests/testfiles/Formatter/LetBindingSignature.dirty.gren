module LetBindingSignature exposing (..)

-- A let-binding can carry its own type signature on the line above. The
-- formatter must preserve it; dropping the signature changes the AST.
process : Int -> Int
process n =
    let
        doubled : Int -> Int
        doubled m =
            m * 2

        -- A function binding without a signature still drops its body to
        -- the next line, because it takes an argument.
        plain x = x + 1

        -- A plain value binding (no args, no signature) stays inline.
        bias = 7

        labelFor : Int -> String
        labelFor v =
            "n=" ++ String.fromInt v
    in
    doubled (plain n) + bias
