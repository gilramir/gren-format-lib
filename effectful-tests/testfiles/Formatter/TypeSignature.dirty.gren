module TypeSignature exposing (..)

-- Short signature stays on one line
add : Int -> Int -> Int
add a b = a + b

-- Single-arg function type needs parens in signature
applyTwice : (a -> a) -> a -> a
applyTwice f x = f (f x)

-- Long signature wraps; continuation indents +4
processItems : Array String -> Dict String Int -> (String -> Bool) -> Array String -> Result String (Array String)
processItems items dict pred fallback = []
