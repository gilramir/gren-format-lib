effect module TrickyComments where {- c1 -}
    { command = TrickyCmd {- c2 -}
    , subscription = TrickySub {- c3 -}
    } exposing (..)

{-| Accumulates one regression case per previously-mishandled comment
placement, identified by the bug letters from broken.txt.

Bug B — block comments inside an effect module's `where { ... }`
block used to be evicted to trailing continuation lines after
`exposing (..)`. Now they stay adjacent to their original slot:
c1 lands just after `where`, c2 stays inside the first binding,
c3 stays inside the second binding.
-}

import Task

-- Bug C — a comment in an import-with-`as`-alias line used to shift
-- one slot to the right (past `as`, or past `exposing`). With computed
-- positions for `as`/alias/`exposing`, a single comment stays in its
-- original slot. (A multi-comment-per-line variant remains partly off
-- because computed positions can't reflect the columns the earlier
-- comments push everything to.)
import Array {- between module and `as` -} as A
import Dict as D {- between alias and `exposing` -} exposing ( Dict )

-- Bug A — block comment between two union variants was previously
-- dropped entirely; now it renders on its own line in place.
type Shape
    = Circle Float
    | Rectangle Float Float
    {- block comment between two union variants -}
    | Empty

type TrickyCmd msg
    = TrickyCmd (Task.Task Never msg)

type TrickySub msg
    = TrickySub Never
