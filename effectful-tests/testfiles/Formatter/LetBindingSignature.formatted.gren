module LetBindingSignature exposing (..)


-- A let-binding can carry its own type signature on the line above. The
-- formatter must preserve it; dropping the signature changes the AST.
process : Int -> Int
process n =
    let
        doubled : Int -> Int
        doubled m =
            m * 2

        -- Body is an operator expression, so it drops to the next line
        -- (arguments and signatures don't affect this).
        plain x =
            x + 1

        -- Body is a literal, so it stays inline.
        bias =
            7

        labelFor : Int -> String
        labelFor v =
            "n=" ++ String.fromInt v
    in
    doubled (plain n) + bias
