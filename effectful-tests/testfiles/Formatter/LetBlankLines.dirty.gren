module LetBlankLines exposing (..)


-- The formatter forces exactly one blank line between `let` bindings,
-- whether or not the author wrote one, normalizing any run of blanks down
-- to one. A comment stays tight to the binding below it; the forced blank
-- goes above the comment.
compute x =
    let
        a = x + 1



        b = a * 2
        c = b - 3

        d = c + 4
        -- adjacent comment (no authored blank) stays tight to its binding
        e = d * 5

        {- authored blank above this comment is preserved as one -}
        f = e + 6
    in
    a + b + c + d + e + f
