effect module TrickyComments where { {- c1 -} command = TrickyCmd {- c2 -}, subscription = TrickySub {- c3 -} } exposing (..)


{-| Accumulates one regression case per previously-mishandled comment
placement, identified by the bug letters from broken.txt.

Bug B — block comments inside an effect module's `where { ... }`
block used to be evicted to trailing continuation lines after
`exposing (..)`. Now they stay adjacent to their original slot:
c1 lands just after `where`, c2 stays inside the first binding,
c3 stays inside the second binding.
-}


import Task


-- Bug C — a comment in an import-with-`as`-alias line used to shift
-- one slot to the right (past `as`, or past `exposing`). With computed
-- positions for `as`/alias/`exposing`, a single comment stays in its
-- original slot. (A multi-comment-per-line variant remains partly off
-- because computed positions can't reflect the columns the earlier
-- comments push everything to.)
import Array {- between module and `as` -} as A
import Dict as D {- between alias and `exposing` -} exposing (Dict)


-- Bug A — block comment between two union variants was previously
-- dropped entirely; now it renders on its own line in place.
type Shape
    = Circle Float
    | Rectangle Float Float
    {- block comment between two union variants -}
    | Empty


-- Bug F — a block comment between `\` and the first lambda pattern
-- used to be hoisted out of the lambda head to a position before `\`.
-- Now PrefixGlue carries a Located String so the prefix character has
-- a source position, and the comment lands inside the lambda head.
lambdaPrefix =
    \ {- between backslash and first pattern -} x -> x


-- Bug G — a line comment immediately before a triple-quoted multi-line
-- string used to be moved AFTER the string (because the MultilineString
-- LPT node had no source position, so the surrounding OriginalRows'
-- row range didn't cover the string and the comment fell to the wrong
-- top-level slot). MultilineString now carries a Located so the comment
-- stays in place above the string.
multilineAdjacent =
    -- single-line comment immediately before a multi-line string
    """
    multi-line content
    """


-- Bug H — a backward pipeline whose intermediate step ended with a
-- trailing `--` comment used to emit a stray blank line (with stale
-- continuation-arg indent) before the next step. PipelineStep now
-- peels the trailing comment off the step children and renders it
-- glued to the last arg, leaving the next step's leading hardNl to
-- terminate the line at the correct outer indent.
backwardPipe : String -> String
backwardPipe x =
    String.append "!" -- comment between two backward-pipe steps
        <| String.append x -- another comment between steps
        <| "?"


-- Bug J — a line comment between a function's type signature and its
-- definition used to be indented +4 (as a continuation of the
-- signature) and to leave a stray indented blank line. The signature's
-- OriginalRows row range had been stretching from the signature line
-- all the way down to the definition because the AST's `name`
-- location points at the definition's name (not the signature's). The
-- signature's name node now uses the AST-supplied `signature.start`
-- instead, so the OriginalRows row range stops at the signature line
-- and the comment lands at root level between the two declarations.
sigToDef : Int -> Int
-- a comment that lands between the signature and the definition
sigToDef x =
    x


-- Bug K — a block comment inside an extensible record type (between
-- the extension variable and `|`) used to be hoisted above the whole
-- signature declaration. `RecordUpdate` now carries the extension
-- variable as a `Located String`, so its subtree's first position
-- starts at the variable's column and the comment can descend into
-- the RecordUpdate and land between the base and the first field.
extensibleSig : { a {- between extension var and pipe -} | foo : Int, bar : String } -> Int
extensibleSig _ =
    0


type TrickyCmd msg
    = TrickyCmd (Task.Task Never msg)


type TrickySub msg
    = TrickySub Never
