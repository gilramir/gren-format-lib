module FunctionCalls exposing (..)

-- Short call stays on one line
short = foo a b c

-- Long call: args continue at the same column as the function name
long = someFunction firstLongArgument secondLongArgument thirdLongArgument fourthLongArgument fifthLongArgument

-- Call inside let binding: args continue at same column as function name
inLet =
    let
        x = someFunction firstLongArgument secondLongArgument thirdLongArgument fourthLongArgument extraLongArg
    in
    x

-- Nested calls (parens around inner calls)
nested = outer (inner a b) (another c d)
