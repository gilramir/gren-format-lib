effect module AmbiguousEffectModule where { command   {- authored between `command` and `=` -}   = MyCmd } exposing (..)

-- Companion to Ambiguous.dirty.gren for the elided-token `where`-block case,
-- which needs an effect-module header (see proposal-context-token-2.md).
--
-- The `command` / `=` / `{` / `}` positions inside the `where { ... }` block
-- are synthesized, so a comment authored between `command` and `=` is evicted
-- out of the block to between `where` and `{`. The .formatted.gren captures
-- this CURRENT (incorrect) output as a regression guard.

import Task

type MyCmd msg
    = MyCmd (Task.Task Never msg)
