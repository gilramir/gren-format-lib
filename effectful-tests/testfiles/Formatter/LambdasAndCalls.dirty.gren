module LambdasAndCalls exposing (doubleAll, keepPositive, applyTwice)

-- Double every element in an array
doubleAll : Array Int -> Array Int
doubleAll nums = Array.map (\n -> n * 2) nums

-- Keep only positive numbers
keepPositive : Array Int -> Array Int
keepPositive nums = Array.filter (\n -> n > 0) nums

{- Apply a function to a value twice -}
applyTwice : (a -> a) -> a -> a
applyTwice f x = f (f x)
