module Ambiguous exposing (..)

-- This file pins comment placement at ELIDED-TOKEN positions: spots beside a
-- token the AST does not carry a position for (the `as` keyword, the import
-- alias name, `|`, `=`, `:`, ...). The formatter cannot tell which side of such
-- a token a comment was meant for, so it commits to one canonical rendering and
-- always produces it; two distinct author intents collapse to that output. This
-- is deliberate — we are not adding token positions to the AST. See the
-- "Comments at elided-token positions" section of Formatter/README.md.
--
-- The matching .formatted.gren is that canonical rendering. (The effect-module
-- `where` case is in AmbiguousEffectModule because it needs a different module
-- header.)

-- Case 1 — import alias. Comment authored between `as` and the alias `Bar`.
-- Neither `as` nor the alias (a bare String in the AST) has a position, so the
-- comment is evicted past the whole import line. The mirror-image intent
-- (comment between `Foo` and `as`) collapses to this same output: the two
-- placements are indistinguishable.
import Foo as Bar
{- authored between `as` and `Bar` -}


-- Case 2 — as-pattern. Comment authored AFTER `as`, with extra spaces.
-- Canonical rendering places it BEFORE `as`; either authored side lands here.
unwrap x =
    when x is
        { a } {- authored after `as` -} as whole ->
            whole


-- Case 3 — extensible record `|` (type). Comment authored AFTER `|`. Canonical
-- rendering places it on its own line BEFORE `|`.
field :
    { r
        {- authored after `|` -}
        | name : String
    } -> String
field r =
    r.name


-- Case 4 — record update `|`. Comment authored AFTER `|`, inside the braces.
-- Canonical rendering lifts it OUT, before the whole update expression.
relabel rec = {- authored after `|` -}
    { rec | name = 1 }


-- Case 5 — union variant `|`. Comment authored AFTER `|` (between `|` and `B`).
-- Canonical rendering places it BEFORE `|`, after the preceding variant.
type T
    = A
    {- authored after `|` -}
    | B


-- Case 6 — declaration `=`. Comment authored BEFORE `=` (between the name and
-- `=`), with extra spaces. Canonical rendering places it AFTER `=`.
six = {- authored before `=` -} 42


-- Case 7 — signature `:`. Comment authored BEFORE `:` (between the name and
-- `:`), with extra spaces. Canonical rendering places it AFTER `:`.
seven : {- authored before `:` -} Int
seven =
    7
