module Records exposing ( makePoint, movePoint, distSq, singleton, makeOrigin, scalePoint, firstX )

{- Record creation, access, and update -}


-- Construct a 2D point record
makePoint : Int -> Int -> { x : Int, y : Int }
makePoint x y =
    { x = x
    , y = y
    }


-- Shift a point by dx and dy
movePoint : Int -> Int -> { x : Int, y : Int } -> { x : Int, y : Int }
movePoint dx dy pt =
    { pt
        | x = pt.x + dx
        , y = pt.y + dy
    }


-- Squared distance between two points
distSq : { x : Int, y : Int } -> { x : Int, y : Int } -> Int
distSq a b =
    let
        -- Differences in each axis
        dx = a.x - b.x
        dy = a.y - b.y
    in
    dx * dx + dy * dy


-- Single-field record stays inline
singleton : Int -> { x : Int }
singleton x = { x = x }


-- Record created inside a let binding
makeOrigin : { x : Int, y : Int }
makeOrigin =
    let
        pt =
            { x = 0
            , y = 0
            }
    in
    pt


-- Record literal in an if/else branch
scalePoint : Bool -> { x : Int, y : Int } -> { x : Int, y : Int }
scalePoint double pt =
    if double then
        { x = pt.x * 2
        , y = pt.y * 2
        }
    else
        { x = pt.x
        , y = pt.y
        }


-- Record passed as a function argument stays inline
firstX : Int
firstX = distSq { x = 0, y = 0 } { x = 1, y = 0 }
