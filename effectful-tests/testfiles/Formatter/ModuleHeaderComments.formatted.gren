module {- comment between `module` keyword and module name -} ModuleHeaderComments
    {- comment between module name and `exposing` -} exposing
    {- comment between `exposing` and `(` -} ( foo, bar )

-- single-line comment before the first import
import Array

-- comments inside an import without an `as` alias
import Dict {- comment between import module name and `exposing` -} exposing ( Dict )

-- comments inside an import without an `as`, using `exposing`
import Math {- between Math and `exposing` -} exposing (..)


foo : Int -> Int
foo x =
    x


bar : Int -> Int
bar x =
    x
