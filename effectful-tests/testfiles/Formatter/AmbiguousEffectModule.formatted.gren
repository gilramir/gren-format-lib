effect module AmbiguousEffectModule where
    {- authored between `command` and `=` -} { command = MyCmd } exposing (..)

-- Companion to Ambiguous.dirty.gren for the elided-token `where`-block case,
-- which needs an effect-module header. See the "Comments at elided-token
-- positions" section of Formatter/README.md.
--
-- The `command` / `=` / `{` / `}` positions inside the `where { ... }` block
-- carry no position in the AST, so a comment anywhere in the header collapses
-- to one slot: between `where` and `{`. The .formatted.gren is that canonical
-- rendering.

import Task

type MyCmd msg
    = MyCmd (Task.Task Never msg)
